[36.086021, "i", "(\n            num=2,\n            name=\"Grayscale\",\n            description=\"Convert the video to grayscale pixel format (pix_fmt=gray).\",\n            media_type=\"video\",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution=\"format=gray\",\n            out_ext=\"mkv\",\n            validate=v_validate_gray(),\n        )\n    )\n\n    # 3) Trim 10-second audio to exactly 3 seconds\n    levels.append(\n        Level(\n            num=3,\n            name=\"Audio Trim\",\n            description=\"Trim a 10-second audio clip to exactly 3 seconds.\",\n            media_type=\"audio\",\n            lavfi_input=aud_src_10s,\n            duration=10.0,\n            solution=\"atrim=0:3,asetpts=N/SR/TB\",\n            out_ext=\"wav\",\n            validate=a_validate_duration(3.0),\n        )\n    )\n\n    # 4) Crop center 200x200 from 640x480\n    levels.append(\n        Level(\n            num=4,\n            name=\"Center Crop\",\n            description=\"Crop the center 200x200 region from a 640x480 video.\",\n            med"]
[36.086028, "o", "import shlex\r\n\u001b[?2004l\r"]
[36.086038, "i", "ia_type=\"video\",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\n            out_ext=\"mkv\",\n            validate=v_validate_wh(200, 200),\n        )\n    )\n\n    # 5) Multi-step: scale to 320x240 and hflip\n    levels.append(\n        Level(\n            num=5,\n            name=\"Scale + HFlip\",\n            description=\"Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\",\n            media_type=\"video\",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution=\"scale=320:240,hflip\",\n            out_ext=\"mkv\",\n            validate=v_validate_wh(320, 240),\n        )\n    )\n\n    return levels\n\n\ndef output_filename(level: Level) -> str:\n    return f\"level{level.num:02d}_{level.name.lower().replace(' ', '_')}.{level.out_ext}\"\n\n\ndef run_level(level: Level, filtergraph: str, outfile: str) -> Tuple[bool, str, str]:\n    # Returns: (ok, reason, ffmpeg_stderr_tail)\n    ensure_dirs()\n\n    # Build ffmpeg co"]
