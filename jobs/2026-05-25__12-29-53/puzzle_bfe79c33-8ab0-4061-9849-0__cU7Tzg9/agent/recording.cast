[36.085675, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport shlex\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nAPP_DIR = \"/app\"\nASSETS_DIR = os.path.join(APP_DIR, \"assets\")\nOUTPUT_DIR = os.path.join(APP_DIR, \"output\")\nMANIFEST_PATH = os.path.join(APP_DIR, \"manifest.json\")\n\n\ndef run(cmd: List[str]) -> subprocess.CompletedProcess:\n    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cmd = [\n        \"ffprobe\",\n        \"-v\",\n        \"error\",\n        \"-print_format\",\n        \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(f\"ffprobe failed for {path}: {p.stderr}\")\n    return json.loads(p.stdout)\n\n\ndef get_first_str"]
[36.085808, "i", "eam(probe: Dict, codec_type: str) -> Optional[Dict]:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\ndef approx_equal(a: float, b: float, tol: float = 0.02) -> bool:\n    return abs(a - b) <= tol\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    media_type: str  # 'video' or 'audio'\n    lavfi_input: str\n    duration: float\n    solution: str\n    out_ext: str\n    validate: Callable[[str], Tuple[bool, str]]\n\n\ndef build_levels() -> List[Level]:\n    # Common video source: deterministic testsrc2\n    vid_src_10s = \"testsrc2=size=640x480:rate=30\"\n    aud_src_10s = \"sine=frequency=440:sample_rate=48000\"\n\n    def v_validate_wh(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n        def _v(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            vs = get_first_stream(pr, \"video\")\n            if not vs:\n                return False, \"no video stream\"\n            aw = int(vs.get(\"width\", -1))"]
[36.085829, "o", "cat > /app/ffpuzzle.py <<'PY'\r\n\u001b[?2004l\r"]
[36.085847, "i", "\n            ah = int(vs.get(\"height\", -1))\n            if aw != w or ah != h:\n                return False, f\"expected {w}x{h}, got {aw}x{ah}\"\n            return True, \"ok\"\n        return _v\n\n    def v_validate_gray() -> Callable[[str], Tuple[bool, str]]:\n        def _v(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            vs = get_first_stream(pr, \"video\")\n            if not vs:\n                return False, \"no video stream\"\n            # For strictness we check that pix_fmt is a grayscale format; we will encode lossless to ffv1 with gray.\n            pix = vs.get(\"pix_fmt\")\n            if pix != \"gray\":\n                return False, f\"expected pix_fmt gray, got {pix}\"\n            return True, \"ok\"\n        return _v\n\n    def a_validate_duration(target: float) -> Callable[[str], Tuple[bool, str]]:\n        def _a(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            a = get_first_stream(pr, \"audio\")\n            if not a:\n                return False, \"no au"]
[36.085927, "o", "\u001b[?2004h> "]
[36.085961, "i", "dio stream\"\n            # Prefer stream duration; fall back to format duration\n            dur_s = a.get(\"duration\")\n            if dur_s is None:\n                dur_s = pr.get(\"format\", {}).get(\"duration\")\n            if dur_s is None:\n                return False, \"no duration reported\"\n            dur = float(dur_s)\n            if not approx_equal(dur, target, tol=0.02):\n                return False, f\"expected duration ~{target}s, got {dur:.6f}s\"\n            return True, \"ok\"\n        return _a\n\n    levels: List[Level] = []\n\n    # 1) Scale 640x480 -> 320x240\n    levels.append(\n        Level(\n            num=1,\n            name=\"Downscale\",\n            description=\"Scale a 640x480 video down to exactly 320x240.\",\n            media_type=\"video\",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution=\"scale=320:240\",\n            out_ext=\"mkv\",\n            validate=v_validate_wh(320, 240),\n        )\n    )\n\n    # 2) Convert to grayscale pixel format\n    levels.append(\n        Level"]
