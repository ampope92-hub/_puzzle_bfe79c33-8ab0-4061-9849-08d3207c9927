[36.128828, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129, "o", "            print(reason)\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129128, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129229, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.129323, "o", ">     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.12935, "o", "> "]
[36.129429, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.12957, "o", "    for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129599, "o", "        outname = output_filename(lvl)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129748, "o", "        outpath = os.path.join(OUTPUT_DIR, outname)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129859, "o", "        ok, reason, tail = run_level(lvl, lvl.solution, outpath)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.129955, "o", "            print(\"PASS\")\r\n\u001b[?2004l\r"]
[36.129967, "o", "\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r"]
[36.130028, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.130098, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r"]
[36.130119, "o", "\u001b[?2004h> "]
[36.13028, "o", "            # Keep output minimal for CI but include reason on stderr\r\n\u001b[?2004l\r"]
[36.130363, "o", "\u001b[?2004h> "]
[36.130437, "o", "            print(reason)\r\n\u001b[?2004l\r"]
[36.130604, "o", "\u001b[?2004h>             if tail:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(tail)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append(\r\n\u001b[?2004l\r"]
[36.130716, "o", "\u001b[?2004h>             {\r\n\u001b[?2004l\r\u001b[?2004h>                 \"level\": lvl.num,\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.130872, "o", ">                 \"filename\": outname,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.130956, "o", "                \"status\": bool(ok),\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.131187, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.131281, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.131334, "o", "    print(f\"Score: {score}/{total}\")\r\n"]
[36.131392, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[36.131458, "o", "    return 0\r\n\u001b[?2004l\r"]
[36.131606, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[36.131764, "o", "\u001b[?2004h> def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r"]
[36.131781, "o", "\u001b[?2004h> "]
[36.131806, "o", "    parser = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.131987, "o", "    parser.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run all levels with known solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.132019, "o", "> "]
[36.132046, "o", "    args = parser.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h"]
[36.132179, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[36.132202, "o", ">     levels = build_levels()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.132383, "o", "    if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h>         return auto_solve(levels)\r\n\u001b[?2004l\r"]
[36.132418, "o", "\u001b[?2004h>     return interactive(levels)\r\n\u001b[?2004l\r"]
[36.132565, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.132583, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[36.132648, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY"]
[36.132663, "o", "\r\n"]
