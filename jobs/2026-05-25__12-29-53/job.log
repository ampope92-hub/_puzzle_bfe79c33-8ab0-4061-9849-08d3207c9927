Sending keys: ['cat > /app/ffpuzzle.py <<\'PY\'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport shlex\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nAPP_DIR = "/app"\nASSETS_DIR = os.path.join(APP_DIR, "assets")\nOUTPUT_DIR = os.path.join(APP_DIR, "output")\nMANIFEST_PATH = os.path.join(APP_DIR, "manifest.json")\n\n\ndef run(cmd: List[str]) -> subprocess.CompletedProcess:\n    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cmd = [\n        "ffprobe",\n        "-v",\n        "error",\n        "-print_format",\n        "json",\n        "-show_format",\n        "-show_streams",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(f"ffprobe failed for {path}: {p.stderr}")\n    return json.loads(p.stdout)\n\n\ndef get_first_stream(probe: Dict, codec_type: str) -> Optional[Dict]:\n    for s in probe.get("streams", []):\n        if s.get("codec_type") == codec_type:\n            return s\n    return None\n\n\ndef approx_equal(a: float, b: float, tol: float = 0.02) -> bool:\n    return abs(a - b) <= tol\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    media_type: str  # \'video\' or \'audio\'\n    lavfi_input: str\n    duration: float\n    solution: str\n    out_ext: str\n    validate: Callable[[str], Tuple[bool, str]]\n\n\ndef build_levels() -> List[Level]:\n    # Common video source: deterministic testsrc2\n    vid_src_10s = "testsrc2=size=640x480:rate=30"\n    aud_src_10s = "sine=frequency=440:sample_rate=48000"\n\n    def v_validate_wh(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n        def _v(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            vs = get_first_stream(pr, "video")\n            if not vs:\n                return False, "no video stream"\n            aw = int(vs.get("width", -1))\n            ah = int(vs.get("height", -1))\n            if aw != w or ah != h:\n                return False, f"expected {w}x{h}, got {aw}x{ah}"\n            return True, "ok"\n        return _v\n\n    def v_validate_gray() -> Callable[[str], Tuple[bool, str]]:\n        def _v(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            vs = get_first_stream(pr, "video")\n            if not vs:\n                return False, "no video stream"\n            # For strictness we check that pix_fmt is a grayscale format; we will encode lossless to ffv1 with gray.\n            pix = vs.get("pix_fmt")\n            if pix != "gray":\n                return False, f"expected pix_fmt gray, got {pix}"\n            return True, "ok"\n        return _v\n\n    def a_validate_duration(target: float) -> Callable[[str], Tuple[bool, str]]:\n        def _a(path: str) -> Tuple[bool, str]:\n            pr = ffprobe_json(path)\n            a = get_first_stream(pr, "audio")\n            if not a:\n                return False, "no audio stream"\n            # Prefer stream duration; fall back to format duration\n            dur_s = a.get("duration")\n            if dur_s is None:\n                dur_s = pr.get("format", {}).get("duration")\n            if dur_s is None:\n                return False, "no duration reported"\n            dur = float(dur_s)\n            if not approx_equal(dur, target, tol=0.02):\n                return False, f"expected duration ~{target}s, got {dur:.6f}s"\n            return True, "ok"\n        return _a\n\n    levels: List[Level] = []\n\n    # 1) Scale 640x480 -> 320x240\n    levels.append(\n        Level(\n            num=1,\n            name="Downscale",\n            description="Scale a 640x480 video down to exactly 320x240.",\n            media_type="video",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution="scale=320:240",\n            out_ext="mkv",\n            validate=v_validate_wh(320, 240),\n        )\n    )\n\n    # 2) Convert to grayscale pixel format\n    levels.append(\n        Level(\n            num=2,\n            name="Grayscale",\n            description="Convert the video to grayscale pixel format (pix_fmt=gray).",\n            media_type="video",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution="format=gray",\n            out_ext="mkv",\n            validate=v_validate_gray(),\n        )\n    )\n\n    # 3) Trim 10-second audio to exactly 3 seconds\n    levels.append(\n        Level(\n            num=3,\n            name="Audio Trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.",\n            media_type="audio",\n            lavfi_input=aud_src_10s,\n            duration=10.0,\n            solution="atrim=0:3,asetpts=N/SR/TB",\n            out_ext="wav",\n            validate=a_validate_duration(3.0),\n        )\n    )\n\n    # 4) Crop center 200x200 from 640x480\n    levels.append(\n        Level(\n            num=4,\n            name="Center Crop",\n            description="Crop the center 200x200 region from a 640x480 video.",\n            media_type="video",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n            out_ext="mkv",\n            validate=v_validate_wh(200, 200),\n        )\n    )\n\n    # 5) Multi-step: scale to 320x240 and hflip\n    levels.append(\n        Level(\n            num=5,\n            name="Scale + HFlip",\n            description="Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.",\n            media_type="video",\n            lavfi_input=vid_src_10s,\n            duration=2.0,\n            solution="scale=320:240,hflip",\n            out_ext="mkv",\n            validate=v_validate_wh(320, 240),\n        )\n    )\n\n    return levels\n\n\ndef output_filename(level: Level) -> str:\n    return f"level{level.num:02d}_{level.name.lower().replace(\' \', \'_\')}.{level.out_ext}"\n\n\ndef run_level(level: Level, filtergraph: str, outfile: str) -> Tuple[bool, str, str]:\n    # Returns: (ok, reason, ffmpeg_stderr_tail)\n    ensure_dirs()\n\n    # Build ffmpeg command.\n    # Use deterministic encoding settings and codecs that preserve requested properties.\n    # Video: use FFV1 in Matroska (lossless) so pix_fmt/size survive exactly.\n    # Audio: use PCM in WAV.\n    if level.media_type == "video":\n        cmd = [\n            "ffmpeg",\n            "-hide_banner",\n            "-v",\n            "error",\n            "-f",\n            "lavfi",\n            "-t",\n            str(level.duration),\n            "-i",\n            level.lavfi_input,\n            "-vf",\n            filtergraph,\n            "-an",\n            "-c:v",\n            "ffv1",\n            "-pix_fmt",\n            "gray" if level.num == 2 else "yuv420p",  # enforce output pix_fmt for grayscale level\n            "-y",\n            outfile,\n        ]\n    else:\n        cmd = [\n            "ffmpeg",\n            "-hide_banner",\n            "-v",\n            "error",\n            "-f",\n            "lavfi",\n            "-t",\n            str(level.duration),\n            "-i",\n            level.lavfi_input,\n            "-af",\n            filtergraph,\n            "-vn",\n            "-c:a",\n            "pcm_s16le",\n            "-ar",\n            "48000",\n            "-ac",\n            "1",\n            "-y",\n            outfile,\n        ]\n\n    p = run(cmd)\n    tail = (p.stderr or "").strip()[-800:]\n    if p.returncode != 0:\n        return False, "ffmpeg failed", tail\n\n    try:\n        ok, reason = level.validate(outfile)\n        return ok, reason, tail\n    except Exception as e:\n        return False, f"validation error: {e}", tail\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    total = len(levels) * 10\n    for lvl in levels:\n        print(f"Level {lvl.num}: {lvl.name}")\n        print(lvl.description)\n        print("Enter FFmpeg filtergraph expression:")\n        try:\n            fg = input("> ").strip()\n        except EOFError:\n            print("\\nExiting.")\n            break\n        if not fg:\n            print("No filtergraph provided.")\n            continue\n        outpath = os.path.join(OUTPUT_DIR, output_filename(lvl))\n        ok, reason, _ = run_level(lvl, fg, outpath)\n        if ok:\n            print("PASS")\n            score += 10\n        else:\n            print("FAIL")\n            print(reason)\n        print()\n    print(f"Score: {score}/{total}")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    ensure_dirs()\n    manifest = []\n    score = 0\n    total = len(levels) * 10\n\n    for lvl in levels:\n        print(f"Level {lvl.num}: {lvl.name}")\n        outname = output_filename(lvl)\n        outpath = os.path.join(OUTPUT_DIR, outname)\n        ok, reason, tail = run_level(lvl, lvl.solution, outpath)\n        if ok:\n            print("PASS")\n            score += 10\n        else:\n            print("FAIL")\n            # Keep output minimal for CI but include reason on stderr\n            print(reason)\n            if tail:\n                print(tail)\n\n        manifest.append(\n            {\n                "level": lvl.num,\n                "filename": outname,\n                "status": bool(ok),\n            }\n        )\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump(manifest, f, indent=2, sort_keys=True)\n\n    print(f"Score: {score}/{total}")\n    return 0\n\n\ndef main(argv: List[str]) -> int:\n    parser = argparse.ArgumentParser(description="FFmpeg filtergraph puzzle game")\n    parser.add_argument("--auto-solve", action="store_true", help="run all levels with known solutions")\n    args = parser.parse_args(argv)\n\n    levels = build_levels()\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == "__main__":\n    raise SystemExit(main(sys.argv[1:]))\nPY\nchmod +x /app/ffpuzzle.py\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
