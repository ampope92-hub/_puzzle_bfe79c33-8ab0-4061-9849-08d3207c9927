[53.350487, "o", "def interactive_mode(all_levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.35059, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.350802, "o", "> "]
[53.350973, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.351068, "o", "    for lvl in all_levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.351193, "o", "        print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.351249, "o", "        print(\"Enter a filtergraph expression (e.g. scale=320:240):\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.351318, "o", "> "]
[53.351477, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h>             fg = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h>             fg = \"\"\r\n\u001b[?2004l\r"]
[53.351579, "o", "\u001b[?2004h>         passed, msg = run_level(lvl, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.351752, "o", ">             score += 10\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.351917, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"  Reason: {msg}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352033, "o", "        manifest.append({\"level\": lvl.number, \"filename\": os.path.basename(lvl.output_path), \"passed\": bool(passed)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352142, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r"]
