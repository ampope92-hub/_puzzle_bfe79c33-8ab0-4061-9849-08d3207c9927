[53.352474, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def autosolve_mode(all_levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n"]
[53.352504, "o", "\u001b[?2004l\r\u001b[?2004h"]
[53.352582, "o", "> "]
[53.352605, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352674, "o", "    for lvl in all_levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352698, "o", "        print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.352796, "o", ">         passed, _msg = run_level(lvl, lvl.solution)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352859, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r"]
[53.352986, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.352997, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
