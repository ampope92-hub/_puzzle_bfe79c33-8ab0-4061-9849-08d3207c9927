[53.353563, "o", "    print(f\"Score: {score}/{len(all_levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.353628, "o", "def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.353719, "o", "    parser = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.353851, "o", "    parser.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run all levels with known correct solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.353921, "o", "> "]
[53.354044, "o", "    args = parser.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     all_lvls = levels()\r\n\u001b[?2004l\r"]
[53.354142, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.354294, "o", "        return autosolve_mode(all_lvls)\r\n\u001b[?2004l\r\u001b[?2004h>     return interactive_mode(all_lvls)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[53.354404, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
