[53.297112, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport shlex\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef run_cmd(cmd: List[str]) -> Tuple[int, str, str]:\n    p = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n    return p.returncode, p.stdout, p.stderr\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cmd = [\n        \"ffprobe\",\n        \"-v\",\n        \"error\",\n        \"-print_format\",\n        \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        path,\n    ]\n    rc, out, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(f\"ffprobe failed for {path}: {err.strip()}\")\n    return json.loads(out)\n\n\ndef get_first_stream(probe: Dict, codec_type: s"]
[53.297284, "i", "tr) -> Optional[Dict]:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\ndef validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(path)\n        s = get_first_stream(probe, \"video\")\n        if not s:\n            return False, \"no video stream\"\n        if int(s.get(\"width\", -1)) != w or int(s.get(\"height\", -1)) != h:\n            return False, f\"expected {w}x{h}, got {s.get('width')}x{s.get('height')}\"\n        return True, \"ok\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(path)\n        s = get_first_stream(probe, \"video\")\n        if not s:\n            return False, \"no video stream\"\n        got = s.get(\"pix_fmt\")\n        if got != pix_fmt:\n            return False, f\"expected pix_fmt={pix_fmt}, got {got}\"\n        return True, \"ok\"\n    except Exception as e:\n        return"]
[53.297368, "o", "cat > /app/ffpuzzle.py <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.297394, "i", " False, str(e)\n\n\ndef validate_audio_duration_range(path: str, lo: float, hi: float) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(path)\n        s = get_first_stream(probe, \"audio\")\n        if not s:\n            return False, \"no audio stream\"\n\n        dur = None\n        if s.get(\"duration\") is not None:\n            try:\n                dur = float(s[\"duration\"])\n            except Exception:\n                dur = None\n        if dur is None:\n            fmt = probe.get(\"format\", {})\n            if fmt.get(\"duration\") is not None:\n                dur = float(fmt[\"duration\"])\n\n        if dur is None:\n            return False, \"could not determine duration\"\n        if not (lo <= dur <= hi):\n            return False, f\"expected duration in [{lo},{hi}] sec, got {dur}\"\n        return True, \"ok\"\n    except Exception as e:\n        return False, str(e)\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    input_path: str\n    output_path: str\n    generate_input: Callable[[], None"]
[53.297489, "o", "> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.297639, "i", "]\n    build_ffmpeg_cmd: Callable[[str], List[str]]  # takes filtergraph\n    validate: Callable[[], Tuple[bool, str]]\n    solution: str\n\n\ndef gen_level1_input(path: str) -> None:\n    # 640x480 synthetic video, deterministic\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"testsrc2=size=640x480:rate=30:duration=2\",\n        \"-c:v\",\n        \"libx264\",\n        \"-pix_fmt\",\n        \"yuv420p\",\n        path,\n    ]\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(err.strip())\n\n\ndef gen_level2_input(path: str) -> None:\n    # Input can be any video; output must be gray in rawvideo/avi.\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"testsrc2=size=320x240:rate=30:duration=2\",\n        \"-c:v\",\n        \"mpeg4\",\n        \"-q:v\",\n        \"3\",\n        path,\n    ]\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(err.strip())"]
[53.297796, "o", "import argparse\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> import shlex\r\n\u001b[?2004l\r\u001b[?2004h> import subprocess\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r"]
[53.298003, "i", "\n\n\ndef gen_level3_input(path: str) -> None:\n    # 10-second sine wave, deterministic\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"sine=frequency=440:sample_rate=48000:duration=10\",\n        \"-c:a\",\n        \"pcm_s16le\",\n        path,\n    ]\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(err.strip())\n\n\ndef gen_level4_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"testsrc2=size=640x480:rate=30:duration=2\",\n        \"-c:v\",\n        \"libx264\",\n        \"-pix_fmt\",\n        \"yuv420p\",\n        path,\n    ]\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(err.strip())\n\n\ndef gen_level5_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"testsrc2=size=640x480:rate=30:duration=2\",\n      "]
[53.298272, "o", "\u001b[?2004h> from dataclasses import dataclass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.298314, "i", "  \"-c:v\",\n        \"libx264\",\n        \"-pix_fmt\",\n        \"yuv420p\",\n        path,\n    ]\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        raise RuntimeError(err.strip())\n\n\ndef ffmpeg_video_cmd(input_path: str, output_path: str, filtergraph: str, extra: Optional[List[str]] = None) -> List[str]:\n    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", input_path, \"-vf\", filtergraph]\n    if extra:\n        cmd += extra\n    cmd.append(output_path)\n    return cmd\n\n\ndef ffmpeg_audio_cmd(input_path: str, output_path: str, filtergraph: str, extra: Optional[List[str]] = None) -> List[str]:\n    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", input_path, \"-af\", filtergraph]\n    if extra:\n        cmd += extra\n    cmd.append(output_path)\n    return cmd\n\n\ndef safe_remove(path: str) -> None:\n    try:\n        os.remove(path)\n    except FileNotFoundError:\n        pass\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    # Ensure input exists\n    if not os.path.exists(level.input_path):\n        level.generate_input()"]
[53.298345, "i", "\n\n    safe_remove(level.output_path)\n\n    cmd = level.build_ffmpeg_cmd(filtergraph)\n    rc, _, err = run_cmd(cmd)\n    if rc != 0:\n        return False, f\"ffmpeg failed: {err.strip()}\"\n\n    passed, msg = level.validate()\n    return passed, msg\n\n\ndef levels() -> List[Level]:\n    l1_in = os.path.join(ASSETS_DIR, \"level1_input.mp4\")\n    l1_out = os.path.join(OUTPUT_DIR, \"level1_output.mp4\")\n\n    l2_in = os.path.join(ASSETS_DIR, \"level2_input.avi\")\n    l2_out = os.path.join(OUTPUT_DIR, \"level2_output.avi\")\n\n    l3_in = os.path.join(ASSETS_DIR, \"level3_input.wav\")\n    l3_out = os.path.join(OUTPUT_DIR, \"level3_output.wav\")\n\n    l4_in = os.path.join(ASSETS_DIR, \"level4_input.mp4\")\n    l4_out = os.path.join(OUTPUT_DIR, \"level4_output.mp4\")\n\n    l5_in = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n    l5_out = os.path.join(OUTPUT_DIR, \"level5_output.mp4\")\n\n    return [\n        Level(\n            number=1,\n            name=\"Scale down\",\n            description=\"Scale a 640x480 video down to exactly 320x240.\",\n          "]
[53.299035, "i", "  input_path=l1_in,\n            output_path=l1_out,\n            generate_input=lambda p=l1_in: gen_level1_input(p),\n            build_ffmpeg_cmd=lambda fg, i=l1_in, o=l1_out: ffmpeg_video_cmd(\n                i, o, fg, extra=[\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"]\n            ),\n            validate=lambda p=l1_out: validate_video_dims(p, 320, 240),\n            solution=\"scale=320:240\",\n        ),\n        Level(\n            number=2,\n            name=\"Grayscale\",\n            description=\"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\",\n            input_path=l2_in,\n            output_path=l2_out,\n            generate_input=lambda p=l2_in: gen_level2_input(p),\n            build_ffmpeg_cmd=lambda fg, i=l2_in, o=l2_out: ffmpeg_video_cmd(\n                i,\n                o,\n                fg,\n                extra=[\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"],\n            ),\n            validate=lambda p=l2_out: validate_pix_fmt(p, \"gray\"),\n            solution=\"format=gray\",\n        )"]
