[53.353163, "o", "        manifest.append({\"level\": lvl.number, \"filename\": os.path.basename(lvl.output_path), \"passed\": bool(passed)})\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.35325, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h>     with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.353351, "o", ">         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
