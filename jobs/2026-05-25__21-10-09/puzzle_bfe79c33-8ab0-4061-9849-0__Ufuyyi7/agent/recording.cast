[41.813606, "i", "cat > /app/ffpuzzle.py << 'ENDOFSCRIPT'\nimport subprocess\nimport json\nimport os\nimport sys\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\nLEVELS = [\n    {\n        \"level\": 1,\n        \"name\": \"Scale Down\",\n        \"description\": \"Scale a 640x480 video down to 320x240.\",\n        \"input_file\": \"level1_input.mp4\",\n        \"output_file\": \"level1_output.mp4\",\n        \"gen_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level1_input.mp4\")\n        ],\n        \"solution\": \"scale=320:240\",\n        \"output_args\": [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"],\n        \"validate\": lambda info: info.get(\"width\") == 320 and info.get(\"height\") == 240,\n    },\n    {\n        \"level\": 2,\n        \"name\": \"Grayscale\",\n        \"description\": \"Convert a video to grayscale (output pixel format must be 'gray'). Use .avi container with rawvi"]
[41.81367, "i", "deo codec.\",\n        \"input_file\": \"level2_input.avi\",\n        \"output_file\": \"level2_output.avi\",\n        \"gen_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"rgb24\",\n            os.path.join(ASSETS_DIR, \"level2_input.avi\")\n        ],\n        \"solution\": \"format=gray\",\n        \"output_args\": [\"-c:v\", \"rawvideo\"],\n        \"validate\": lambda info: info.get(\"pix_fmt\") == \"gray\",\n    },\n    {\n        \"level\": 3,\n        \"name\": \"Audio Trim\",\n        \"description\": \"Trim a 10-second audio clip to exactly 3 seconds.\",\n        \"input_file\": \"level3_input.wav\",\n        \"output_file\": \"level3_output.wav\",\n        \"gen_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"sine=frequency=440:duration=10\",\n            os.path.join(ASSETS_DIR, \"level3_input.wav\")\n        ],\n        \"solution\": \"atrim=0:3,asetpts=PTS-STARTPTS\",\n        \"output_args\": [],\n        \"validate\": lambda info: 2.9 <= info."]
[41.813686, "i", "get(\"duration\", 0) <= 3.1,\n    },\n    {\n        \"level\": 4,\n        \"name\": \"Center Crop\",\n        \"description\": \"Crop the center 200x200 region from a 640x480 video.\",\n        \"input_file\": \"level4_input.mp4\",\n        \"output_file\": \"level4_output.mp4\",\n        \"gen_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level4_input.mp4\")\n        ],\n        \"solution\": \"crop=200:200:220:140\",\n        \"output_args\": [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"],\n        \"validate\": lambda info: info.get(\"width\") == 200 and info.get(\"height\") == 200,\n    },\n    {\n        \"level\": 5,\n        \"name\": \"Scale and Flip\",\n        \"description\": \"Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\",\n        \"input_file\": \"level5_input.mp4\",\n        \"output_file\": \"level5_output.mp4\",\n        \"gen_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n"]
[41.813694, "i", "            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n        ],\n        \"solution\": \"scale=320:240,hflip\",\n        \"output_args\": [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"],\n        \"validate\": lambda info: info.get(\"width\") == 320 and info.get(\"height\") == 240,\n    },\n]\n\n\ndef ensure_dirs():\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef generate_input(level):\n    cmd = level[\"gen_cmd\"]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n\n\ndef apply_filtergraph(level, filtergraph):\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    \n    is_audio = level[\"level\"] == 3\n    \n    cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\n    \n    if is_audio:\n        cmd += [\"-af\", filtergraph]\n    else:\n        cmd += [\"-vf\", filtergraph]\n    \n    cmd += lev"]
[41.813707, "i", "el[\"output_args\"]\n    cmd += [output_path]\n    \n    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\n    return result.returncode == 0\n\n\ndef probe_output(level):\n    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    \n    if not os.path.exists(output_path):\n        return None\n    \n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \"-show_streams\", \"-show_format\", output_path\n    ]\n    \n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        return None\n    \n    try:\n        data = json.loads(result.stdout)\n    except json.JSONDecodeError:\n        return None\n    \n    info = {}\n    \n    if data.get(\"streams\"):\n        stream = data[\"streams\"][0]\n        if \"width\" in stream:\n            info[\"width\"] = int(stream[\"width\"])\n        if \"height\" in stream:\n            info[\"height\"] = int(stream[\"height\"])\n        if \"pix_fmt\" in stream:\n            info[\"pix_fmt\"] = stream[\"pix_fmt\"]\n    "]
