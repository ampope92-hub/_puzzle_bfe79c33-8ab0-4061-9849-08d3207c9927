[41.829883, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.830059, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.830236, "o", "def apply_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r  \r\n    \u001b[?2004h> "]
[41.830497, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r"]
[41.830575, "o", "\u001b[?2004h> "]
[41.83099, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\rn\u001b[?2004h> "]
[41.831253, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     is_audio = level[\"level\"] == 3\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\r\n\u001b[?2004l\r\u001b[?2004h>     "]
[41.831425, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.831624, "o", "    if is_audio:\r\n\u001b[?2004l\r   \u001b[?2004h>         cmd += [\"-af\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.831713, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.831805, "o", "        cmd += [\"-vf\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     cmd += level[\"output_args\"]\r\n\u001b[?2004l\r\u001b[?2004h>     cmd += [output_path]\r\n"]
[41.831856, "o", "\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.831884, "o", "> "]
[41.832087, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.832249, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.832275, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def probe_output(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.832343, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.832489, "o", "    if not os.path.exists(output_path):\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     cmd = ["]
[41.832572, "o", "\r\n\u001b[?2004l\r"]
[41.832679, "o", "\u001b[?2004h> "]
[41.832872, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-show_streams\", \"-show_format\", output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.832911, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.832952, "o", "> "]
[41.833056, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r"]
[41.833143, "o", "\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r"]
[41.833163, "o", "\u001b[?2004h> "]
[41.833256, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.833336, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.833438, "o", "        data = json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h>     except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.833496, "o", "> "]
[41.833559, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[41.833597, "o", "\u001b[?2004h> "]
[41.833676, "o", "    info = {}\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.833751, "o", "    if data.get(\"streams\"):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.833774, "o", "        stream = data[\"streams\"][0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.833854, "o", "        if \"width\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.833862, "o", "> "]
[41.833962, "o", "            info[\"width\"] = int(stream[\"width\"])\r\n\u001b[?2004l\r"]
[41.834102, "o", "\u001b[?2004h> "]
[41.834125, "o", "        if \"height\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.834255, "o", "            info[\"height\"] = int(stream[\"height\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.834483, "o", "        if \"pix_fmt\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>             info[\"pix_fmt\"] = stream[\"pix_fmt\"]\r\n\u001b[?2004l\r\u001b[?2004h>         # Duration: try stream duration first, then format duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.834671, "o", "        if \"duration\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.834801, "o", "            info[\"duration\"] = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.834824, "o", "        elif data.get(\"format\") and \"duration\" in data[\"format\"]:\r\n\u001b[?2004l\r"]
[41.835032, "o", "\u001b[?2004h>             info[\"duration\"] = float(data[\"format\"][\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83518, "o", "    return info\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level(level, info):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.835338, "o", "    if info is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.835476, "o", "    return level[\"validate\"](info)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.835564, "o", "def run_auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.835624, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r"]
[41.835778, "o", "\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[41.835929, "o", "\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83598, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r"]
[41.836075, "o", "\u001b[?2004h> "]
[41.836089, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         # Generate input\r\n\u001b[?2004l\r"]
[41.836168, "o", "\u001b[?2004h>         generate_input(level)\r\n\u001b[?2004l\r"]
[41.836344, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Apply solution\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.836418, "o", "        success = apply_filtergraph(level, level[\"solution\"])\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[41.836468, "o", "\u001b[?2004h> "]
[41.836489, "o", "        if success:\r\n\u001b[?2004l\r"]
[41.836528, "o", "\u001b[?2004h> "]
[41.836661, "o", "            info = probe_output(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.836789, "o", "            passed = validate_level(level, info)\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.836898, "o", "            passed = False\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.837007, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83706, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.837109, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r"]
[41.837208, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.837219, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.837346, "o", "            \"level\": level[\"level\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83749, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n"]
[41.837512, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[41.837603, "o", "    print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83768, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r"]
[41.837699, "o", "\u001b[?2004h> "]
[41.83779, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.83786, "o", "def run_interactive():\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.837955, "o", ">     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
