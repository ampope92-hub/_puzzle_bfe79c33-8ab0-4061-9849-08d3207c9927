[41.840435, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h"]
[41.840452, "o", "> "]
[41.840486, "o", "    \r\n\u001b[?2004l\r"]
[41.840504, "o", "\u001b[?2004h> "]
