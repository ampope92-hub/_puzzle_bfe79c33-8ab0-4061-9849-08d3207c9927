[41.838158, "o", "\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.838177, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.838324, "o", ">     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"\\n{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.838404, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.838534, "o", "        print(f\"\\n{level['description']}\")\r\n\u001b[?2004l\r"]
[41.838603, "o", "\u001b[?2004h>         print(f\"\\nInput file: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.838718, "o", "        print(f\"Output file: {level['output_file']}\")\r\n\u001b[?2004l\r"]
[41.838856, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Generate input\r\n\u001b[?2004l\r\u001b[?2004h>         generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[41.838994, "o", "\u001b[?2004h>         filtergraph = input(\"\\nEnter your filtergraph expression: \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839022, "o", "        if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839147, "o", "            print(\"  FAIL (empty input)\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839291, "o", "            manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>                 \"level\": level[\"level\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839339, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839386, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839417, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r"]
[41.8395, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839592, "o", "        success = apply_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839664, "o", "        if success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839751, "o", "            info = probe_output(level)\r\n\u001b[?2004l\r\u001b[?2004h>             passed = validate_level(level, info)\r\n\u001b[?2004l\r"]
[41.839767, "o", "\u001b[?2004h> "]
[41.839931, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             passed = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.839985, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
