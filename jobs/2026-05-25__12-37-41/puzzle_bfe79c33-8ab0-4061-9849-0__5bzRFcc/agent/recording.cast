[59.534019, "i", "cat > /app/ffpuzzle.py << 'PYTHON_SCRIPT'\n#!/usr/bin/env python3\n\"\"\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nthrough progressively harder media transformation challenges.\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef ensure_dirs():\n    \"\"\"Create assets and output directories if they don't exist.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_cmd(cmd, timeout=30):\n    \"\"\"Run a command and return (returncode, stdout, stderr).\"\"\"\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=timeout\n        )\n        return result.returncode, result.stdout.decode(), result.stderr.decode()\n    except subprocess.TimeoutExpired:\n        return -1, \"\", \"Command timed out\"\n    except Exception as e:\n      "]
[59.534089, "i", "  return -1, \"\", str(e)\n\n\ndef generate_input(level):\n    \"\"\"Generate synthetic input for a level using FFmpeg lavfi sources.\"\"\"\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    \n    # Skip if already generated\n    if os.path.exists(input_path):\n        return input_path\n    \n    cmd = level[\"generate_cmd\"](input_path)\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        print(f\"  ERROR generating input: {stderr}\")\n        return None\n    return input_path\n\n\ndef apply_filtergraph(input_path, filtergraph, output_path, level):\n    \"\"\"Apply a filtergraph to the input and produce output.\"\"\"\n    media_type = level.get(\"media_type\", \"video\")\n    \n    if media_type == \"audio\":\n        cmd = [\n            \"ffmpeg\", \"-y\",\n            \"-i\", input_path,\n            \"-af\", filtergraph,\n            \"-vn\",\n            output_path\n        ]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\",\n            \"-i\", input_path,\n            \"-vf\", filtergraph,\n            \"-an\",\n            \"-t\", \"2\",\n  "]
