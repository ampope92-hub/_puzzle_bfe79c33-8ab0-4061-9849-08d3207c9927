[59.550718, "o", "    return rc == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rec_typ\u001b[?2004h> \r\n\u001b[?2004l\re"]
[59.550763, "o", "\u001b[?2004h> "]
[59.551281, "o", "def probe_file(filepath):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.551478, "o", "    \"\"\"Use ffprobe to get JSON info about a file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.551657, "o", "    cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffprobe\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.551833, "o", "        \"-v\", \"quiet\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.551866, "o", "        \"-print_format\", \"json\",\r\n\u001b[?2004l\r"]
[59.551898, "o", "\u001b[?2004h> "]
[59.552145, "o", "        \"-show_format\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.552371, "o", "        \"-show_streams\",\r\n\u001b[?2004l\r\u001b[?2004h>         filepath\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.552524, "o", ">     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.552547, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.552683, "o", "    if rc != 0:\r\n\u001b[?2004l\ri\u001b[?2004h>         return None\r\n\u001b[?2004l\r  r\u001b[?2004h> "]
[59.552941, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h>         return json.loads(stdout)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.553092, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r"]
[59.553242, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_output(output_path, level):\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.553257, "o", "> "]
[59.553617, "o", "    \"\"\"Validate the output file against level requirements.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     if not os.path.exists(output_path):\r\n\u001b[?2004l\r"]
[59.553683, "o", "\u001b[?2004h> "]
[59.554023, "o", "        return False, \"Output file does not exist\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.554493, "o", "    probe_data = probe_file(output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, \"Could not probe output file\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     validator = level[\"validator\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.554654, "o", "    return validator(probe_data)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r     \"val\u001b[?2004h> \r\n\u001b[?2004l\ri"]
[59.554828, "o", "\u001b[?2004h> "]
[59.554935, "o", "# --- Level Definitions ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.555154, "o", "def gen_video_640x480(output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.555261, "o", "    \"\"\"Generate a 640x480 test video using testsrc.\"\"\"\r\n\u001b[?2004l\r"]
[59.555558, "o", "\u001b[?2004h>     return [\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\rversion\",\r\n        \"description\": (\r\n  \u001b[?2004h>         \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.556023, "o", "        \"-i\", \"testsrc=duration=5:size=640x480:rate=25\",\r\n\u001b[?2004l\r"]
[59.556063, "o", "\u001b[?2004h>         \"-c:v\", \"libx264\", \"-preset\", \"ultrafast\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-t\", \"5\",\r\n\u001b[?2004l\r      "]
[59.556417, "o", "\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def gen_audio_10s(output_path):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Generate a 10-second audio sine wave.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.556526, "o", "    return [\r\n\u001b[?2004l\rd\": gen_vi\u001b[?2004h> "]
[59.556693, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.557145, "o", "        \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.557592, "o", "        \"-i\", \"sine=frequency=440:duration=10\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.557826, "o", "def validate_level1(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.558131, "o", "    \"\"\"Check that video is 320x240.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.558273, "o", "            width = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.558654, "o", "            height = stream.get(\"height\")\r\n\u001b[?2004l\rse th\u001b[?2004h> "]
[59.559365, "o", "            if width == 320 and height == 240:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.559857, "o", "                return True, \"Correct! Video is 320x240.\"\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h>                 return False, f\"Expected 320x240 but got {width}x{height}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.560202, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level2(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.560238, "o", "    \"\"\"Check that video is in grayscale pixel format.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r{\r\n        \"number\": 4,\r\n        \"\u001b[?2004h"]
[59.560323, "o", "> "]
[59.560495, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>             pix_fmt = stream.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r"]
[59.560527, "o", "\u001b[?2004h>             # Accept any grayscale format\r\n"]
[59.560591, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[59.560746, "o", "            if pix_fmt in (\"gray\", \"gray8\", \"gray16le\", \"gray16be\", \"ya8\", \"monob\", \"monow\"):\r\n\u001b[?2004l\rcenter is.\"\r\n        ),\r\n        \"input_\u001b[?2004h> "]
[59.561265, "o", "                return True, f\"Correct! Pixel format is {pix_fmt}.\"\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.561308, "o", "                return False, f\"Expected grayscale format but got {pix_fmt}\"\r\n\u001b[?2004l\r\u001b[?2004h>     return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\": gen_video_640x480,\r\n        \"media_type\": \"video\",\r\n        \"solution\": \"crop=200:200:(iw-200)/2:(ih-200)/2\",\r\n   \u001b[?2004h"]
[59.56137, "o", "> "]
[59.561535, "o", "def validate_level3(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.561681, "o", ">     \"\"\"Check that audio duration is approximately 3 seconds.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.561819, "o", "    # Check format duration\r\n\u001b[?2004l\r\u001b[?2004h>     fmt_duration = probe_data.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r0x48"]
[59.561994, "o", "\u001b[?2004h>     if fmt_duration is not None:\r\n\u001b[?2004l\r\u001b[?2004h>         dur = float(fmt_duration)\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.562039, "o", ">         if 2.9 <= dur <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.562167, "o", "            return True, f\"Correct! Audio duration is {dur:.2f}s.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.56226, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.562408, "o", "            return False, f\"Expected ~3.0s duration but got {dur:.2f}s\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.562437, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h"]
[59.562495, "o", "> "]
[59.562602, "o", "    # Fallback: check stream duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.562727, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.562853, "o", "        if stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.562964, "o", "            dur_str = stream.get(\"duration\")\r\n\u001b[?2004l\r_level5,\r\n      \u001b[?2004h>             if dur_str:\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.563036, "o", "> "]
[59.563149, "o", "                dur = float(dur_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.563276, "o", "                if 2.9 <= dur <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.563301, "o", "> "]
[59.563704, "o", "                    return True, f\"Correct! Audio duration is {dur:.2f}s.\"\r\n\u001b[?2004l\r"]
[59.563729, "o", "\u001b[?2004h> "]
[59.563964, "o", "                else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.564528, "o", "                    return False, f\"Expected ~3.0s duration but got {dur:.2f}s\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.565016, "o", "    return False, \"Could not determine audio duration\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.565059, "o", "> \r\n\u001b[?2004l\re\u001b[?2004h> "]
[59.565224, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.565316, "o", "def validate_level4(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.565342, "o", "> "]
[59.565774, "o", "    \"\"\"Check that video is 200x200.\"\"\"\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[59.565926, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r"]
[59.565947, "o", "\u001b[?2004h> "]
[59.56611, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.566499, "o", "            width = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.566787, "o", "            height = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567018, "o", "            if width == 200 and height == 200:\r\n\u001b[?2004l\r"]
[59.567046, "o", "\u001b[?2004h> "]
[59.567255, "o", "                return True, \"Correct! Video is 200x200 (center crop).\"\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567425, "o", "                return False, f\"Expected 200x200 but got {width}x{height}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567445, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567502, "o", "def validate_level5(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567666, "o", "    \"\"\"Check that video is 320x240 (scaled and flipped).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.567748, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.568113, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.568136, "o", "            width = stream.get(\"width\")\r\n\u001b[?2004l\r"]
[59.568263, "o", "\u001b[?2004h>             height = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.5686, "o", "            if width == 320 and height == 240:\r\n\u001b[?2004l\r\u001b[?2004h>                 return True, \"Correct! Video is 320x240 and flipped.\"\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.56887, "o", "                return False, f\"Expected 320x240 but got {width}x{height}\"\r\n\u001b[?2004l\r"]
[59.568929, "o", "\u001b[?2004h>     return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[59.568951, "o", "\u001b[?2004h> "]
[59.569118, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> LEVELS = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h> "]
