[167.801927, "o", ">     parser.add_argument(\r\n\u001b[?2004l\r\u001b[?2004h>         \"--auto-solve\",\r\n\u001b[?2004l\r\u001b[?2004h>         action=\"store_true\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.801946, "o", "        help=\"Run all levels with known correct solutions\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
