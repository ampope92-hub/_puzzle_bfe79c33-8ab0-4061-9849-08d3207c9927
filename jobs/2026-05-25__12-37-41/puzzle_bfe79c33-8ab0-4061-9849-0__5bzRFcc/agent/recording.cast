[167.747716, "o", "    \"\"\"Generate synthetic input for a level using FFmpeg lavfi sources.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.748472, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.748931, "o", "    if os.path.exists(input_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.749081, "o", "        return input_path\r\n\u001b[?2004l\r"]
[167.749318, "o", "\u001b[?2004h>     cmd = level[\"generate_cmd\"](input_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.749736, "o", "> "]
[167.750033, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.750475, "o", "        print(f\"  ERROR generating input: {stderr}\")\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.750882, "o", "    return input_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[167.751028, "o", "\u001b[?2004h> "]
[167.751504, "o", "def apply_filtergraph(input_path, filtergraph, output_path, level):\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.751544, "o", "> "]
[167.752111, "o", "    \"\"\"Apply a filtergraph to the input and produce output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.752316, "o", "> "]
[167.752694, "o", "    media_type = level.get(\"media_type\", \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.752898, "o", "    extra_output_opts = level.get(\"output_opts\", [])\r\n\u001b[?2004l\r"]
[167.753087, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.753305, "o", "    if media_type == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.753503, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.753886, "o", "            \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.754086, "o", ">             \"-i\", input_path,\r\n\u001b[?2004l\r 200x200 (center crop).\"\r\n     "]
[167.754247, "o", "\u001b[?2004h> "]
[167.754416, "o", "            \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.754471, "o", "> "]
[167.75462, "o", "            \"-vn\"\r\n\u001b[?2004l\r"]
[167.754869, "o", "\u001b[?2004h> "]
[167.755373, "o", "        ] + extra_output_opts + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.755641, "o", "> "]
[167.755809, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.756077, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.756422, "o", "            \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.756528, "o", "            \"-an\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.756755, "o", "            \"-t\", \"2\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.756999, "o", "        ] + extra_output_opts + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.757306, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.757435, "o", "    return rc == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rt\u001b[?2004h"]
[167.757609, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[167.757889, "o", "> def probe_file(filepath):\r\n\u001b[?2004l\r"]
[167.75803, "o", "\u001b[?2004h> "]
[167.758209, "o", "    \"\"\"Use ffprobe to get JSON info about a file.\"\"\"\r\n\u001b[?2004l\r"]
[167.758383, "o", "\u001b[?2004h>     cmd = [\r\n"]
[167.758582, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[167.758661, "o", "        \"ffprobe\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.75901, "o", "        \"-v\", \"quiet\",\r\n\u001b[?2004l\r"]
[167.759453, "o", "\u001b[?2004h>         \"-print_format\", \"json\",\r\n\u001b[?2004l\r"]
[167.75984, "o", "\u001b[?2004h>         \"-show_format\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-show_streams\",\r\n\u001b[?2004l\r"]
[167.760179, "o", "\u001b[?2004h> "]
[167.760389, "o", "        filepath\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.760589, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.760797, "o", "> "]
[167.761302, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if rc != 0:\r\n\u001b[?2004l\ro\u001b[?2004h>         return None\r\n\u001b[?2004l\rl D"]
[167.761474, "o", "\u001b[?2004h> "]
[167.761745, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h>         return json.loads(stdout)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.761794, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.761964, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r  \u001b[?2004h"]
[167.76209, "o", "> "]
[167.76237, "o", "def validate_output(output_path, level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.763325, "o", "    \"\"\"Validate the output file against level requirements.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.76355, "o", "    if not os.path.exists(output_path):\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.763723, "o", "> "]
[167.76422, "o", "        return False, \"Output file does not exist\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.764387, "o", "    probe_data = probe_file(output_path)\r\n"]
[167.764441, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[167.76454, "o", "    if probe_data is None:\r\n\u001b[?2004l\ra\u001b[?2004h> "]
[167.764781, "o", "        return False, \"Could not probe output file\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.764969, "o", "    validator = level[\"validator\"]\r\n\u001b[?2004l\r"]
[167.76507, "o", "\u001b[?2004h>     return validator(probe_data)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[167.765168, "o", "\u001b[?2004h> "]
[167.765297, "o", "# --- Input Generators ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.765623, "o", "def gen_video_640x480(output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.765887, "o", "    return [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.766011, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.766224, "o", "        \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.766472, "o", "        \"-i\", \"testsrc=duration=5:size=640x480:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.766813, "o", "        \"-c:v\", \"libx264\", \"-preset\", \"ultrafast\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.767224, "o", "        \"-t\", \"5\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.767304, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rixel f\u001b[?2004h> "]
[167.767453, "o", "def gen_audio_10s(output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.767595, "o", "    return [\r\n\u001b[?2004l\r"]
[167.767926, "o", "\u001b[?2004h>         \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\rut_640x480.mp4\",\r\n       \u001b[?2004h>         \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.768162, "o", "        \"-i\", \"sine=frequency=440:duration=10\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.768304, "o", "        \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_path\r\n\u001b[?2004l\r"]
[167.768416, "o", "\u001b[?2004h>     ]\r\n\u001b[?2004l\r"]
[167.768458, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.768601, "o", "\r\n"]
[167.768928, "o", "\u001b[?2004l\r\u001b[?2004h> # --- Validators ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.769126, "o", "def validate_level1(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.769465, "o", "    \"\"\"Check that video is 320x240.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.770458, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>             width = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.770912, "o", "            height = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h>             if width == 320 and height == 240:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.771057, "o", "                return True, \"Correct! Video is 320x240.\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.771246, "o", ">             else:\r\n\u001b[?2004l\r"]
[167.771559, "o", "\u001b[?2004h>                 return False, f\"Expected 320x240 but got {width}x{height}\"\r\n\u001b[?2004l\r"]
[167.77193, "o", "\u001b[?2004h> "]
[167.772052, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level2(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.77223, "o", "    \"\"\"Check that video is in grayscale pixel format.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.77247, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.77261, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.772817, "o", "            pix_fmt = stream.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.772943, "o", ">             grayscale_fmts = ("]
[167.77311, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>                 \"gray\", \"gray8\", \"gray16le\", \"gray16be\",\r\n\u001b[?2004l\r"]
[167.77316, "o", "\u001b[?2004h> "]
[167.77341, "o", "                \"ya8\", \"monob\", \"monow\", \"gray10le\",\r\n\u001b[?2004l\rn\u001b[?2004h> "]
[167.773721, "o", "                \"gray12le\", \"gray14le\", \"gray9le\"\r\n\u001b[?2004l\r\u001b[?2004h>             )\r\n\u001b[?2004l\rse the 'crop' filter.\u001b[?2004h"]
[167.773857, "o", ">             if pix_fmt in grayscale_fmts:\r\n\u001b[?2004l\r"]
[167.773918, "o", "\u001b[?2004h> "]
[167.774411, "o", "                return True, f\"Correct! Pixel format is {pix_fmt}.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.774523, "o", "            else:\r\n\u001b[?2004l\r"]
[167.77461, "o", "\u001b[?2004h> "]
[167.774746, "o", "                return False, f\"Expected grayscale format but got {pix_fmt}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.774825, "o", "> "]
[167.774862, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r"]
[167.775081, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level3(probe_data):\r\n\u001b[?2004l\r"]
[167.775308, "o", "\u001b[?2004h>     \"\"\"Check that audio duration is approximately 3 seconds.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.775444, "o", "    fmt_duration = probe_data.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.775662, "o", "    if fmt_duration is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.776006, "o", "        dur = float(fmt_duration)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.77605, "o", "        if 2.9 <= dur <= 3.1:\r\n"]
[167.776073, "o", "\u001b[?2004l\r"]
[167.776283, "o", "\u001b[?2004h> "]
[167.776366, "o", "            return True, f\"Correct! Audio duration is {dur:.2f}s.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.776518, "o", "        else:\r\n\u001b[?2004l\rt: Us\u001b[?2004h> "]
[167.777242, "o", "            return False, f\"Expected ~3.0s duration but got {dur:.2f}s\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.777329, "o", "> "]
[167.777442, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.777648, "o", "        if stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.777833, "o", "            dur_str = stream.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.77787, "o", "> "]
[167.77799, "o", "            if dur_str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.778155, "o", "                dur = float(dur_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.778284, "o", "                if 2.9 <= dur <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.778519, "o", "                    return True, f\"Correct! Audio duration is {dur:.2f}s.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.779116, "o", "                else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.779399, "o", "                    return False, f\"Expected ~3.0s duration but got {dur:.2f}s\"\r\n\u001b[?2004l\r"]
[167.779489, "o", "\u001b[?2004h> "]
[167.779672, "o", "    return False, \"Could not determine audio duration\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.779754, "o", "\r\n\u001b[?2004l\r"]
[167.780024, "o", "\u001b[?2004h> def validate_level4(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.780345, "o", "    \"\"\"Check that video is 200x200.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.780495, "o", "    for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.780624, "o", "> "]
[167.780806, "o", "            width = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.780934, "o", "            height = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.78107, "o", "            if width == 200 and height == 200:\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.781097, "o", "> "]
[167.781347, "o", "                return True, \"Correct! Video is 200x200 (center crop).\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.781485, "o", "            else:\r\n\u001b[?2004l\r"]
[167.781645, "o", "\u001b[?2004h> "]
[167.781751, "o", "                return False, f\"Expected 200x200 but got {width}x{height}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.781821, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.781913, "o", "> \r\n\u001b[?2004l\r "]
[167.782107, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ro\u001b[?2004h> def validate_level5(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Check that video is 320x240 (scaled and flipped).\"\"\"\r\n\u001b[?2004l\r"]
[167.782186, "o", "\u001b[?2004h>     for stream in probe_data.get(\"streams\", []):\r\n\u001b[?2004l\r"]
[167.782229, "o", "\u001b[?2004h> "]
[167.78231, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.782413, "o", "            width = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.782524, "o", "            height = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.782645, "o", "            if width == 320 and height == 240:\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.782673, "o", "> "]
[167.782862, "o", "                return True, \"Correct! Video is 320x240 and flipped.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.782966, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.783657, "o", "                return False, f\"Expected 320x240 but got {width}x{height}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.783864, "o", "    return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[167.783895, "o", " "]
[167.784018, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> # --- Level Definitions ---\r\n\u001b[?2004l\r"]
[167.784137, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> LEVELS = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.784296, "o", "        \"number\": 1,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.784468, "o", "        \"name\": \"Level 1: Scale Down\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.784551, "o", "        \"description\": (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.78469, "o", "            \"You have a 640x480 video. Scale it down to 320x240.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.784889, "o", "            \"Hint: Use the 'scale' filter with width:height.\"\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r "]
