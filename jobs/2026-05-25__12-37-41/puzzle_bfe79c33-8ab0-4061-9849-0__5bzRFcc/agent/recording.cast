[167.74132, "o", "def run_cmd(cmd, timeout=30):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.741414, "i", " in probe_data.get(\"streams\", []):\n        if stream.get(\"codec_type\") == \"video\":\n            width = stream.get(\"width\")\n            height = stream.get(\"height\")\n            if width == 320 and height == 240:\n                return True, \"Correct! Video is 320x240 and flipped.\"\n            else:\n                return False, f\"Expected 320x240 but got {width}x{height}\"\n    return False, \"No video stream found\"\n\n\n# --- Level Definitions ---\n\nLEVELS = [\n    {\n        \"number\": 1,\n        \"name\": \"Level 1: Scale Down\",\n        \"description\": (\n            \"You have a 640x480 video. Scale it down to 320x240.\\n\"\n            \"Hint: Use the 'scale' filter with width:height.\"\n        ),\n        \"input_file\": \"input_640x480.mp4\",\n        \"output_file\": \"level1_output.mp4\",\n        \"generate_cmd\": gen_video_640x480,\n        \"media_type\": \"video\",\n        \"solution\": \"scale=320:240\",\n        \"validator\": validate_level1,\n        \"points\": 10,\n    },\n    {\n        \"number\": 2,\n        \"name\": \"Level 2: Grayscale Conve"]
[167.741483, "i", "rsion\",\n        \"description\": (\n            \"You have a 640x480 color video. Convert it to grayscale.\\n\"\n            \"Hint: Use the 'format' filter to change the pixel format.\"\n        ),\n        \"input_file\": \"input_640x480.mp4\",\n        \"output_file\": \"level2_output.mkv\",\n        \"generate_cmd\": gen_video_640x480,\n        \"media_type\": \"video\",\n        \"output_opts\": [\"-c:v\", \"ffv1\", \"-pix_fmt\", \"gray\"],\n        \"solution\": \"format=gray\",\n        \"validator\": validate_level2,\n        \"points\": 10,\n    },\n    {\n        \"number\": 3,\n        \"name\": \"Level 3: Audio Trim\",\n        \"description\": (\n            \"You have a 10-second audio clip (440Hz sine wave).\\n\"\n            \"Trim it to exactly 3 seconds starting from the beginning.\\n\"\n            \"Hint: Use the 'atrim' filter with start and end times.\"\n        ),\n        \"input_file\": \"input_audio_10s.wav\",\n        \"output_file\": \"level3_output.wav\",\n        \"generate_cmd\": gen_audio_10s,\n        \"media_type\": \"audio\",\n        \"solution\": \"atrim=start=0:end=3"]
