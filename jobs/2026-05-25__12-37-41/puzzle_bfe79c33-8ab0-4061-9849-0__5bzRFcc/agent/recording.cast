[167.79927, "o", "        if user_input.lower() == \"quit\":\r\n\u001b[?2004l\r"]
[167.799282, "o", "\u001b[?2004h> "]
[167.799407, "o", "            print(\"\\nThanks for playing!\")\r\n\u001b[?2004l\r\u001b[?2004h>             break"]
[167.799532, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if user_input.lower() == \"skip\":\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  Skipped.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.799565, "o", "            manifest_entries.append({\r\n\u001b[?2004l\r"]
[167.799652, "o", "\u001b[?2004h> "]
[167.799674, "o", "                \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.799766, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h>                 \"validation\": False\r\n\u001b[?2004l\r"]
[167.799954, "o", "\u001b[?2004h>             })\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.800001, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         # Run the level\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.800115, "o", "        passed, output_path = run_level(level, user_input, verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.800268, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             earned_points += level[\"points\"]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[167.800386, "o", "\u001b[?2004h>         manifest_entries.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h"]
[167.800418, "o", ">             \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.800525, "o", "            \"validation\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
