[59.549749, "o", "            \"-i\", input_path,\r\n\u001b[?2004l\rf\u001b[?2004h"]
[59.549858, "o", ">             \"-vf\", filtergraph,\r\n"]
[59.55004, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[59.550082, "o", "            \"-an\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
