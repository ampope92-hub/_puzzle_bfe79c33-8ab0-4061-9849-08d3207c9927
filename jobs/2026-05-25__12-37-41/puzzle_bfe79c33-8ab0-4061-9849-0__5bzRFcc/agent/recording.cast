[59.570475, "o", "\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         \"number\": 2,\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": \"Level 2: Grayscale Conversion\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"description\": (\r\n\u001b[?2004l\r_\u001b[?2004h> "]
[59.570639, "o", "            \"You have a 640x480 color video. Convert it to grayscale.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.570749, "o", "            \"Hint: Use the 'format' filter to change the pixel format.\"\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.571058, "o", "        \"input_file\": \"input_640x480.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
