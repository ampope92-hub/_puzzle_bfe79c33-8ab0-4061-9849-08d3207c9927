[59.569273, "o", "        \"name\": \"Level 1: Scale Down\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.569481, "o", "        \"description\": (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.569509, "o", "            \"You have a 640x480 video. Scale it down to 320x240.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.569634, "o", "            \"Hint: Use the 'scale' filter with width:height.\"\r\n\u001b[?2004l\rp\u001b[?2004h"]
