[167.80125, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.80135, "o", "    print(f\"Manifest written to {MANIFEST_PATH}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[167.801477, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def main():\r\n\u001b[?2004l\r"]
