[167.737061, "i", "cat > /app/ffpuzzle.py << 'PYTHON_SCRIPT'\n#!/usr/bin/env python3\n\"\"\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nthrough progressively harder media transformation challenges.\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef ensure_dirs():\n    \"\"\"Create assets and output directories if they don't exist.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_cmd(cmd, timeout=30):\n    \"\"\"Run a command and return (returncode, stdout, stderr).\"\"\"\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=timeout\n        )\n        return result.returncode, result.stdout.decode(), result.stderr.decode()\n    except subprocess.TimeoutExpired:\n        return -1, \"\", \"Command timed out\"\n    except Exception as e:\n      "]
[167.737447, "i", "  return -1, \"\", str(e)\n\n\ndef generate_input(level):\n    \"\"\"Generate synthetic input for a level using FFmpeg lavfi sources.\"\"\"\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    if os.path.exists(input_path):\n        return input_path\n    cmd = level[\"generate_cmd\"](input_path)\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        print(f\"  ERROR generating input: {stderr}\")\n        return None\n    return input_path\n\n\ndef apply_filtergraph(input_path, filtergraph, output_path, level):\n    \"\"\"Apply a filtergraph to the input and produce output.\"\"\"\n    media_type = level.get(\"media_type\", \"video\")\n    extra_output_opts = level.get(\"output_opts\", [])\n\n    if media_type == \"audio\":\n        cmd = [\n            \"ffmpeg\", \"-y\",\n            \"-i\", input_path,\n            \"-af\", filtergraph,\n            \"-vn\"\n        ] + extra_output_opts + [output_path]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\",\n            \"-i\", input_path,\n            \"-vf\", filtergraph,\n            \"-an\",\n       "]
[167.73772, "o", "cat > /app/ffpuzzle.py << 'PYTHON_SCRIPT'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[167.740273, "i", "     \"-t\", \"2\"\n        ] + extra_output_opts + [output_path]\n\n    rc, stdout, stderr = run_cmd(cmd)\n    return rc == 0\n\n\ndef probe_file(filepath):\n    \"\"\"Use ffprobe to get JSON info about a file.\"\"\"\n    cmd = [\n        \"ffprobe\",\n        \"-v\", \"quiet\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        filepath\n    ]\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        return None\n    try:\n        return json.loads(stdout)\n    except json.JSONDecodeError:\n        return None\n\n\ndef validate_output(output_path, level):\n    \"\"\"Validate the output file against level requirements.\"\"\"\n    if not os.path.exists(output_path):\n        return False, \"Output file does not exist\"\n    probe_data = probe_file(output_path)\n    if probe_data is None:\n        return False, \"Could not probe output file\"\n    validator = level[\"validator\"]\n    return validator(probe_data)\n\n\n# --- Input Generators ---\n\ndef gen_video_640x480(output_path):\n    return [\n        \"ffmpeg\", \"-y\",\n       "]
[167.740517, "o", "\"\"\"FFmpeg Filtergraph Puzzle Game\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> A terminal-based puzzle game that teaches FFmpeg filtergraphs\r\n\u001b[?2004l\r\u001b[?2004h> through progressively harder media transformation challenges.\r\n\u001b[?2004l\r\u001b[?2004h> \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> import argparse\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> import subprocess\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ASSETS_DIR = \"/app/assets\"\r\n\u001b[?2004l\r\u001b[?2004h> OUTPUT_DIR = \"/app/output\"\r\n\u001b[?2004l\r\u001b[?2004h> MANIFEST_PATH = \"/app/manifest.json\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_dirs():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Create assets and output directories if they don't exist.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h>     os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n"]
[167.740556, "i", " \"-f\", \"lavfi\",\n        \"-i\", \"testsrc=duration=5:size=640x480:rate=25\",\n        \"-c:v\", \"libx264\", \"-preset\", \"ultrafast\",\n        \"-t\", \"5\",\n        output_path\n    ]\n\n\ndef gen_audio_10s(output_path):\n    return [\n        \"ffmpeg\", \"-y\",\n        \"-f\", \"lavfi\",\n        \"-i\", \"sine=frequency=440:duration=10\",\n        \"-c:a\", \"pcm_s16le\",\n        output_path\n    ]\n\n\n# --- Validators ---\n\ndef validate_level1(probe_data):\n    \"\"\"Check that video is 320x240.\"\"\"\n    for stream in probe_data.get(\"streams\", []):\n        if stream.get(\"codec_type\") == \"video\":\n            width = stream.get(\"width\")\n            height = stream.get(\"height\")\n            if width == 320 and height == 240:\n                return True, \"Correct! Video is 320x240.\"\n            else:\n                return False, f\"Expected 320x240 but got {width}x{height}\"\n    return False, \"No video stream found\"\n\n\ndef validate_level2(probe_data):\n    \"\"\"Check that video is in grayscale pixel format.\"\"\"\n    for stream in probe_data.get(\"streams\", []):\n  "]
[167.740573, "o", "\u001b[?2004l\r\u001b[?2004h"]
[167.740905, "i", "      if stream.get(\"codec_type\") == \"video\":\n            pix_fmt = stream.get(\"pix_fmt\", \"\")\n            grayscale_fmts = (\n                \"gray\", \"gray8\", \"gray16le\", \"gray16be\",\n                \"ya8\", \"monob\", \"monow\", \"gray10le\",\n                \"gray12le\", \"gray14le\", \"gray9le\"\n            )\n            if pix_fmt in grayscale_fmts:\n                return True, f\"Correct! Pixel format is {pix_fmt}.\"\n            else:\n                return False, f\"Expected grayscale format but got {pix_fmt}\"\n    return False, \"No video stream found\"\n\n\ndef validate_level3(probe_data):\n    \"\"\"Check that audio duration is approximately 3 seconds.\"\"\"\n    fmt_duration = probe_data.get(\"format\", {}).get(\"duration\")\n    if fmt_duration is not None:\n        dur = float(fmt_duration)\n        if 2.9 <= dur <= 3.1:\n            return True, f\"Correct! Audio duration is {dur:.2f}s.\"\n        else:\n            return False, f\"Expected ~3.0s duration but got {dur:.2f}s\"\n    for stream in probe_data.get(\"streams\", []):\n        if strea"]
