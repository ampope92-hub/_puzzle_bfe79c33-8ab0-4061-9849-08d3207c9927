[9.007716, "i", "--\n\ndef _rot13(s: str) -> str:\n    a = []\n    for ch in s:\n        o = ord(ch)\n        if 65 <= o <= 90:\n            a.append(chr(((o - 65 + 13) % 26) + 65))\n        elif 97 <= o <= 122:\n            a.append(chr(((o - 97 + 13) % 26) + 97))\n        else:\n            a.append(ch)\n    return \"\".join(a)\n\n\ndef decode_solution(blob: str) -> str:\n    # blob is: reverse(base64(rot13(solution)))\n    b64 = blob[::-1]\n    raw = base64.b64decode(b64.encode(\"ascii\")).decode(\"utf-8\")\n    return _rot13(raw)\n\n\ndef build_levels() -> List[Level]:\n    # Pre-encoded blobs (NOT plaintext solutions): reverse(base64(rot13(solution)))\n    # Solutions correspond to: \n    # L1: scale=320:240\n    # L2: format=gray\n    # L3: atrim=0:3\n    # L4: crop=200:200:(in_w-200)/2:(in_h-200)/2\n    # L5: scale=320:240,hflip\n    sol_blobs = {\n        1: \"=0TPS4kHZp9yL6MHc0RHa\",\n        2: \"==QKnQXZsFmd\",\n        3: \"=MjO6MzY6pHZvp2YyFmd\",\n        4: \"==QN0AjM0cTOwQjY6I2byVmdpByLt92YuQnbpB3LvwWai9yL09mYv8mLuQnbpB3LvwWai9yL0AjM0cTOwQjY6I2c0RHa\",\n     "]
