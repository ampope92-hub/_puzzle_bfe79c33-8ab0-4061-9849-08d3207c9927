[9.007378, "i", ")\n    # Create ref if missing.\n    if not os.path.exists(ref):\n        inp = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n        cp = run([\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", inp, \"-vf\", \"scale=320:240,format=gray\", \"-frames:v\", \"1\", ref])\n        if cp.returncode != 0:\n            return False, \"Failed generating reference for flip validation\"\n\n    def edge_means(video_path: str) -> Tuple[float, float]:\n        # Use signalstats to get YAVG for left and right crops\n        # Extract one frame, convert to gray, split crops, compute metadata.\n        filt = (\n            \"format=gray,\"\n            \"split=2[l][r];\"\n            \"[l]crop=10:240:0:0,signalstats,metadata=print:file=-[lout];\"\n            \"[r]crop=10:240:310:0,signalstats,metadata=print:file=-[rout]\"\n        )\n        cp = run([\"ffmpeg\", \"-v\", \"error\", \"-i\", video_path, \"-filter_complex\", filt, \"-frames:v\", \"1\", \"-f\", \"null\", \"-\"])\n        if cp.returncode != 0:\n            raise RuntimeError(cp.stderr.strip() or \"edge means ffmpeg failed\")\n       "]
