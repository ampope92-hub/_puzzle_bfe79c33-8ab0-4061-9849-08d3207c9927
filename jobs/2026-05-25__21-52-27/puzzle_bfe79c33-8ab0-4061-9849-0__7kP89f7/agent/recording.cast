[9.056242, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_inputs(levels: List[Level]) -> None:\r\n\u001b[?2004l\r"]
[9.056313, "o", "\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.056347, "o", "> "]
[9.056494, "o", "        in_path = os.path.join(ASSETS_DIR, lvl.input_filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.056623, "o", "        if not os.path.exists(in_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.056741, "o", "            lvl.generate_input(in_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.056956, "o", "def attempt_level(lvl: Level, filtergraph: str) -> Tuple[bool, str, str]:\r\n\u001b[?2004l\r"]
[9.057058, "o", "\u001b[?2004h> "]
[9.05731, "o", "    in_path = os.path.join(ASSETS_DIR, lvl.input_filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.057461, "o", "    out_path = os.path.join(OUTPUT_DIR, lvl.output_filename)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
