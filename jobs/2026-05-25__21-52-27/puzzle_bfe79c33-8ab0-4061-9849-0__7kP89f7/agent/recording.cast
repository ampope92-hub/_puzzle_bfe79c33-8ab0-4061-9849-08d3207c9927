[9.007657, "i", " out = cp.stdout.strip().splitlines()\n        # Parse lines like: frame:... lavfi.signalstats.YAVG=...\n        left = None\n        right = None\n        for line in out:\n            if \"lavfi.signalstats.YAVG=\" in line:\n                val = float(line.split(\"lavfi.signalstats.YAVG=\")[-1])\n                if left is None:\n                    left = val\n                else:\n                    right = val\n        if left is None or right is None:\n            raise RuntimeError(\"Could not parse YAVG\")\n        return left, right\n\n    try:\n        ref_l, ref_r = edge_means(ref)\n        out_l, out_r = edge_means(path)\n    except Exception as e:\n        return False, f\"Flip validation error: {e}\"\n\n    # For a horizontal flip, left/right should swap approximately.\n    if abs(out_l - ref_r) < 1.0 and abs(out_r - ref_l) < 1.0:\n        return True, \"\"\n    return False, f\"Expected horizontal flip signature; got edges (L,R)=({out_l:.2f},{out_r:.2f}) vs ref (L,R)=({ref_l:.2f},{ref_r:.2f})\"\n\n\n# ---- Solution obfuscation --"]
