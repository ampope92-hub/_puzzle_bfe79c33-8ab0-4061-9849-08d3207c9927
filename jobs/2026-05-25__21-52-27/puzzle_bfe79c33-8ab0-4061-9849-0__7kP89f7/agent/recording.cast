[9.007017, "i", "json(path)\n    v = get_first_stream(p, \"video\")\n    w = int(v.get(\"width\", -1))\n    h = int(v.get(\"height\", -1))\n    if w == 200 and h == 200:\n        return True, \"\"\n    return False, f\"Expected 200x200, got {w}x{h}\"\n\n\ndef val_scale_and_hflip(path: str) -> Tuple[bool, str]:\n    # Validate size and also that it is horizontally flipped relative to a known reference.\n    # We'll check flip by comparing left vs right edge luma sums against a reference frame.\n    p = ffprobe_json(path)\n    v = get_first_stream(p, \"video\")\n    w = int(v.get(\"width\", -1))\n    h = int(v.get(\"height\", -1))\n    if not (w == 320 and h == 240):\n        return False, f\"Expected 320x240, got {w}x{h}\"\n\n    # Produce a deterministic signature using ffmpeg: sample frame 0 as gray, compute crop stats.\n    # We'll compute mean of left 10px and right 10px and ensure swapped vs non-flipped reference.\n    # Reference: generate the expected (scale only) version and compare edge means.\n    ref = os.path.join(OUTPUT_DIR, \"__ref_level5_scaleonly.mp4\""]
