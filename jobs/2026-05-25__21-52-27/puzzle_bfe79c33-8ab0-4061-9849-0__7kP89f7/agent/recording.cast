[9.008307, "i", "\n        return False, out_path, f\"ffmpeg error: {err}\"\n\n    passed, msg = lvl.validate(out_path)\n    if not passed:\n        return False, out_path, msg\n    return True, out_path, \"\"\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        print(lvl.description)\n        try:\n            fg = input(\"> \").strip()\n        except EOFError:\n            print(\"  FAIL\")\n            continue\n\n        passed, _, msg = attempt_level(lvl, fg)\n        if passed:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n            if msg:\n                print(f\"  Reason: {msg}\")\n    print(f\"Score: {score}/{len(levels)*10}\")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    score = 0\n\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        blob = getattr(lvl, \"_sol_blob\")\n        fg = decode_solution(blob)\n        passed, _, msg = attempt_level(lvl, fg)\n "]
[9.008373, "i", "       if passed:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n            if msg:\n                print(f\"  Reason: {msg}\")\n\n        manifest.append({\n            \"level\": lvl.num,\n            \"filename\": lvl.output_filename,\n            \"passed\": bool(passed),\n        })\n\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump(manifest, f, indent=2)\n        f.write(\"\\n\")\n\n    print(f\"Score: {score}/{len(levels)*10}\")\n    return 0 if score == len(levels) * 10 else 1\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run deterministically with built-in solutions\")\n    args = ap.parse_args(argv)\n\n    ensure_dirs()\n    levels = build_levels()\n    ensure_inputs(levels)\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == \"__main__\":\n    raise SystemE"]
