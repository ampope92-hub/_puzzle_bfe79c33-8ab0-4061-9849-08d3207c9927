[9.054152, "o", "            input_filename=\"level4_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.054248, "o", "            output_filename=\"level4_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.054348, "o", "            is_audio=False,\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.054377, "o", ">             generate_input=gen_level4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.05451, "o", "            validate=val_crop_center_200,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.054581, "o", "            extra_output_args=[\"-pix_fmt\", \"yuv420p\"],\r\n\u001b[?2004l\r"]
[9.054651, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.054731, "o", "            num=5,\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.05482, "o", ">             name=\"Scale + hflip\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.054912, "o", "> "]
[9.055019, "o", "            description=\"Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\\nEnter a filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.055098, "o", "            input_filename=\"level5_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
