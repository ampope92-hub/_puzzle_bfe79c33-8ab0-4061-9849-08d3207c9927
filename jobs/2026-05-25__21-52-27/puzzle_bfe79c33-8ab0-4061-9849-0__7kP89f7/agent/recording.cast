[9.055736, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.055845, "o", "    # attach solution blob onto object via closure lookup\r\n\u001b[?2004l\r"]
[9.055928, "o", "\u001b[?2004h> "]
[9.055986, "o", "    for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.056028, "o", "        setattr(lvl, \"_sol_blob\", sol_blobs[lvl.num])\r\n"]
