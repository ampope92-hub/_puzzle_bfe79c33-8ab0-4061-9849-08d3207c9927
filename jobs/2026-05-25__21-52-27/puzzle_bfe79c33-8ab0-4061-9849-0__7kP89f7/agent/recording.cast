[9.009173, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.009367, "o", "def ffprobe_json(path: str) -> Dict:\r\n\u001b[?2004l\r\u001b[?2004h>     cp = run([\r\n"]
[9.009525, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[9.009717, "o", "        \"ffprobe\", \"-v\", \"error\",\r\n\u001b[?2004l\ra\u001b[?2004h> "]
[9.009846, "o", "        \"-show_streams\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.00994, "o", "        \"-show_format\",\r\n\u001b[?2004l\r"]
[9.009962, "o", "\u001b[?2004h> "]
[9.010052, "o", "        \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.010215, "o", "> "]
[9.010329, "o", "        path,\r\n\u001b[?2004l\r\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h>     if cp.returncode != 0:\r\n\u001b[?2004l\ruration_seconds(p)\r\n    if dur is None:\r\n        r\u001b[?2004h> "]
[9.010491, "o", "        raise RuntimeError(f\"ffprobe failed for {path}: {cp.stderr.strip()}\")\r\n\u001b[?2004l\r"]
[9.010607, "o", "\u001b[?2004h>     return json.loads(cp.stdout)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[9.010756, "o", "> "]
[9.010863, "o", "def get_first_stream(probe: Dict, codec_type: str) -> Dict:\r\n\u001b[?2004l\r"]
[9.010957, "o", "\u001b[?2004h> "]
[9.011093, "o", "    for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.011237, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r"]
[9.011267, "o", "\u001b[?2004h>             return s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.011449, "o", "    raise KeyError(f\"No {codec_type} stream found\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.011617, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.011755, "o", "def parse_duration_seconds(probe: Dict) -> Optional[float]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.012253, "o", "    # Prefer format.duration, fall back to stream.duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.012447, "o", "    fmt = probe.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.012494, "o", "> "]
[9.012581, "o", "    dur = fmt.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.012693, "o", "    if dur is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.012782, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.013098, "o", "            return float(dur)\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.013205, "o", "> "]
[9.013352, "o", "        except ValueError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.01348, "o", "            pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.01363, "o", "    # fall back to first audio/video stream duration if available\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.013958, "o", "    for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.014494, "o", "        if \"duration\" in s and s.get(\"duration\") is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.01457, "o", "            try:\r\n\u001b[?2004l\r"]
[9.014644, "o", "\u001b[?2004h> "]
[9.014882, "o", "                return float(s[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.015164, "o", "            except ValueError:\r\n\u001b[?2004l\r"]
[9.015228, "o", "\u001b[?2004h> "]
[9.015332, "o", "                continue\r\n\u001b[?2004l\r"]
[9.015365, "o", "\u001b[?2004h> "]
[9.01551, "o", "    return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.016189, "o", "def run_ffmpeg_filter(input_path: str, output_path: str, filtergraph: str, *, is_audio: bool, extra_output_args: Optional[List[str]] = None) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[9.016232, "o", "\u001b[?2004h> "]
[9.016431, "o", "    # Use -filter_complex to allow general filtergraphs; keep mapping simple.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.016533, "o", "    # For video: map v:0; For audio: map a:0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.016596, "o", "    extra_output_args = extra_output_args or []\r\n\u001b[?2004l\r"]
[9.016625, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.017001, "o", "    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", input_path, \"-filter_complex\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.017064, "o", "> "]
[9.017186, "o", "    if is_audio:\r\n\u001b[?2004l\r"]
[9.017861, "o", "\u001b[?2004h>         cmd += [\"-map\", \"[a]\" if \"[a]\" in filtergraph else \"0:a:0\"]"]
[9.01803, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.018157, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.018319, "o", "        cmd += [\"-map\", \"[v]\" if \"[v]\" in filtergraph else \"0:v:0\"]\r\n\u001b[?2004l\r\u001b[?2004h>     cmd += extra_output_args\r\n\u001b[?2004l\r"]
[9.018447, "o", "\u001b[?2004h>     cmd += [output_path]\r\n\u001b[?2004l\re, \"Failed generating ref\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     cp = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.018487, "o", "> "]
[9.018571, "o", "    if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.018729, "o", "        return False, cp.stderr.strip() or cp.stdout.strip()\r\n\u001b[?2004l\r\u001b[?2004h>     return True, \"\"\r\n\u001b[?2004l\r"]
[9.018891, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass\r\n\u001b[?2004l\rfor left and \u001b[?2004h> class Level:\r\n\u001b[?2004l\r\u001b[?2004h>     num: int\r\n\u001b[?2004l\r       # Extr"]
[9.019054, "o", "\u001b[?2004h>     name: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.019159, "o", "    description: str\r\n\u001b[?2004l\r\u001b[?2004h>     input_filename: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.019277, "o", "    output_filename: str\r\n\u001b[?2004l\r\u001b[?2004h>     is_audio: bool\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.019477, "o", "    generate_input: Callable[[str], None]\r\n\u001b[?2004l\r"]
[9.019652, "o", "\u001b[?2004h> "]
[9.019817, "o", "    validate: Callable[[str], Tuple[bool, str]]\r\n\u001b[?2004l\radata=prin\u001b[?2004h>     # output args (container/codec specifics)\r\n\u001b[?2004l\r"]
[9.019904, "o", "\u001b[?2004h>     extra_output_args: List[str]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.020052, "o", "# ---- Input generation ----\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.020094, "o", "def gen_level1(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.020156, "o", "> "]
[9.020199, "o", "    # 640x480 synthetic video, 2 seconds\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.020219, "o", "    run([\r\n\u001b[?2004l\r"]
[9.020423, "o", "\u001b[?2004h> "]
[9.020449, "o", "        \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.020574, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.02061, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\rme\u001b[?2004h> "]
[9.020789, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         path,\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.020947, "o", "> "]
[9.021123, "o", "    ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[9.021247, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[9.02132, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.021428, "o", "def gen_level2(path: str) -> None:\r\n"]
[9.021522, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[9.021683, "o", "    # Use AVI container, rawvideo, fixed pix_fmt to make gray validation strict.\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.021805, "o", ">     run([\r\n"]
[9.021961, "o", "\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\", \"-v\", \"error\","]
[9.02199, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.022183, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.02228, "o", "> "]
[9.022354, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.022486, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         path,\r\n\u001b[?2004l\r\u001b[?2004h>     ])\r\n"]
[9.022556, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[9.022654, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.02273, "o", "def gen_level3(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.022814, "o", "    # 10-second audio clip\r\n\u001b[?2004l\r\u001b[?2004h>     run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.022961, "o", "        \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r rais\u001b[?2004h> "]
[9.023289, "o", "        \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\r\n\u001b[?2004l\r"]
[9.02331, "o", "\u001b[?2004h>         \"-t\", \"10\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.023446, "o", "        \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r"]
[9.023476, "o", "\u001b[?2004h> "]
[9.023577, "o", "        path,\r\n\u001b[?2004l\r"]
[9.023647, "o", "\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.023762, "o", "def gen_level4(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.023947, "o", "        \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.023991, "o", "> "]
[9.024121, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.024214, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.024229, "o", ">         path,\r\n\u001b[?2004l\r"]
[9.024395, "o", " abs(out_r - r\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.0246, "o", "def gen_level5(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.024702, "o", "        \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r; \u001b[?2004h> "]
[9.024792, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.02491, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\ration \u001b[?2004h> "]
[9.024988, "o", "        path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.025018, "o", "    ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.025063, "o", "\r\n\u001b[?2004l\r"]
[9.025252, "o", "\u001b[?2004h> # ---- Validation ----\r\n\u001b[?2004l\r) -> str:\r\n    a = []\r\n  \u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h"]
[9.025332, "o", "> "]
[9.025413, "o", "def val_scale_320x240(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[9.025508, "o", "\u001b[?2004h>     v = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r))\r\n     "]
[9.025541, "o", "\u001b[?2004h> "]
[9.02564, "o", "    w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.025742, "o", "    h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.025861, "o", "    if w == 320 and h == 240:\r\n\u001b[?2004l\r\u001b[?2004h>         return True, \"\"\r\n\u001b[?2004l\r\r\n   "]
[9.026052, "o", "\u001b[?2004h>     return False, f\"Expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.026149, "o", "def val_gray_pixfmt(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.026389, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h>     v = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r"]
[9.026506, "o", "\u001b[?2004h>     pix = v.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h>     if pix == \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.026703, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.026905, "o", "    return False, f\"Expected pix_fmt gray, got {pix}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.027122, "o", "def val_audio_trim_3s(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.027231, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.027344, "o", "    a = get_first_stream(p, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.027486, "o", "    _ = a  # ensure audio exists\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.027665, "o", "    dur = parse_duration_seconds(p)\r\n\u001b[?2004l\r\u001b[?2004h>     if dur is None:\r\n\u001b[?2004l\rcale=320:2\u001b[?2004h> "]
[9.027825, "o", "        return False, \"Could not determine duration\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.028128, "o", "    if 2.9 <= dur <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.028257, "o", "        return True, \"\"\r\n\u001b[?2004l\r \"=\u001b[?2004h> "]
[9.028369, "o", "    return False, f\"Expected duration ~3s, got {dur:.3f}s\"\r\n\u001b[?2004l\r"]
[9.028472, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.028636, "o", "def val_crop_center_200(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[9.028749, "o", "\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.028923, "o", "    v = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.029133, "o", "    w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.029307, "o", "    h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r"]
[9.029408, "o", "\u001b[?2004h> "]
[9.029528, "o", "    if w == 200 and h == 200:\r\n\u001b[?2004l\r"]
[9.02962, "o", "\u001b[?2004h>         return True, \"\"\r\n\u001b[?2004l\r=\"\u001b[?2004h> "]
[9.029917, "o", "    return False, f\"Expected 200x200, got {w}x{h}\"\r\n\u001b[?2004l\r"]
[9.030126, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def val_scale_and_hflip(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.030346, "o", "    # Validate size and also that it is horizontally flipped relative to a known reference.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.030893, "o", "    # We'll check flip by comparing left vs right edge luma sums against a reference frame.\r\n\u001b[?2004l\r"]
[9.031009, "o", "\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[9.031307, "o", "\u001b[?2004h>     v = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.031414, "o", "    w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r"]
[9.031439, "o", "\u001b[?2004h> "]
[9.031576, "o", "    h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.031765, "o", "    if not (w == 320 and h == 240):\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.031871, "o", "> "]
[9.032132, "o", "        return False, f\"Expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r"]
[9.032153, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[9.032262, "o", "> "]
[9.032573, "o", "    # Produce a deterministic signature using ffmpeg: sample frame 0 as gray, compute crop stats.\r\n\u001b[?2004l\r"]
[9.032673, "o", "\u001b[?2004h> "]
[9.033002, "o", "    # We'll compute mean of left 10px and right 10px and ensure swapped vs non-flipped reference.\r\n\u001b[?2004l\r"]
[9.033095, "o", "\u001b[?2004h> "]
[9.033244, "o", "    # Reference: generate the expected (scale only) version and compare edge means.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.033582, "o", "    ref = os.path.join(OUTPUT_DIR, \"__ref_level5_scaleonly.mp4\")\r\n\u001b[?2004l\r"]
[9.03361, "o", "\u001b[?2004h> "]
[9.033731, "o", "    # Create ref if missing.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.033883, "o", "    if not os.path.exists(ref):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.034083, "o", "        inp = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.034424, "o", "> "]
[9.034591, "o", "        cp = run([\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", inp, \"-vf\", \"scale=320:240,format=gray\", \"-frames:v\", \"1\", ref])\r\n\u001b[?2004l\r"]
[9.034625, "o", "\u001b[?2004h>         if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.035262, "o", "            return False, \"Failed generating reference for flip validation\"\r\n\u001b[?2004l\r"]
[9.035485, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.035602, "o", "    def edge_means(video_path: str) -> Tuple[float, float]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.035628, "o", "        # Use signalstats to get YAVG for left and right crops\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.036028, "o", "        # Extract one frame, convert to gray, split crops, compute metadata.\r\n\u001b[?2004l\r\u001b[?2004h>         filt = (\r\n\u001b[?2004l\rfilen\u001b[?2004h"]
[9.036165, "o", ">             \"format=gray,\"\r\n\u001b[?2004l\r\u001b[?2004h>             \"split=2[l][r];\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.036253, "o", "> "]
[9.036741, "o", "            \"[l]crop=10:240:0:0,signalstats,metadata=print:file=-[lout];\"\r\n\u001b[?2004l\r"]
[9.036905, "o", "\u001b[?2004h> "]
[9.037011, "o", "            \"[r]crop=10:240:310:0,signalstats,metadata=print:file=-[rout]\"\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.037633, "o", "        cp = run([\"ffmpeg\", \"-v\", \"error\", \"-i\", video_path, \"-filter_complex\", filt, \"-frames:v\", \"1\", \"-f\", \"null\", \"-\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.037855, "o", "        if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.038055, "o", "            raise RuntimeError(cp.stderr.strip() or \"edge means ffmpeg failed\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.038146, "o", "> "]
[9.038661, "o", "        out = cp.stdout.strip().splitlines()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.03949, "o", "        # Parse lines like: frame:... lavfi.signalstats.YAVG=...\r\n\u001b[?2004l\r\u001b[?2004h>         left = None\r\n\u001b[?2004l\r\u001b[?2004h>         right = None\r\n\u001b[?2004l\r\u001b[?2004h>         for line in out:\r\n\u001b[?2004l\r"]
[9.039573, "o", "\u001b[?2004h> "]
[9.0399, "o", "            if \"lavfi.signalstats.YAVG=\" in line:\r\n\u001b[?2004l\r\u001b[?2004h>                 val = float(line.split(\"lavfi.signalstats.YAVG=\")[-1])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.040122, "o", "                if left is None:\r\n\u001b[?2004l\rbject via closure lo\u001b[?2004h>                     left = val\r\n\u001b[?2004l\rokup\r\n    for lvl in levels:\r\n   \u001b[?2004h>                 else:\r\n"]
[9.040133, "o", "\u001b[?2004l\r\u001b[?2004h"]
[9.040244, "o", ">                     right = val\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.040278, "o", "> "]
[9.040462, "o", "        if left is None or right is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041126, "o", "            raise RuntimeError(\"Could not parse YAVG\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041159, "o", "        return left, right\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rS"]
[9.04123, "o", "\u001b[?2004h> "]
[9.04129, "o", "    try:\r\n\u001b[?2004l\r"]
[9.041364, "o", "\u001b[?2004h> "]
[9.041479, "o", "        ref_l, ref_r = edge_means(ref)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041561, "o", "        out_l, out_r = edge_means(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041721, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041918, "o", "        return False, f\"Flip validation error: {e}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.041985, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.04205, "o", "> "]
[9.042215, "o", "    # For a horizontal flip, left/right should swap approximately.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.042419, "o", "    if abs(out_l - ref_r) < 1.0 and abs(out_r - ref_l) < 1.0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.042447, "o", "> "]
[9.042521, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.042564, "o", "> "]
[9.043043, "o", "    return False, f\"Expected horizontal flip signature; got edges (L,R)=({out_l:.2f},{out_r:.2f}) vs ref (L,R)=({ref_l:.2f},{ref_r:.2f})\"\r\n\u001b[?2004l\r"]
[9.043125, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.043232, "o", "# ---- Solution obfuscation ----\r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.043462, "o", "def _rot13(s: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.04358, "o", ">     a = []\r\n\u001b[?2004l\r\u001b[?2004h>     for ch in s:\r\n\u001b[?2004l\r\u001b[?2004h>         o = ord(ch)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.043613, "o", "        if 65 <= o <= 90:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.043737, "o", "            a.append(chr(((o - 65 + 13) % 26) + 65))\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.043836, "o", "> "]
[9.043864, "o", "        elif 97 <= o <= 122:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.044096, "o", "            a.append(chr(((o - 97 + 13) % 26) + 97))\r\n\u001b[?2004l\rscore\u001b[?2004h> "]
[9.044215, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.044309, "o", "            a.append(ch)\r\n\u001b[?2004l\r"]
[9.044618, "o", "\u001b[?2004h>     return \"\".join(a)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[9.04477, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.044994, "o", "def decode_solution(blob: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.045153, "o", ">     # blob is: reverse(base64(rot13(solution)))\r\n\u001b[?2004l\r"]
[9.045252, "o", "\u001b[?2004h> "]
[9.04532, "o", "    b64 = blob[::-1]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.045545, "o", "    raw = base64.b64decode(b64.encode(\"ascii\")).decode(\"utf-8\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.045665, "o", ">     return _rot13(raw)\r\n\u001b[?2004l\r"]
[9.045789, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rem\u001b[?2004h> "]
[9.045833, "o", "def build_levels() -> List[Level]:\r\n\u001b[?2004l\r"]
[9.045951, "o", "\u001b[?2004h> "]
[9.046166, "o", "    # Pre-encoded blobs (NOT plaintext solutions): reverse(base64(rot13(solution)))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.046257, "o", "    # Solutions correspond to: \r\n\u001b[?2004l\r"]
[9.04641, "o", "\u001b[?2004h>     # L1: scale=320:240\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.046531, "o", "    # L2: format=gray\r\n\u001b[?2004l\r    "]
[9.046644, "o", "\u001b[?2004h>     # L3: atrim=0:3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.046831, "o", "    # L4: crop=200:200:(in_w-200)/2:(in_h-200)/2\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.047043, "o", "    # L5: scale=320:240,hflip\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.047126, "o", "    sol_blobs = {\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.04726, "o", "> "]
[9.047389, "o", "        1: \"=0TPS4kHZp9yL6MHc0RHa\",\r\n\u001b[?2004l\r"]
[9.047492, "o", "\u001b[?2004h> "]
[9.04762, "o", "        2: \"==QKnQXZsFmd\",\r\n\u001b[?2004l\r"]
[9.047677, "o", "\u001b[?2004h> "]
[9.0478, "o", "        3: \"=MjO6MzY6pHZvp2YyFmd\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.048403, "o", "        4: \"==QN0AjM0cTOwQjY6I2byVmdpByLt92YuQnbpB3LvwWai9yL09mYv8mLuQnbpB3LvwWai9yL0AjM0cTOwQjY6I2c0RHa\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.048541, "o", "> "]
[9.048886, "o", "        5: \"=wWZsNnboV2Y,0TPS4kHZp9yL6MHc0RHa\"\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[9.048914, "o", "> "]
[9.049148, "o", "    levels: List[Level] = [\r\n\u001b[?2004l\r"]
[9.049327, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r   "]
[9.049399, "o", "\u001b[?2004h"]
[9.049494, "o", "> "]
[9.049613, "o", "            num=1,\r\n\u001b[?2004l\r\"\u001b[?2004h> "]
[9.04986, "o", "            name=\"Downscale\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.049942, "o", "> "]
[9.050174, "o", "            description=\"Scale a 640x480 video down to 320x240.\\nEnter a filtergraph.\",\r\n\u001b[?2004l\r"]
[9.050518, "o", "\u001b[?2004h> "]
[9.050693, "o", "            input_filename=\"level1_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_filename=\"level1_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             is_audio=False,\r\n\u001b[?2004l\r\u001b[?2004h>             generate_input=gen_level1,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.050725, "o", "            validate=val_scale_320x240,\r\n\u001b[?2004l\rt=2)\r\n        \u001b[?2004h> "]
[9.05087, "o", "            extra_output_args=[\"-pix_fmt\", \"yuv420p\"],\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r"]
[9.051048, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             num=2,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.05108, "o", "            name=\"Grayscale\","]
[9.051227, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.051457, "o", "            description=\"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\\nEnter a filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.051591, "o", "            input_filename=\"level2_input.avi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.051864, "o", "            output_filename=\"level2_output.avi\",\r\n\u001b[?2004l\r"]
[9.05199, "o", "\u001b[?2004h>             is_audio=False,\r\n\u001b[?2004l\rgs\u001b[?2004h"]
[9.052086, "o", "> "]
[9.052206, "o", "            generate_input=gen_level2,\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.052294, "o", "> "]
[9.052366, "o", "            validate=val_gray_pixfmt,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.05289, "o", "            extra_output_args=[\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"],\r\n\u001b[?2004l\r"]
[9.052921, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r interactiv\u001b[?2004h> "]
[9.053019, "o", "        Level(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.053173, "o", "            num=3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.053241, "o", "            name=\"Audio trim\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.05337, "o", "            description=\"Trim a 10-second audio clip to exactly 3 seconds.\\nEnter a filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[9.05351, "o", "            input_filename=\"level3_input.wav\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_filename=\"level3_output.wav\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[9.053623, "o", ">             is_audio=True,\r\n\u001b[?2004l\r\u001b[?2004h> "]
