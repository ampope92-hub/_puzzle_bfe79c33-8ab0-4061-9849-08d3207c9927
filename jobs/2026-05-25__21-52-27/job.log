ge_means(ref)\n        out_l, out_r = edge_means(path)\n    except Exception as e:\n        return False, f"Flip validation error: {e}"\n\n    # For a horizontal flip, left/right should swap approximately.\n    if abs(out_l - ref_r) < 1.0 and abs(out_r - ref_l) < 1.0:\n        return True, ""\n    return False, f"Expected horizontal flip signature; got edges (L,R)=({out_l:.2f},{out_r:.2f}) vs ref (L,R)=({ref_l:.2f},{ref_r:.2f})"\n\n\n# ---- Solution obfuscation ----\n\ndef _rot13(s: str) -> str:\n    a = []\n    for ch in s:\n        o = ord(ch)\n        if 65 <= o <= 90:\n            a.append(chr(((o - 65 + 13) % 26) + 65))\n        elif 97 <= o <= 122:\n            a.append(chr(((o - 97 + 13) % 26) + 97))\n        else:\n            a.append(ch)\n    return "".join(a)\n\n\ndef decode_solution(blob: str) -> str:\n    # blob is: reverse(base64(rot13(solution)))\n    b64 = blob[::-1]\n    raw = base64.b64decode(b64.encode("ascii")).decode("utf-8")\n    return _rot13(raw)\n\n\ndef build_levels() -> List[Level]:\n    # Pre-encoded blobs (NOT plaintext solutions): reverse(base64(rot13(solution)))\n    # Solutions correspond to: \n    # L1: scale=320:240\n    # L2: format=gray\n    # L3: atrim=0:3\n    # L4: crop=200:200:(in_w-200)/2:(in_h-200)/2\n    # L5: scale=320:240,hflip\n    sol_blobs = {\n        1: "=0TPS4kHZp9yL6MHc0RHa",\n        2: "==QKnQXZsFmd",\n        3: "=MjO6MzY6pHZvp2YyFmd",\n        4: "==QN0AjM0cTOwQjY6I2byVmdpByLt92YuQnbpB3LvwWai9yL09mYv8mLuQnbpB3LvwWai9yL0AjM0cTOwQjY6I2c0RHa",\n        5: "=wWZsNnboV2Y,0TPS4kHZp9yL6MHc0RHa"\n    }\n\n    levels: List[Level] = [\n        Level(\n            num=1,\n            name="Downscale",\n            description="Scale a 640x480 video down to 320x240.\\nEnter a filtergraph.",\n            input_filename="level1_input.mp4",\n            output_filename="level1_output.mp4",\n            is_audio=False,\n            generate_input=gen_level1,\n            validate=val_scale_320x240,\n            extra_output_args=["-pix_fmt", "yuv420p"],\n        ),\n        Level(\n            num=2,\n            name="Grayscale",\n            description="Convert a video to grayscale. Output pixel format must be exactly \'gray\'.\\nEnter a filtergraph.",\n            input_filename="level2_input.avi",\n            output_filename="level2_output.avi",\n            is_audio=False,\n            generate_input=gen_level2,\n            validate=val_gray_pixfmt,\n            extra_output_args=["-c:v", "rawvideo", "-pix_fmt", "gray"],\n        ),\n        Level(\n            num=3,\n            name="Audio trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.\\nEnter a filtergraph.",\n            input_filename="level3_input.wav",\n            output_filename="level3_output.wav",\n            is_audio=True,\n            generate_input=gen_level3,\n            validate=val_audio_trim_3s,\n            extra_output_args=["-c:a", "pcm_s16le"],\n        ),\n        Level(\n            num=4,\n            name="Center crop",\n            description="Crop the center 200x200 region from a 640x480 video.\\nEnter a filtergraph.",\n            input_filename="level4_input.mp4",\n            output_filename="level4_output.mp4",\n            is_audio=False,\n            generate_input=gen_level4,\n            validate=val_crop_center_200,\n            extra_output_args=["-pix_fmt", "yuv420p"],\n        ),\n        Level(\n            num=5,\n            name="Scale + hflip",\n            description="Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\\nEnter a filtergraph.",\n            input_filename="level5_input.mp4",\n            output_filename="level5_output.mp4",\n            is_audio=False,\n            generate_input=gen_level5,\n            validate=val_scale_and_hflip,\n            extra_output_args=["-pix_fmt", "yuv420p"],\n        ),\n    ]\n\n    # attach solution blob onto object via closure lookup\n    for lvl in levels:\n     