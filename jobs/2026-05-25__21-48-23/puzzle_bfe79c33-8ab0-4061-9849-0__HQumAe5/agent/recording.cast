[94.761508, "o", "    if lv.kind == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.76154, "o", "        if lv.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h>             extra = [\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[94.761669, "o", "> "]
[94.761809, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.761891, "o", "            extra = [\"-pix_fmt\", \"yuv420p\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.762009, "o", "        p = run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         extra = [\"-c:a\", \"pcm_s16le\"]\r\n\u001b[?2004l\r"]
