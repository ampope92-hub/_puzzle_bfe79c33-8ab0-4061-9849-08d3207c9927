[142.890157, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[142.890176, "o", "> def build_inputs(levels: List[Level]) -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     for lv in levels:\r\n\u001b[?2004l\r"]
[142.890268, "o", "\u001b[?2004h>         if not os.path.exists(lv.input_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.89033, "o", "            lv.input_builder(lv.input_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[142.890338, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890405, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.89047, "o", "def run_level(lv: Level, filtergraph: str) -> bool:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890543, "o", "    if os.path.exists(lv.output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890665, "o", "        os.remove(lv.output_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if lv.kind == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890734, "o", "        if lv.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890815, "o", "            extra = [\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"]\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.890838, "o", "            extra = [\"-pix_fmt\", \"yuv420p\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[142.890926, "o", "> "]
[142.890992, "o", "        p = run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\r\n\u001b[?2004l\r\u001b[?2004h"]
[142.891009, "o", "> "]
[142.891057, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.891186, "o", "        extra = [\"-c:a\", \"pcm_s16le\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.891306, "o", "        p = run_audio_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[142.891436, "o", "\u001b[?2004l\r\u001b[?2004h>     if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[142.89159, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         return bool(lv.validator(lv.output_path))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.891704, "o", "    except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[142.891712, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.891816, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     for lv in levels:\r\n\u001b[?2004l\r"]
[142.891925, "o", "\u001b[?2004h>         print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.891953, "o", "        print(lv.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.892018, "o", "        try:\r\n\u001b[?2004l\r"]
[142.892095, "o", "\u001b[?2004h> "]
[142.892113, "o", "            fg = input(\"Enter filtergraph (or 'q' to quit): \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r"]
[142.892183, "o", "\u001b[?2004h>             print(\"\\nExiting.\")"]
[142.892247, "o", "\r\n\u001b[?2004l\r"]
[142.892383, "o", "\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h>         if fg.lower() in (\"q\", \"quit\", \"exit\"):\r\n\u001b[?2004l\r"]
[142.892404, "o", "\u001b[?2004h> "]
[142.892477, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.892493, "o", "        passed = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.892599, "o", "        print(\"  PASS\" if passed else \"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893176, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest: List[Dict[str, Any]] = []\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893301, "o", "        fg = decode_solution(lv.solution_token)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893438, "o", "        passed = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"  PASS\" if passed else \"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893461, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893531, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893675, "o", "        manifest.append({\"level\": lv.num, \"filename\": lv.output_filename, \"passed\": bool(passed)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r"]
[142.893744, "o", "\u001b[?2004h> "]
[142.893881, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.893936, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.894002, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def main() -> int:\r\n\u001b[?2004l\r\u001b[?2004h"]
[142.894118, "o", "> "]
[142.89424, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.894332, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions\")\r\n\u001b[?2004l\r\u001b[?2004h>     args = ap.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.894423, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.894532, "o", "    levels = make_levels()\r\n\u001b[?2004l\r\u001b[?2004h>     build_inputs(levels)\r\n\u001b[?2004l\r"]
[142.89466, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h>         return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[142.894679, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[142.894762, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[142.894844, "o", "\u001b[?2004h> "]
[142.894858, "o", "    raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> '''\r\n\u001b[?2004l\r"]
