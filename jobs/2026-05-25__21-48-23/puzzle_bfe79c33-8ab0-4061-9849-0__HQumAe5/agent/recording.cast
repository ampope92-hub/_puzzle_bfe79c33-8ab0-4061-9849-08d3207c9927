[94.716377, "i", "me=\"level5_input.mp4\",\n            output_filename=\"level5_output.mp4\",\n            input_builder=build_level5_input,\n            validator=validate_scale_and_hflip,\n            solution_token=\"cGlsaGxhLGwwMjoyMjM9ZWxjYXM=\",\n        ),\n    ]\n\n\ndef build_inputs(levels: List[Level]) -> None:\n    for lv in levels:\n        if not os.path.exists(lv.input_path):\n            lv.input_builder(lv.input_path)\n\n\ndef run_level(lv: Level, filtergraph: str) -> bool:\n    if os.path.exists(lv.output_path):\n        os.remove(lv.output_path)\n\n    if lv.kind == \"video\":\n        if lv.num == 2:\n            extra = [\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"]\n        else:\n            extra = [\"-pix_fmt\", \"yuv420p\"]\n        p = run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\n    else:\n        extra = [\"-c:a\", \"pcm_s16le\"]\n        p = run_audio_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\n\n    if p.returncode != 0:\n        return False\n    try:\n        return bool(lv.validator(lv.ou"]
[94.716389, "i", "tput_path))\n    except Exception:\n        return False\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    for lv in levels:\n        print(f\"Level {lv.num}: {lv.name}\")\n        print(lv.description)\n        try:\n            fg = input(\"Enter filtergraph (or 'q' to quit): \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n        if fg.lower() in (\"q\", \"quit\", \"exit\"):\n            break\n        passed = run_level(lv, fg)\n        print(\"  PASS\" if passed else \"  FAIL\")\n        if passed:\n            score += 10\n    print(f\"Score: {score}/{len(levels)*10}\")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest: List[Dict[str, Any]] = []\n    score = 0\n    for lv in levels:\n        print(f\"Level {lv.num}: {lv.name}\")\n        fg = decode_solution(lv.solution_token)\n        passed = run_level(lv, fg)\n        print(\"  PASS\" if passed else \"  FAIL\")\n        if passed:\n            score += 10\n        manifest.append({\"level\": lv.num, \"filename\": lv.outpu"]
[94.716457, "i", "t_filename, \"passed\": bool(passed)})\n\n    print(f\"Score: {score}/{len(levels)*10}\")\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump(manifest, f, indent=2)\n        f.write(\"\\n\")\n    return 0\n\n\ndef main() -> int:\n    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n    ap.add_argument(\"--auto-solve\", action=\"store_true\")\n    args = ap.parse_args()\n\n    ensure_dirs()\n    levels = make_levels()\n    build_inputs(levels)\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\nPY\n"]
