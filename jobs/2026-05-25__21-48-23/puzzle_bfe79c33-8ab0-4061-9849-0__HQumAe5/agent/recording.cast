[194.641197, "i", "python3 -c 'import pathlib; lines=[\n\"#!/usr/bin/env python3\\n\",\n\"import argparse\\n\",\n\"import base64\\n\",\n\"import json\\n\",\n\"import os\\n\",\n\"import subprocess\\n\",\n\"from dataclasses import dataclass\\n\",\n\"from typing import Any, Dict, List, Optional\\n\\n\",\n\"ASSETS_DIR=\\\"/app/assets\\\"\\n\",\n\"OUTPUT_DIR=\\\"/app/output\\\"\\n\",\n\"MANIFEST_PATH=\\\"/app/manifest.json\\\"\\n\\n\",\n\"def run(cmd: List[str]) -> subprocess.CompletedProcess:\\n\",\n\"    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\\n\\n\",\n\"def ensure_dirs() -> None:\\n\",\n\"    os.makedirs(ASSETS_DIR, exist_ok=True)\\n\",\n\"    os.makedirs(OUTPUT_DIR, exist_ok=True)\\n\\n\",\n\"def ffprobe_json(path: str) -> Dict[str, Any]:\\n\",\n\"    cmd=[\\\"ffprobe\\\",\\\"-v\\\",\\\"error\\\",\\\"-print_format\\\",\\\"json\\\",\\\"-show_format\\\",\\\"-show_streams\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(f\\\"ffprobe failed for {path}:\\\\n{p.stderr}\\\")\\n\",\n\"    return json.loads(p.stdout)\\n\\n\",\n\"def get_first_stream(probe: Dict[str, Any], codec_type: str) "]
[194.641231, "i", "-> Dict[str, Any]:\\n\",\n\"    for s in probe.get(\\\"streams\\\",[]):\\n\",\n\"        if s.get(\\\"codec_type\\\")==codec_type: return s\\n\",\n\"    raise KeyError(f\\\"No {codec_type} stream found\\\")\\n\\n\",\n\"def parse_duration_seconds(probe: Dict[str, Any]) -> Optional[float]:\\n\",\n\"    dur=probe.get(\\\"format\\\",{}).get(\\\"duration\\\")\\n\",\n\"    if dur in (None,\\\"N/A\\\",\\\"\\\"): return None\\n\",\n\"    try: return float(dur)\\n\",\n\"    except Exception: return None\\n\\n\",\n\"def within(x: float, lo: float, hi: float) -> bool:\\n\",\n\"    return lo <= x <= hi\\n\\n\",\n\"def _rot13(s: str) -> str:\\n\",\n\"    out=[]\\n\",\n\"    for ch in s:\\n\",\n\"        o=ord(ch)\\n\",\n\"        if 65<=o<=90: out.append(chr(((o-65+13)%26)+65))\\n\",\n\"        elif 97<=o<=122: out.append(chr(((o-97+13)%26)+97))\\n\",\n\"        else: out.append(ch)\\n\",\n\"    return \\\"\\\".join(out)\\n\\n\",\n\"def decode_solution(token: str) -> str:\\n\",\n\"    raw=base64.b64decode(token.encode(\\\"ascii\\\")).decode(\\\"utf-8\\\")\\n\",\n\"    return _rot13(raw[::-1])\\n\\n\",\n\"@dataclass\\n\",\n\"class Level:\\n\",\n\"    num: int\\n"]
[194.641238, "i", "\",\n\"    name: str\\n\",\n\"    kind: str\\n\",\n\"    description: str\\n\",\n\"    input_filename: str\\n\",\n\"    output_filename: str\\n\",\n\"    input_builder: Any\\n\",\n\"    validator: Any\\n\",\n\"    solution_token: str\\n\\n\",\n\"    @property\\n\",\n\"    def input_path(self) -> str:\\n\",\n\"        return os.path.join(ASSETS_DIR,self.input_filename)\\n\\n\",\n\"    @property\\n\",\n\"    def output_path(self) -> str:\\n\",\n\"        return os.path.join(OUTPUT_DIR,self.output_filename)\\n\\n\",\n\"def build_level1_input(path: str) -> None:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\\",\\\"-v\\\",\\\"error\\\",\\\"-f\\\",\\\"lavfi\\\",\\\"-i\\\",\\\"testsrc2=size=640x480:rate=30\\\",\\\"-t\\\",\\\"2\\\",\\\"-pix_fmt\\\",\\\"yuv420p\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(p.stderr)\\n\\n\",\n\"def build_level2_input(path: str) -> None:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\\",\\\"-v\\\",\\\"error\\\",\\\"-f\\\",\\\"lavfi\\\",\\\"-i\\\",\\\"testsrc2=size=320x240:rate=30\\\",\\\"-t\\\",\\\"2\\\",\\\"-c:v\\\",\\\"rawvideo\\\",\\\"-pix_fmt\\\",\\\"rgb24\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(p.s"]
[194.641242, "i", "tderr)\\n\\n\",\n\"def build_level3_input(path: str) -> None:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\\",\\\"-v\\\",\\\"error\\\",\\\"-f\\\",\\\"lavfi\\\",\\\"-i\\\",\\\"sine=frequency=440:sample_rate=44100:duration=10\\\",\\\"-c:a\\\",\\\"pcm_s16le\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(p.stderr)\\n\\n\",\n\"def build_level4_input(path: str) -> None:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\\",\\\"-v\\\",\\\"error\\\",\\\"-f\\\",\\\"lavfi\\\",\\\"-i\\\",\\\"testsrc2=size=640x480:rate=30\\\",\\\"-t\\\",\\\"2\\\",\\\"-pix_fmt\\\",\\\"yuv420p\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(p.stderr)\\n\\n\",\n\"def build_level5_input(path: str) -> None:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\\",\\\"-v\\\",\\\"error\\\",\\\"-f\\\",\\\"lavfi\\\",\\\"-i\\\",\\\"testsrc2=size=640x480:rate=30\\\",\\\"-t\\\",\\\"2\\\",\\\"-pix_fmt\\\",\\\"yuv420p\\\",path]\\n\",\n\"    p=run(cmd)\\n\",\n\"    if p.returncode!=0: raise RuntimeError(p.stderr)\\n\\n\",\n\"def run_video_filter(in_path: str, out_path: str, filtergraph: str, extra_out: Optional[List[str]] = None) -> subprocess.CompletedProcess:\\n\",\n\"    cmd=[\\\"ffmpeg\\\",\\\"-y\\"]
