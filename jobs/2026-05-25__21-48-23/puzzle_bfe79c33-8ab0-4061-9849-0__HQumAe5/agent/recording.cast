[51.376088, "o", "        manifest.append({\"level\": lv.num, \"filename\": lv.output_filename, \"passed\": bool(passed)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[51.376206, "o", "\u001b[?2004h>     print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.376286, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.376353, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r"]
