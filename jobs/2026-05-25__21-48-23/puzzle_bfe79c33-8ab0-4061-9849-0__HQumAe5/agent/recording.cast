[142.858812, "i", "rn _rot13(raw[::-1])\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    kind: str  # 'video' or 'audio'\n    description: str\n    input_filename: str\n    output_filename: str\n    input_builder: Any\n    validator: Any\n    solution_token: str\n\n    @property\n    def input_path(self) -> str:\n        return os.path.join(ASSETS_DIR, self.input_filename)\n\n    @property\n    def output_path(self) -> str:\n        return os.path.join(OUTPUT_DIR, self.output_filename)\n\n\n# --- input generators ---\n\ndef build_level1_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-pix_fmt\", \"yuv420p\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef build_level2_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=320x240:rate=30\",\n        \"-t\", \"2\",\n        \"-c:v\", \"rawvideo\",\n        \"-pix_fmt"]
