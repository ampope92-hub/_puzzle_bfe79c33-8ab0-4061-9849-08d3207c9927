[142.858902, "i", "\", \"rgb24\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef build_level3_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=44100:duration=10\",\n        \"-c:a\", \"pcm_s16le\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef build_level4_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-pix_fmt\", \"yuv420p\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef build_level5_input(path: str) -> None:\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-pix_fmt\", \"yuv420p\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError("]
