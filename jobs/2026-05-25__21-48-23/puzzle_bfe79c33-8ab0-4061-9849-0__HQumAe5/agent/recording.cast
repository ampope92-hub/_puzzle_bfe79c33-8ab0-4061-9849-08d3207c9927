[142.859006, "i", "tion_3s(path: str) -> bool:\n    pr = ffprobe_json(path)\n    d = parse_duration_seconds(pr)\n    return (d is not None) and within(float(d), 2.9, 3.1)\n\n\ndef validate_crop_center_200(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return int(v.get(\"width\", -1)) == 200 and int(v.get(\"height\", -1)) == 200\n\n\ndef validate_scale_and_hflip(path: str) -> bool:\n    return validate_scaled_320x240(path)\n\n\ndef make_levels() -> List[Level]:\n    return [\n        Level(1, \"Scale 640x480 down to 320x240\", \"video\",\n              \"Input: 640x480 video. Goal: output must be exactly 320x240.\",\n              \"level1_input.mp4\", \"level1_output.mp4\",\n              build_level1_input, validate_scaled_320x240,\n              \"PTAyNDozMj0lbGFjcw==\"),\n        Level(2, \"Convert video to grayscale\", \"video\",\n              \"Input: color video. Goal: output pixel format must be exactly 'gray'. (AVI + rawvideo)\",\n              \"level2_input.avi\", \"level2_output.avi\",\n              build_level2_input, v"]
