[94.493374, "o", "#!/usr/bin/env python3\r\nimport argparse\r\nimport base64\r\nimport json\r\nimport os\r\nimport subprocess\r\nimport sys\r\nfrom dataclasses import dataclass\r\nfrom typing import Any, Dict, List, Optional\r\n\r\nASSETS_DIR = \"/app/assets\"\r\nOUTPUT_DIR = \"/app/output\"\r\nMANIFEST_PATH = \"/app/manifest.json\"\r\n\r\n\r\ndef run(cmd: List[str]) -> subprocess.CompletedProcess:\r\n    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\r\n\r\n\r\ndef ensure_dirs() -> None:\r\n    os.makedirs(ASSETS_DIR, exist_ok=True)\r\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\r\n\r\ndef ffprobe_json(path: str) -> Dict[str, Any]:\r\n    cmd = [\r\n        \"ffprobe\",\r\n        \"-v\",\r\n        \"error\",\r\n        \"-print_format\",\r\n        \"json\",\r\n        \"-show_format\",\r\n        \"-show_streams\",\r\n        path,\r\n    ]\r\n    p = run(cmd)\r\n    if p.returncode != 0:\r\n        raise RuntimeError(f\"ffprobe failed for {path}:\\n{p.stderr}\")\r\n    return json.loads(p.stdout)\r\n\r\n\r\ndef get_first_stream(probe: Dict[str, Any], codec_type: str) -> Dict[str, Any"]
[94.493942, "o", "]:\r\n    for s in probe.get(\"streams\", []):\r\n        if s.get(\"codec_type\") == codec_type:\r\n            return s\r\n    raise KeyError(f\"No {codec_type} stream found\")\r\n\r\n\r\ndef parse_duration_seconds(probe: Dict[str, Any]) -> Optional[float]:\r\n    # Prefer stream duration if present; fallback to container duration.\r\n    try:\r\n        fmt = probe.get(\"format\", {})\r\n        if \"duration\" in fmt and fmt[\"duration\"] not in (None, \"N/A\", \"\"):\r\n            return float(fmt[\"duration\"])\r\n    except Exception:\r\n        pass\r\n    return None\r\n\r\n\r\ndef within(x: float, lo: float, hi: float) -> bool:\r\n    return lo <= x <= hi\r\n\r\n\r\n# --- solution obfuscation helpers (avoid plaintext filtergraphs in source) ---\r\n\r\ndef _rot13(s: str) -> str:\r\n    out = []\r\n    for ch in s:\r\n        o = ord(ch)\r\n        if 65 <= o <= 90:\r\n            out.append(chr(((o - 65 + 13) % 26) + 65))\r\n        elif 97 <= o <= 122:\r\n            out.append(chr(((o - 97 + 13) % 26) + 97))\r\n        else:\r\n            out.append(ch)\r\n    return \"\".join(out)\r"]
[94.494152, "o", "\n\r\n\r\ndef decode_solution(token: str) -> str:\r\n    # token: base64( rot13(solution)[::-1] )\r\n    raw = base64.b64decode(token.encode(\"ascii\")).decode(\"utf-8\")\r\n    return _rot13(raw[::-1])\r\n\r\n\r\n@dataclass\r\nclass Level:\r\n    num: int\r\n    name: str\r\n    kind: str  # 'video' or 'audio'\r\n    description: str\r\n    input_filename: str\r\n    output_filename: str\r\n    input_builder: Any\r\n    validator: Any\r\n    solution_token: str\r\n\r\n    @property\r\n    def input_path(self) -> str:\r\n        return os.path.join(ASSETS_DIR, self.input_filename)\r\n\r\n    @property\r\n    def output_path(self) -> str:\r\n        return os.path.join(OUTPUT_DIR, self.output_filename)\r\n\r\n\r\n# --- input generators ---\r\n\r\ndef build_level1_input(path: str) -> None:\r\n    # 640x480 test pattern, 2 seconds\r\n    cmd = [\r\n        \"ffmpeg\",\r\n        \"-y\",\r\n        \"-v\",\r\n        \"error\",\r\n        \"-f\",\r\n        \"lavfi\",\r\n        \"-i\",\r\n        \"testsrc2=size=640x480:rate=30\",\r\n        \"-t\",\r\n        \"2\",\r\n"]
