[51.376651, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.376714, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions\")\r\n\u001b[?2004l\r\u001b[?2004h>     args = ap.parse_args()\r\n\u001b[?2004l\r"]
