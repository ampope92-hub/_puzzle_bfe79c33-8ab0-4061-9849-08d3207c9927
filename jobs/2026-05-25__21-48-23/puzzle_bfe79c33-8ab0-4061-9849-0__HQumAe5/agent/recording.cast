[94.762425, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         return bool(lv.validator(lv.output_path))\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.762451, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[94.762585, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r"]
[94.762719, "o", "\u001b[?2004h>     for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lv.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.762808, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h>             fg = input(\"Enter filtergraph (or 'q' to quit): \").strip()\r\n"]
[94.762869, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[94.763005, "o", "        except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.763157, "o", "            print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.763165, "o", "        if fg.lower() in (\"q\", \"quit\", \"exit\"):\r\n\u001b[?2004l\r"]
[94.763328, "o", "\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h>         passed = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.763468, "o", "        print(\"  PASS\" if passed else \"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.763556, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.763725, "o", "    print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
