[142.858983, "i", "p.stderr)\n\n\ndef run_video_filter(in_path: str, out_path: str, filtergraph: str, extra_out: Optional[List[str]] = None) -> subprocess.CompletedProcess:\n    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", in_path, \"-vf\", filtergraph]\n    if extra_out:\n        cmd.extend(extra_out)\n    cmd.append(out_path)\n    return run(cmd)\n\n\ndef run_audio_filter(in_path: str, out_path: str, filtergraph: str, extra_out: Optional[List[str]] = None) -> subprocess.CompletedProcess:\n    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", in_path, \"-af\", filtergraph]\n    if extra_out:\n        cmd.extend(extra_out)\n    cmd.append(out_path)\n    return run(cmd)\n\n\n# --- validators ---\n\ndef validate_scaled_320x240(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return int(v.get(\"width\", -1)) == 320 and int(v.get(\"height\", -1)) == 240\n\n\ndef validate_gray_pixfmt(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return v.get(\"pix_fmt\") == \"gray\"\n\n\ndef validate_audio_dura"]
