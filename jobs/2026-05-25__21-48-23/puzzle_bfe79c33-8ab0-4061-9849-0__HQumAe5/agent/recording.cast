[51.370867, "o", "\u001b[?2004h> def run_level(lv: Level, filtergraph: str) -> bool:\r\n\u001b[?2004l\r\u001b[?2004h>     # Remove prior output to ensure deterministic re-generation\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371006, "o", "    if os.path.exists(lv.output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371153, "o", "        os.remove(lv.output_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if lv.kind == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>         extra = None\r\n\u001b[?2004l\r"]
[51.371333, "o", "\u001b[?2004h>         # ensure container/codec constraints when needed\r\n\u001b[?2004l\r\u001b[?2004h>         if lv.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371434, "o", "            extra = [\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\"]\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371516, "o", "            extra = [\"-pix_fmt\", \"yuv420p\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371725, "o", "        p = run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371824, "o", "        extra = [\"-c:a\", \"pcm_s16le\"]\r\n\u001b[?2004l\r\u001b[?2004h>         p = run_audio_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371887, "o", "    if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.371907, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[51.371912, "o", "\u001b[?2004h"]
[51.372072, "o", ">     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.372185, "o", "        return bool(lv.validator(lv.output_path))\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.372228, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.372279, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.372319, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.372369, "o", "    score = 0\r\n\u001b[?2004l\r"]
[51.372614, "o", "\u001b[?2004h>     for lv in levels:"]
[51.37279, "o", "\r\n\u001b[?2004l\r"]
[51.372875, "o", "\u001b[?2004h>         print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r"]
[51.372895, "o", "\u001b[?2004h"]
[51.373043, "o", ">         print(lv.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.37332, "o", "        prompt = \"Enter filtergraph (or 'q' to quit): \"\r\n"]
[51.373383, "o", "\u001b[?2004l\r"]
[51.37339, "o", "\u001b[?2004h"]
[51.373576, "o", ">         try:\r\n"]
[51.373738, "o", "\u001b[?2004l\r\u001b[?2004h>             fg = input(prompt).strip()\r\n\u001b[?2004l\r"]
[51.373884, "o", "\u001b[?2004h>         except EOFError:\r\n"]
[51.374052, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[51.374206, "o", "            print(\"\\nExiting.\")\r\n\u001b[?2004l\r"]
[51.374306, "o", "\u001b[?2004h"]
[51.374467, "o", ">             break\r\n\u001b[?2004l\r"]
