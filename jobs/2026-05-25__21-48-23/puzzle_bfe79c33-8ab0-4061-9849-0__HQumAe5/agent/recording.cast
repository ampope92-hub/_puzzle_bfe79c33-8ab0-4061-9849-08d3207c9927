[94.71617, "i", "rs (strict where specified) ---\n\ndef validate_scaled_320x240(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return int(v.get(\"width\", -1)) == 320 and int(v.get(\"height\", -1)) == 240\n\n\ndef validate_gray_pixfmt(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return v.get(\"pix_fmt\") == \"gray\"\n\n\ndef validate_audio_duration_3s(path: str) -> bool:\n    pr = ffprobe_json(path)\n    d = parse_duration_seconds(pr)\n    if d is None:\n        return False\n    return within(float(d), 2.9, 3.1)\n\n\ndef validate_crop_center_200(path: str) -> bool:\n    pr = ffprobe_json(path)\n    v = get_first_stream(pr, \"video\")\n    return int(v.get(\"width\", -1)) == 200 and int(v.get(\"height\", -1)) == 200\n\n\ndef validate_scale_and_hflip(path: str) -> bool:\n    # Strictly validate scale. (Flip verification would require frame comparison.)\n    return validate_scaled_320x240(path)\n\n\ndef make_levels() -> List[Level]:\n    return [\n        Level(\n            num=1,\n  "]
