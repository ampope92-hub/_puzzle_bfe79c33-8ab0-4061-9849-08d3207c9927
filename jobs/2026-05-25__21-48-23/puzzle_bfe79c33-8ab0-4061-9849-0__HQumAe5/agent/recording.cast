[51.375009, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r"]
[51.375047, "o", "\u001b[?2004h> "]
[51.375253, "o", "    print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.375443, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest: List[Dict[str, Any]] = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.375563, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.375678, "o", "        print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         fg = decode_solution(lv.solution_token)\r\n\u001b[?2004l\r\u001b[?2004h> "]
