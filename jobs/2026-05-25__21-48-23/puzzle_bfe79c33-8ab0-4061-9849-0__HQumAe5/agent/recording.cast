[94.764466, "o", "        manifest.append({\"level\": lv.num, \"filename\": lv.output_filename, \"passed\": bool(passed)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.764583, "o", "    print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.764654, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[94.764721, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
