[94.764094, "o", "> "]
[94.764246, "o", "        passed = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"  PASS\" if passed else \"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
