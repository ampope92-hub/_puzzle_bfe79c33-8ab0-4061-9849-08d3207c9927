[194.656273, "o", "\u001b[?2004h> \"def validate_scale_and_hflip(path: str) -> bool:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    return validate_scaled_320x240(path)\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.656299, "o", "> "]
[194.656432, "o", "\"def make_levels() -> List[Level]:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    return [\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.656621, "o", "\"        Level(1,\\\"Scale 640x480 down to 320x240\\\",\\\"video\\\",\\\"Input: 640x480 video. Goal: output must be exactly 320x240.\\\",\\\"level1_input.mp4\\\",\\\"level1_output.mp4\\\",build_level1_input,validate_scaled_320x240,\\\"MDQyOjAyMz1yeW5wZg==\\\"),\\n\",\r\n\u001b[?2004l\r"]
[194.656671, "o", "\u001b[?2004h> "]
[194.656908, "o", "\"        Level(2,\\\"Convert video to grayscale\\\",\\\"video\\\",\\\"Input: color video. Goal: output pixel format must be exactly 'gray'. (AVI + rawvideo)\\\",\\\"level2_input.avi\\\",\\\"level2_output.avi\\\",build_level2_input,validate_gray_pixfmt,\\\"bG5ldD1nbnplYnM=\\\"),\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.657172, "o", "\"        Level(3,\\\"Trim 10s audio to exactly 3s\\\",\\\"audio\\\",\\\"Input: 10-second audio. Goal: output duration must be between 2.9 and 3.1 seconds.\\\",\\\"level3_input.wav\\\",\\\"level3_output.wav\\\",build_level3_input,validate_audio_duration_3s,\\\"Mz1xYXI9enZlZ24=\\\"),\\n\",\r\n\u001b[?2004l\r"]
[194.657192, "o", "\u001b[?2004h> "]
[194.657461, "o", "\"        Level(4,\\\"Crop center 200x200\\\",\\\"video\\\",\\\"Input: 640x480 video. Goal: crop the center region to 200x200.\\\",\\\"level4_input.mp4\\\",\\\"level4_output.mp4\\\",build_level4_input,validate_crop_center_200,\\\"MDQxOjAyMjowMDI6MDAyPWNiZXA=\\\"),\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.657755, "o", "\"        Level(5,\\\"Scale to 320x240 and horizontal flip\\\",\\\"video\\\",\\\"Input: 640x480 video. Goal: scale to 320x240 and apply horizontal flip.\\\",\\\"level5_input.mp4\\\",\\\"level5_output.mp4\\\",build_level5_input,validate_scale_and_hflip,\\\"Y3Z5c3UsMDQyOjAyMz1yeW5wZg==\\\"),\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.657883, "o", "\"    ]\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.657972, "o", "\"def build_inputs(levels: List[Level]) -> None:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    for lv in levels:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.657997, "o", "\"        if not os.path.exists(lv.input_path):\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658094, "o", "\"            lv.input_builder(lv.input_path)\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658145, "o", "\"def run_level(lv: Level, filtergraph: str) -> bool:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658372, "o", "\"    if os.path.exists(lv.output_path): os.remove(lv.output_path)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658433, "o", "\"    if lv.kind==\\\"video\\\":\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658517, "o", "\"        extra=[\\\"-pix_fmt\\\",\\\"yuv420p\\\"]\\n\",\r\n\u001b[?2004l\r"]
[194.658553, "o", "\u001b[?2004h> "]
[194.658684, "o", "\"        if lv.num==2: extra=[\\\"-c:v\\\",\\\"rawvideo\\\",\\\"-pix_fmt\\\",\\\"gray\\\"]\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.658721, "o", "\"        p=run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.65874, "o", "\"    else:\\n\",\r\n\u001b[?2004l\r"]
[194.658822, "o", "\u001b[?2004h> "]
[194.65891, "o", "\"        p=run_audio_filter(lv.input_path, lv.output_path, filtergraph, extra_out=[\\\"-c:a\\\",\\\"pcm_s16le\\\"])\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659002, "o", "\"    if p.returncode!=0: return False\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659066, "o", "\"    try: return bool(lv.validator(lv.output_path))\\n\",\r\n\u001b[?2004l\r"]
[194.659096, "o", "\u001b[?2004h> \"    except Exception: return False\\n\\n\",\r\n\u001b[?2004l\r"]
[194.659161, "o", "\u001b[?2004h> "]
[194.659245, "o", "\"def interactive(levels: List[Level]) -> int:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659349, "o", "\"    score=0\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    for lv in levels:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"        print(f\\\"Level {lv.num}: {lv.name}\\\")\\n\",\r\n\u001b[?2004l\r"]
[194.659423, "o", "\u001b[?2004h> "]
[194.659488, "o", "\"        print(lv.description)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659637, "o", "\"        try: fg=input(\\\"Enter filtergraph (or 'q' to quit): \\\").strip()\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659755, "o", "\"        except EOFError: print(\\\"\\\\nExiting.\\\"); break\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.659915, "o", "\"        if fg.lower() in (\\\"q\\\",\\\"quit\\\",\\\"exit\\\"): break\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.659945, "o", "> \"        passed=run_level(lv, fg)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"        print(\\\"  PASS\\\" if passed else \\\"  FAIL\\\")\\n\",\r\n\u001b[?2004l\r"]
[194.659972, "o", "\u001b[?2004h> "]
[194.660069, "o", "\"        if passed: score += 10\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660184, "o", "\"    print(f\\\"Score: {score}/{len(levels)*10}\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.66029, "o", "\"    return 0\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"def auto_solve(levels: List[Level]) -> int:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    manifest=[]\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.660405, "o", "> \"    score=0\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660445, "o", "\"    for lv in levels:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660504, "o", "\"        print(f\\\"Level {lv.num}: {lv.name}\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660577, "o", "\"        fg=decode_solution(lv.solution_token)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660604, "o", "\"        passed=run_level(lv, fg)\\n\",\r\n\u001b[?2004l\r"]
[194.660745, "o", "\u001b[?2004h> \"        print(\\\"  PASS\\\" if passed else \\\"  FAIL\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.660894, "o", "\"        if passed: score += 10\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"        manifest.append({\\\"level\\\": lv.num, \\\"filename\\\": lv.output_filename, \\\"passed\\\": bool(passed)})\\n\",\r\n\u001b[?2004l\r"]
[194.660921, "o", "\u001b[?2004h> "]
[194.661041, "o", "\"    print(f\\\"Score: {score}/{len(levels)*10}\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.661139, "o", "\"    with open(MANIFEST_PATH,\\\"w\\\",encoding=\\\"utf-8\\\") as f:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.661195, "o", "\"        json.dump(manifest,f,indent=2); f.write(\\\"\\\\n\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.661225, "o", "> "]
[194.661577, "o", "\"    return 0\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.661723, "o", "> \"def main() -> int:\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.661776, "o", "\"    ap=argparse.ArgumentParser(description=\\\"FFmpeg filtergraph puzzle game\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.661995, "o", "> \"    ap.add_argument(\\\"--auto-solve\\\", action=\\\"store_true\\\", help=\\\"Run all levels with built-in solutions\\\")\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.662033, "o", "\"    args=ap.parse_args()\\n\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[194.662095, "o", "> "]
[194.662174, "o", "\"    ensure_dirs(); levels=make_levels(); build_inputs(levels)\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[194.662411, "o", "\"    return auto_solve(levels) if args.auto_solve else interactive(levels)\\n\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"if __name__==\\\"__main__\\\":\\n\",\r\n\u001b[?2004l\r\u001b[?2004h> \"    raise SystemExit(main())\\n\",\r\n\u001b[?2004l\r"]
[194.662433, "o", "\u001b[?2004h> "]
[194.662578, "o", "]; pathlib.Path(\"/app/ffpuzzle.py\").write_text(\"\".join(lines), encoding=\"utf-8\")'\r\n\u001b[?2004l\r"]
