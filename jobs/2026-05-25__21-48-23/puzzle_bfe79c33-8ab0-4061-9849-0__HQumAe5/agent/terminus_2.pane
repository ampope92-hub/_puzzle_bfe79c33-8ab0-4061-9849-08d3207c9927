[?2004l[?2004h> "    cmd.append(out_path)\n",
[?2004l[?2004h> "    return run(cmd)\n\n",
[?2004l[?2004h> "def validate_scaled_320x240(path: str) -> bool:\n",
[?2004l[?2004h> "    pr=ffprobe_json(path); v=get_first_stream(pr,\"video\");\n",
[?2004l[?2004h> "    return int(v.get(\"width\",-1))==320 and int(v.get(\"height\",-1))==240\n\n",
[?2004l[?2004h> "def validate_gray_pixfmt(path: str) -> bool:\n",
[?2004l[?2004h> "    pr=ffprobe_json(path); v=get_first_stream(pr,\"video\");\n",
[?2004l[?2004h> "    return v.get(\"pix_fmt\")==\"gray\"\n\n",
[?2004l[?2004h> "def validate_audio_duration_3s(path: str) -> bool:\n",
[?2004l[?2004h> "    pr=ffprobe_json(path); d=parse_duration_seconds(pr);\n",
[?2004l[?2004h> "    return (d is not None) and within(float(d),2.9,3.1)\n\n",
[?2004l[?2004h> "def validate_crop_center_200(path: str) -> bool:\n",
[?2004l[?2004h> "    pr=ffprobe_json(path); v=get_first_stream(pr,\"video\");\n",
[?2004l[?2004h> "    return int(v.get(\"width\",-1))==200 and int(v.get(\"height\",-1))==200\n\n",
[?2004l[?2004h> "def validate_scale_and_hflip(path: str) -> bool:\n",
[?2004l[?2004h> "    return validate_scaled_320x240(path)\n\n",
[?2004l[?2004h> "def make_levels() -> List[Level]:\n",
[?2004l[?2004h> "    return [\n",
[?2004l[?2004h> "        Level(1,\"Scale 640x480 down to 320x240\",\"video\",\"Input: 640x480 video. Goal: output must be exactly 320x240.\",\"level1_input.mp4\",\"level1_output.mp4\",build_level1_input,validate_scaled_320x240,\"MDQyOjAyMz1yeW5wZg==\"),\n",
[?2004l[?2004h> "        Level(2,\"Convert video to grayscale\",\"video\",\"Input: color video. Goal: output pixel format must be exactly 'gray'. (AVI + rawvideo)\",\"level2_input.avi\",\"level2_output.avi\",build_level2_input,validate_gray_pixfmt,\"bG5ldD1nbnplYnM=\"),\n",
[?2004l[?2004h> "        Level(3,\"Trim 10s audio to exactly 3s\",\"audio\",\"Input: 10-second audio. Goal: output duration must be between 2.9 and 3.1 seconds.\",\"level3_input.wav\",\"level3_output.wav\",build_level3_input,validate_audio_duration_3s,\"Mz1xYXI9enZlZ24=\"),\n",
[?2004l[?2004h> "        Level(4,\"Crop center 200x200\",\"video\",\"Input: 640x480 video. Goal: crop the center region to 200x200.\",\"level4_input.mp4\",\"level4_output.mp4\",build_level4_input,validate_crop_center_200,\"MDQxOjAyMjowMDI6MDAyPWNiZXA=\"),\n",
[?2004l[?2004h> "        Level(5,\"Scale to 320x240 and horizontal flip\",\"video\",\"Input: 640x480 video. Goal: scale to 320x240 and apply horizontal flip.\",\"level5_input.mp4\",\"level5_output.mp4\",build_level5_input,validate_scale_and_hflip,\"Y3Z5c3UsMDQyOjAyMz1yeW5wZg==\"),\n",
[?2004l[?2004h> "    ]\n\n",
[?2004l[?2004h> "def build_inputs(levels: List[Level]) -> None:\n",
[?2004l[?2004h> "    for lv in levels:\n",
[?2004l[?2004h> "        if not os.path.exists(lv.input_path):\n",
[?2004l[?2004h> "            lv.input_builder(lv.input_path)\n\n",
[?2004l[?2004h> "def run_level(lv: Level, filtergraph: str) -> bool:\n",
[?2004l[?2004h> "    if os.path.exists(lv.output_path): os.remove(lv.output_path)\n",
[?2004l[?2004h> "    if lv.kind==\"video\":\n",
[?2004l[?2004h> "        extra=[\"-pix_fmt\",\"yuv420p\"]\n",
[?2004l[?2004h> "        if lv.num==2: extra=[\"-c:v\",\"rawvideo\",\"-pix_fmt\",\"gray\"]\n",
[?2004l[?2004h> "        p=run_video_filter(lv.input_path, lv.output_path, filtergraph, extra_out=extra)\n",
[?2004l[?2004h> "    else:\n",
[?2004l[?2004h> "        p=run_audio_filter(lv.input_path, lv.output_path, filtergraph, extra_out=[\"-c:a\",\"pcm_s16le\"])\n",
[?2004l[?2004h> "    if p.returncode!=0: return False\n",
[?2004l[?2004h> "    try: return bool(lv.validator(lv.output_path))\n",
[?2004l[?2004h> "    except Exception: return False\n\n",
[?2004l[?2004h> "def interactive(levels: List[Level]) -> int:\n",
[?2004l[?2004h> "    score=0\n",
[?2004l[?2004h> "    for lv in levels:\n",
[?2004l[?2004h> "        print(f\"Level {lv.num}: {lv.name}\")\n",
[?2004l[?2004h> "        print(lv.description)\n",
[?2004l[?2004h> "        try: fg=input(\"Enter filtergraph (or 'q' to quit): \").strip()\n",
[?2004l[?2004h> "        except EOFError: print(\"\\nExiting.\"); break\n",
[?2004l[?2004h> "        if fg.lower() in (\"q\",\"quit\",\"exit\"): break\n",
[?2004l[?2004h> "        passed=run_level(lv, fg)\n",
[?2004l[?2004h> "        print(\"  PASS\" if passed else \"  FAIL\")\n",
[?2004l[?2004h> "        if passed: score += 10\n",
[?2004l[?2004h> "    print(f\"Score: {score}/{len(levels)*10}\")\n",
[?2004l[?2004h> "    return 0\n\n",
[?2004l[?2004h> "def auto_solve(levels: List[Level]) -> int:\n",
[?2004l[?2004h> "    manifest=[]\n",
[?2004l[?2004h> "    score=0\n",
[?2004l[?2004h> "    for lv in levels:\n",
[?2004l[?2004h> "        print(f\"Level {lv.num}: {lv.name}\")\n",
[?2004l[?2004h> "        fg=decode_solution(lv.solution_token)\n",
[?2004l[?2004h> "        passed=run_level(lv, fg)\n",
[?2004l[?2004h> "        print(\"  PASS\" if passed else \"  FAIL\")\n",
[?2004l[?2004h> "        if passed: score += 10\n",
[?2004l[?2004h> "        manifest.append({\"level\": lv.num, \"filename\": lv.output_filename, \"passed\": bool(passed)})\n",
[?2004l[?2004h> "    print(f\"Score: {score}/{len(levels)*10}\")\n",
[?2004l[?2004h> "    with open(MANIFEST_PATH,\"w\",encoding=\"utf-8\") as f:\n",
[?2004l[?2004h> "        json.dump(manifest,f,indent=2); f.write(\"\\n\")\n",
[?2004l[?2004h> "    return 0\n\n",
[?2004l[?2004h> "def main() -> int:\n",
[?2004l[?2004h> "    ap=argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n",
[?2004l[?2004h> "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions\")\n",
[?2004l[?2004h> "    args=ap.parse_args()\n",
[?2004l[?2004h> "    ensure_dirs(); levels=make_levels(); build_inputs(levels)\n",
[?2004l[?2004h> "    return auto_solve(levels) if args.auto_solve else interactive(levels)\n\n",
[?2004l[?2004h> "if __name__==\"__main__\":\n",
[?2004l[?2004h> "    raise SystemExit(main())\n",
[?2004l[?2004h> ]; pathlib.Path("/app/ffpuzzle.py").write_text("".join(lines), encoding="utf-8")'
