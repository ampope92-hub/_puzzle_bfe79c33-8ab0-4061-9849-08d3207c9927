[57.8313, "i", "320,\n                \"height\": 240\n            }\n        }\n    },\n]\n\n\ndef ensure_dirs():\n    \"\"\"Create assets and output directories if they don't exist.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_cmd(args, quiet=True):\n    \"\"\"Run a command and return (returncode, stdout, stderr).\"\"\"\n    kwargs = {}\n    if quiet:\n        kwargs[\"stdout\"] = subprocess.PIPE\n        kwargs[\"stderr\"] = subprocess.PIPE\n    result = subprocess.run(args, **kwargs)\n    stdout = result.stdout.decode(\"utf-8\", errors=\"replace\") if result.stdout else \"\"\n    stderr = result.stderr.decode(\"utf-8\", errors=\"replace\") if result.stderr else \"\"\n    return result.returncode, stdout, stderr\n\n\ndef generate_input(level):\n    \"\"\"Generate synthetic input for a level using FFmpeg lavfi sources.\"\"\"\n    input_gen = level[\"input_gen\"]\n    if os.path.exists(input_gen[\"output\"]):\n        return True\n    rc, _, stderr = run_cmd(input_gen[\"args\"])\n    if rc != 0:\n        print(f\"  ERROR generating input"]
