[203.98155, "i", "python3 << 'PYEOF'\nwith open('/app/ffpuzzle.py', 'r') as f:\n    lines = f.readlines()\n\n# Find and fix level 2 output_file and template\nfor i, line in enumerate(lines):\n    if '\"output_file\": os.path.join(OUTPUT_DIR, \"level2_output.mp4\")' in line:\n        lines[i] = line.replace('level2_output.mp4', 'level2_output.mkv')\n    if '\"ffmpeg\", \"-y\", \"-i\", os.path.join(ASSETS_DIR, \"level2_input.mp4\"),' in line:\n        # This is the template line for level 2\n        # Check next lines to confirm it's the template (not input_gen)\n        if i+1 < len(lines) and '{filtergraph}' in lines[i+1]:\n            # Replace lines i+2 and i+3 (codec and output)\n            lines[i+2] = '            \"-c:v\", \"ffv1\",\\n'\n            lines[i+3] = '            os.path.join(OUTPUT_DIR, \"level2_output.mkv\")\\n'\n\nwith open('/app/ffpuzzle.py', 'w') as f:\n    f.writelines(lines)\n\nprint('Done')\nPYEOF\n"]
