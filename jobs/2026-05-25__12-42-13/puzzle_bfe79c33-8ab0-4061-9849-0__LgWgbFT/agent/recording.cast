[102.511246, "o", "sed -i 's/\"ffmpeg\", \"-y\", \"-i\", os.path.join(ASSETS_DIR, \"level2_input.mp4\"),/\"ffmpeg\", \"-y\", \"-i\", os.path.join(ASSETS_DIR, \"level2_input.mp4\"),/' /app/ffpuzzle.py\r\n\u001b[?2004l\r"]
