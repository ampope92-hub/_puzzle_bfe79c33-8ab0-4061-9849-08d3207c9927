[102.74477, "i", "python3 -c \"\nimport re\n\nwith open('/app/ffpuzzle.py', 'r') as f:\n    content = f.read()\n\n# Fix level 2 template - add pix_fmt gray\nold = '''\\\"ffmpeg\\\", \\\"-y\\\", \\\"-i\\\", os.path.join(ASSETS_DIR, \\\"level2_input.mp4\\\"),\n            \\\"-vf\\\", \\\"{filtergraph}\\\",\n            \\\"-c:v\\\", \\\"libx264\\\",\n            os.path.join(OUTPUT_DIR, \\\"level2_output.mp4\\\")'''\n\nnew = '''\\\"ffmpeg\\\", \\\"-y\\\", \\\"-i\\\", os.path.join(ASSETS_DIR, \\\"level2_input.mp4\\\"),\n            \\\"-vf\\\", \\\"{filtergraph}\\\",\n            \\\"-c:v\\\", \\\"libx264\\\", \\\"-pix_fmt\\\", \\\"gray\\\",\n            os.path.join(OUTPUT_DIR, \\\"level2_output.mp4\\\")'''\n\ncontent = content.replace(old, new)\n\nwith open('/app/ffpuzzle.py', 'w') as f:\n    f.write(content)\n\nprint('Done')\n\"\n"]
