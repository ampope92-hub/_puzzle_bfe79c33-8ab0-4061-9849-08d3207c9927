[57.831368, "i", "ted}', got '{actual}'\"\n\n    return True, \"All checks passed\"\n\n\ndef run_level(level, filtergraph, verbose=True):\n    \"\"\"Run a single level with the given filtergraph. Returns (passed, details).\"\"\"\n    # Generate input\n    if not generate_input(level):\n        return False, \"Failed to generate input\"\n\n    # Run filtergraph\n    success, error = run_filtergraph(level, filtergraph)\n    if not success:\n        if verbose:\n            print(f\"  FFmpeg error: {error[:200]}\")\n        return False, \"FFmpeg failed\"\n\n    # Validate output\n    passed, details = validate_output(level)\n    return passed, details\n\n\ndef auto_solve():\n    \"\"\"Run all levels with known correct solutions.\"\"\"\n    ensure_dirs()\n    manifest = []\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f\"Level {level['number']}: {level['name']}\")\n        passed, details = run_level(level, level[\"solution\"], verbose=True)\n\n        if passed:\n            print(\"  PASS\")\n            total_score += 10\n        els"]
