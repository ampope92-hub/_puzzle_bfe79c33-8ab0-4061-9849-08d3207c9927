[57.854359, "o", "> \r\n\u001b[?2004l\rl\u001b[?2004h> "]
[57.854455, "o", "def run_cmd(args, quiet=True):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.854568, "o", "    \"\"\"Run a command and return (returncode, stdout, stderr).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     kwargs = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.854679, "o", "    if quiet:\r\n\u001b[?2004l\r"]
[57.854812, "o", "\u001b[?2004h>         kwargs[\"stdout\"] = subprocess.PIPE\r\n\u001b[?2004l\r\u001b[?2004h>         kwargs[\"stderr\"] = subprocess.PIPE\r\n\u001b[?2004l\rror: \u001b[?2004h"]
[57.854831, "o", "> "]
[57.854943, "o", "    result = subprocess.run(args, **kwargs)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.855198, "o", "    stdout = result.stdout.decode(\"utf-8\", errors=\"replace\") if result.stdout else \"\"\r\n\u001b[?2004l\r"]
[57.855286, "o", "\u001b[?2004h> "]
[57.855356, "o", "    stderr = result.stderr.decode(\"utf-8\", errors=\"replace\") if result.stderr else \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.855466, "o", "    return result.returncode, stdout, stderr\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.855494, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.855646, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.85579, "o", "    \"\"\"Generate synthetic input for a level using FFmpeg lavfi sources.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.855847, "o", "> "]
[57.85596, "o", "    input_gen = level[\"input_gen\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.856199, "o", "    if os.path.exists(input_gen[\"output\"]):\r\n\u001b[?2004l\r\u001b[?2004h>         return True\r\n\u001b[?2004l\r\u001b[?2004h>     rc, _, stderr = run_cmd(input_gen[\"args\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.856307, "o", "    if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.856475, "o", "        print(f\"  ERROR generating input: {stderr}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.856575, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.856636, "o", "    return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r   "]
[57.856706, "o", "\u001b[?2004h> "]
[57.856795, "o", "def run_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.856822, "o", "> "]
[57.857021, "o", "    \"\"\"Run the user's filtergraph through FFmpeg.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.857315, "o", "    template = level[\"ffmpeg_template\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.857348, "o", "> "]
[57.85744, "o", "    cmd = []\r\n\u001b[?2004l\rss\u001b[?2004h> "]
[57.85746, "o", "    for arg in template:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.857576, "o", "        if \"{filtergraph}\" in arg:\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.857603, "o", "> "]
[57.858152, "o", "            cmd.append(arg.replace(\"{filtergraph}\", filtergraph))\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.858265, "o", "> "]
[57.858505, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             cmd.append(arg)\r\n\u001b[?2004l\r\u001b[?2004h>     rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.858731, "o", "        return False, stderr\r\n\u001b[?2004l\r\u001b[?2004h>     return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.858861, "o", "def probe_output(output_file, stream_type):\r\n\u001b[?2004l\r"]
[57.858931, "o", "\u001b[?2004h>     \"\"\"Use ffprobe to get stream properties as JSON.\"\"\"\r\n\u001b[?2004l\r(LEVELS) * 10\r\n\r\n    print"]
[57.858947, "o", "\u001b[?2004h> "]
[57.859038, "o", "    cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.859226, "o", "        \"ffprobe\", \"-v\", \"quiet\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-print_format\", \"json\",\r\n\u001b[?2004l\r"]
[57.859592, "o", "\u001b[?2004h>         \"-show_streams\", \"-show_format\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_file\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.859727, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if rc != 0:\r\n\u001b[?2004l\r\"Type 'skip' to skip a level, '\u001b[?2004h>         return None\r\n\u001b[?2004l\r)\r\n\r\n"]
[57.859869, "o", "\u001b[?2004h> "]
[57.860059, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h>         data = json.loads(stdout)\r\n\u001b[?2004l\r"]
[57.860132, "o", "\u001b[?2004h> "]
[57.860286, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[57.860338, "o", "\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.860472, "o", "    # Find the relevant stream\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.860591, "o", "    for stream in data.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.860742, "o", "        if stream.get(\"codec_type\") == stream_type:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.860798, "o", "            # Also include format-level data\r\n\u001b[?2004l\rp\u001b[?2004h> "]
[57.860987, "o", "            stream[\"_format\"] = data.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h>             return stream\r\n\u001b[?2004l\r\u001b[?2004h>     return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.861037, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86111, "o", "def validate_output(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.861219, "o", "    \"\"\"Validate the output file against level requirements.\"\"\"\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[57.861291, "o", "    output_file = level[\"output_file\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86135, "o", "    validation = level[\"validation\"]\r\n\u001b[?2004l\r"]
[57.861392, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.861521, "o", "    if not os.path.exists(output_file):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.861652, "o", "        return False, \"Output file does not exist\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.861771, "o", "    stream = probe_output(output_file, validation[\"stream_type\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.861905, "o", "    if stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.862007, "o", "        return False, \"Could not probe output file\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.862152, "o", "    checks = validation[\"checks\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.862347, "o", "    for key, expected in checks.items():\r\n\u001b[?2004l\r\u001b[?2004h>         if key == \"duration_range\":\r\n\u001b[?2004l\r"]
[57.862377, "o", "\u001b[?2004h> "]
[57.862502, "o", "            # Check duration within a range\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.862644, "o", "            duration = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.862712, "o", "            # Try stream duration first, then format duration\r\n\u001b[?2004l\r \u001b[?2004h> "]
[57.863194, "o", "            if \"duration\" in stream and stream[\"duration\"] != \"N/A\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.863276, "o", "> "]
[57.86335, "o", "                duration = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.863477, "o", "            elif \"_format\" in stream and \"duration\" in stream[\"_format\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.863611, "o", "                duration = float(stream[\"_format\"][\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.863661, "o", "            if duration is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.863886, "o", "                return False, \"Could not determine duration\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.863911, "o", "> "]
[57.864091, "o", "            min_dur, max_dur = expected\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.864284, "o", "            if not (min_dur <= duration <= max_dur):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.864479, "o", "                return False, f\"Duration {duration:.2f}s not in range [{min_dur}, {max_dur}]\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.864536, "o", "> "]
[57.864614, "o", "        elif key == \"pix_fmt\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86478, "o", "            actual = stream.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h>             if actual != expected:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.864906, "o", "                return False, f\"Pixel format: expected '{expected}', got '{actual}'\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.864923, "o", "        elif key == \"width\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86517, "o", "            actual = int(stream.get(\"width\", 0))\r\n\u001b[?2004l\r\u001b[?2004h>             if actual != expected:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.865257, "o", "                return False, f\"Width: expected {expected}, got {actual}\"\r\n\u001b[?2004l\r\u001b[?2004h>         elif key == \"height\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86534, "o", "            actual = int(stream.get(\"height\", 0))\r\n\u001b[?2004l\r\u001b[?2004h>             if actual != expected:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.865512, "o", "                return False, f\"Height: expected {expected}, got {actual}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.865562, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             actual = stream.get(key)\r\n\u001b[?2004l\r\u001b[?2004h>             if str(actual) != str(expected):\r\n\u001b[?2004l\r"]
[57.865595, "o", "\u001b[?2004h> "]
[57.865674, "o", "                return False, f\"{key}: expected '{expected}', got '{actual}'\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.865777, "o", "    return True, \"All checks passed\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.865928, "o", "def run_level(level, filtergraph, verbose=True):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run a single level with the given filtergraph. Returns (passed, details).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866021, "o", "    # Generate input\r\n\u001b[?2004l\r\u001b[?2004h>     if not generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866102, "o", "        return False, \"Failed to generate input\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866253, "o", "    # Run filtergraph\r\n\u001b[?2004l\r\u001b[?2004h>     success, error = run_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.866398, "o", ">     if not success:\r\n\u001b[?2004l\r\u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"  FFmpeg error: {error[:200]}\")\r\n\u001b[?2004l\r"]
[57.866481, "o", "\u001b[?2004h> "]
[57.866546, "o", "        return False, \"FFmpeg failed\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866611, "o", "    # Validate output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866632, "o", "    passed, details = validate_output(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866716, "o", "    return passed, details\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866797, "o", "def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r"]
[57.866853, "o", "\u001b[?2004h> "]
[57.866889, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.866969, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867042, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867072, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867218, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867338, "o", "        passed, details = run_level(level, level[\"solution\"], verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867387, "o", "            total_score += 10\r\n\u001b[?2004l\r"]
[57.867445, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"  FAIL - {details}\")\r\n"]
[57.867472, "o", "\u001b[?2004l\r"]
[57.867544, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867646, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": level[\"number\"],\r\n\u001b[?2004l\r"]
[57.867757, "o", "\u001b[?2004h>             \"filename\": os.path.basename(level[\"output_file\"]),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.867774, "o", "            \"valid\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[57.86786, "o", ">     print(f\"\\nScore: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r"]
[57.867887, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[57.867984, "o", "> "]
[57.868162, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h>     with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.868291, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Manifest written to {MANIFEST_PATH}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive():\r\n\u001b[?2004l\r"]
[57.86847, "o", "\u001b[?2004h>     \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.868657, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\"*60)\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"  FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\"*60)\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r"]
[57.868734, "o", "\u001b[?2004h> "]
[57.868929, "o", "    print(\"Solve each level by entering the correct FFmpeg filtergraph.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869047, "o", "    print(\"Type 'skip' to skip a level, 'quit' to exit.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869131, "o", "        print(f\"--- Level {level['number']}: {level['name']} ---\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(level[\"description\"])\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[57.869184, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[57.869329, "o", "        # Generate input\r\n\u001b[?2004l\r\u001b[?2004h>         if not generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.86942, "o", "            print(\"  ERROR: Could not generate input. Skipping.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869514, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         while True:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869623, "o", "            try:\r\n\u001b[?2004l\r\u001b[?2004h>                 answer = input(\"Your filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869703, "o", "            except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869786, "o", "                return\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[57.869919, "o", "\u001b[?2004h>             if answer.lower() == \"quit\":\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.869991, "o", "                print(f\"Final Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.870067, "o", "                return\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.870086, "o", "            if answer.lower() == \"skip\":\r\n\u001b[?2004l\r"]
[57.870131, "o", "\u001b[?2004h> "]
[57.87029, "o", "                print(\"  Skipped.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>                 break\r\n\u001b[?2004l\r\u001b[?2004h>             if not answer:\r\n\u001b[?2004l\r"]
[57.870369, "o", "\u001b[?2004h>                 continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.870429, "o", "            passed, details = run_level(level, answer, verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.870504, "o", "            if passed:\r\n\u001b[?2004l\r"]
[57.870562, "o", "\u001b[?2004h> "]
[57.870633, "o", "                print(\"  PASS! Well done!\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>                 total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.870692, "o", "> "]
[57.870726, "o", "                break\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.870852, "o", "                print(f\"  FAIL - {details}\")\r\n\u001b[?2004l\r\u001b[?2004h>                 print(\"  Try again or type 'skip' to move on.\\n\")\r\n\u001b[?2004l\r"]
[57.870873, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.871035, "o", "    print(f\"\\nScore: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.871055, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.87112, "o", "def main():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.871265, "o", "    parser = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h>     parser.add_argument(\r\n\u001b[?2004l\r"]
[57.871276, "o", "\u001b[?2004h>         \"--auto-solve\", action=\"store_true\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[57.871289, "o", "> "]
[57.871456, "o", "        help=\"Run all levels with known correct solutions\"\r\n\u001b[?2004l\r\u001b[?2004h>     )\r\n\u001b[?2004l\r\u001b[?2004h>     args = parser.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.871498, "o", "    if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h>         auto_solve()\r\n\u001b[?2004l\r"]
[57.871564, "o", "\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[57.871679, "o", "        interactive()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
