[57.831324, "i", ": {stderr}\")\n        return False\n    return True\n\n\ndef run_filtergraph(level, filtergraph):\n    \"\"\"Run the user's filtergraph through FFmpeg.\"\"\"\n    template = level[\"ffmpeg_template\"]\n    cmd = []\n    for arg in template:\n        if \"{filtergraph}\" in arg:\n            cmd.append(arg.replace(\"{filtergraph}\", filtergraph))\n        else:\n            cmd.append(arg)\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        return False, stderr\n    return True, \"\"\n\n\ndef probe_output(output_file, stream_type):\n    \"\"\"Use ffprobe to get stream properties as JSON.\"\"\"\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\",\n        \"-print_format\", \"json\",\n        \"-show_streams\", \"-show_format\",\n        output_file\n    ]\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        return None\n    try:\n        data = json.loads(stdout)\n    except json.JSONDecodeError:\n        return None\n    # Find the relevant stream\n    for stream in data.get(\"streams\", []):\n        if stream.get(\"codec_type\") == stream_type:\n          "]
