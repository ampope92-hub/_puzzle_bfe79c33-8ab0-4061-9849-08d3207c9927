SETS_DIR, "level5_input.mp4"),\n            "-vf", "{filtergraph}",\n            "-c:v", "libx264", "-pix_fmt", "yuv420p",\n            os.path.join(OUTPUT_DIR, "level5_output.mp4")\n        ],\n        "solution": "scale=320:240,hflip",\n        "validation": {\n            "stream_type": "video",\n            "checks": {\n                "width": 320,\n                "height": 240\n            }\n        }\n    },\n]\n\n\ndef ensure_dirs():\n    """Create assets and output directories if they don\'t exist."""\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_cmd(args, quiet=True):\n    """Run a command and return (returncode, stdout, stderr)."""\n    kwargs = {}\n    if quiet:\n        kwargs["stdout"] = subprocess.PIPE\n        kwargs["stderr"] = subprocess.PIPE\n    result = subprocess.run(args, **kwargs)\n    stdout = result.stdout.decode("utf-8", errors="replace") if result.stdout else ""\n    stderr = result.stderr.decode("utf-8", errors="replace") if result.stderr else ""\n    return result.returncode, stdout, stderr\n\n\ndef generate_input(level):\n    """Generate synthetic input for a level using FFmpeg lavfi sources."""\n    input_gen = level["input_gen"]\n    if os.path.exists(input_gen["output"]):\n        return True\n    rc, _, stderr = run_cmd(input_gen["args"])\n    if rc != 0:\n        print(f"  ERROR generating input: {stderr}")\n        return False\n    return True\n\n\ndef run_filtergraph(level, filtergraph):\n    """Run the user\'s filtergraph through FFmpeg."""\n    template = level["ffmpeg_template"]\n    cmd = []\n    for arg in template:\n        if "{filtergraph}" in arg:\n            cmd.append(arg.replace("{filtergraph}", filtergraph))\n        else:\n            cmd.append(arg)\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        return False, stderr\n    return True, ""\n\n\ndef probe_output(output_file, stream_type):\n    """Use ffprobe to get stream properties as JSON."""\n    cmd = [\n        "ffprobe", "-v", "quiet",\n        "-print_format", "json",\n        "-show_streams", "-show_format",\n        output_file\n    ]\n    rc, stdout, stderr = run_cmd(cmd)\n    if rc != 0:\n        return None\n    try:\n        data = json.loads(stdout)\n    except json.JSONDecodeError:\n        return None\n    # Find the relevant stream\n    for stream in data.get("streams", []):\n        if stream.get("codec_type") == stream_type:\n            # Also include format-level data\n            stream["_format"] = data.get("format", {})\n            return stream\n    return None\n\n\ndef validate_output(level):\n    """Validate the output file against level requirements."""\n    output_file = level["output_file"]\n    validation = level["validation"]\n\n    if not os.path.exists(output_file):\n        return False, "Output file does not exist"\n\n    stream = probe_output(output_file, validation["stream_type"])\n    if stream is None:\n        return False, "Could not probe output file"\n\n    checks = validation["checks"]\n    for key, expected in checks.items():\n        if key == "duration_range":\n            # Check duration within a range\n            duration = None\n            # Try stream duration first, then format duration\n            if "duration" in stream and stream["duration"] != "N/A":\n                duration = float(stream["duration"])\n            elif "_format" in stream and "duration" in stream["_format"]:\n                duration = float(stream["_format"]["duration"])\n            if duration is None:\n                return False, "Could not determine duration"\n            min_dur, max_dur = expected\n            if not (min_dur <= duration <= max_dur):\n                return False, f"Duration {duration:.2f}s not in range [{min_dur}, {max_dur}]"\n        elif key == "pix_fmt":\n            actual = stream.get("pix_fmt", "")\n            if actual != expected:\n                return False, f"Pixel format: expected \'{expected}\', got \'{actual}\'"\n        elif key == "width":\n            actual = int(stream.get("width", 0))\n            if actual != expected:\n                return False, f"Width: expected {expected}, got {actual}"\n        elif key == "height":\n            actual = int(stream.get("height", 0))\n            if actual != expected:\n                return False, f"Height: expected {expected}, got {actual}"\n        else:\n            actual = stream.get(key)\n            if str(actual) != str(expected):\n                return False, f"{key}: expected \'{expected}\', got \'{actual}\'"\n\n    return True, "All checks passed"\n\n\ndef run_level(level, filtergraph, verbose=True):\n    """Run a single level with the given filtergraph. Returns (passed, details)."""\n    # Generate input\n    if not generate_input(level):\n        return False, "Failed to generate input"\n\n    # Run filtergraph\n    success, error = run_filtergraph(level, filtergraph)\n    if not success:\n        if verbose:\n            print(f"  FFmpeg error: {error[:200]}")\n        return False, "FFmpeg failed"\n\n    # Validate output\n    passed, details = validate_output(level)\n    return passed, details\n\n\ndef auto_solve():\n    """Run all levels with known correct solutions."""\n    ensure_dirs()\n    manifest = []\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f"Level {level[\'number\']}: {level[\'name\']}")\n        passed, details = run_level(level, level["solution"], verbose=True)\n\n        if passed:\n            print("  PASS")\n            total_score += 10\n        else:\n            print(f"  FAIL - {details}")\n\n        manifest.append({\n            "level": level["number"],\n            "filename": os.path.basename(level["output_file"]),\n            "valid": passed\n        })\n\n    print(f"\\nScore: {total_score}/{total_possible}")\n\n    # Write manifest\n    with open(MANIFEST_PATH, "w") as f:\n        json.dump(manifest, f, indent=2)\n    print(f"Manifest written to {MANIFEST_PATH}")\n\n\ndef interactive():\n    """Run the game in interactive mode."""\n    ensure_dirs()\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    print("="*60)\n    print("  FFmpeg Filtergraph Puzzle Game")\n    print("="*60)\n    print()\n    print("Solve each level by entering the correct FFmpeg filtergraph.")\n    print("Type \'skip\' to skip a level, \'quit\' to exit.\\n")\n\n    for level in LEVELS:\n        print(f"--- Level {level[\'number\']}: {level[\'name\']} ---")\n        print(level["description"])\n        print()\n\n        # Generate input\n        if not generate_input(level):\n            print("  ERROR: Could not generate input. Skipping.\\n")\n            continue\n\n        while True:\n            try:\n                answer = input("Your filtergraph> ").strip()\n            except (EOFError, KeyboardInterrupt):\n                print("\\nExiting.")\n                return\n\n            if answer.lower() == "quit":\n                print("\\nExiting.")\n                print(f"Final Score: {total_score}/{total_possible}")\n                return\n            if answer.lower() == "skip":\n                print("  Skipped.\\n")\n                break\n            if not answer:\n                continue\n\n            passed, details = run_level(level, answer, verbose=True)\n            if passed:\n                print("  PASS! Well done!\\n")\n                total_score += 10\n                break\n            else:\n                print(f"  FAIL - {details}")\n                print("  Try again or type \'skip\' to move on.\\n")\n\n    print(f"\\nScore: {total_score}/{total_possible}")\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="FFmpeg Filtergraph Puzzle Game")\n    parser.add_argument(\n        "--auto-solve", action="store_true",\n        help="Run all levels with known correct solutions"\n    )\n    args = parser.parse_args()\n\n