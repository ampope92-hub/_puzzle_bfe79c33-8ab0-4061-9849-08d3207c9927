[39.933502, "i", ",\n        kind=\"video\",\n        input_ext=\"mp4\",\n        output_ext=\"mp4\",\n        autosolve_filter=\"scale=320:240,hflip\",\n        validate=v5_validate,\n    ))\n\n    return levels\n\n\ndef play_level(level: Level, filtergraph: str, tag: str) -> Tuple[bool, str, str]:\n    \"\"\"Returns (ok, output_path, detail_message).\"\"\"\n    ensure_dirs()\n    in_path = level.input_path()\n    out_path = level.output_path(tag=tag)\n\n    if not os.path.exists(in_path):\n        ffmpeg_generate_input(level.number, level.kind, in_path)\n\n    rc, out, err = ffmpeg_apply_filter(level.kind, in_path, filtergraph, out_path)\n    if rc != 0:\n        return False, out_path, f\"ffmpeg failed: {err.strip()}\"\n\n    try:\n        info = ffprobe_json(out_path)\n    except Exception as e:\n        return False, out_path, str(e)\n\n    ok, msg = level.validate(info)\n    return ok, out_path, msg\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    points = 0\n    total = len(levels) * 10\n\n    for lvl in levels:\n        print(f\"Level {lvl.number}: {"]
