[39.933268, "i", "  w, h = vs.get(\"width\"), vs.get(\"height\")\n        ok = (w == 200 and h == 200)\n        return ok, f\"width={w} height={h} (expected 200x200)\"\n\n    levels.append(Level(\n        number=4,\n        name=\"Center Crop\",\n        description=\"Crop the center 200x200 region from a 640x480 video.\",\n        kind=\"video\",\n        input_ext=\"mp4\",\n        output_ext=\"mp4\",\n        autosolve_filter=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\n        validate=v4_validate,\n    ))\n\n    # Level 5: scale to 320x240 and hflip\n    def v5_validate(info: Dict) -> Tuple[bool, str]:\n        vs = get_first_stream(info, \"video\")\n        if not vs:\n            return False, \"No video stream\"\n        w, h = vs.get(\"width\"), vs.get(\"height\")\n        ok = (w == 320 and h == 240)\n        return ok, f\"width={w} height={h} (expected 320x240); flip not easily probeable\"\n\n    levels.append(Level(\n        number=5,\n        name=\"Scale + Flip\",\n        description=\"Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\""]
