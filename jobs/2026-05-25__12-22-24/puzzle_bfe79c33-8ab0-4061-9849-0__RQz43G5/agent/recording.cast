[39.93073, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport shlex\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run(cmd: List[str]) -> Tuple[int, str, str]:\n    p = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n    return p.returncode, p.stdout, p.stderr\n\n\ndef ffmpeg_generate_input(level_num: int, kind: str, path: str) -> None:\n    \"\"\"Generate a deterministic synthetic input using lavfi.\"\"\"\n    if kind == \"video\":\n        # Deterministic test pattern, 10 seconds, 30 fps\n        cmd = [\n            \"ffmpeg\", \"-hide_banner\", \"-y\",\n            \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n            \"-t\", \"10\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\""]
[39.931123, "i", ", \"yuv420p\",\n            path,\n        ]\n    elif kind == \"audio\":\n        # Deterministic sine wave, 10 seconds\n        cmd = [\n            \"ffmpeg\", \"-hide_banner\", \"-y\",\n            \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\n            \"-t\", \"10\",\n            \"-c:a\", \"aac\",\n            path,\n        ]\n    else:\n        raise ValueError(f\"Unknown kind: {kind}\")\n\n    rc, out, err = run(cmd)\n    if rc != 0:\n        raise RuntimeError(f\"Failed to generate input for level {level_num}:\\n{err}\")\n\n\ndef ffmpeg_apply_filter(kind: str, in_path: str, filtergraph: str, out_path: str) -> Tuple[int, str, str]:\n    \"\"\"Apply user filtergraph to input and write output.\"\"\"\n    if kind == \"video\":\n        # Apply filtergraph as -vf; keep encoding deterministic.\n        cmd = [\n            \"ffmpeg\", \"-hide_banner\", \"-y\",\n            \"-i\", in_path,\n            \"-vf\", filtergraph,\n            \"-an\",\n            \"-c:v\", \"libx264\",\n            \"-pix_fmt\", \"yuv420p\",\n            out_path,\n        ]\n    else:\n    "]
