[39.933829, "i", "   if not fg:\n            print(\"No filtergraph provided.\")\n            continue\n\n        ok, out_path, detail = play_level(lvl, fg, tag=\"user\")\n        print(\"PASS\" if ok else \"FAIL\")\n        print(detail)\n        print(f\"Output: {out_path}\")\n        if ok:\n            score += 10\n\n    total = len(levels) * 10\n    print(f\"Score: {score}/{total}\")\n    return 0\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    parser = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n    parser.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with known correct solutions\")\n    args = parser.parse_args(argv)\n\n    levels = mk_levels()\n    ensure_dirs()\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\nPY\n"]
