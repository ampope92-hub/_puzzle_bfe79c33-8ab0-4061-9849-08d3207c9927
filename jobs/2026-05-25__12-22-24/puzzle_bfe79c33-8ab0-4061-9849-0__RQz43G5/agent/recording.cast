[39.932512, "i", "format.duration, fall back to stream.duration\n    d = parse_float(info.get(\"format\", {}).get(\"duration\"))\n    if d is not None:\n        return d\n    for s in info.get(\"streams\", []):\n        d2 = parse_float(s.get(\"duration\"))\n        if d2 is not None:\n            return d2\n    return None\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    kind: str  # \"video\" or \"audio\"\n    input_ext: str\n    output_ext: str\n    autosolve_filter: str\n    validate: Callable[[Dict], Tuple[bool, str]]  # returns (ok, message)\n\n    def input_path(self) -> str:\n        return os.path.join(ASSETS_DIR, f\"level{self.number}_input.{self.input_ext}\")\n\n    def output_path(self, tag: str = \"user\") -> str:\n        return os.path.join(OUTPUT_DIR, f\"level{self.number}_{tag}_output.{self.output_ext}\")\n\n\ndef mk_levels() -> List[Level]:\n    levels: List[Level] = []\n\n    # Level 1: scale 640x480 -> 320x240\n    def v1_validate(info: Dict) -> Tuple[bool, str]:\n        vs = get_first_stream(info, \"video\")\n        if"]
