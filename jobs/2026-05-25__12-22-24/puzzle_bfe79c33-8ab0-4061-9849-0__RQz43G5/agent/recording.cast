[39.971644, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.971778, "o", "        return False, out_path, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ok, msg = level.validate(info)\r\n\u001b[?2004l\r"]
[39.971831, "o", "\u001b[?2004h>     return ok, out_path, msg\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[39.971917, "o", "\u001b[?2004h> "]
[39.972076, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     points = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.972099, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[39.972115, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[39.972171, "o", "    for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.972248, "o", "> "]
[39.97232, "o", "        print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.972405, "o", "        ok, out_path, detail = play_level(lvl, lvl.autosolve_filter, tag=\"auto\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.972531, "o", "        print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.972602, "o", "        # Deterministic artifacts: always write output file if ffmpeg succeeded; manifest records status.\r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r"]
[39.97278, "o", "\u001b[?2004h>             \"level\": lvl.number,\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": os.path.basename(out_path),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.972975, "o", "            \"status\": bool(ok),\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             points += 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.973132, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.973306, "o", "        json.dump(manifest, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[39.973496, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {points}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.973588, "o", "    return 0 if points == total else 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.973642, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.973795, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0"]
[39.974005, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.974144, "o", "        print(f\"\\nLevel {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.974279, "o", "        print(\"Enter an FFmpeg filtergraph expression (e.g., scale=320:240).\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r"]
[39.974432, "o", "\u001b[?2004h>             fg = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r"]
[39.974565, "o", "\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break"]
[39.974598, "o", "\r\n\u001b[?2004l\r"]
[39.974759, "o", "\u001b[?2004h>         if not fg:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.974898, "o", "            print(\"No filtergraph provided.\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.97503, "o", "        ok, out_path, detail = play_level(lvl, fg, tag=\"user\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975243, "o", "        print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(detail)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975275, "o", "        print(f\"Output: {out_path}\")\r\n"]
[39.975382, "o", "\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h"]
[39.975414, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975564, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975586, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[39.975674, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975786, "o", "def main(argv: Optional[List[str]] = None) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975895, "o", "    parser = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.975975, "o", "    parser.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with known correct solutions\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.976051, "o", "    args = parser.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.976202, "o", "    levels = mk_levels()\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l\r"]
[39.97629, "o", "\u001b[?2004h>         return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[39.97634, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[39.976474, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[39.976509, "o", "\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
