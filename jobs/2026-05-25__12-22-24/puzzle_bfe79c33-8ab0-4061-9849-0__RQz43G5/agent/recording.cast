[39.933017, "i", "      output_ext=\"mkv\",\n        autosolve_filter=\"format=gray\",\n        validate=v2_validate,\n    ))\n\n    # Level 3: trim 10s audio to exactly 3s\n    def a3_validate(info: Dict) -> Tuple[bool, str]:\n        d = duration_seconds(info)\n        if d is None:\n            return False, \"No duration found\"\n        # Strict: within 0.01 seconds of exactly 3.0 to avoid container rounding artifacts.\n        ok = abs(d - 3.0) <= 0.01\n        return ok, f\"duration={d:.6f} (expected 3.000000 +/- 0.010000)\"\n\n    levels.append(Level(\n        number=3,\n        name=\"Trim Audio\",\n        description=\"Trim a 10-second audio clip to exactly 3 seconds.\",\n        kind=\"audio\",\n        input_ext=\"m4a\",\n        output_ext=\"m4a\",\n        autosolve_filter=\"atrim=0:3,asetpts=N/SR/TB\",\n        validate=a3_validate,\n    ))\n\n    # Level 4: crop center 200x200 from 640x480\n    def v4_validate(info: Dict) -> Tuple[bool, str]:\n        vs = get_first_stream(info, \"video\")\n        if not vs:\n            return False, \"No video stream\"\n      "]
