[50.63903, "i", "l_ffmpeg(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    # Always overwrite outputs\n    if level.media_type == \"video\":\n        if level.num == 2:\n            # Force rawvideo in AVI to preserve pix_fmt exactly.\n            cmd = [\n                \"ffmpeg\",\n                \"-y\",\n                \"-v\",\n                \"error\",\n                \"-i\",\n                level.input_path,\n                \"-vf\",\n                filtergraph,\n                \"-an\",\n                \"-c:v\",\n                \"rawvideo\",\n                \"-pix_fmt\",\n                \"gray\",\n                level.output_path,\n            ]\n        else:\n            cmd = [\n                \"ffmpeg\",\n                \"-y\",\n                \"-v\",\n                \"error\",\n                \"-i\",\n                level.input_path,\n                \"-vf\",\n                filtergraph,\n                \"-an\",\n                \"-c:v\",\n                \"libx264\",\n                \"-pix_fmt\",\n                \"yuv420p\",\n                level.output_path,\n   "]
