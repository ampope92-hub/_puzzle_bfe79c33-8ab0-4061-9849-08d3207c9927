[50.670263, "o", "        ),\r\n\u001b[?2004l\r"]
[50.670322, "o", "\u001b[?2004h> "]
[50.670398, "o", "        Level(\r\n\u001b[?2004l\r"]
[50.670484, "o", "\u001b[?2004h>             num=3,"]
[50.67054, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.670624, "o", "> "]
[50.67075, "o", "            name=\"Trim 10s audio to 3s\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.670971, "o", "            description=(\r\n\u001b[?2004l\r"]
[50.671014, "o", "\u001b[?2004h> "]
[50.671542, "o", "                \"Input is a 10-second audio clip.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.672133, "o", "                \"Goal: trim it to exactly ~3 seconds (validation: 2.9 to 3.1 seconds).\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.672748, "o", "                \"Enter an FFmpeg audio filtergraph (for -af).\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.672814, "o", "> "]
[50.672877, "o", "            ),\r\n\u001b[?2004l\r"]
[50.673095, "o", "\u001b[?2004h> "]
[50.673281, "o", "            input_path=l3_in,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.673392, "o", "            output_path=l3_out,\r\n\u001b[?2004l\r"]
[50.673444, "o", "\u001b[?2004h> "]
