[50.639127, "i", "         ]\n    else:\n        cmd = [\n            \"ffmpeg\",\n            \"-y\",\n            \"-v\",\n            \"error\",\n            \"-i\",\n            level.input_path,\n            \"-af\",\n            filtergraph,\n            \"-vn\",\n            \"-c:a\",\n            \"pcm_s16le\",\n            level.output_path,\n        ]\n\n    rc, _, err = run(cmd)\n    if rc != 0:\n        return False, err.strip() or \"ffmpeg failed\"\n\n    ok, msg = level.validate_output(level.output_path)\n    return ok, msg\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    score = 0\n    total = len(levels) * 10\n\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        ok, _msg = run_level_ffmpeg(lvl, lvl.auto_solution)\n        if ok:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n        manifest.append(\n            {\n                \"level\": lvl.num,\n                \"filename\": os.path.basename(lvl.output_path),\n                \"passed\": bool(ok),\n            }\n        "]
