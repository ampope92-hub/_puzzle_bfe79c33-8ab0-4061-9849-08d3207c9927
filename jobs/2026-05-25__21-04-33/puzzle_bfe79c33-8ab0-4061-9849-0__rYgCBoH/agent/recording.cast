[50.637901, "i", "   rc, _, err = run(cmd)\n    if rc != 0:\n        raise RuntimeError(f\"Failed generating level5 input: {err.strip()}\")\n\n\ndef validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    vs = get_first_stream(probe, \"video\")\n    if not vs:\n        return False, \"No video stream found\"\n    width = vs.get(\"width\")\n    height = vs.get(\"height\")\n    if width != w or height != h:\n        return False, f\"Expected {w}x{h}, got {width}x{height}\"\n    return True, \"OK\"\n\n\ndef validate_pix_fmt_gray(path: str) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    vs = get_first_stream(probe, \"video\")\n    if not vs:\n        return False, \"No video stream found\"\n    pix_fmt = vs.get(\"pix_fmt\")\n    if pix_fmt != \"gray\":\n        return False, f\"Expected pix_fmt gray, got {pix_fmt}\"\n    return True, \"OK\"\n\n\ndef validate_audio_duration(path: str, lo: float = 2.9, hi: float = 3.1) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    a = get_first_stream(probe, \"audio\")\n    if not a:\n  "]
