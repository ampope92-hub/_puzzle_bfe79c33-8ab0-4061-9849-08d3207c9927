[50.65417, "o", "def validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.65424, "o", "> "]
[50.654286, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r0\u001b[?2004h> "]
[50.654484, "o", "    vs = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r"]
[50.654508, "o", "\u001b[?2004h> "]
[50.654595, "o", "    if not vs:\r\n\u001b[?2004l\r"]
[50.654611, "o", "\u001b[?2004h> "]
[50.65482, "o", "        return False, \"No video stream found\"\r\n\u001b[?2004l\r"]
[50.654849, "o", "\u001b[?2004h> "]
[50.654949, "o", "    width = vs.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655014, "o", "    height = vs.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655221, "o", "    if width != w or height != h:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655379, "o", "        return False, f\"Expected {w}x{h}, got {width}x{height}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655475, "o", "    return True, \"OK\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.655698, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655781, "o", "def validate_pix_fmt_gray(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655833, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.655892, "o", "    vs = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\ria_\u001b[?2004h> "]
[50.656033, "o", "    if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.65621, "o", "        return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h>     pix_fmt = vs.get(\"pix_fmt\")"]
[50.656309, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.656491, "o", "    if pix_fmt != \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.656733, "o", "        return False, f\"Expected pix_fmt gray, got {pix_fmt}\"\r\n\u001b[?2004l\r"]
[50.656842, "o", "\u001b[?2004h>     return True, \"OK\"\r\n\u001b[?2004l\r\"scale=320:240,hflip\",\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.656884, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.657169, "o", "def validate_audio_duration(path: str, lo: float = 2.9, hi: float = 3.1) -> Tuple[bool, str]:\r\n\u001b[?2004l\rls:\r\n     "]
[50.657556, "o", "\u001b[?2004h> "]
[50.65783, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.657995, "o", "    a = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r"]
[50.658099, "o", "\u001b[?2004h>     if not a:"]
[50.658144, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.658218, "o", "        return False, \"No audio stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.658273, "o", "    dur = parse_duration_seconds(probe)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.658349, "o", "    if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.658643, "o", "        return False, \"Could not determine duration\"\r\n\u001b[?2004l\r"]
[50.658753, "o", "\u001b[?2004h>     if not (lo <= dur <= hi):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.659193, "o", "        return False, f\"Expected duration between {lo} and {hi}, got {dur:.3f}\"\r\n\u001b[?2004l\r"]
[50.659286, "o", "\u001b[?2004h> "]
[50.659346, "o", "    return True, \"OK\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
