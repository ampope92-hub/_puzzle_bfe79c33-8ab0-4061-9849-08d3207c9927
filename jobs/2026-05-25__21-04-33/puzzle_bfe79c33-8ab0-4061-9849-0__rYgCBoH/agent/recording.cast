[50.674591, "o", "> "]
[50.674719, "o", "            auto_solution=\"atrim=0:3\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.674784, "o", ">         ),\r\n\u001b[?2004l\r"]
[50.674915, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r0\r\n        else:\u001b[?2004h> "]
[50.675068, "o", "            num=4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.675224, "o", "            name=\"Center crop 200x200\",\r\n\u001b[?2004l\rp\u001b[?2004h> "]
[50.675489, "o", "            description=(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.675779, "o", "                \"Input is a 640x480 video.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.675967, "o", "                \"Goal: crop the center 200x200 region (exactly 200x200).\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.676455, "o", "                \"Enter an FFmpeg video filtergraph (for -vf).\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.676638, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.676728, "o", "> "]
[50.676846, "o", "            input_path=l4_in,\r\n\u001b[?2004l\r"]
[50.676919, "o", "\u001b[?2004h> "]
[50.677079, "o", "            output_path=l4_out,\r\n\u001b[?2004l\r"]
[50.677132, "o", "\u001b[?2004h> "]
[50.677256, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.677848, "o", "            generate_input=lambda p=l4_in: generate_level4_input(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.678178, "o", "            validate_output=lambda p: validate_video_dims(p, 200, 200),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.678747, "o", "            auto_solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.678853, "o", "        ),\r\n\u001b[?2004l\r"]
[50.678871, "o", "\u001b[?2004h> "]
[50.678938, "o", "        Level(\r\n\u001b[?2004l\r\u001b[?2004h>             num=5,\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.679012, "o", "> "]
[50.679073, "o", "            name=\"Scale then horizontal flip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.679141, "o", "            description=(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.679185, "o", "                \"Input is a 640x480 video.\\n\"\r\n"]
[50.679272, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[50.679351, "o", "                \"Goal: scale to 320x240 AND apply a horizontal flip.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.679463, "o", "                \"Enter an FFmpeg video filtergraph (for -vf).\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.679528, "o", "> "]
[50.67961, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.679718, "o", "            input_path=l5_in,\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.679785, "o", ">             output_path=l5_out,\r\n\u001b[?2004l\r"]
[50.679867, "o", "\u001b[?2004h>             media_type=\"video\",\r\n\u001b[?2004l\r"]
[50.679913, "o", "\u001b[?2004h> "]
[50.680007, "o", "            generate_input=lambda p=l5_in: generate_level5_input(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.680112, "o", "            validate_output=lambda p: validate_video_dims(p, 320, 240),\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.680167, "o", "> "]
[50.680213, "o", "            auto_solution=\"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.680266, "o", "> "]
[50.680324, "o", "        ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n"]
[50.680407, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.680445, "o", "\u001b[?2004h> "]
[50.680506, "o", "def ensure_inputs(levels: List[Level]) -> None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.680567, "o", ">     for lvl in levels:\r\n\u001b[?2004l\r"]
[50.680629, "o", "\u001b[?2004h> "]
[50.680695, "o", "        if not os.path.exists(lvl.input_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.680781, "o", "            lvl.generate_input()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.68089, "o", "def run_level_ffmpeg(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.680944, "o", "> "]
[50.680992, "o", "    # Always overwrite outputs\r\n\u001b[?2004l\r"]
[50.681051, "o", "\u001b[?2004h> "]
[50.681109, "o", "    if level.media_type == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681185, "o", "        if level.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681276, "o", "            # Force rawvideo in AVI to preserve pix_fmt exactly.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681327, "o", "            cmd = ["]
[50.681383, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681402, "o", "                \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681463, "o", "                \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.681519, "o", "> "]
[50.681592, "o", "                \"-v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681656, "o", "                \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681706, "o", "                \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.681777, "o", "                level.input_path,\r\n\u001b[?2004l\r"]
[50.681834, "o", "\u001b[?2004h> "]
[50.681887, "o", "                \"-vf\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.681959, "o", "> "]
[50.682021, "o", "                filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-an\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.682077, "o", "> "]
[50.682143, "o", "                \"-c:v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682203, "o", "                \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682223, "o", "                \"-pix_fmt\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682292, "o", "                \"gray\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.682353, "o", "> "]
[50.68243, "o", "                level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>             ]\r\n\u001b[?2004l\r"]
[50.682466, "o", "\u001b[?2004h> "]
[50.682514, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682585, "o", "            cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682647, "o", "                \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.68272, "o", "                \"-v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.682773, "o", "                \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.6829, "o", "                \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>                 level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-vf\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.682928, "o", "> "]
[50.68301, "o", "                filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.683066, "o", "> "]
[50.683178, "o", "                \"-an\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-c:v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.683239, "o", "                \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.683315, "o", "                \"-pix_fmt\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"yuv420p\",\r\n\u001b[?2004l\r"]
[50.683367, "o", "\u001b[?2004h> "]
[50.683395, "o", "                level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.683481, "o", "            ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.683549, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.683718, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.68377, "o", "            \"-y\",\r\n\u001b[?2004l\r"]
[50.683825, "o", "\u001b[?2004h> "]
[50.683905, "o", "            \"-v\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"error\",\r\n\u001b[?2004l\r"]
[50.683965, "o", "\u001b[?2004h>             \"-i\",\r\n\u001b[?2004l\r"]
[50.684031, "o", "\u001b[?2004h> "]
[50.684138, "o", "            level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684271, "o", "            \"-af\",\r\n\u001b[?2004l\r\u001b[?2004h>             filtergraph,"]
[50.684293, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684361, "o", "            \"-vn\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684419, "o", "            \"-c:a\",\r\n\u001b[?2004l\r"]
[50.684504, "o", "\u001b[?2004h>             \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.684533, "o", "> "]
[50.684608, "o", "            level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r"]
[50.684689, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684752, "o", "    rc, _, err = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684803, "o", "    if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684873, "o", "        return False, err.strip() or \"ffmpeg failed\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.684951, "o", "    ok, msg = level.validate_output(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.684998, "o", "> "]
[50.685022, "o", "    return ok, msg\r\n\u001b[?2004l\r"]
[50.685094, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.685199, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r"]
[50.685257, "o", "\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.685378, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[50.685436, "o", "> "]
[50.685507, "o", "    for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.685591, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.685673, "o", "        ok, _msg = run_level_ffmpeg(lvl, lvl.auto_solution)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.68576, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.68578, "o", "> "]
[50.685855, "o", "            score += 10\r\n\u001b[?2004l\r"]
[50.685962, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.686044, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append(\r\n\u001b[?2004l\r"]
[50.686102, "o", "\u001b[?2004h>             {\r\n\u001b[?2004l\r"]
[50.686173, "o", "\u001b[?2004h> "]
[50.686252, "o", "                \"level\": lvl.num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.686347, "o", "                \"filename\": os.path.basename(lvl.output_path),\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.686399, "o", "> "]
[50.686461, "o", "                \"passed\": bool(ok),\r\n\u001b[?2004l\r"]
[50.686545, "o", "\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.686639, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.686702, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.686784, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.686844, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[50.686891, "o", "\u001b[?2004h> "]
[50.686952, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(\"\\n\")\r\n\u001b[?2004l\r"]
[50.687078, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     return 0 if score == total else 1\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.68712, "o", "> \r\n\u001b[?2004l\r"]
[50.68718, "o", "\u001b[?2004h> "]
[50.687247, "o", "\r\n\u001b[?2004l\r"]
[50.687386, "o", "\u001b[?2004h> def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.687446, "o", "    points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total = len(levels) * 10\r\n\u001b[?2004l\r"]
[50.687516, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.687755, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.687786, "o", "        prompt = \"Filtergraph> \"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.687848, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.687943, "o", "            fg = input(prompt).strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688022, "o", "        except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r"]
[50.688041, "o", "\u001b[?2004h> "]
[50.688118, "o", "            break\r\n\u001b[?2004l\r"]
[50.688177, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688257, "o", "        ok, msg = run_level_ffmpeg(lvl, fg)\r\n\u001b[?2004l\r"]
[50.688333, "o", "\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688398, "o", "            print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688459, "o", "            points += 10\r\n\u001b[?2004l\r"]
[50.688523, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688578, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688651, "o", "            print(msg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.68872, "o", "        print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688802, "o", "    print(f\"Score: {points}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.688919, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.688993, "o", "\u001b[?2004h> def main() -> int:\r\n\u001b[?2004l\r"]
[50.689076, "o", "\u001b[?2004h> "]
[50.689188, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.689344, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run deterministic solutions for all levels\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.6894, "o", "> "]
[50.689481, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r"]
[50.689545, "o", "\u001b[?2004h> "]
[50.689619, "o", "    levels = build_levels()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.689678, "o", "    ensure_inputs(levels)\r\n\u001b[?2004l\r"]
[50.689728, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l\r"]
[50.689805, "o", "\u001b[?2004h> "]
[50.68983, "o", "        return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.689907, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.689968, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.690018, "o", "\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[50.690093, "o", "\u001b[?2004h> "]
[50.69015, "o", "    raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
