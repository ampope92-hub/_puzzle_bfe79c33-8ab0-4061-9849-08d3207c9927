R, base)\n\n    def slug(self) -> str:\n        return "".join(c.lower() if c.isalnum() else "_" for c in self.name).strip("_")\n\n    def build_ffmpeg_cmd(self, filtergraph: str, out_path: str) -> List[str]:\n        # Use a deterministic encoding setup where possible.\n        if self.media_type == "video":\n            # Keep it simple: encode to H.264 in MP4 with fixed framerate.\n            return [\n                "ffmpeg",\n                "-hide_banner",\n                "-loglevel",\n                "error",\n                "-y",\n                "-f",\n                "lavfi",\n                "-i",\n                self.lavfi_input,\n                "-vf",\n                filtergraph,\n                "-an",\n                "-r",\n                "30",\n                "-t",\n                "2",\n                "-pix_fmt",\n                "yuv420p",\n                "-c:v",\n                "libx264",\n                "-preset",\n                "veryfast",\n                "-crf",\n                "18",\n                out_path,\n            ]\n        else:\n            # Audio: encode to WAV PCM for deterministic probing.\n            return [\n                "ffmpeg",\n                "-hide_banner",\n                "-loglevel",\n                "error",\n                "-y",\n                "-f",\n                "lavfi",\n                "-i",\n                self.lavfi_input,\n                "-af",\n                filtergraph,\n                "-vn",\n                "-c:a",\n                "pcm_s16le",\n                out_path,\n            ]\n\n    def validate(self, out_path: str) -> LevelResult:\n        raise NotImplementedError\n\n\nclass Level1(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w = vs.get("width")\n        h = vs.get("height")\n        if w == 320 and h == 240:\n            return LevelResult(True, "width==320 height==240")\n        return LevelResult(False, f"Expected 320x240, got {w}x{h}")\n\n\nclass Level2(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        pix_fmt = vs.get("pix_fmt")\n        # grayscale should be \'gray\'\n        if pix_fmt == "gray":\n            return LevelResult(True, "pix_fmt==gray")\n        return LevelResult(False, f"Expected pix_fmt gray, got {pix_fmt}")\n\n\nclass Level3(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        a = get_first_stream(probe, "audio")\n        if not a:\n            return LevelResult(False, "No audio stream found")\n        dur = parse_float(probe.get("format", {}).get("duration"))\n        if dur is None:\n            return LevelResult(False, "No duration found")\n        # Be strict-ish but allow tiny container rounding.\n        if approx_equal(dur, 3.0, eps=0.05):\n            return LevelResult(True, f"duration≈3.0s (got {dur})")\n        return LevelResult(False, f"Expected duration 3.0s, got {dur}")\n\n\nclass Level4(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w = vs.get("width")\n        h = vs.get("height")\n        if w == 200 and h == 200:\n            return LevelResult(True, "width==200 height==200")\n        return LevelResult(False, f"Expected 200x200, got {w}x{h}")\n\n\nclass Level5(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w = vs.get("width")\n        h = vs.get("height")\n        if not (w == 320 and h == 240):\n            return LevelResult(False, f"Expected 320x240, got {w}x{h}")\n\n        # To confirm hflip occurred, render a deterministic test pattern as input and\n        # compare checksum vs a known-good output generated from the known solution.\n        # We do this by hashing the first decoded frame.\n        # Simpler: compute framemd5 for first frame of output and compare against\n        # framemd5 computed from running known solution.\n        # This stays deterministic given fixed source, duration, fps, codec settings.\n        def framemd5(path: str) -> Tuple[bool, str]:\n            cmd = [\n                "ffmpeg",\n                "-hide_banner",\n                "-loglevel",\n                "error",\n                "-i",\n                path,\n                "-frames:v",\n                "1",\n                "-f",\n                "framemd5",\n                "-",\n            ]\n            p = run(cmd, capture=True)\n            if p.returncode != 0:\n                return False, p.stderr\n            # last non-comment line contains MD5 per frame\n            lines = [ln.strip() for ln in p.stdout.splitlines() if ln.strip() and not ln.startswith("#")]\n            return True, lines[-1] if lines else ""\n\n        ok1, md_user = framemd5(out_path)\n        if not ok1:\n            return LevelResult(False, f"framemd5 failed: {md_user}")\n\n        # generate reference output to a temp file\n        ref_path = out_path + ".ref.mp4"\n        try:\n            cmd_ref = self.build_ffmpeg_cmd(self.known_solution, ref_path)\n            p2 = run(cmd_ref, capture=True)\n            if p2.returncode != 0:\n                return LevelResult(False, f"Reference render failed: {p2.stderr}")\n            ok2, md_ref = framemd5(ref_path)\n            if not ok2:\n                return LevelResult(False, f"ref framemd5 failed: {md_ref}")\n            if md_user == md_ref:\n                return LevelResult(True, "dimensions OK and hflip verified via framemd5")\n            return LevelResult(False, "dimensions OK but content does not match expected hflip+scale")\n        finally:\n            try:\n                if os.path.exists(ref_path):\n                    os.remove(ref_path)\n            except Exception:\n                pass\n\n\ndef levels() -> List[Level]:\n    # Inputs are synthetic lavfi sources.\n    return [\n        Level1(\n            number=1,\n            name="Scale 640x480 down to 320x240",\n            description="Transform the input video from 640x480 to exactly 320x240.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="scale=320:240",\n        ),\n        Level2(\n            number=2,\n            name="Convert to grayscale",\n            description="Convert the input video to grayscale pixel format (pix_fmt must be \'gray\').",\n            media_type="video",\n            lavfi_input="testsrc2=size=320x240:rate=30",\n            output_ext="mp4",\n            known_solution="format=gray",\n        ),\n        Level3(\n            number=3,\n            name="Trim 10s audio to 3s",\n            description="Trim the 10-second synthetic audio clip to exactly 3 seconds.",\n            media_type="audio",\n            lavfi_input="sine=frequency=440:sample_rate=48000:duration=10",\n            output_ext="wav",\n            known_solution="atrim=0:3",\n        ),\n        Level4(\n            number=4,\n            name="Crop center 200x200 from 640x480",\n            description="Crop the center 200x200 region from a 640x480 input video.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n        ),\n        Level5(\n            number=5,\n            name="Scale to 320x240 and hflip",\n            description="Take a 640x480 video, scale it to 320x240, and apply a horizontal flip.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="scale=320:240,hflip",\n        ),\n    ]\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\n    out_path = level.output_path()\n    cmd = level.build_ffmpeg_cmd(filtergraph, out_path)\n    p = run(cmd, capture=True)\n    if p.returncode != 0:\n        # remove any partial output\n        try:\n            if os.path.exists(out_path):\n                os.remove(out_path)\n        except Exception:\n            pass\n        return False, out_path, f"ffmpeg failed: {p.stderr.strip()}"\n\n    try:\n        res = level.validate(out_path)\n        return res.ok, out_path, res.details\n    except Exception as e:\n        return False, out_path, f"validation error: {e}"\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    total = 0\n    earned = 0\n    for lvl in levels():\n        total += 10\n        print(f"\\nLevel {lvl.number}: {lvl.name}")\n        print(lvl.description)\n        print("Enter an FFmpeg filtergraph expression:")\n        try:\n            fg = input("> ").strip()\n        except EOFError:\n            print("\\nExiting.")\n            break\n        ok, out_path, details = run_level(lvl, fg)\n        if ok:\n            earned += 10\n            print("PASS")\n        else:\n            print("FAIL")\n        print(details)\n        print(f"Output: {out_path}")\n    print(f"Score: {earned}/{total}")\n    return 0\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    manifest: List[Dict[str, Any]] = []\n\n    total_levels = len(levels())\n    total = total_levels * 10\n   