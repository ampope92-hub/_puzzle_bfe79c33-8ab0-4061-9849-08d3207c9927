o_fps: int = 30\n\n    def slug(self) -> str:\n        return "".join(c.lower() if c.isalnum() else "_" for c in self.name).strip("_")\n\n    def output_path(self) -> str:\n        base = f"level{self.number:02d}_{self.slug()}.{self.output_ext}"\n        return os.path.join(OUTPUT_DIR, base)\n\n    def build_ffmpeg_cmd(self, filtergraph: str, out_path: str) -> List[str]:\n        if self.media_type == "video":\n            # For deterministic results, use constant fps and short duration.\n            cmd = [\n                "ffmpeg",\n                "-hide_banner",\n                "-loglevel",\n                "error",\n                "-y",\n                "-f",\n                "lavfi",\n                "-i",\n                self.lavfi_input,\n                "-vf",\n                filtergraph,\n                "-an",\n                "-r",\n                str(self.video_fps),\n                "-t",\n                str(self.video_duration),\n                "-pix_fmt",\n                self.output_pix_fmt,\n                "-c:v",\n                self.output_vcodec,\n            ]\n            # Only apply x264-specific knobs when using x264.\n            if self.output_vcodec == "libx264":\n                cmd += ["-preset", "veryfast", "-crf", "18"]\n            cmd += [out_path]\n            return cmd\n\n        # Audio: deterministic WAV PCM\n        return [\n            "ffmpeg",\n            "-hide_banner",\n            "-loglevel",\n            "error",\n            "-y",\n            "-f",\n            "lavfi",\n            "-i",\n            self.lavfi_input,\n            "-af",\n            filtergraph,\n            "-vn",\n            "-c:a",\n            "pcm_s16le",\n            out_path,\n        ]\n\n    def validate(self, out_path: str) -> LevelResult:\n        raise NotImplementedError\n\n\nclass Level1(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w, h = vs.get("width"), vs.get("height")\n        if w == 320 and h == 240:\n            return LevelResult(True, "width==320 height==240")\n        return LevelResult(False, f"Expected 320x240, got {w}x{h}")\n\n\nclass Level2(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        pix_fmt = vs.get("pix_fmt")\n        if pix_fmt == "gray":\n            return LevelResult(True, "pix_fmt==gray")\n        return LevelResult(False, f"Expected pix_fmt gray, got {pix_fmt}")\n\n\nclass Level3(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        a = get_first_stream(probe, "audio")\n        if not a:\n            return LevelResult(False, "No audio stream found")\n        dur = parse_float(probe.get("format", {}).get("duration"))\n        if dur is None:\n            return LevelResult(False, "No duration found")\n        if approx_equal(dur, 3.0, eps=0.05):\n            return LevelResult(True, f"duration≈3.0s (got {dur})")\n        return LevelResult(False, f"Expected duration 3.0s, got {dur}")\n\n\nclass Level4(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w, h = vs.get("width"), vs.get("height")\n        if w == 200 and h == 200:\n            return LevelResult(True, "width==200 height==200")\n        return LevelResult(False, f"Expected 200x200, got {w}x{h}")\n\n\nclass Level5(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        # Check dimensions strictly, then verify content matches known solution via framemd5 of first frame.\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return LevelResult(False, "No video stream found")\n        w, h = vs.get("width"), vs.get("height")\n        if not (w == 320 and h == 240):\n            return LevelResult(False, f"Expected 320x240, got {w}x{h}")\n\n        def framemd5_first_frame(path: str) -> str:\n            p = run(\n                [\n                    "ffmpeg",\n                    "-hide_banner",\n                    "-loglevel",\n                    "error",\n                    "-i",\n                    path,\n                    "-frames:v",\n                    "1",\n                    "-f",\n                    "framemd5",\n                    "-",\n                ],\n                capture=True,\n            )\n            if p.returncode != 0:\n                raise RuntimeError(p.stderr.strip())\n            lines = [ln.strip() for ln in p.stdout.splitlines() if ln.strip() and not ln.startswith("#")]\n            return lines[-1] if lines else ""\n\n        md_user = framemd5_first_frame(out_path)\n\n        ref_path = out_path + ".ref.mp4"\n        try:\n            p2 = run(self.build_ffmpeg_cmd(self.known_solution, ref_path), capture=True)\n            if p2.returncode != 0:\n                return LevelResult(False, f"Reference render failed: {p2.stderr.strip()}")\n            md_ref = framemd5_first_frame(ref_path)\n            if md_user == md_ref:\n                return LevelResult(True, "dimensions OK and hflip verified via framemd5")\n            return LevelResult(False, "dimensions OK but content does not match expected hflip+scale")\n        finally:\n            try:\n                if os.path.exists(ref_path):\n                    os.remove(ref_path)\n            except Exception:\n                pass\n\n\ndef levels() -> List[Level]:\n    return [\n        Level1(\n            number=1,\n            name="Scale 640x480 down to 320x240",\n            description="Transform the input video from 640x480 to exactly 320x240.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="scale=320:240",\n        ),\n        # Use MKV+FFV1 to preserve pix_fmt=gray (H.264/MP4 will force 4:2:0).\n        Level2(\n            number=2,\n            name="Convert to grayscale",\n            description="Convert the input video to grayscale pixel format (pix_fmt must be \'gray\').",\n            media_type="video",\n            lavfi_input="testsrc2=size=320x240:rate=30",\n            output_ext="mkv",\n            known_solution="format=gray",\n            output_pix_fmt="gray",\n            output_vcodec="ffv1",\n        ),\n        Level3(\n            number=3,\n            name="Trim 10s audio to 3s",\n            description="Trim the 10-second synthetic audio clip to exactly 3 seconds.",\n            media_type="audio",\n            lavfi_input="sine=frequency=440:sample_rate=48000:duration=10",\n            output_ext="wav",\n            known_solution="atrim=0:3",\n        ),\n        Level4(\n            number=4,\n            name="Crop center 200x200 from 640x480",\n            description="Crop the center 200x200 region from a 640x480 input video.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n        ),\n        Level5(\n            number=5,\n            name="Scale to 320x240 and hflip",\n            description="Take a 640x480 video, scale it to 320x240, and apply a horizontal flip.",\n            media_type="video",\n            lavfi_input="testsrc2=size=640x480:rate=30",\n            output_ext="mp4",\n            known_solution="scale=320:240,hflip",\n        ),\n    ]\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\n    out_path = level.output_path()\n    p = run(level.build_ffmpeg_cmd(filtergraph, out_path), capture=True)\n    if p.returncode != 0:\n        try:\n            if os.path.exists(out_path):\n                os.remove(out_path)\n        except Exception:\n            pass\n        return False, out_path, f"ffmpeg failed: {p.stderr.strip()}"\n\n    try:\n        res = level.validate(out_path)\n        return res.ok, out_path, res.details\n    except Exception as e:\n        return False, out_path, f"validation error: {e}"\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    total = 0\n    earned = 0\n    for lvl in levels():\n        total += 10\n        print(f"\\nLevel {lvl.number}: {lvl.name}")\n        print(lvl.description)\n        print("Enter an FFmpeg filtergraph expression:")\n        try:\n            fg = input("> ").strip()\n        except EOFError:\n            print("\\nExiting.")\n            break\n        ok, out_path, details = run_level(lvl, fg)\n        if ok:\n            earned += 10\n            print("PASS")\n        else:\n            print("FAIL")\n        print(details)\n        print(f"Output: {out_path}")\n    print(f"Score: {earned}/{total}")\n    return 0\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    manifest: List[Dict[str, Any]] = []\n\n    lvls = levels()\n    total = len(lvls) * 10\n    earned = 0\n\n    for lvl in lvls:\n        print(f"Level {lvl.number}: {lvl.name}")\n        ok, out_path, _details = run_level(lvl, lvl.known_solution)\n        print("PASS" if ok else "FAIL")\n        if ok:\n            earned += 10\n        manifest.append(\n            {\n                "level": lvl.number,\n                "filename": os.path.basename(out_path),\n                "valid": bool(ok),\n            }\n        )\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump(manifest, f, indent=2, sort_keys=True)\n\n    print(f"Score: {earned}/{total}")\n    return 0\n\n\ndef main(argv: List[str]) -> int:\n    ap = argparse.ArgumentParser(description="FFmpeg filtergraph puzzle game")\n    ap.add_argument("--auto-solve", action="store_true", help="run through all levels with known solutions")\n    args = ap.parse_args(argv)\n    return auto_solve() if args.auto_solve else interactive()\n\n\nif __name__ == "__main__":\n    raise SystemExit(main(sys.argv[1:]))\nPY\nchmod +x /app/ffpuzzle.py\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
