def get_first_stream(probe: Dict[str, Any], codec_type: str) -> Optional[Dict[str, Any]]:
    for s in probe.get("streams", []):
        if s.get("codec_type") == codec_type:
            return s
    return None


def parse_float(x: Any) -> Optional[float]:
    if x is None:
        return None
    try:
        return float(x)
    except Exception:
        return None


def approx_equal(a: float, b: float, eps: float = 0.05) -> bool:
    return abs(a - b) <= eps


@dataclass
class LevelResult:
    ok: bool
    details: str


@dataclass
class Level:
    number: int
    name: str
    description: str
    media_type: str  # 'video' or 'audio'
    lavfi_input: str
    output_ext: str
    known_solution: str

    def output_path(self) -> str:
        base = f"level{self.number:02d}_{self.slug()}.{self.output_ext}"
        return os.path.join(OUTPUT_DIR, base)

    def slug(self) -> str:
        return "".join(c.lower() if c.isalnum() else "_" for c in self.name).strip("_")

