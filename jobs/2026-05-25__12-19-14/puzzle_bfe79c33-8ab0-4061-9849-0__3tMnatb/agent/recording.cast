[130.811712, "i", "_h-200)/2\",\n        ),\n        Level5(\n            number=5,\n            name=\"Scale to 320x240 and hflip\",\n            description=\"Take a 640x480 video, scale it to 320x240, and apply a horizontal flip.\",\n            media_type=\"video\",\n            lavfi_input=\"testsrc2=size=640x480:rate=30\",\n            output_ext=\"mp4\",\n            known_solution=\"scale=320:240,hflip\",\n        ),\n    ]\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\n    out_path = level.output_path()\n    p = run(level.build_ffmpeg_cmd(filtergraph, out_path), capture=True)\n    if p.returncode != 0:\n        try:\n            if os.path.exists(out_path):\n                os.remove(out_path)\n        except Exception:\n            pass\n        return False, out_path, f\"ffmpeg failed: {p.stderr.strip()}\"\n\n    try:\n        res = level.validate(out_path)\n        return res.ok, out_path, res.details\n    except E"]
