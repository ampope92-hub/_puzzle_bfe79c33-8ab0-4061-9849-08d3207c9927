[47.655772, "i", "s(p.stdout)\n\n\ndef get_first_stream(probe: Dict[str, Any], codec_type: str) -> Optional[Dict[str, Any]]:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\ndef parse_float(x: Any) -> Optional[float]:\n    if x is None:\n        return None\n    try:\n        return float(x)\n    except Exception:\n        return None\n\n\ndef approx_equal(a: float, b: float, eps: float = 0.05) -> bool:\n    return abs(a - b) <= eps\n\n\n@dataclass\nclass LevelResult:\n    ok: bool\n    details: str\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    media_type: str  # 'video' or 'audio'\n    lavfi_input: str\n    output_ext: str\n    known_solution: str\n\n    def output_path(self) -> str:\n        base = f\"level{self.number:02d}_{self.slug()}.{self.output_ext}\"\n        return os.path.join(OUTPUT_DIR, base)\n\n    def slug(self) -> str:\n        return \"\".join(c.lower() if c.isalnum() else \"_\" for c in self.name).strip(\"_\")\n\n    def build_ffmpeg_cmd(s"]
