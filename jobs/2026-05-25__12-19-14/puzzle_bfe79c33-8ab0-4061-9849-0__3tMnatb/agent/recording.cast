[47.689665, "o", "\u001b[?2004h> "]
[47.690097, "o", "        return LevelResult(False, f\"Expected 200x200, got {w}x{h}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.690241, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.690387, "o", "class Level5(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
