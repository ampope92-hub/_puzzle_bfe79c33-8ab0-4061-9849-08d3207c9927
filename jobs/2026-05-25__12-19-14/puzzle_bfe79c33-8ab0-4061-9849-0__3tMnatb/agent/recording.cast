[47.688878, "o", "        vs = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.68903, "o", "        if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.689215, "o", "            return LevelResult(False, \"No video stream found\")\r\n\u001b[?2004l\r\u001b[?2004h>         w = vs.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.68936, "o", "        h = vs.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h>         if w == 200 and h == 200:\r\n"]
[47.689479, "o", "\u001b[?2004l\r\u001b[?2004h> "]
