[130.810359, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\nfrom dataclasses import dataclass, field\nfrom typing import Any, Dict, List, Optional, Tuple\n\nAPP_DIR = \"/app\"\nASSETS_DIR = os.path.join(APP_DIR, \"assets\")\nOUTPUT_DIR = os.path.join(APP_DIR, \"output\")\nMANIFEST_PATH = os.path.join(APP_DIR, \"manifest.json\")\n\n\ndef run(cmd: List[str], *, capture: bool = True) -> subprocess.CompletedProcess:\n    return subprocess.run(\n        cmd,\n        stdout=subprocess.PIPE if capture else None,\n        stderr=subprocess.PIPE if capture else None,\n        text=True,\n        check=False,\n    )\n\n\ndef ffprobe_json(path: str) -> Dict[str, Any]:\n    cmd = [\n        \"ffprobe\",\n        \"-v\",\n        \"error\",\n        \"-print_format\",\n        \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        path,\n    ]\n    p = run(cmd, capture=True)\n    if p.returncode != 0:\n        raise RuntimeError(f\"ffprobe failed for {path}: {p.stderr.strip()}\")\n    return json.lo"]
[130.810554, "i", "ads(p.stdout)\n\n\ndef get_first_stream(probe: Dict[str, Any], codec_type: str) -> Optional[Dict[str, Any]]:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\ndef parse_float(x: Any) -> Optional[float]:\n    try:\n        return float(x)\n    except Exception:\n        return None\n\n\ndef approx_equal(a: float, b: float, eps: float = 0.05) -> bool:\n    return abs(a - b) <= eps\n\n\n@dataclass\nclass LevelResult:\n    ok: bool\n    details: str\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    media_type: str  # 'video' or 'audio'\n    lavfi_input: str\n    output_ext: str\n    known_solution: str\n\n    # Per-level output controls (video only)\n    output_pix_fmt: str = \"yuv420p\"\n    output_vcodec: str = \"libx264\"\n\n    # Render controls\n    video_duration: float = 2.0\n    video_fps: int = 30\n\n    def slug(self) -> str:\n        return \"\".join(c.lower() if c.isalnum() else \"_\" for c in self.name).strip(\"_\")\n\n    def output_path("]
