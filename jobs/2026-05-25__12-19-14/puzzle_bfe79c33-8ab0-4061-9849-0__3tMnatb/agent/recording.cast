[130.810965, "i", "\"Expected duration 3.0s, got {dur}\")\n\n\nclass Level4(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return LevelResult(False, \"No video stream found\")\n        w, h = vs.get(\"width\"), vs.get(\"height\")\n        if w == 200 and h == 200:\n            return LevelResult(True, \"width==200 height==200\")\n        return LevelResult(False, f\"Expected 200x200, got {w}x{h}\")\n\n\nclass Level5(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        # Check dimensions strictly, then verify content matches known solution via framemd5 of first frame.\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return LevelResult(False, \"No video stream found\")\n        w, h = vs.get(\"width\"), vs.get(\"height\")\n        if not (w == 320 and h == 240):\n            return LevelResult(False, f\"Expected 320x240, got {w}x{h}\")\n\n        def fr"]
