[62.951145, "i", "python3 - <<'PY'\nimport io\nimport re\np='/app/ffpuzzle.py'\nwith open(p,'r',encoding='utf-8') as f:\n    s=f.read()\n# Add output_pix_fmt to Level dataclass\nif 'output_pix_fmt: str' not in s:\n    s=s.replace('    output_ext: str\\n    known_solution: str\\n', '    output_ext: str\\n    known_solution: str\\n    output_pix_fmt: str = \"yuv420p\"\\n')\n# In build_ffmpeg_cmd, replace hardcoded -pix_fmt yuv420p with self.output_pix_fmt\ns=s.replace('                \"-pix_fmt\",\\n                \"yuv420p\",\\n', '                \"-pix_fmt\",\\n                self.output_pix_fmt,\\n')\n# Set Level2 to output_pix_fmt='gray'\n# Insert output_pix_fmt argument into Level2(...) call.\npat=r'(Level2\\(\\n\\s*number=2,\\n\\s*name=\"Convert to grayscale\",[\\s\\S]*?known_solution=\"format=gray\",\\n)\\s*\\)'\nm=re.search(pat,s)\nif m and 'output_pix_fmt' not in m.group(0):\n    repl=m.group(1) + '            output_pix_fmt=\"gray\",\\n        )'\n    s=s[:m.start()]+repl+s[m.end():]\nwith open(p,'w',encoding='utf-8') as f:\n    f.write(s)\nprint('patched')\nPY\n"]
