[47.691066, "o", "> "]
[47.691221, "o", "        if not vs:\r\n\u001b[?2004l\r fl\u001b[?2004h> "]
[47.691404, "o", "            return LevelResult(False, \"No video stream found\")\r\n\u001b[?2004l\r\u001b[?2004h>         w = vs.get(\"width\")\r\n\u001b[?2004l\r=3\u001b[?2004h"]
[47.691499, "o", "> "]
[47.691544, "o", "        h = vs.get(\"height\")\r\n\u001b[?2004l\r"]
[47.691678, "o", "\u001b[?2004h>         if not (w == 320 and h == 240):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.691989, "o", "            return LevelResult(False, f\"Expected 320x240, got {w}x{h}\")\r\n\u001b[?2004l\r"]
[47.692142, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69229, "o", "        # To confirm hflip occurred, render a deterministic test pattern as input and\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.692506, "o", "        # compare checksum vs a known-good output generated from the known solution.\r\n\u001b[?2004l\r"]
[47.692606, "o", "\u001b[?2004h> "]
[47.692774, "o", "        # We do this by hashing the first decoded frame.\r\n\u001b[?2004l\r"]
[47.692925, "o", "\u001b[?2004h> "]
[47.693004, "o", "        # Simpler: compute framemd5 for first frame of output and compare against\r\n\u001b[?2004l\r"]
[47.69303, "o", "\u001b[?2004h> "]
[47.693287, "o", "        # framemd5 computed from running known solution.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.693512, "o", "        # This stays deterministic given fixed source, duration, fps, codec settings.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.693637, "o", "        def framemd5(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>             cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.693856, "o", "                \"ffmpeg\",\r\n\u001b[?2004l\r"]
[47.694036, "o", "\u001b[?2004h> "]
[47.694136, "o", "                \"-hide_banner\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.694272, "o", "                \"-loglevel\",\r\n\u001b[?2004l\rut_pat\u001b[?2004h> "]
[47.694415, "o", "                \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.694676, "o", "                \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>                 path,\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-frames:v\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.694833, "o", "> "]
[47.694978, "o", "                \"1\",\r\n\u001b[?2004l\r) "]
[47.695138, "o", "\u001b[?2004h>                 \"-f\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"framemd5\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-\",\r\n\u001b[?2004l\r in l\u001b[?2004h> "]
[47.695376, "o", "            ]\r\n\u001b[?2004l\r"]
[47.695553, "o", "\u001b[?2004h>             p = run(cmd, capture=True)\r\n\u001b[?2004l\r\u001b[?2004h>             if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>                 return False, p.stderr\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695709, "o", "            # last non-comment line contains MD5 per frame\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.695999, "o", "            lines = [ln.strip() for ln in p.stdout.splitlines() if ln.strip() and not ln.startswith(\"#\")]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.696244, "o", "            return True, lines[-1] if lines else \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         ok1, md_user = framemd5(out_path)\r\n\u001b[?2004l\r"]
[47.696379, "o", "\u001b[?2004h>         if not ok1:\r\n\u001b[?2004l\r          print(\"PAS"]
[47.696518, "o", "\u001b[?2004h> "]
[47.696639, "o", "            return LevelResult(False, f\"framemd5 failed: {md_user}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.696783, "o", "\r\n\u001b[?2004l\r"]
[47.69682, "o", "\u001b[?2004h>         # generate reference output to a temp file\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.697095, "o", "        ref_path = out_path + \".ref.mp4\"\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r0\r\n\r\n\r\ndef auto_solve() -\u001b[?2004h> "]
[47.697242, "o", "            cmd_ref = self.build_ffmpeg_cmd(self.known_solution, ref_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.697491, "o", "            p2 = run(cmd_ref, capture=True)\r\n\u001b[?2004l\r\u001b[?2004h>             if p2.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.697753, "o", "                return LevelResult(False, f\"Reference render failed: {p2.stderr}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.697906, "o", "            ok2, md_ref = framemd5(ref_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.697995, "o", ">             if not ok2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69833, "o", "                return LevelResult(False, f\"ref framemd5 failed: {md_ref}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698437, "o", "            if md_user == md_ref:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.698863, "o", "                return LevelResult(True, \"dimensions OK and hflip verified via framemd5\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69908, "o", "            return LevelResult(False, \"dimensions OK but content does not match expected hflip+scale\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.699139, "o", "        finally:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.699278, "o", "            try:\r\n\u001b[?2004l\r            \u001b[?2004h> "]
[47.699567, "o", "                if os.path.exists(ref_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.69974, "o", "                    os.remove(ref_path)\r\n\u001b[?2004l\r\u001b[?2004h>             except Exception:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.699885, "o", "                pass\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.70032, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def levels() -> List[Level]:\r\n\u001b[?2004l\r\u001b[?2004h>     # Inputs are synthetic lavfi sources.\r\n\u001b[?2004l\r\u001b[?2004h>     return [\r\n\u001b[?2004l\r\u001b[?2004h>         Level1(\r\n\u001b[?2004l\r\u001b[?2004h>             number=1,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Scale 640x480 down to 320x240\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.700611, "o", "            description=\"Transform the input video from 640x480 to exactly 320x240.\",\r\n\u001b[?2004l\run\u001b[?2004h> "]
[47.700756, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
