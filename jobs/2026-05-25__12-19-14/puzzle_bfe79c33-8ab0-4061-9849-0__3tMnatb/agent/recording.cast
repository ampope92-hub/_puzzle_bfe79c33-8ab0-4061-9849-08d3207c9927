[130.868342, "o", "        ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level4(\r\n\u001b[?2004l\r\u001b[?2004h>             number=4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.868534, "o", "            name=\"Crop center 200x200 from 640x480\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.868734, "o", "            description=\"Crop the center 200x200 region from a 640x480 input video.\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.868973, "o", "> "]
[130.870002, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h>             lavfi_input=\"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             known_solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level5(\r\n\u001b[?2004l\r\u001b[?2004h>             number=5,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Scale to 320x240 and hflip\",\r\n\u001b[?2004l\r"]
[130.870296, "o", "\u001b[?2004h>             description=\"Take a 640x480 video, scale it to 320x240, and apply a horizontal flip.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.870763, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h>             lavfi_input=\"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             known_solution=\"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.87236, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_dirs() -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h>     os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     out_path = level.output_path()\r\n\u001b[?2004l\r\u001b[?2004h>     p = run(level.build_ffmpeg_cmd(filtergraph, out_path), capture=True)\r\n\u001b[?2004l\r\u001b[?2004h>     if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             if os.path.exists(out_path):\r\n\u001b[?2004l\r\u001b[?2004h>                 os.remove(out_path)\r\n\u001b[?2004l\r"]
[130.872691, "o", "\u001b[?2004h>         except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>             pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.872747, "o", "        return False, out_path, f\"ffmpeg failed: {p.stderr.strip()}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.872856, "o", ">         res = level.validate(out_path)\r\n\u001b[?2004l\r"]
[130.8732, "o", "\u001b[?2004h>         return res.ok, out_path, res.details\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.873253, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, out_path, f\"validation error: {e}\"\r\n\u001b[?2004l\r"]
[130.873701, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     total = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.873961, "o", "    for lvl in levels():\r\n\u001b[?2004l\r\u001b[?2004h>         total += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.874281, "o", "        print(f\"\\nLevel {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"Enter an FFmpeg filtergraph expression:\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.874638, "o", "            fg = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.874897, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h>         ok, out_path, details = run_level(lvl, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r"]
[130.874944, "o", "\u001b[?2004h> "]
[130.875049, "o", "            earned += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.875062, "o", "            print(\"PASS\")"]
[130.875273, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.875482, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.875498, "o", "> "]
[130.876052, "o", "        print(details)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.876248, "o", "        print(f\"Output: {out_path}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.876431, "o", ">     print(f\"Score: {earned}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[130.876557, "o", "\u001b[?2004h> def auto_solve() -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.876588, "o", "    ensure_dirs()\r\n\u001b[?2004l\r"]
[130.876981, "o", "\u001b[?2004h> "]
[130.877183, "o", "    manifest: List[Dict[str, Any]] = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     lvls = levels()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.877544, "o", "    total = len(lvls) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     earned = 0\r\n\u001b[?2004l\r"]
[130.87773, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in lvls:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r"]
[130.878051, "o", "\u001b[?2004h>         ok, out_path, _details = run_level(lvl, lvl.known_solution)\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.87852, "o", ">         print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.878796, "o", "            earned += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.878945, "o", "        manifest.append(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.87905, "o", "            {\r\n\u001b[?2004l\r\u001b[?2004h>                 \"level\": lvl.number,\r\n\u001b[?2004l\r"]
[130.879221, "o", "\u001b[?2004h> "]
[130.879364, "o", "                \"filename\": os.path.basename(out_path),\r\n\u001b[?2004l\r\u001b[?2004h>                 \"valid\": bool(ok),"]
[130.879462, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             }\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.879492, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[130.87953, "o", "> "]
[130.879696, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.879795, "o", "> "]
[130.879853, "o", "        json.dump(manifest, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r"]
[130.879931, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.879966, "o", "    print(f\"Score: {earned}/{total}\")"]
[130.880037, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.880259, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.880357, "o", "def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.880387, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.880582, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run through all levels with known solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[130.88069, "o", "> "]
[130.880728, "o", "    args = ap.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.880822, "o", "    return auto_solve() if args.auto_solve else interactive()\r\n\u001b[?2004l\r"]
[130.881033, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.88113, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
