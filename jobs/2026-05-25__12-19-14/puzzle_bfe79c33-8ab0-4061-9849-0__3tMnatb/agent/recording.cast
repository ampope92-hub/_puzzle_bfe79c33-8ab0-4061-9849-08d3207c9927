[47.701203, "o", "\r\n\u001b[?2004l\r"]
[47.701322, "o", "\u001b[?2004h>             known_solution=\"scale=320:240\",\r\n\u001b[?2004l\r"]
[47.701493, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level2(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.701772, "o", "            number=2,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Convert to grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.70181, "o", "> "]
[47.702055, "o", "            description=\"Convert the input video to grayscale pixel format (pix_fmt must be 'gray').\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702226, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702415, "o", "            lavfi_input=\"testsrc2=size=320x240:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702672, "o", "            known_solution=\"format=gray\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level3(\r\n\u001b[?2004l\r\u001b[?2004h>             number=3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702811, "o", "            name=\"Trim 10s audio to 3s\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.702933, "o", "            description=\"Trim the 10-second synthetic audio clip to exactly 3 seconds.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703074, "o", "            media_type=\"audio\",\r\n\u001b[?2004l\r\u001b[?2004h>             lavfi_input=\"sine=frequency=440:sample_rate=48000:duration=10\",\r\n\u001b[?2004l\r"]
[47.703197, "o", "\u001b[?2004h>             output_ext=\"wav\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703336, "o", "            known_solution=\"atrim=0:3\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703344, "o", "        ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level4(\r\n\u001b[?2004l\r"]
[47.703357, "o", "\u001b[?2004h> "]
[47.703474, "o", "            number=4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70357, "o", "            name=\"Crop center 200x200 from 640x480\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703677, "o", "            description=\"Crop the center 200x200 region from a 640x480 input video.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.703802, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r"]
[47.703827, "o", "\u001b[?2004h> "]
[47.703897, "o", "            lavfi_input=\"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.703934, "o", "> "]
[47.70408, "o", "            known_solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704237, "o", "        Level5(\r\n\u001b[?2004l\r\u001b[?2004h>             number=5,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704453, "o", "            name=\"Scale to 320x240 and hflip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704593, "o", "            description=\"Take a 640x480 video, scale it to 320x240, and apply a horizontal flip.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704688, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704726, "o", "            lavfi_input=\"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.704834, "o", "            known_solution=\"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.704954, "o", ">     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_dirs() -> None:\r\n\u001b[?2004l\r"]
[47.704994, "o", "\u001b[?2004h> "]
[47.705114, "o", "    os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70514, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.705238, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.705498, "o", "def run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     out_path = level.output_path()\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = level.build_ffmpeg_cmd(filtergraph, out_path)\r\n\u001b[?2004l\r"]
[47.705679, "o", "\u001b[?2004h>     p = run(cmd, capture=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.705736, "o", "    if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.705861, "o", "        # remove any partial output\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.706006, "o", "            if os.path.exists(out_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.706215, "o", "                os.remove(out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         except Exception:\r\n\u001b[?2004l\r\u001b[?2004h>             pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.706411, "o", "        return False, out_path, f\"ffmpeg failed: {p.stderr.strip()}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.706571, "o", "        res = level.validate(out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         return res.ok, out_path, res.details\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70672, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, out_path, f\"validation error: {e}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.706797, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.706821, "o", ">     total = 0\r\n"]
[47.70691, "o", "\u001b[?2004l\r\u001b[?2004h>     earned = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707023, "o", "    for lvl in levels():\r\n\u001b[?2004l\r\u001b[?2004h>         total += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707156, "o", "        print(f\"\\nLevel {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707255, "o", "        print(\"Enter an FFmpeg filtergraph expression:\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             fg = input(\"> \").strip()"]
[47.707278, "o", "\r\n\u001b[?2004l\r"]
[47.707324, "o", "\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r"]
[47.707464, "o", "\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707575, "o", "        ok, out_path, details = run_level(lvl, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r"]
[47.707602, "o", "\u001b[?2004h"]
[47.707681, "o", ">             earned += 10\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"PASS\")"]
[47.707738, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707905, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.707938, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708088, "o", "        print(details)\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Output: {out_path}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708182, "o", "    print(f\"Score: {earned}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708322, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708477, "o", "def auto_solve() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.70856, "o", "    manifest: List[Dict[str, Any]] = []\r\n\u001b[?2004l\r"]
[47.70871, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708734, "o", "    total_levels = len(levels())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708911, "o", "    total = total_levels * 10\r\n\u001b[?2004l\r\u001b[?2004h>     earned = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.708996, "o", "    for lvl in levels():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709121, "o", "        print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709283, "o", "        ok, out_path, details = run_level(lvl, lvl.known_solution)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709396, "o", "            earned += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709551, "o", "            print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709649, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709782, "o", "        # details are useful for debugging but not required by spec; keep brief.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709947, "o", "        # print(details)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.709999, "o", "            {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.710132, "o", "                \"level\": lvl.number,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.710145, "o", "                \"filename\": os.path.basename(out_path),\r\n\u001b[?2004l\r"]
[47.710213, "o", "\u001b[?2004h> "]
[47.7103, "o", "                \"valid\": bool(ok),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.710372, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.710504, "o", "\u001b[?2004h> "]
[47.710589, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.710682, "o", "        json.dump(manifest, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.710703, "o", "> \r\n\u001b[?2004l\r"]
[47.710767, "o", "\u001b[?2004h> "]
[47.71093, "o", "    print(f\"Score: {earned}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.711016, "o", "def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.711111, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.711313, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run through all levels with known solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.71137, "o", "> "]
[47.7114, "o", "    args = ap.parse_args(argv)\r\n\u001b[?2004l\r"]
[47.711431, "o", "\u001b[?2004h> "]
[47.711551, "o", "    if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.711653, "o", "        return auto_solve()\r\n\u001b[?2004l\r\u001b[?2004h>     return interactive()\r\n\u001b[?2004l\r"]
[47.71182, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[47.711916, "o", "\u001b[?2004h>     raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r"]
