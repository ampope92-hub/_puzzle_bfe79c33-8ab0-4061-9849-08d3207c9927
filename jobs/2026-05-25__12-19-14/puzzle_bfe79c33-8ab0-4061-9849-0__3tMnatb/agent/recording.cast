[47.656429, "i", "om the known solution.\n        # We do this by hashing the first decoded frame.\n        # Simpler: compute framemd5 for first frame of output and compare against\n        # framemd5 computed from running known solution.\n        # This stays deterministic given fixed source, duration, fps, codec settings.\n        def framemd5(path: str) -> Tuple[bool, str]:\n            cmd = [\n                \"ffmpeg\",\n                \"-hide_banner\",\n                \"-loglevel\",\n                \"error\",\n                \"-i\",\n                path,\n                \"-frames:v\",\n                \"1\",\n                \"-f\",\n                \"framemd5\",\n                \"-\",\n            ]\n            p = run(cmd, capture=True)\n            if p.returncode != 0:\n                return False, p.stderr\n            # last non-comment line contains MD5 per frame\n            lines = [ln.strip() for ln in p.stdout.splitlines() if ln.strip() and not ln.startswith(\"#\")]\n            return True, lines[-1] if lines else \"\"\n\n        ok1, md_user = fr"]
