[130.810816, "i", "ibx264\":\n                cmd += [\"-preset\", \"veryfast\", \"-crf\", \"18\"]\n            cmd += [out_path]\n            return cmd\n\n        # Audio: deterministic WAV PCM\n        return [\n            \"ffmpeg\",\n            \"-hide_banner\",\n            \"-loglevel\",\n            \"error\",\n            \"-y\",\n            \"-f\",\n            \"lavfi\",\n            \"-i\",\n            self.lavfi_input,\n            \"-af\",\n            filtergraph,\n            \"-vn\",\n            \"-c:a\",\n            \"pcm_s16le\",\n            out_path,\n        ]\n\n    def validate(self, out_path: str) -> LevelResult:\n        raise NotImplementedError\n\n\nclass Level1(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return LevelResult(False, \"No video stream found\")\n        w, h = vs.get(\"width\"), vs.get(\"height\")\n        if w == 320 and h == 240:\n            return LevelResult(True, \"width==320 height==240\")\n        return LevelResu"]
[130.810951, "i", "lt(False, f\"Expected 320x240, got {w}x{h}\")\n\n\nclass Level2(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return LevelResult(False, \"No video stream found\")\n        pix_fmt = vs.get(\"pix_fmt\")\n        if pix_fmt == \"gray\":\n            return LevelResult(True, \"pix_fmt==gray\")\n        return LevelResult(False, f\"Expected pix_fmt gray, got {pix_fmt}\")\n\n\nclass Level3(Level):\n    def validate(self, out_path: str) -> LevelResult:\n        probe = ffprobe_json(out_path)\n        a = get_first_stream(probe, \"audio\")\n        if not a:\n            return LevelResult(False, \"No audio stream found\")\n        dur = parse_float(probe.get(\"format\", {}).get(\"duration\"))\n        if dur is None:\n            return LevelResult(False, \"No duration found\")\n        if approx_equal(dur, 3.0, eps=0.05):\n            return LevelResult(True, f\"duration≈3.0s (got {dur})\")\n        return LevelResult(False, f"]
