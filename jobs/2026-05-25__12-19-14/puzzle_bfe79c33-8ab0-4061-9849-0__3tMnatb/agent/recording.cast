[130.810788, "i", "self) -> str:\n        base = f\"level{self.number:02d}_{self.slug()}.{self.output_ext}\"\n        return os.path.join(OUTPUT_DIR, base)\n\n    def build_ffmpeg_cmd(self, filtergraph: str, out_path: str) -> List[str]:\n        if self.media_type == \"video\":\n            # For deterministic results, use constant fps and short duration.\n            cmd = [\n                \"ffmpeg\",\n                \"-hide_banner\",\n                \"-loglevel\",\n                \"error\",\n                \"-y\",\n                \"-f\",\n                \"lavfi\",\n                \"-i\",\n                self.lavfi_input,\n                \"-vf\",\n                filtergraph,\n                \"-an\",\n                \"-r\",\n                str(self.video_fps),\n                \"-t\",\n                str(self.video_duration),\n                \"-pix_fmt\",\n                self.output_pix_fmt,\n                \"-c:v\",\n                self.output_vcodec,\n            ]\n            # Only apply x264-specific knobs when using x264.\n            if self.output_vcodec == \"l"]
