[47.686178, "o", "\u001b[?2004h>     def validate(self, out_path: str) -> LevelResult:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.686297, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r    Level2(\r\n            number=2,\r\n            name=\"Convert to grayscale\",\r\n            descri\u001b[?2004h> "]
[47.686336, "o", "        a = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.686495, "o", "        if not a:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.686698, "o", "            return LevelResult(False, \"No audio stream found\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.687007, "o", "        dur = parse_float(probe.get(\"format\", {}).get(\"duration\"))\r\n\u001b[?2004l\rutput_\u001b[?2004h> "]
[47.687196, "o", "        if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.68734, "o", "> "]
[47.687452, "o", "            return LevelResult(False, \"No duration found\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.687658, "o", "        # Be strict-ish but allow tiny container rounding.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.687785, "o", "        if approx_equal(dur, 3.0, eps=0.05):\r\n\u001b[?2004l\r"]
[47.687843, "o", "\u001b[?2004h> "]
[47.688021, "o", "            return LevelResult(True, f\"duration≈3.0s (got {dur})\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.688139, "o", "        return LevelResult(False, f\"Expected duration 3.0s, got {dur}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.688172, "o", "\u001b[?2004h> \r\n\u001b[?2004l\ra\u001b[?2004h> "]
