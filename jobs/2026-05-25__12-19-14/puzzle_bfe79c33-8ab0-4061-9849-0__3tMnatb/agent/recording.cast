[134.954092, "i", "python3 - <<'PY'\nimport json,glob,os,subprocess\nfiles=sorted(glob.glob('/app/output/*'))\nprint([os.path.basename(f) for f in files])\nl2=[f for f in files if 'level02_' in os.path.basename(f)][0]\npr=subprocess.run(['ffprobe','-v','error','-print_format','json','-show_streams',l2],stdout=subprocess.PIPE,text=True)\nprobe=json.loads(pr.stdout)\nvs=[s for s in probe.get('streams',[]) if s.get('codec_type')=='video'][0]\nprint('level2 pix_fmt:', vs.get('pix_fmt'))\nPY\n"]
