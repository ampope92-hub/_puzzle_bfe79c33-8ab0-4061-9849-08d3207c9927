[130.812536, "i", "xception as e:\n        return False, out_path, f\"validation error: {e}\"\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    total = 0\n    earned = 0\n    for lvl in levels():\n        total += 10\n        print(f\"\\nLevel {lvl.number}: {lvl.name}\")\n        print(lvl.description)\n        print(\"Enter an FFmpeg filtergraph expression:\")\n        try:\n            fg = input(\"> \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n        ok, out_path, details = run_level(lvl, fg)\n        if ok:\n            earned += 10\n            print(\"PASS\")\n        else:\n            print(\"FAIL\")\n        print(details)\n        print(f\"Output: {out_path}\")\n    print(f\"Score: {earned}/{total}\")\n    return 0\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    manifest: List[Dict[str, Any]] = []\n\n    lvls = levels()\n    total = len(lvls) * 10\n    earned = 0\n\n    for lvl in lvls:\n        print(f\"Level {lvl.number}: {lvl.name}\")\n        ok, out_path, _details = run_level(lvl, lvl.known_solution)\n        print"]
