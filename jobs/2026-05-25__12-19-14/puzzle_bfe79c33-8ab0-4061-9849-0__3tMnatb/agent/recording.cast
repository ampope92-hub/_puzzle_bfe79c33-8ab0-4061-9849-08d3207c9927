[130.867653, "o", "            description=\"Trim the 10-second synthetic audio clip to exactly 3 seconds.\",\r\n\u001b[?2004l\r\u001b[?2004h>             media_type=\"audio\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[130.867762, "o", "            lavfi_input=\"sine=frequency=440:sample_rate=48000:duration=10\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
