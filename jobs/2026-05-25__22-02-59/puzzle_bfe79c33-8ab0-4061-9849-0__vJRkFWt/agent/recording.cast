[49.339375, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef run(cmd: List[str], *, capture: bool = False, check: bool = True) -> subprocess.CompletedProcess:\n    return subprocess.run(cmd, text=True, capture_output=capture, check=check)\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cp = run([\n        \"ffprobe\", \"-v\", \"error\",\n        \"-show_streams\", \"-show_format\",\n        \"-of\", \"json\",\n        path\n    ], capture=True)\n    return json.loads(cp.stdout)\n\n\ndef parse_duration_seconds(probe: Dict) -> Optional[float]:\n    # Prefer format.duration, fallback to first stream duration\n    fmt = probe.get(\"format\") or {}\n    dur = fmt.get(\"duration\""]
