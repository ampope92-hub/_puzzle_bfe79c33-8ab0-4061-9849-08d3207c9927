[49.342067, "i", "expected pix_fmt gray, got {pix}\"\n\n\ndef validate_level3(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    st = first_stream(p, \"audio\")\n    if not st:\n        return False, \"no audio stream\"\n    dur = parse_duration_seconds(p)\n    if dur is None:\n        return False, \"could not read duration\"\n    if 2.9 <= dur <= 3.1:\n        return True, f\"ok ({dur:.3f}s)\"\n    return False, f\"expected duration ~3s, got {dur:.3f}s\"\n\n\ndef validate_level4(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    st = first_stream(p, \"video\")\n    if not st:\n        return False, \"no video stream\"\n    w, h = st.get(\"width\"), st.get(\"height\")\n    if w == 200 and h == 200:\n        return True, \"ok\"\n    return False, f\"expected 200x200, got {w}x{h}\"\n\n\ndef validate_level5(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    st = first_stream(p, \"video\")\n    if not st:\n        return False, \"no video stream\"\n    w, h = st.get(\"width\"), st.get(\"height\")\n    if w == 320 and h == 240:\n        return False, f\""]
