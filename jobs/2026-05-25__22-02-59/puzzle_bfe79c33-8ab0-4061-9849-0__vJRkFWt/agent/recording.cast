[49.361569, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.362032, "o", "    return False, f\"expected pix_fmt gray, got {pix}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level3(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.362389, "o", "    st = first_stream(p, \"audio\")\r\n\u001b[?2004l\rbf_d\u001b[?2004h>     if not st:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.362775, "o", "        return False, \"no audio stream\"\r\n\u001b[?2004l\r\u001b[?2004h>     dur = parse_duration_seconds(p)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.363151, "o", "    if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, \"could not read duration\"\r\n\u001b[?2004l\r\u001b[?2004h>     if 2.9 <= dur <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.363448, "o", "        return True, f\"ok ({dur:.3f}s)\"\r\n\u001b[?2004l\r \u001b[?2004h> "]
[49.363942, "o", "    return False, f\"expected duration ~3s, got {dur:.3f}s\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level4(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h>     st = first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>     if not st:\r\n\u001b[?2004l\r   ap = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Gam\u001b[?2004h>         return False, \"no video stream\"\r\n\u001b[?2004l\rument(\"--auto-solve\", \u001b[?2004h> "]
[49.364408, "o", "    w, h = st.get(\"width\"), st.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h>     if w == 200 and h == 200:\r\n\u001b[?2004l\rsolutions\")\r\n    args = ap.pars\u001b[?2004h>         return True, \"ok\"\r\n\u001b[?2004l\re_args()\r\n\r\n    ensure_dirs(\u001b[?2004h>     return False, f\"expected 200x200, got {w}x{h}\"\r\n\u001b[?2004l\r)\r\n\r\n    manifest = []\r\n    points = 0\r\n    total = 5 *\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r"]
[49.364784, "o", "\u001b[?2004h> def validate_level5(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.36523, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h>     st = first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>     if not st:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.365535, "o", "        return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h>     w, h = st.get(\"width\"), st.get(\"height\")\r\n\u001b[?2004l\r"]
[49.365736, "o", "\u001b[?2004h> "]
[49.366007, "o", "    if w == 320 and h == 240:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.366403, "o", "        return False, f\"dimensions wrong: got {w}x{h}\"  # placeholder unreachable\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.366503, "o", "> "]
[49.366863, "o", "    # We must check both scaling and flip. We'll validate dimensions and that it is flipped by comparing hashes\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.367038, "o", "    # of first frame between expected and produced.\r\n\u001b[?2004l\r # A\u001b[?2004h> "]
[49.367163, "o", "    if not (w == 320 and h == 240):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.36734, "o", "        return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r"]
[49.367486, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.367986, "o", "    # Determine flip by producing reference frame with known correct filter and comparing.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.368302, "o", "    # Use md5 muxer for deterministic comparison.\r\n"]
[49.368327, "o", "\u001b[?2004l\r"]
[49.368437, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.368621, "o", "        in_path = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.368762, "o", "> "]
[49.368932, "o", "        ref_md5 = run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.36909, "o", "            \"ffmpeg\", \"-v\", \"error\", \"-i\", in_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.369271, "o", "            \"-vf\", \"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.369407, "o", "            \"-frames:v\", \"1\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.369559, "o", "            \"-f\", \"md5\", \"-\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.36971, "o", "        ], capture=True).stdout.strip()\r\n\u001b[?2004l\r"]
[49.369823, "o", "\u001b[?2004h> "]
[49.369991, "o", "        out_md5 = run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37015, "o", "            \"ffmpeg\", \"-v\", \"error\", \"-i\", path,\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.370183, "o", "> "]
[49.370653, "o", "            \"-frames:v\", \"1\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-f\", \"md5\", \"-\"\r\n\u001b[?2004l\r\u001b[?2004h>         ], capture=True).stdout.strip()\r\n\u001b[?2004l\r\u001b[?2004h>     except subprocess.CalledProcessError as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.370708, "o", "        return False, (e.stderr or \"md5 compare failed\").strip()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[49.370724, "o", "\u001b[?2004h"]
[49.370744, "o", "> "]
[49.370852, "o", "    if ref_md5 == out_md5:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.370981, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r"]
[49.371057, "o", "\u001b[?2004h> "]
[49.371072, "o", "    return False, \"frame does not match expected scaled+hflip output\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.371193, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def levels() -> List[Level]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.371326, "o", "    # Solutions are base64(encoded) then reversed. Not plaintext.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.371552, "o", "    # Plaintext solutions (for reference):\r\n\u001b[?2004l\r\u001b[?2004h>     # 1) scale=320:240\r\n\u001b[?2004l\r"]
[49.371599, "o", "\u001b[?2004h>     # 2) format=gray\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.371652, "o", "    # 3) atrim=0:3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.371744, "o", "    # 4) crop=200:200:(in_w-200)/2:(in_h-200)/2\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.371882, "o", ">     # 5) scale=320:240,hflip\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.372012, "o", "    enc = lambda s: base64.b64encode(s.encode(\"utf-8\")).decode(\"ascii\")[::-1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[49.372107, "o", "\u001b[?2004h>     return [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37215, "o", "        Level(\r\n\u001b[?2004l\r\u001b[?2004h>             1,\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.372401, "o", "> "]
[49.372494, "o", "            \"Scale down\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"Scale a 640x480 video down to 320x240. Enter a video filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37255, "o", "            \"level1_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.372581, "o", "            \"level1_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.372714, "o", "            validate_level1,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.372778, "o", "            enc(\"scale=320:240\"),\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r"]
[49.372883, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             2,\r\n\u001b[?2004l\r"]
[49.37298, "o", "\u001b[?2004h> "]
[49.373043, "o", "            \"Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373207, "o", "            \"Convert a video to grayscale. Output pixel format must be exactly 'gray'. Enter a video filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373276, "o", "            \"level2_input.avi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373348, "o", "            \"level2_output.avi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373411, "o", "            validate_level2,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373437, "o", "            enc(\"format=gray\"),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373534, "o", "        ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373613, "o", "        Level(\r\n\u001b[?2004l\r\u001b[?2004h>             3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373714, "o", "            \"Audio trim\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.373808, "o", "> "]
[49.373901, "o", "            \"Trim a 10-second audio clip to exactly 3 seconds. Enter an audio filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.373964, "o", "            \"level3_input.wav\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.374066, "o", "            \"level3_output.wav\",\r\n\u001b[?2004l\r\u001b[?2004h>             validate_level3,\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.37414, "o", "> "]
[49.374204, "o", "            enc(\"atrim=0:3\"),\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r"]
[49.374225, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r"]
[49.374278, "o", "\u001b[?2004h>             4,\r\n\u001b[?2004l\r"]
[49.374404, "o", "\u001b[?2004h>             \"Center crop\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37461, "o", "            \"Crop the center 200x200 region from a 640x480 video. Enter a video filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"level4_input.mp4\","]
[49.374638, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37474, "o", "            \"level4_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.374912, "o", "            validate_level4,\r\n\u001b[?2004l\r\u001b[?2004h>             enc(\"crop=200:200:(in_w-200)/2:(in_h-200)/2\"),\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.375226, "o", ">         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             5,\r\n\u001b[?2004l\r\u001b[?2004h>             \"Scale + flip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.375414, "o", "            \"Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip. Enter a video filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.375521, "o", "            \"level5_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.375685, "o", "            \"level5_output.mp4\",\r\n\u001b[?2004l\r"]
[49.375806, "o", "\u001b[?2004h> "]
[49.375895, "o", "            validate_level5,\r\n\u001b[?2004l\r"]
[49.376015, "o", "\u001b[?2004h> "]
[49.376139, "o", "            enc(\"scale=320:240,hflip\"),\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[49.376199, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37631, "o", "def play_level(lvl: Level, *, auto_solve: bool) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.376468, "o", "    input_path = ffmpeg_generate_input(lvl.num, lvl.input_filename)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.376544, "o", ">     if auto_solve:\r\n\u001b[?2004l\r"]
[49.37658, "o", "\u001b[?2004h> "]
[49.376743, "o", "        fg = obf_decode(lvl.solution_obf)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r"]
[49.376816, "o", "\u001b[?2004h> "]
[49.376931, "o", "        fg = input(\"Filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.376973, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377076, "o", "    ok_build, out_or_err = build_output(lvl.num, input_path, lvl.output_filename, fg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377152, "o", "    if not ok_build:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377239, "o", "        return False, out_or_err\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[49.377303, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[49.377353, "o", "    ok_val, msg = lvl.validator(out_or_err)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377374, "o", "    return ok_val, msg\r\n"]
[49.377528, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def main() -> int:\r\n\u001b[?2004l\r"]
[49.37762, "o", "\u001b[?2004h> "]
[49.37767, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377783, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run with built-in solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.377801, "o", "> "]
[49.37787, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.377934, "o", "\r\n\u001b[?2004l\r"]
[49.378005, "o", "\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[49.378066, "o", "\u001b[?2004h> "]
[49.378169, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     points = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.378191, "o", "    total = 5 * 10\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.37821, "o", "> \r\n\u001b[?2004l\r"]
[49.378269, "o", "\u001b[?2004h> "]
[49.378293, "o", "    for lvl in levels():\r\n\u001b[?2004l\r"]
[49.378351, "o", "\u001b[?2004h> "]
[49.378407, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.37846, "o", "> "]
[49.378545, "o", "        passed, msg = play_level(lvl, auto_solve=args.auto_solve)\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.378563, "o", "> "]
[49.378612, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.378646, "o", "> "]
[49.378729, "o", "            points += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.378806, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.378889, "o", ">         else:\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.378983, "o", ">             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.37904, "o", "            if not args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.379149, "o", "                print(f\"  Reason: {msg}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.379189, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.379257, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.379392, "o", "            \"level\": lvl.num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.379466, "o", "            \"filename\": lvl.output_filename,\r\n\u001b[?2004l\r"]
[49.379525, "o", "\u001b[?2004h> "]
[49.379595, "o", "            \"passed\": bool(passed),\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r"]
[49.379689, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.379766, "o", "> "]
[49.379917, "o", "    # Always write manifest (CI expects it from auto-solve; harmless for interactive too)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.380059, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.380119, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.38021, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[49.380399, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {points}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[49.380438, "o", "    return 0 if args.auto_solve and points == total else 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.380636, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[49.38068, "o", "> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
