[49.34419, "i", "*, auto_solve: bool) -> Tuple[bool, str]:\n    input_path = ffmpeg_generate_input(lvl.num, lvl.input_filename)\n\n    if auto_solve:\n        fg = obf_decode(lvl.solution_obf)\n    else:\n        print(lvl.description)\n        fg = input(\"Filtergraph> \").strip()\n\n    ok_build, out_or_err = build_output(lvl.num, input_path, lvl.output_filename, fg)\n    if not ok_build:\n        return False, out_or_err\n\n    ok_val, msg = lvl.validator(out_or_err)\n    return ok_val, msg\n\n\ndef main() -> int:\n    ap = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\n    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run with built-in solutions\")\n    args = ap.parse_args()\n\n    ensure_dirs()\n\n    manifest = []\n    points = 0\n    total = 5 * 10\n\n    for lvl in levels():\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        passed, msg = play_level(lvl, auto_solve=args.auto_solve)\n        if passed:\n            points += 10\n            print(\"  PASS\")\n        else:\n            print(\"  FAIL\")\n            if"]
