[133.806998, "i", "python3 - <<'PY'\nimport re\np='/app/ffpuzzle.py'\ntext=open(p,'r',encoding='utf-8').read()\n# Replace the ffmpeg command block inside ssim_score\ntext=re.sub(r'cp = run\\(\\[\\n\\s*\"ffmpeg\", \"-v\", \"error\",\\n\\s*\"-i\", in_path,\\n\\s*\"-i\", path,\\n\\s*\"-t\", \"1\",\\n\\s*\"-filter_complex\", f\"\\[0:v\\]\\{ref_vf\\}\\[ref\\];\\[ref\\]\\[1:v\\]ssim\",\\n\\s*\"-f\", \"null\", \"-\"\\n\\s*\\], capture=True\\)',\n            'cp = run([\\n            \"ffmpeg\", \"-hide_banner\", \"-nostats\", \"-v\", \"info\",\\n            \"-i\", in_path,\\n            \"-i\", path,\\n            \"-t\", \"1\",\\n            \"-filter_complex\", f\"[0:v]{ref_vf},format=yuv420p[ref];[1:v]format=yuv420p[out];[ref][out]ssim\",\\n            \"-f\", \"null\", \"-\"\\n        ], capture=True)',\n            text,\n            flags=re.S)\nopen(p,'w',encoding='utf-8').write(text)\nPY\n"]
