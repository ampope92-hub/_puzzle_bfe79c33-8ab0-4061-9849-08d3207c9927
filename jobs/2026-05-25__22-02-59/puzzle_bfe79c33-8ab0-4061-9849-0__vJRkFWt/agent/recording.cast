[49.341686, "i", "    except subprocess.CalledProcessError as e:\n        msg = (e.stderr or \"\").strip()\n        if not msg:\n            msg = \"ffmpeg failed\"\n        return False, msg\n\n    return True, out_path\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_filename: str\n    output_filename: str\n    validator: Callable[[str], Tuple[bool, str]]\n    # obfuscated solution string (not plaintext)\n    solution_obf: str\n\n\ndef validate_level1(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    st = first_stream(p, \"video\")\n    if not st:\n        return False, \"no video stream\"\n    w, h = st.get(\"width\"), st.get(\"height\")\n    if w == 320 and h == 240:\n        return True, \"ok\"\n    return False, f\"expected 320x240, got {w}x{h}\"\n\n\ndef validate_level2(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    st = first_stream(p, \"video\")\n    if not st:\n        return False, \"no video stream\"\n    pix = st.get(\"pix_fmt\")\n    if pix == \"gray\":\n        return True, \"ok\"\n    return False, f\""]
