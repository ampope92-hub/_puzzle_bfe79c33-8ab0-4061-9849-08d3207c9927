[?2004l[?2004h>         return props
[?2004l[?2004h>     for stream in probe_data["streams"]:
[?2004l[?2004h>         if stream.get("codec_type") == "video":
[?2004l[?2004h>             props["width"] = stream.get("width")
[?2004l[?2004h>             props["height"] = stream.get("height")
[?2004l[?2004h>             props["pix_fmt"] = stream.get("pix_fmt")
[?2004l[?2004h>             if "duration" in stream:
[?2004l[?2004h>                 try:
