[?2004l[?2004h> def probe_file(filepath):
[?2004l[?2004h>     cmd = [
[?2004l[?2004h>         "ffprobe", "-v", "quiet", "-print_format", "json",
[?2004l[?2004h>         "-show_streams", "-show_format", filepath
[?2004l[?2004h>     ]
[?2004l[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)
[?2004l[?2004h>     if result.returncode != 0:
[?2004l[?2004h>         return None
[?2004l[?2004h>     try:
[?2004l[?2004h>         data = json.loads(result.stdout)
[?2004l[?2004h>     except json.JSONDecodeError:
[?2004l[?2004h>         return None
[?2004l[?2004h>     return data
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def extract_props(probe_data):
[?2004l[?2004h>     """Extract relevant properties from ffprobe output."""
