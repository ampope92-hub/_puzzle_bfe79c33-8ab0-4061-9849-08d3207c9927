[?2004l[?2004h>                 except (ValueError, TypeError):
[?2004l[?2004h>                     pass
[?2004l[?2004h>         elif stream.get("codec_type") == "audio":
[?2004l[?2004h>             if "duration" in stream:
[?2004l[?2004h>                 try:
[?2004l[?2004h>                     props["duration"] = float(stream["duration"])
[?2004l[?2004h>                 except (ValueError, TypeError):
[?2004l[?2004h>                     pass
[?2004l[?2004h>     # Fallback to format duration if stream duration not available
[?2004l[?2004h>     if "duration" not in props and "format" in probe_data:
[?2004l[?2004h>         try:
