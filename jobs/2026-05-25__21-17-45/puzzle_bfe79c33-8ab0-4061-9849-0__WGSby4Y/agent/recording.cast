[37.760574, "i", "cat > /app/ffpuzzle.py << 'PYTHON_SCRIPT'\nimport subprocess\nimport json\nimport sys\nimport os\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\nLEVELS = [\n    {\n        \"number\": 1,\n        \"name\": \"Scale Down\",\n        \"description\": \"Scale a 640x480 video down to 320x240\",\n        \"input_file\": \"level1_input.mp4\",\n        \"output_file\": \"level1_output.mp4\",\n        \"generate_cmd\": lambda inp: [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", inp\n        ],\n        \"solve_filter\": \"scale=320:240\",\n        \"output_cmd\": lambda inp, filt, out: [\n            \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", filt,\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", out\n        ],\n        \"validate\": lambda probe: (\n            probe.get(\"width\") == 320 and probe.get(\"height\") == 240\n        ),\n    },\n    {\n        \"number\": 2,\n        \"name\": \"Grayscale\",\n        \"description\""]
[37.760689, "i", ": \"Convert a video to grayscale (output pixel format must be gray). Use .avi container with rawvideo codec.\",\n        \"input_file\": \"level2_input.avi\",\n        \"output_file\": \"level2_output.avi\",\n        \"generate_cmd\": lambda inp: [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"rgb24\", inp\n        ],\n        \"solve_filter\": \"format=gray\",\n        \"output_cmd\": lambda inp, filt, out: [\n            \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", filt,\n            \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\", out\n        ],\n        \"validate\": lambda probe: (\n            probe.get(\"pix_fmt\") == \"gray\"\n        ),\n    },\n    {\n        \"number\": 3,\n        \"name\": \"Trim Audio\",\n        \"description\": \"Trim a 10-second audio clip to exactly 3 seconds\",\n        \"input_file\": \"level3_input.wav\",\n        \"output_file\": \"level3_output.wav\",\n        \"generate_cmd\": lambda inp: [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n           "]
