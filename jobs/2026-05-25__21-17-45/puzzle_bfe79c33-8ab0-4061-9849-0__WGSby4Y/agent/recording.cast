[37.761371, "i", " return props\n\n\ndef validate_level(level, output_path):\n    probe_data = probe_file(output_path)\n    if probe_data is None:\n        return False\n    props = extract_props(probe_data)\n    return level[\"validate\"](props)\n\n\ndef auto_solve():\n    ensure_dirs()\n    manifest = []\n    total_score = 0\n    max_score = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f\"Level {level['number']}: {level['name']}\")\n        generate_input(level)\n        success, out_path = run_filter(level, level[\"solve_filter\"])\n        passed = False\n        if success and os.path.exists(out_path):\n            passed = validate_level(level, out_path)\n        if passed:\n            total_score += 10\n            print(\"  PASS\")\n        else:\n            print(\"  FAIL\")\n        manifest.append({\n            \"level\": level[\"number\"],\n            \"filename\": level[\"output_file\"],\n            \"passed\": passed\n        })\n\n    print(f\"Score: {total_score}/{max_score}\")\n\n    with open(MANIFEST_PATH, \"w\") as f:\n        json.dump(manifest, f"]
