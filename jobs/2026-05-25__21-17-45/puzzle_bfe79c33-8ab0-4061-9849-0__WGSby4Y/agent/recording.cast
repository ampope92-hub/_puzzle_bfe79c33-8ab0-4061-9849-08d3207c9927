[37.7794, "o", "\u001b[?2004h>         \"name\": \"Scale and Flip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.780129, "o", "        \"description\": \"Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.780215, "o", "> "]
[37.780503, "o", "        \"input_file\": \"level5_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.780699, "o", "        \"output_file\": \"level5_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.781246, "o", "> "]
[37.78194, "o", "        \"generate_cmd\": lambda inp: [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.782141, "o", "            \"testsrc=duration=2:size=640x480:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.782639, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", inp\r\n\u001b[?2004l\r\u001b[?2004h>         ],\r\n\u001b[?2004l\r"]
[37.782825, "o", "\u001b[?2004h>         \"solve_filter\": \"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.783671, "o", "        \"output_cmd\": lambda inp, filt, out: [\r\n\u001b[?2004l\r"]
[37.783953, "o", "\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", filt,\r\n\u001b[?2004l\r"]
[37.784041, "o", "\u001b[?2004h> "]
[37.784443, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", out\r\n\u001b[?2004l\r\u001b[?2004h>         ],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.784835, "o", "        \"validate\": lambda probe: (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.785018, "o", "            probe.get(\"width\") == 320 and probe.get(\"height\") == 240\r\n\u001b[?2004l\r"]
[37.785236, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.785466, "o", "\r\n\u001b[?2004l\r \u001b[?2004h> def ensure_dirs():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.786086, "o", "    os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.786399, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.786557, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.786808, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.786938, "o", "def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.787126, "o", "    inp = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = level[\"generate_cmd\"](inp)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.78747, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\rlve\" in sys.argv:\r\n        auto_solve()\r\n    else:\r\n        interactive_mode()\r\nPYTHON_SCRIPT\r\n\u001b[?2004h> "]
[37.787583, "o", "    return inp\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.787631, "o", "def run_filter(level, filtergraph):\r\n\u001b[?2004l\r"]
[37.787783, "o", "\u001b[?2004h> "]
[37.787927, "o", "    inp = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     out = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r"]
[37.788062, "o", "\u001b[?2004h> "]
[37.788182, "o", "    cmd = level[\"output_cmd\"](inp, filtergraph, out)\r\n\u001b[?2004l\r"]
[37.788327, "o", "\u001b[?2004h> "]
[37.788517, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.78859, "o", "    return result.returncode == 0, out\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[37.788726, "o", "\u001b[?2004l\r"]
[37.788767, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.788944, "o", "def probe_file(filepath):\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.789119, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.789348, "o", "> "]
[37.789541, "o", "        \"-show_streams\", \"-show_format\", filepath\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.789645, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r"]
[37.789739, "o", "\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.789833, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.789942, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.790029, "o", "        data = json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.790123, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.790435, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h>     return data\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.790697, "o", "def extract_props(probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.790836, "o", "    \"\"\"Extract relevant properties from ffprobe output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     props = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.791166, "o", "    if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>         return props\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.791376, "o", "    for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.791608, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r"]
[37.791771, "o", "\u001b[?2004h>             props[\"width\"] = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.792045, "o", "            props[\"height\"] = stream.get(\"height\")\r\n\u001b[?2004l\r"]
[37.792099, "o", "\u001b[?2004h> "]
[37.792248, "o", "            props[\"pix_fmt\"] = stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.792333, "o", "            if \"duration\" in stream:\r\n\u001b[?2004l\r"]
[37.79248, "o", "\u001b[?2004h>                 try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.79268, "o", "                    props[\"duration\"] = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.79278, "o", "                except (ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h>                     pass\r\n"]
[37.792913, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[37.793121, "o", "        elif stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h>             if \"duration\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>                 try:\r\n\u001b[?2004l\r"]
[37.7934, "o", "\u001b[?2004h>                     props[\"duration\"] = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.793465, "o", ">                 except (ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.793609, "o", "                    pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.793741, "o", "    # Fallback to format duration if stream duration not available\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.793853, "o", "    if \"duration\" not in props and \"format\" in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.79408, "o", "            props[\"duration\"] = float(probe_data[\"format\"].get(\"duration\", 0))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.794178, "o", "        except (ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h>             pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.794325, "o", "    return props\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.794408, "o", "def validate_level(level, output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.794509, "o", "    probe_data = probe_file(output_path)\r\n\u001b[?2004l\r"]
[37.79462, "o", "\u001b[?2004h> "]
[37.79479, "o", "    if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.795032, "o", "> "]
[37.795235, "o", "    props = extract_props(probe_data)\r\n\u001b[?2004l\r\u001b[?2004h>     return level[\"validate\"](props)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[37.795305, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve():"]
[37.795463, "o", "\r\n\u001b[?2004l\r"]
[37.795482, "o", "\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r"]
[37.7955, "o", "\u001b[?2004h> "]
[37.79564, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r"]
[37.795889, "o", "\u001b[?2004h>     max_score = len(LEVELS) * 10"]
[37.795945, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.79608, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.79618, "o", "        generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.796441, "o", "        success, out_path = run_filter(level, level[\"solve_filter\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.796545, "o", "        passed = False\r\n\u001b[?2004l\r\u001b[?2004h>         if success and os.path.exists(out_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.796701, "o", "            passed = validate_level(level, out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.796772, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.796937, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797029, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797172, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797319, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797374, "o", "            \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797485, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797593, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.797641, "o", "    print(f\"Score: {total_score}/{max_score}\")"]
[37.797832, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798095, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.798165, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798278, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798481, "o", "    max_score = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r"]
[37.79858, "o", "\u001b[?2004h> "]
[37.79862, "o", "        print(f\"\\n{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798783, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798956, "o", "        print(f\"\\nDescription: {level['description']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.798987, "o", "        print(f\"Input file: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.799204, "o", "        print(f\"Output file: {level['output_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r"]
[37.799425, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[37.799524, "o", "\u001b[?2004h> "]
[37.799634, "o", "        filtergraph = input(\"Enter your filtergraph expression: \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.799773, "o", "        if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  No filter provided. FAIL\")\r\n\u001b[?2004l\r"]
[37.799818, "o", "\u001b[?2004h> "]
[37.799949, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.800069, "o", "        success, out_path = run_filter(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.800224, "o", "        if not success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.800361, "o", "            print(\"  FFmpeg failed to apply your filter. FAIL\")\r\n\u001b[?2004l\r"]
[37.800386, "o", "\u001b[?2004h> "]
[37.800787, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.800877, "o", "        passed = validate_level(level, out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.800909, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.801151, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.801369, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"\\nScore: {total_score}/{max_score}\")\r\n\u001b[?2004l\r"]
[37.801402, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.801526, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     if \"--auto-solve\" in sys.argv:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[37.80157, "o", "        auto_solve()\r\n\u001b[?2004l\r\u001b[?2004h"]
[37.801629, "o", ">     else:\r\n"]
[37.801651, "o", "\u001b[?2004l\r"]
[37.801935, "o", "\u001b[?2004h"]
[37.802117, "o", ">         interactive_mode()\r\n\u001b[?2004l\r\u001b[?2004h> PYTHON_SCRIPT\r\n\u001b[?2004l\r"]
[37.803528, "o", "\u001b[?2004hroot@e75925ef2ee3:/app# "]
[38.761068, "i", "python3 /app/ffpuzzle.py --auto-solve\n"]
[38.761515, "o", "python3 /app/ffpuzzle.py --auto-solve\r\n\u001b[?2004l\r"]
[38.796646, "o", "Level 1: Scale Down\r\n"]
[39.227142, "o", "  PASS\r\nLevel 2: Grayscale\r\n"]
[39.466652, "o", "  PASS\r\nLevel 3: Trim Audio\r\n"]
[39.626975, "o", "  PASS\r\nLevel 4: Center Crop\r\n"]
[39.974805, "o", "  PASS\r\nLevel 5: Scale and Flip\r\n"]
[40.42333, "o", "  PASS\r\nScore: 50/50\r\n"]
[40.427563, "o", "\u001b[?2004hroot@e75925ef2ee3:/app# "]
[76.071056, "i", "ls /app/assets/\n"]
[76.071594, "o", "ls /app/assets/\r\n\u001b[?2004l\r"]
[76.078687, "o", "level1_input.mp4  level2_input.avi  level3_input.wav  level4_input.mp4\tlevel5_input.mp4\r\n"]
[76.079626, "o", "\u001b[?2004hroot@e75925ef2ee3:/app# "]
[76.32323, "i", "ls /app/output/\n"]
[76.323418, "o", "ls /app/output/\r\n\u001b[?2004l\r"]
[76.325515, "o", "level1_output.mp4  level2_output.avi  level3_output.wav  level4_output.mp4  level5_output.mp4\r\n"]
[76.325796, "o", "\u001b[?2004hroot@e75925ef2ee3:/app# "]
[76.577544, "i", "cat /app/manifest.json\n"]
[76.577922, "o", "cat /app/manifest.json\r\n\u001b[?2004l\r"]
[76.579209, "o", "[\r\n  {\r\n    \"level\": 1,\r\n    \"filename\": \"level1_output.mp4\",\r\n    \"passed\": true\r\n  },\r\n  {\r\n    \"level\": 2,\r\n    \"filename\": \"level2_output.avi\",\r\n    \"passed\": true\r\n  },\r\n  {\r\n    \"level\": 3,\r\n    \"filename\": \"level3_output.wav\",\r\n    \"passed\": true\r\n  },\r\n  {\r\n    \"level\": 4,\r\n    \"filename\": \"level4_output.mp4\",\r\n    \"passed\": true\r\n  },\r\n  {\r\n    \"level\": 5,\r\n    \"filename\": \"level5_output.mp4\",\r\n    \"passed\": true\r\n  }\r\n]"]
[76.579528, "o", "\u001b[?2004hroot@e75925ef2ee3:/app# "]
