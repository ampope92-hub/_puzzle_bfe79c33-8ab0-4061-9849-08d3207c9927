[37.761563, "i", ", indent=2)\n\n\ndef interactive_mode():\n    ensure_dirs()\n    total_score = 0\n    max_score = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f\"\\n{'='*50}\")\n        print(f\"Level {level['number']}: {level['name']}\")\n        print(f\"{'='*50}\")\n        print(f\"\\nDescription: {level['description']}\")\n        print(f\"Input file: {level['input_file']}\")\n        print(f\"Output file: {level['output_file']}\")\n        print()\n\n        generate_input(level)\n\n        filtergraph = input(\"Enter your filtergraph expression: \").strip()\n        if not filtergraph:\n            print(\"  No filter provided. FAIL\")\n            continue\n\n        success, out_path = run_filter(level, filtergraph)\n        if not success:\n            print(\"  FFmpeg failed to apply your filter. FAIL\")\n            continue\n\n        passed = validate_level(level, out_path)\n        if passed:\n            total_score += 10\n            print(\"  PASS\")\n        else:\n            print(\"  FAIL\")\n\n    print(f\"\\nScore: {total_score}/{max_score}\")\n\n\nif"]
