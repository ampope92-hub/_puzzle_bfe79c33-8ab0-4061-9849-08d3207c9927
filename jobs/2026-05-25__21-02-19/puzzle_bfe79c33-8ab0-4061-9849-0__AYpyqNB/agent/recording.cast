[47.842734, "o", "> "]
[47.842828, "i", "-vf\"\n        extra = []\n        # Keep output deterministic and widely compatible.\n        if out_path.endswith(\".mp4\"):\n            extra = [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", \"-an\"]\n        elif out_path.endswith(\".avi\"):\n            # rawvideo to preserve pix_fmt exactly (required for level 2)\n            extra = [\"-c:v\", \"rawvideo\", \"-an\"]\n        cmd = [\n            \"ffmpeg\",\n            \"-y\",\n            \"-v\",\n            \"error\",\n            \"-i\",\n            in_path,\n            vf_opt,\n            filtergraph,\n            *extra,\n            out_path,\n        ]\n    else:\n        # audio\n        cmd = [\n            \"ffmpeg\",\n            \"-y\",\n            \"-v\",\n            \"error\",\n            \"-i\",\n            in_path,\n            \"-af\",\n            filtergraph,\n            out_path,\n        ]\n\n    p = run(cmd)\n    if p.returncode != 0:\n        return False, \"ffmpeg error\", p.stderr.strip()\n\n    ok, msg = level.validate_output(out_path)\n    return ok, msg, \"\"\n\n\ndef interactive(levels: List[Leve"]
