[47.892972, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.8931, "o", "\u001b[?2004h> def run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.89325, "o", ">     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.893386, "o", "    in_path = os.path.join(ASSETS_DIR, level.input_filename)\r\n\u001b[?2004l\r\u001b[?2004h>     out_path = os.path.join(OUTPUT_DIR, level.output_filename)\r\n\u001b[?2004l\r"]
[47.893464, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.893519, "o", "    # Always regenerate input for determinism.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.893539, "o", "    level.generate_input(in_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.893663, "o", "    safe_unlink(out_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.893839, "o", "\u001b[?2004h>     if level.media_type == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>         vf_opt = \"-vf\"\r\n\u001b[?2004l\r"]
[47.893897, "o", "\u001b[?2004h>         extra = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894048, "o", "        # Keep output deterministic and widely compatible.\r\n\u001b[?2004l\r\u001b[?2004h>         if out_path.endswith(\".mp4\"):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894229, "o", "            extra = [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", \"-an\"]\r\n\u001b[?2004l\r\u001b[?2004h>         elif out_path.endswith(\".avi\"):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894457, "o", "            # rawvideo to preserve pix_fmt exactly (required for level 2)\r\n\u001b[?2004l\r\u001b[?2004h>             extra = [\"-c:v\", \"rawvideo\", \"-an\"]\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894542, "o", "            \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894589, "o", "            \"-v\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894674, "o", "            \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.894729, "o", "> "]
[47.894801, "o", "            in_path,\r\n\u001b[?2004l\r\u001b[?2004h>             vf_opt,\r\n\u001b[?2004l\r\u001b[?2004h>             filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.894876, "o", "            *extra,\r\n\u001b[?2004l\r\u001b[?2004h>             out_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]"]
[47.894915, "o", "\r\n\u001b[?2004l\r"]
[47.89495, "o", "\u001b[?2004h>     else:\r\n"]
[47.894971, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.895054, "o", "        # audio\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\",\r\n\u001b[?2004l\r"]
[47.895228, "o", "\u001b[?2004h>             \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.895342, "o", "            \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>             in_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.895447, "o", "            \"-af\",\r\n\u001b[?2004l\r\u001b[?2004h>             filtergraph,\r\n\u001b[?2004l\r"]
[47.895547, "o", "\u001b[?2004h>             out_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.895562, "o", "\u001b[?2004h> "]
[47.895647, "o", "    p = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if p.returncode != 0:\r\n\u001b[?2004l\r"]
[47.895748, "o", "\u001b[?2004h>         return False, \"ffmpeg error\", p.stderr.strip()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.895813, "o", "\u001b[?2004h> "]
[47.895871, "o", "    ok, msg = level.validate_output(out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.895936, "o", "    return ok, msg, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.89599, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896011, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896078, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896101, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896202, "o", "    for lv in levels:\r\n\u001b[?2004l\r"]
[47.89626, "o", "\u001b[?2004h>         print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896314, "o", "        print(lv.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896384, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896449, "o", "            fg = input(\"Filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896501, "o", "        except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896533, "o", "            print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r"]
[47.896579, "o", "\u001b[?2004h> "]
[47.896623, "o", "        ok, vmsg, emsg = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:"]
[47.89668, "o", "\r\n\u001b[?2004l\r"]
[47.896728, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896773, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896801, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.896936, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             if emsg:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897063, "o", "                print(f\"  ffmpeg: {emsg}\")\r\n\u001b[?2004l\r\u001b[?2004h>             else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897147, "o", "                print(f\"  validate: {vmsg}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897211, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[47.897262, "o", "> "]
[47.897283, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r"]
[47.897355, "o", "\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897413, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897512, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897551, "o", "    for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897604, "o", "        print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897692, "o", "        ok, vmsg, emsg = run_level(lv, lv.autosolve_filter)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r"]
[47.897818, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897874, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.897954, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.898079, "o", "            # Keep deterministic, but provide a hint in stderr if needed\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.898135, "o", "> "]
[47.898174, "o", "            detail = emsg or vmsg\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.898276, "o", "            if detail:\r\n\u001b[?2004l\r\u001b[?2004h>                 print(f\"  {detail}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.898373, "o", "\u001b[?2004h>         manifest.append(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.898466, "o", "            {\"level\": lv.num, \"filename\": lv.output_filename, \"passed\": bool(ok)}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.898486, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.898548, "o", "\u001b[?2004h> "]
[47.898574, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.898671, "o", "\u001b[?2004h>     with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n"]
[47.898731, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[47.898842, "o", "        json.dump(manifest, f, indent=2, sort_keys=False)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.898919, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[47.89904, "o", "\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[47.899112, "o", "\u001b[?2004h> "]
[47.899166, "o", "def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899223, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r"]
[47.899246, "o", "\u001b[?2004h>     ap.add_argument(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899325, "o", "        \"--auto-solve\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899408, "o", "        action=\"store_true\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.8995, "o", "        help=\"Run all levels with known-correct solutions (CI mode)\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.8996, "o", ">     )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899632, "o", "    args = ap.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899721, "o", "    levels = build_levels()\r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899786, "o", "        return auto_solve(levels)\r\n\u001b[?2004l\r"]
[47.899854, "o", "\u001b[?2004h> "]
[47.899902, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.899952, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.900005, "o", "> PY\r\n\u001b[?2004l\r"]
