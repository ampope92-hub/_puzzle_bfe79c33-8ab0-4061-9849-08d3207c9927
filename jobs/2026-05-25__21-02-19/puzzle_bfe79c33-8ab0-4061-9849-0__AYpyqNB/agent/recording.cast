[47.892505, "o", "> "]
[47.892552, "o", "            output_filename=\"level5_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.892609, "o", "> "]
[47.892663, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
