[47.841988, "i", "!= 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level1(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, \"video\")\n    if not vs:\n        return False, \"No video stream\"\n    w, h = vs.get(\"width\"), vs.get(\"height\")\n    if w != 320 or h != 240:\n        return False, f\"Expected 320x240, got {w}x{h}\"\n    return True, \"OK\"\n\n\ndef gen_level2_input(path: str) -> None:\n    # Use AVI + rawvideo so pix_fmt is preserved exactly.\n    safe_unlink(path)\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"testsrc2=size=320x240:rate=30\",\n        \"-t\",\n        \"2\",\n        \"-c:v\",\n        \"rawvideo\",\n        \"-pix_fmt\",\n        \"yuv420p\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level2(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, \"video\")\n    if not vs:\n        return False, \"N"]
