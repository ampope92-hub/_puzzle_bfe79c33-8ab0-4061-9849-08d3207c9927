[47.842, "i", "o video stream\"\n    pix_fmt = vs.get(\"pix_fmt\")\n    if pix_fmt != \"gray\":\n        return False, f\"Expected pix_fmt gray, got {pix_fmt}\"\n    return True, \"OK\"\n\n\ndef gen_level3_input(path: str) -> None:\n    safe_unlink(path)\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n        \"-i\",\n        \"sine=frequency=440:sample_rate=48000\",\n        \"-t\",\n        \"10\",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level3(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    fmt = info.get(\"format\", {})\n    dur = to_float(fmt.get(\"duration\"))\n    if dur is None:\n        return False, \"Missing duration\"\n    if not (2.9 <= dur <= 3.1):\n        return False, f\"Expected duration ~3s, got {dur}\"\n    return True, \"OK\"\n\n\ndef gen_level4_input(path: str) -> None:\n    safe_unlink(path)\n    cmd = [\n        \"ffmpeg\",\n        \"-y\",\n        \"-v\",\n        \"error\",\n        \"-f\",\n        \"lavfi\",\n    "]
