[47.891071, "o", "            description=\"Crop the center 200x200 region from a 640x480 video.\\nEnter a video filtergraph (e.g., crop=...).\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[47.891487, "o", "            input_filename=\"level4_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[47.891517, "o", "> "]
[47.89169, "o", "            output_filename=\"level4_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
