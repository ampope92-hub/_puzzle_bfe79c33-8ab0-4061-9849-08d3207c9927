  "testsrc2=size=640x480:rate=30",\n        "-t",\n        "2",\n        "-pix_fmt",\n        "yuv420p",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level1(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, "video")\n    if not vs:\n        return False, "No video stream"\n    w, h = vs.get("width"), vs.get("height")\n    if w != 320 or h != 240:\n        return False, f"Expected 320x240, got {w}x{h}"\n    return True, "OK"\n\n\ndef gen_level2_input(path: str) -> None:\n    # Use AVI + rawvideo so pix_fmt is preserved exactly.\n    safe_unlink(path)\n    cmd = [\n        "ffmpeg",\n        "-y",\n        "-v",\n        "error",\n        "-f",\n        "lavfi",\n        "-i",\n        "testsrc2=size=320x240:rate=30",\n        "-t",\n        "2",\n        "-c:v",\n        "rawvideo",\n        "-pix_fmt",\n        "yuv420p",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level2(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, "video")\n    if not vs:\n        return False, "No video stream"\n    pix_fmt = vs.get("pix_fmt")\n    if pix_fmt != "gray":\n        return False, f"Expected pix_fmt gray, got {pix_fmt}"\n    return True, "OK"\n\n\ndef gen_level3_input(path: str) -> None:\n    safe_unlink(path)\n    cmd = [\n        "ffmpeg",\n        "-y",\n        "-v",\n        "error",\n        "-f",\n        "lavfi",\n        "-i",\n        "sine=frequency=440:sample_rate=48000",\n        "-t",\n        "10",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level3(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    fmt = info.get("format", {})\n    dur = to_float(fmt.get("duration"))\n    if dur is None:\n        return False, "Missing duration"\n    if not (2.9 <= dur <= 3.1):\n        return False, f"Expected duration ~3s, got {dur}"\n    return True, "OK"\n\n\ndef gen_level4_input(path: str) -> None:\n    safe_unlink(path)\n    cmd = [\n        "ffmpeg",\n        "-y",\n        "-v",\n        "error",\n        "-f",\n        "lavfi",\n        "-i",\n        "testsrc2=size=640x480:rate=30",\n        "-t",\n        "2",\n        "-pix_fmt",\n        "yuv420p",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level4(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, "video")\n    if not vs:\n        return False, "No video stream"\n    w, h = vs.get("width"), vs.get("height")\n    if w != 200 or h != 200:\n        return False, f"Expected 200x200, got {w}x{h}"\n    return True, "OK"\n\n\ndef gen_level5_input(path: str) -> None:\n    safe_unlink(path)\n    cmd = [\n        "ffmpeg",\n        "-y",\n        "-v",\n        "error",\n        "-f",\n        "lavfi",\n        "-i",\n        "testsrc2=size=640x480:rate=30",\n        "-t",\n        "2",\n        "-pix_fmt",\n        "yuv420p",\n        path,\n    ]\n    p = run(cmd)\n    if p.returncode != 0:\n        raise RuntimeError(p.stderr)\n\n\ndef validate_level5(path: str) -> Tuple[bool, str]:\n    info = ffprobe_json(path)\n    vs = get_first_stream(info, "video")\n    if not vs:\n        return False, "No video stream"\n    w, h = vs.get("width"), vs.get("height")\n    if w != 320 or h != 240:\n        return False, f"Expected 320x240, got {w}x{h}"\n    return True, "OK"\n\n\ndef build_levels() -> List[Level]:\n    return [\n        Level(\n            num=1,\n            name="Scale down",\n            description="Scale a 640x480 video down to 320x240.\\nEnter a video filtergraph (e.g., scale=...).",\n            input_filename="level1_input.mp4",\n            output_filename="level1_output.mp4",\n            media_type="video",\n            generate_input=gen_level1_input,\n            validate_output=validate_level1,\n            autosolve_filter="scale=320:240",\n        ),\n        Level(\n            num=2,\n            name="Grayscale",\n            description="Convert a video to grayscale. Output pixel format must be exactly gray.\\nEnter a video filtergraph (e.g., format=...).",\n            input_filename="level2_input.avi",\n            output_filename="level2_output.avi",\n            media_type="video",\n            generate_input=gen_level2_input,\n            validate_output=validate_level2,\n            autosolve_filter="format=gray",\n        ),\n        Level(\n            num=3,\n            name="Audio trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.\\nEnter an audio filtergraph (e.g., atrim=...).",\n            input_filename="level3_input.wav",\n            output_filename="level3_output.wav",\n            media_type="audio",\n            generate_input=gen_level3_input,\n            validate_output=validate_level3,\n            autosolve_filter="atrim=0:3,asetpts=N/SR/TB",\n        ),\n        Level(\n            num=4,\n            name="Center crop",\n            description="Crop the center 200x200 region from a 640x480 video.\\nEnter a video filtergraph (e.g., crop=...).",\n            input_filename="level4_input.mp4",\n            output_filename="level4_output.mp4",\n            media_type="video",\n            generate_input=gen_level4_input,\n            validate_output=validate_level4,\n            autosolve_filter="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n        ),\n        Level(\n            num=5,\n            name="Scale + hflip",\n            description="Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\\nEnter a video filtergraph.",\n            input_filename="level5_input.mp4",\n            output_filename="level5_output.mp4",\n            media_type="video",\n            generate_input=gen_level5_input,\n            validate_output=validate_level5,\n            autosolve_filter="scale=320:240,hflip",\n        ),\n    ]\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\n    ensure_dirs()\n    in_path = os.path.join(ASSETS_DIR, level.input_filename)\n    out_path = os.path.join(OUTPUT_DIR, level.output_filename)\n\n    # Always regenerate input for determinism.\n    level.generate_input(in_path)\n    safe_unlink(out_path)\n\n    if level.media_type == "video":\n        vf_opt = "-vf"\n        extra = []\n        # Keep output deterministic and widely compatible.\n        if out_path.endswith(".mp4"):\n            extra = ["-c:v", "libx264", "-pix_fmt", "yuv420p", "-an"]\n        elif out_path.endswith(".avi"):\n            # rawvideo to preserve pix_fmt exactly (required for level 2)\n            extra = ["-c:v", "rawvideo", "-an"]\n        cmd = [\n            "ffmpeg",\n            "-y",\n            "-v",\n            "error",\n            "-i",\n            in_path,\n            vf_opt,\n            filtergraph,\n            *extra,\n            out_path,\n        ]\n    else:\n        # audio\n        cmd = [\n            "ffmpeg",\n            "-y",\n            "-v",\n            "error",\n            "-i",\n            in_path,\n            "-af",\n            filtergraph,\n            out_path,\n        ]\n\n    p = run(cmd)\n    if p.returncode != 0:\n        return False, "ffmpeg error", p.stderr.strip()\n\n    ok, msg = level.validate_output(out_path)\n    return ok, msg, ""\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    total = len(levels) * 10\n    for lv in levels:\n        print(f"Level {lv.num}: {lv.name}")\n        print(lv.description)\n        try:\n            fg = input("Filtergraph> ").strip()\n        except EOFError:\n            print("\\nExiting.")\n            break\n        ok, vmsg, emsg = run_level(lv, fg)\n        if ok:\n            print("  PASS")\n            s