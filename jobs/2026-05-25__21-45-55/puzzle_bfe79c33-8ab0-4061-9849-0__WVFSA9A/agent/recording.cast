[61.946956, "o", "\u001b[?2004h> "]
[61.947265, "o", "    for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r"]
[61.94763, "o", "\u001b[?2004h> "]
[61.947952, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.948193, "o", "            return s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.948462, "o", "    return None\r\n\u001b[?2004l\r"]
[61.948702, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[61.949049, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[61.949443, "o", "def duration_seconds(probe: Dict) -> Optional[float]:\r\n\u001b[?2004l\r# Flip v\u001b[?2004h> "]
[61.950963, "o", "    # Prefer stream duration, fallback to format duration.\r\n\u001b[?2004l\r"]
[61.95109, "o", "\u001b[?2004h> "]
[61.951444, "o", "    for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.951886, "o", "        d = s.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.952309, "o", "        if d is not None:\r\n\u001b[?2004l\r"]
[61.9524, "o", "\u001b[?2004h> "]
[61.952628, "o", "            try:\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.952695, "o", "> "]
[61.952942, "o", "                return float(d)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.953193, "o", "            except ValueError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.953641, "o", "                pass\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.954072, "o", "    fmt = probe.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.954431, "o", "    d = fmt.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h>     if d is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.954645, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.954791, "o", "        return float(d)\r\n\u001b[?2004l\r\u001b[?2004h>     except ValueError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.954929, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.955001, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[61.955191, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.955463, "o", "def obf_decode(s: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Decode obfuscated solution string.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rh,\r\n            \"-fr"]
[61.955756, "o", "\u001b[?2004h>     Encoding used:\r\n\u001b[?2004l\r\u001b[?2004h>       - reverse the base64 text\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.955966, "o", "      - base64 is of UTF-8 bytes\r\n\u001b[?2004l\r"]
[61.956118, "o", "\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.956284, "o", "> "]
[61.956491, "o", "    b64 = s[::-1]\r\n\u001b[?2004l\r"]
[61.956638, "o", "\u001b[?2004h> "]
[61.956862, "o", "    return base64.b64decode(b64.encode(\"ascii\")).decode(\"utf-8\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.956904, "o", "> \r\n\u001b[?2004l\r"]
[61.957235, "o", ",\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def build_b64_rev(plain: str) -> str:"]
[61.957468, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.957637, "o", "    # Not used at runtime; helper for developers if needed.\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.957769, "o", "> "]
[61.958396, "o", "    return base64.b64encode(plain.encode(\"utf-8\")).decode(\"ascii\")[::-1]\r\n\u001b[?2004l\re-run w\u001b[?2004h"]
[61.958676, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass\r\n\u001b[?2004l\r\u001b[?2004h> class Level:\r\n\u001b[?2004l\rtes mode using subpr\u001b[?2004h>     num: int\r\n\u001b[?2004l\r"]
[61.958884, "o", "\u001b[?2004h>     name: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.959146, "o", "    description: str\r\n\u001b[?2004l\r\u001b[?2004h>     input_path: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.959275, "o", "    output_path: str\r\n\u001b[?2004l\rs\u001b[?2004h> "]
[61.959658, "o", "    input_builder: Callable[[], None]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.960041, "o", "    output_args: List[str]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.960529, "o", "    validator: Callable[[str], Tuple[bool, str]]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.960638, "o", "    # obfuscated solution string\r\n\u001b[?2004l\r\r\n   "]
[61.96126, "o", "\u001b[?2004h>     sol_obf: str\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.961338, "o", "def ffmpeg_make_input(cmd: List[str], path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.961682, "o", "    # Only generate if missing; keeps runs deterministic and fast.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.96177, "o", "    if os.path.exists(path):\r\n\u001b[?2004l\r pass on dime\u001b[?2004h> "]
[61.961995, "o", "        return\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.962252, "o", "    rc, out, err = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.962442, "o", "    if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.962714, "o", "        raise RuntimeError(f\"FFmpeg input generation failed for {path}: {err.strip()}\")\r\n\u001b[?2004l\r,\u001b[?2004h> \r\n\u001b[?2004l\r"]
[61.962761, "o", "\u001b[?2004h> "]
[61.962772, "o", "\r\n\u001b[?2004l\rl"]
[61.96303, "o", "\u001b[?2004h> "]
[61.963376, "o", "def run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\r\n   \u001b[?2004h> "]
[61.963729, "o", "    # Clean old output to avoid stale pass.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.964063, "o", "    if os.path.exists(level.output_path):\r\n\u001b[?2004l\rInput\u001b[?2004h> "]
[61.964188, "o", "        try:\r\n\u001b[?2004l\r"]
[61.964368, "o", "\u001b[?2004h> "]
[61.964567, "o", "            os.remove(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h>         except OSError:\r\n\u001b[?2004l\rvel1_input(path: str) -> None:\r\n    # \u001b[?2004h"]
[61.964692, "o", "> "]
[61.964816, "o", "            pass\r\n"]
[61.964976, "o", "\u001b[?2004l\r\u001b[?2004h"]
[61.965151, "o", "> \r\n\u001b[?2004l\r"]
[61.965276, "o", "\u001b[?2004h> "]
[61.965381, "o", "    cmd = [\r\n\u001b[?2004l\r"]
[61.965425, "o", "\u001b[?2004h>         \"ffmpeg\",\r\n\u001b[?2004l\r"]
[61.965579, "o", "d = [\r\n        \"ffm\u001b[?2004h> "]
[61.965862, "o", "        \"-hide_banner\",\r\n\u001b[?2004l\ran\u001b[?2004h>         \"-loglevel\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"error\","]
[61.966126, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         \"-y\","]
[61.966393, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.966618, "o", "        level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h>         \"-vf\" if level.num != 3 else \"-af\",\r\n\u001b[?2004l\r"]
[61.966798, "o", "\u001b[?2004h>         filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>         *level.output_args,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.966971, "o", "        level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.967157, "o", "    rc, out, err = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.967328, "o", "    if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.967622, "o", "        return False, (err.strip() or \"ffmpeg failed\")\r\n\u001b[?2004l\r"]
[61.967799, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ok, reason = level.validator(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     return ok, reason\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.967949, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.967996, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.968156, "o", "# ----------------- Validators -----------------\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[61.968213, "o", "\u001b[?2004h> "]
[61.968596, "o", "def validate_scaled_320x240(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.96863, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[61.968838, "o", "\u001b[?2004h>     vs = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.968904, "o", "    if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.969446, "o", "        return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.969684, "o", "    w = vs.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h>     h = vs.get(\"height\")\r\n\u001b[?2004l\rt\u001b[?2004h"]
[61.969768, "o", "> "]
[61.970092, "o", "    if w == 320 and h == 240:\r\n\u001b[?2004l\r"]
[61.97017, "o", "\u001b[?2004h>         return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.970181, "o", "> "]
[61.970541, "o", "    return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rm\u001b[?2004h> "]
[61.970787, "o", "def validate_gray_pixfmt(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.970927, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.971108, "o", "    vs = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.97126, "o", "    if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.971485, "o", "        return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h>     pix = vs.get(\"pix_fmt\")\r\n\u001b[?2004l\r"]
[61.971712, "o", "\u001b[?2004h>     if pix == \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.971758, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.971954, "o", "    return False, f\"expected pix_fmt gray, got {pix}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[61.97199, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972108, "o", "def validate_audio_duration_3s(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972231, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972443, "o", "    a = get_first_stream(p, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972579, "o", "    if not a:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, \"no audio stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972676, "o", "    d = duration_seconds(p)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.972837, "o", "    if d is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.973041, "o", "        return False, \"could not determine duration\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.973196, "o", "    if 2.9 <= d <= 3.1:\r\n\u001b[?2004l\r-y\",\r\n      \u001b[?2004h>         return True, \"\"\r\n\u001b[?2004l\r  \"-f\",\r\n        \"lavfi\",\u001b[?2004h> "]
[61.973439, "o", "    return False, f\"expected duration ~3s, got {d:.3f}s\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.973816, "o", "def validate_crop_200x200(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h>     vs = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>     if not vs:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, \"no video stream\""]
[61.973848, "o", "\r\n\u001b[?2004l\r"]
[61.973955, "o", "\u001b[?2004h>     w = vs.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.974111, "o", "    h = vs.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.974144, "o", "> "]
[61.974292, "o", "    if w == 200 and h == 200:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.974475, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.974787, "o", "    return False, f\"expected 200x200, got {w}x{h}\"\r\n\u001b[?2004l\r"]
[61.974941, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rli\u001b[?2004h> "]
[61.975083, "o", "def validate_scaled_flipped(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.975231, "o", "    # Strictly validate dimension; flipping is hard to validate without\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.975467, "o", "    # comparing pixels. We'll embed an asymmetric test pattern in the input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.975752, "o", "    # so we can also validate flip by sampling a couple pixels.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.975885, "o", "    p = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.975978, "o", "    vs = get_first_stream(p, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.976007, "o", "    if not vs:\r\n"]
[61.976199, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[61.976373, "o", "        return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.976547, "o", "    w = vs.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h>     h = vs.get(\"height\")\r\n\u001b[?2004l\rv420p\",\r\n        \"-t\",\r\n       \u001b[?2004h> "]
[61.976696, "o", "    if not (w == 320 and h == 240):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.976857, "o", "        return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.976977, "o", "    # Flip validation approach:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.977337, "o", "    # The level5 input is constructed so the left edge is red and right edge is blue.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.977552, "o", "    # After hflip, left should be blue-ish and right should be red-ish.\r\n\u001b[?2004l\r"]
[61.977789, "o", "\u001b[?2004h> "]
[61.978002, "o", "    # We extract two 1x1 pixels from left and right and inspect average RGB.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.978315, "o", "    def sample_rgb(x: int, y: int) -> Optional[Tuple[int, int, int]]:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.978508, "o", "            \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.97865, "o", "            \"-hide_banner\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-loglevel\","]
[61.978686, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.97887, "o", "            \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.97894, "o", "            \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979091, "o", "            \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>             path,\r\n\u001b[?2004l\ros.path.join(OUTPUT\u001b[?2004h> "]
[61.979236, "o", "            \"-frames:v\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979361, "o", "            \"1\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979492, "o", "            \"-vf\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979693, "o", "            f\"crop=1:1:{x}:{y},format=rgb24\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979843, "o", "            \"-f\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.979964, "o", "            \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.980147, "o", ">         ]\r\n\u001b[?2004l\rjoin(OUTPU\u001b[?2004h> "]
[61.980303, "o", "        rc, out, err = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.980422, "o", "        if rc != 0 or len(out) < 3:\r\n\u001b[?2004l\r"]
[61.980487, "o", "\u001b[?2004h> "]
[61.980513, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.980649, "o", "        b = out.encode(\"latin1\")\r\n\u001b[?2004l\r"]
[61.980678, "o", "\u001b[?2004h> "]
[61.98132, "o", "        # stdout is text; raw bytes might get mangled. Re-run with bytes mode using subprocess directly.\r\n\u001b[?2004l\r"]
[61.981348, "o", "\u001b[?2004h> "]
[61.981831, "o", "        p2 = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\r\n\u001b[?2004l\r"]
[61.981855, "o", "\u001b[?2004h> "]
[61.982097, "o", "        if p2.returncode != 0 or len(p2.stdout) < 3:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.982216, "o", "            return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.982457, "o", "        r, g, b = p2.stdout[0], p2.stdout[1], p2.stdout[2]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.982605, "o", "        return (r, g, b)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.982751, "o", "    left = sample_rgb(0, 0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[61.982874, "o", ">     right = sample_rgb(319, 0)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.983021, "o", "    if left is None or right is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.983251, "o", "        # If sampling fails, still allow pass on dimensions (but report why)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.983368, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.983738, "o", "    # After correct flip: left should be more blue than red; right more red than blue.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[61.983776, "o", "    lr, lg, lb = left\r\n\u001b[?2004l\r"]
[61.983889, "o", "\u001b[?2004h>     rr, rg, rb = right\r\n\u001b[?2004l\rowMjoxMjAzPWVsYWNz\"  # "]
[61.984018, "o", "\u001b[?2004h> "]
[61.984221, "o", "    if (lb > lr) and (rr > rb):\r\n\u001b[?2004l\r\u001b[?2004h>         return True, \"\"\r\n\u001b[?2004l\r  "]
[61.984324, "o", "\u001b[?2004h> "]
[61.984414, "o", "    return False, \"flip check failed\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
