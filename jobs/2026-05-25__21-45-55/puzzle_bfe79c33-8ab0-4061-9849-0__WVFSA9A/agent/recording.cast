[62.004521, "o", "\u001b[?2004h> "]
[62.004614, "o", "            sol_obf=sol5,\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h>     return levels\r\n\u001b[?2004l\r"]
[62.004634, "o", "\u001b[?2004h"]
[62.004682, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.004779, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.004886, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.004955, "o", "    for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         lv.input_builder()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.005135, "o", "        print(f\"\\nLevel {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r"]
[62.005277, "o", "\u001b[?2004h>         print(lv.description)\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             fg = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.005351, "o", "            fg = \"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.005463, "o", ">         if not fg:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.005567, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.00567, "o", "        ok, reason = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r"]
[62.005698, "o", "\u001b[?2004h> "]
[62.005778, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.005847, "o", "        else:\r\n\u001b[?2004l\r"]
[62.005864, "o", "\u001b[?2004h> "]
[62.005947, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             if reason:\r\n\u001b[?2004l\r"]
[62.006042, "o", "\u001b[?2004h> "]
[62.006063, "o", "                print(f\"  Reason: {reason}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006171, "o", "    print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006202, "o", "    return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[62.006316, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006439, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[62.006462, "o", "> "]
[62.006469, "o", "    for lv in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.0066, "o", "        lv.input_builder()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006763, "o", "        print(f\"Level {lv.num}: {lv.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006786, "o", "        fg = obf_decode(lv.sol_obf)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.006815, "o", "        ok, reason = run_level(lv, fg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.00694, "o", "        if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007063, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007192, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007278, "o", "        manifest.append({\"level\": lv.num, \"filename\": os.path.basename(lv.output_path), \"passed\": bool(ok)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007374, "o", "    print(f\"Score: {score}/{len(levels)*10}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007396, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r"]
[62.007477, "o", "\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.007601, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0 if score == len(levels) * 10 else 1\r\n\u001b[?2004l\r"]
[62.00768, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def main(argv: List[str]) -> int:\r\n"]
[62.00777, "o", "\u001b[?2004l\r\u001b[?2004h"]
[62.007837, "o", "> "]
[62.007926, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.008135, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run all levels with built-in solutions\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[62.008246, "o", "    args = ap.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r"]
[62.008374, "o", "\u001b[?2004h>     levels = make_levels()"]
[62.008488, "o", "\r\n\u001b[?2004l\r"]
[62.008595, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[62.008707, "o", ">     if args.auto_solve:\r\n\u001b[?2004l\r"]
[62.008755, "o", "\u001b[?2004h> "]
[62.008822, "o", "        return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h>     return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[62.008995, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[62.009243, "o", "\u001b[?2004h> "]
[62.009383, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[62.009462, "o", "\u001b[?2004h"]
[62.009523, "o", "> "]
[62.009626, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
