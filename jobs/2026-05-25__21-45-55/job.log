def build_b64_rev(plain: str) -> str:\n    # Not used at runtime; helper for developers if needed.\n    return base64.b64encode(plain.encode("utf-8")).decode("ascii")[::-1]\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_path: str\n    output_path: str\n    input_builder: Callable[[], None]\n    output_args: List[str]\n    validator: Callable[[str], Tuple[bool, str]]\n    # obfuscated solution string\n    sol_obf: str\n\n\ndef ffmpeg_make_input(cmd: List[str], path: str) -> None:\n    # Only generate if missing; keeps runs deterministic and fast.\n    if os.path.exists(path):\n        return\n    rc, out, err = run(cmd)\n    if rc != 0:\n        raise RuntimeError(f"FFmpeg input generation failed for {path}: {err.strip()}")\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    # Clean old output to avoid stale pass.\n    if os.path.exists(level.output_path):\n        try:\n            os.remove(level.output_path)\n        except OSError:\n            pass\n\n    cmd = [\n        "ffmpeg",\n        "-hide_banner",\n        "-loglevel",\n        "error",\n        "-y",\n        "-i",\n        level.input_path,\n        "-vf" if level.num != 3 else "-af",\n        filtergraph,\n        *level.output_args,\n        level.output_path,\n    ]\n    rc, out, err = run(cmd)\n    if rc != 0:\n        return False, (err.strip() or "ffmpeg failed")\n\n    ok, reason = level.validator(level.output_path)\n    return ok, reason\n\n\n# ----------------- Validators -----------------\n\ndef validate_scaled_320x240(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    vs = get_first_stream(p, "video")\n    if not vs:\n        return False, "no video stream"\n    w = vs.get("width")\n    h = vs.get("height")\n    if w == 320 and h == 240:\n        return True, ""\n    return False, f"expected 320x240, got {w}x{h}"\n\n\ndef validate_gray_pixfmt(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    vs = get_first_stream(p, "video")\n    if not vs:\n        return False, "no video stream"\n    pix = vs.get("pix_fmt")\n    if pix == "gray":\n        return True, ""\n    return False, f"expected pix_fmt gray, got {pix}"\n\n\ndef validate_audio_duration_3s(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    a = get_first_stream(p, "audio")\n    if not a:\n        return False, "no audio stream"\n    d = duration_seconds(p)\n    if d is None:\n        return False, "could not determine duration"\n    if 2.9 <= d <= 3.1:\n        return True, ""\n    return False, f"expected duration ~3s, got {d:.3f}s"\n\n\ndef validate_crop_200x200(path: str) -> Tuple[bool, str]:\n    p = ffprobe_json(path)\n    vs = get_first_stream(p, "video")\n    if not vs:\n        return False, "no video stream"\n    w = vs.get("width")\n    h = vs.get("height")\n    if w == 200 and h == 200:\n        return True, ""\n    return False, f"expected 200x200, got {w}x{h}"\n\n\ndef validate_scaled_flipped(path: str) -> Tuple[bool, str]:\n    # Strictly validate dimension; flipping is hard to validate without\n    # comparing pixels. We\'ll embed an asymmetric test pattern in the input\n    # so we can also validate flip by sampling a couple pixels.\n    p = ffprobe_json(path)\n    vs = get_first_stream(p, "video")\n    if not vs:\n        return False, "no video stream"\n    w = vs.get("width")\n    h = vs.get("height")\n    if not (w == 320 and h == 240):\n        return False, f"expected 320x240, got {w}x{h}"\n\n    # Flip validation approach:\n    # The level5 input is constructed so the left edge is red and right edge is blue.\n    # After hflip, left should be blue-ish and right should be red-ish.\n    # We extract two 1x1 pixels from left and right and inspect average RGB.\n    def sample_rgb(x: int, y: int) -> Optional[Tuple[int, int, int]]:\n        cmd = [\n            "ffmpeg",\n            "-hide_banner",\n            "-loglevel",\n            "error",\n            "-y",\n            "-i",\n            path,\n            "-frames:v",\n            "1",\n            "-vf",\n            f"crop=1:1:{x}:{y},format=rgb24",\n            "-f",\n            "rawvideo",\n            "-",\n        ]\n        rc, out, err = run(cmd)\n        if rc != 0 or len(out) < 3:\n            return None\n        b = out.encode("latin1")\n        # stdout is text; raw bytes might get mangled. Re-run with bytes mode using subprocess directly.\n        p2 = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n        if p2.returncode != 0 or len(p2.stdout) < 3:\n            return None\n        r, g, b = p2.stdout[0], p2.stdout[1], p2.stdout[2]\n        return (r, g, b)\n\n    left = sample_rgb(0, 0)\n    right = sample_rgb(319, 0)\n    if left is None or right is None:\n        # If sampling fails, still allow pass on dimensions (but report why)\n        return True, ""\n\n    # After correct flip: left should be more blue than red; right more red than blue.\n    lr, lg, lb = left\n    rr, rg, rb = right\n    if (lb > lr) and (rr > rb):\n        return True, ""\n    return False, "flip check failed"\n\n\n# ----------------- Input builders -----------------\n\ndef build_level1_input(path: str) -> None:\n    # 640x480, 2s, synthetic.\n    cmd = [\n        "ffmpeg",\n        "-hide_banner",\n        "-loglevel",\n        "error",\n        "-y",\n        "-f",\n        "lavfi",\n        "-i",\n        "testsrc2=size=640x480:rate=30",\n        "-t",\n        "2",\n        "-pix_fmt",\n        "yuv420p",\n        "-c:v",\n        "libx264",\n        "-crf",\n        "18",\n        "-preset",\n        "veryfast",\n        path,\n    ]\n    ffmpeg_make_input(cmd, path)\n\n\ndef build_level2_input(path: str) -> None:\n    # 640x480, 2s. Use a standard color source; output in avi rawvideo to keep pix_fmt explicit.\n    cmd = [\n        "ffmpeg",\n        "-hide_banner",\n        "-loglevel",\n        "error",\n        "-y",\n        "-f",\n        "lavf