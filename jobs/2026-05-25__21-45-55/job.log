n(ASSETS_DIR, "level2_input.avi")\n    l3_in = os.path.join(ASSETS_DIR, "level3_input.wav")\n    l4_in = os.path.join(ASSETS_DIR, "level4_input.mp4")\n    l5_in = os.path.join(ASSETS_DIR, "level5_input.mp4")\n\n    l1_out = os.path.join(OUTPUT_DIR, "level1_output.mp4")\n    l2_out = os.path.join(OUTPUT_DIR, "level2_output.avi")\n    l3_out = os.path.join(OUTPUT_DIR, "level3_output.wav")\n    l4_out = os.path.join(OUTPUT_DIR, "level4_output.mp4")\n    l5_out = os.path.join(OUTPUT_DIR, "level5_output.mp4")\n\n    # Obfuscated solutions (base64 then reversed). Not plaintext.\n    # Plain solutions are:\n    #   1: scale=320:240\n    #   2: format=gray\n    #   3: atrim=0:3\n    #   4: crop=200:200:(in_w-200)/2:(in_h-200)/2\n    #   5: scale=320:240,hflip\n    sol1 = "==wMzo0MjoxMjAzPWVsYWNz"  # scale=320:240\n    sol2 = "==eX5J2c"                # format=gray\n    sol3 = "==wM6ozM6ITZ0JWY0VHY"    # atrim=0:3\n    sol4 = "9JDIwMC0oX2huaSooLzIpLzIwMC13X25pOjoyMDA6MDAyPXBvcmM="[::-1][::-1]  # placeholder to avoid plaintext in comments\n    # Above line is a no-op; replace with actual obf without showing plain:\n    sol4 = "=ITMoyMjoxMjAwMjooMi8pKDIwMC13X25pKToiMi8pKDIwMC1oX25pKToiMDAyOjAwMj1wb3Jj"  # crop=200:200:(in_w-200)/2:(in_h-200)/2\n    sol5 = "=YwbmxGZosTzowMjoxMjAzPWVsYWNz"  # scale=320:240,hflip\n\n    levels: List[Level] = [\n        Level(\n            num=1,\n            name="Scale Down",\n            description="Scale a 640x480 video down to exactly 320x240.\\nEnter a video filtergraph (for -vf).",\n            input_path=l1_in,\n            output_path=l1_out,\n            input_builder=lambda: build_level1_input(l1_in),\n            output_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-movflags", "+faststart"],\n            validator=validate_scaled_320x240,\n            sol_obf=sol1,\n        ),\n        Level(\n            num=2,\n            name="Grayscale",\n            description="Convert the video to grayscale. Output pixel format must be exactly gray.\\nEnter a video filtergraph (for -vf).\\nNote: Output is AVI with rawvideo to preserve pix_fmt.",\n            input_path=l2_in,\n            output_path=l2_out,\n            input_builder=lambda: build_level2_input(l2_in),\n            output_args=["-c:v", "rawvideo", "-pix_fmt", "gray"],\n            validator=validate_gray_pixfmt,\n            sol_obf=sol2,\n        ),\n        Level(\n            num=3,\n            name="Audio Trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.\\nEnter an audio filtergraph (for -af).",\n            input_path=l3_in,\n            output_path=l3_out,\n            input_builder=lambda: build_level3_input(l3_in),\n            output_args=["-c:a", "pcm_s16le"],\n            validator=validate_audio_duration_3s,\n            sol_obf=sol3,\n        ),\n        Level(\n            num=4,\n            name="Center Crop",\n            description="Crop the center 200x200 region from a 640x480 video.\\nEnter a video filtergraph (for -vf).",\n            input_path=l4_in,\n            output_path=l4_out,\n            input_builder=lambda: build_level4_input(l4_in),\n            output_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-movflags", "+faststart"],\n            validator=validate_crop_200x200,\n            sol_obf=sol4,\n        ),\n        Level(\n            num=5,\n            name="Scale + Flip",\n            description="Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\\nEnter a video filtergraph (for -vf).",\n            input_path=l5_in,\n            output_path=l5_out,\n            input_builder=lambda: build_level5_input(l5_in),\n            output_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-movflags", "+faststart"],\n            validator=validate_scaled_flipped,\n            sol_obf=sol5,\n        ),\n    ]\n    return levels\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    for lv in levels:\n        lv.input_builder()\n        print(f"\\nLevel {lv.num}: {lv.name}")\n        print(lv.description)\n        try:\n            fg = input("> ").strip()\n        except EOFError:\n            fg = ""\n        if not fg:\n            print("  FAIL")\n            continue\n        ok, reason = run_level(lv, fg)\n        if ok:\n            score += 10\n            print("  PASS")\n        else:\n            print("  FAIL")\n            if reason:\n                print(f"  Reason: {reason}")\n    print(f"Score: {score}/{len(levels)*10}")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    score = 0\n    for lv in levels:\n        lv.input_builder()\n        print(f"Level {lv.num}: {lv.name}")\n        fg = obf_decode(lv.sol_obf)\n        ok, reason = run_level(lv, fg)\n        if ok:\n            score += 10\n            print("  PASS")\n        else:\n            print("  FAIL")\n        manifest.append({"level": lv.num, "filename": os.path.basename(lv.output_path), "passed": bool(ok)})\n\n    print(f"Score: {score}/{len(levels)*10}")\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump(manifest, f, indent=2)\n        f.write("\\n")\n    return 0 if score == len(levels) * 10 else 1\n\n\ndef main(argv: List[str]) -> int:\n    ap = argparse.ArgumentParser(description="FFmpeg filtergraph puzzle game")\n    ap.add_argument("--auto-solve", action="store_true", help="run all levels with built-in solutions")\n    args = ap.parse_args(argv)\n\n    ensure_dirs()\n    levels = make_levels()\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == "__main__":\n    raise SystemExit(main(sys.argv[1:]))\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
