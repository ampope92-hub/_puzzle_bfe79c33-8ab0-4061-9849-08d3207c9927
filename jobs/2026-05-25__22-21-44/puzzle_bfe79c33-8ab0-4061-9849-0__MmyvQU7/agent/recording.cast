[646.220743, "i", "5_output.mp4\", 320, 240),\n    },\n]\n\n\ndef ensure_dirs():\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef gen_video_input(filename, width, height, duration, fmt):\n    output_path = os.path.join(ASSETS_DIR, filename)\n    if fmt == \"avi\":\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\n            \"-c:v\", \"rawvideo\", output_path\n        ]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", output_path\n        ]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return output_path\n\n\ndef gen_audio_input(filename, duration):\n    output_path = os.path.join(ASSETS_DIR, filename)\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n        f\"sine=frequency=440:duration={duration}\",\n        ou"]
