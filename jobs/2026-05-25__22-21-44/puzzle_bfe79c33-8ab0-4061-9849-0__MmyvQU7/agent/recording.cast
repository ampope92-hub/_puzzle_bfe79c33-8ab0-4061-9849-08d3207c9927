[729.267468, "o", "\u001b[?2004h> "]
[729.267844, "o", "    if fmt == \"avi\":\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r      else:\r\n    "]
