[729.23845, "i", "sion\",\n        \"description\": \"Convert a video to grayscale (output pixel format must be 'gray'). Output uses .avi container with rawvideo codec.\",\n        \"input_file\": \"level2_input.avi\",\n        \"output_file\": \"level2_output.avi\",\n        \"gen_input\": lambda: gen_video_input(\"level2_input.avi\", 640, 480, 3, \"avi\"),\n        \"ffmpeg_extra_args\": [\"-c:v\", \"rawvideo\"],\n        \"validate\": lambda: validate_pixel_format(\"level2_output.avi\", \"gray\"),\n    },\n    {\n        \"number\": 3,\n        \"name\": \"Audio Trim\",\n        \"description\": \"Trim a 10-second audio clip to exactly 3 seconds.\",\n        \"input_file\": \"level3_input.wav\",\n        \"output_file\": \"level3_output.wav\",\n        \"gen_input\": lambda: gen_audio_input(\"level3_input.wav\", 10),\n        \"ffmpeg_extra_args\": [],\n        \"validate\": lambda: validate_audio_duration(\"level3_output.wav\", 2.9, 3.1),\n    },\n    {\n        \"number\": 4,\n        \"name\": \"Center Crop\",\n        \"description\": \"Crop the center 200x200 region from a 640x480 video.\",\n        \"input_f"]
[729.238458, "i", "ile\": \"level4_input.mp4\",\n        \"output_file\": \"level4_output.mp4\",\n        \"gen_input\": lambda: gen_video_input(\"level4_input.mp4\", 640, 480, 3, \"mp4\"),\n        \"ffmpeg_extra_args\": [],\n        \"validate\": lambda: validate_video_dimensions(\"level4_output.mp4\", 200, 200),\n    },\n    {\n        \"number\": 5,\n        \"name\": \"Scale and Flip\",\n        \"description\": \"Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\",\n        \"input_file\": \"level5_input.mp4\",\n        \"output_file\": \"level5_output.mp4\",\n        \"gen_input\": lambda: gen_video_input(\"level5_input.mp4\", 640, 480, 3, \"mp4\"),\n        \"ffmpeg_extra_args\": [],\n        \"validate\": lambda: validate_video_dimensions(\"level5_output.mp4\", 320, 240),\n    },\n]\n\n\ndef ensure_dirs():\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef gen_video_input(filename, width, height, duration, fmt):\n    output_path = os.path.join(ASSETS_DIR, filename)\n    if fmt == \"avi\":\n        cmd = [\n            \"ffmpeg\", \""]
[729.238462, "i", "-y\", \"-f\", \"lavfi\", \"-i\",\n            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\n            \"-c:v\", \"rawvideo\", output_path\n        ]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", output_path\n        ]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return output_path\n\n\ndef gen_audio_input(filename, duration):\n    output_path = os.path.join(ASSETS_DIR, filename)\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n        f\"sine=frequency=440:duration={duration}\",\n        output_path\n    ]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return output_path\n\n\ndef run_ffmpeg_filter(input_path, output_path, filtergraph, extra_args=None, is_audio=False):\n    cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\n    if is_audio:\n        cmd += [\"-af\", filtergr"]
[729.23861, "i", "aph]\n    else:\n        cmd += [\"-vf\", filtergraph]\n    if extra_args:\n        cmd += extra_args\n    cmd += [output_path]\n    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\n    return result.returncode == 0\n\n\ndef probe_file(filepath):\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \"-show_format\", \"-show_streams\", filepath\n    ]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        return None\n    return json.loads(result.stdout)\n\n\ndef validate_video_dimensions(filename, expected_w, expected_h):\n    filepath = os.path.join(OUTPUT_DIR, filename)\n    info = probe_file(filepath)\n    if not info:\n        return False\n    for stream in info.get(\"streams\", []):\n        if stream.get(\"codec_type\") == \"video\":\n            w = stream.get(\"width\")\n            h = stream.get(\"height\")\n            return w == expected_w and h == expected_h\n    return False\n\n\ndef validate_pixel_format(filename, expected_fmt"]
