[646.247513, "o", "            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\r\n\u001b[?2004l\r"]
[646.248114, "o", "\u001b[?2004h> "]
[646.248705, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.248906, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.249782, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.250709, "o", "    return output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.251313, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r(\u001b[?2004h> def gen_audio_input(filename, duration):\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.251547, "o", "> "]
[646.251909, "o", "    output_path = os.path.join(ASSETS_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.252423, "o", "        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.252592, "o", "        f\"sine=frequency=440:duration={duration}\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.25273, "o", "        output_path\r\n\u001b[?2004l\r(\u001b[?2004h> "]
[646.252992, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.253608, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h>     return output_path\r\n\u001b[?2004l\r"]
[646.25365, "o", "\u001b[?2004h> "]
[646.253807, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.254244, "o", "def run_ffmpeg_filter(input_path, output_path, filtergraph, extra_args=None, is_audio=False):\r\n\u001b[?2004l\r"]
[646.254444, "o", "\u001b[?2004h> "]
[646.25455, "o", "    cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\r\n\u001b[?2004l\r\u001b[?2004h>     if is_audio:"]
[646.254645, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.254858, "o", "        cmd += [\"-af\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.255153, "o", "        cmd += [\"-vf\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h>     if extra_args:\r\n\u001b[?2004l\r your"]
[646.255284, "o", "\u001b[?2004h> "]
[646.255686, "o", "        cmd += extra_args\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.255828, "o", "    cmd += [output_path]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.256284, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.256662, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rve\u001b[?2004h> def probe_file(filepath):\r\n\u001b[?2004l\rr\"],\r\n             "]
[646.256752, "o", "\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\rname\u001b[?2004h"]
[646.256955, "o", "> "]
[646.257157, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\","]
[646.257295, "o", "\r\n\u001b[?2004l\r"]
[646.257469, "o", "\u001b[?2004h> "]
[646.257662, "o", "        \"-show_format\", \"-show_streams\", filepath\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.257897, "o", ">     ]\r\n\u001b[?2004l\rnue\r\n  \u001b[?2004h> "]
[646.258078, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r"]
[646.258132, "o", "\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r"]
[646.258376, "o", "\u001b[?2004h> "]
[646.258528, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.259013, "o", "    return json.loads(result.stdout)\r\n\u001b[?2004l\r       total_score += 10\r\n        else:\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\r\n \u001b[?2004h> def validate_video_dimensions(filename, expected_w, expected_h):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.259211, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.25938, "o", "    info = probe_file(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.259547, "o", "    if not info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.259757, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.260024, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r"]
[646.260122, "o", "\u001b[?2004h> "]
[646.260274, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.260512, "o", "            w = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.260562, "o", "            h = stream.get(\"height\")\r\n\u001b[?2004l\r"]
[646.260959, "o", "\u001b[?2004h>             return w == expected_w and h == expected_h\r\n\u001b[?2004l\r\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[646.261139, "o", "> "]
[646.261243, "o", "def validate_pixel_format(filename, expected_fmt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.261633, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r"]
[646.261669, "o", "\u001b[?2004h> "]
[646.261942, "o", "    info = probe_file(filepath)\r\n\u001b[?2004l\r\u001b[?2004h>     if not info:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.262215, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.262443, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.262479, "o", "            pix_fmt = stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.262603, "o", "            return pix_fmt == expected_fmt\r\n"]
[646.262662, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[646.262953, "o", "    return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.263049, "o", "def validate_audio_duration(filename, min_dur, max_dur):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.263179, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.26329, "o", "    info = probe_file(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.26347, "o", "    if not info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.263576, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.263728, "o", "    duration = None\r\n\u001b[?2004l\r\u001b[?2004h>     # Try format duration first\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.263861, "o", "    fmt_dur = info.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.263965, "o", "> "]
[646.264062, "o", "    if fmt_dur:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.264093, "o", "        duration = float(fmt_dur)\r\n\u001b[?2004l\r"]
[646.264267, "o", "\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.26441, "o", "        # Try stream duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.264577, "o", "        for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.264682, "o", "            if stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.264715, "o", "                dur = stream.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.264905, "o", "                if dur:\r\n\u001b[?2004l\r\u001b[?2004h>                     duration = float(dur)\r\n\u001b[?2004l\r"]
[646.265183, "o", "\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>     if duration is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.26539, "o", "    return min_dur <= duration <= max_dur\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.265537, "o", "def get_solution(level_idx):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.265656, "o", "    return _decode_solution(SOLUTIONS_ENCODED[level_idx])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.265885, "o", "def run_level(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.265978, "o", "    \"\"\"Run a single level with given filtergraph. Returns True if passed.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.2661, "o", "    # Generate input\r\n\u001b[?2004l\r\u001b[?2004h>     level[\"gen_input\"]()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[646.266181, "o", "> "]
[646.266448, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.266669, "o", "    # Determine if audio level\r\n\u001b[?2004l\r\u001b[?2004h>     is_audio = level[\"number\"] == 3\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[646.266708, "o", "\u001b[?2004h>     # Run ffmpeg with the filtergraph"]
[646.266801, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.267044, "o", "    success = run_ffmpeg_filter(\r\n\u001b[?2004l\r\u001b[?2004h>         input_path, output_path, filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.267196, "o", "        extra_args=level[\"ffmpeg_extra_args\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.267311, "o", "        is_audio=is_audio\r\n\u001b[?2004l\r\u001b[?2004h>     )\r\n\u001b[?2004l\r\u001b[?2004h>     "]
[646.267433, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     if not success:\r\n\u001b[?2004l\r"]
[646.267794, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Validate output\r\n\u001b[?2004l\r\u001b[?2004h>     return level[\"validate\"]()\r\n\u001b[?2004l\r"]
[646.268017, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.268105, "o", "    \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.268247, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.268457, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[646.268564, "o", "\u001b[?2004h>     for i, level in enumerate(LEVELS):\r\n\u001b[?2004l\r"]
[646.268646, "o", "\u001b[?2004h>         solution = get_solution(i)\r\n\u001b[?2004l\r"]
[646.268829, "o", "\u001b[?2004h>         print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[646.268903, "o", "\u001b[?2004h> "]
[646.269021, "o", "        passed = run_level(level, solution)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r"]
[646.269186, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r"]
[646.269364, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[646.269436, "o", "\u001b[?2004h> "]
[646.269473, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.269597, "o", "            \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.269817, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[646.270019, "o", "\u001b[?2004h>     print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.270095, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.270216, "o", "> "]
[646.270358, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.270586, "o", "    \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r"]
[646.270857, "o", "\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\" * 50)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.270973, "o", "    print(\"  FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\" * 50)\r\n\u001b[?2004l\r"]
[646.270998, "o", "\u001b[?2004h> "]
[646.2711, "o", "    print()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.271244, "o", "    for i, level in enumerate(LEVELS):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.271348, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  {level['description']}\")\r\n\u001b[?2004l\r"]
[646.271376, "o", "\u001b[?2004h> "]
[646.271514, "o", "        print(f\"  Input: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[646.271573, "o", "> "]
[646.271838, "o", "        print(f\"  Output: {level['output_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.271996, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         filtergraph = input(\"Enter your filtergraph expression: \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[646.272053, "o", "\u001b[?2004h>         if not filtergraph:\r\n\u001b[?2004l\r"]
[646.27209, "o", "\u001b[?2004h> "]
[646.272274, "o", "            print(\"  FAIL (empty input)\")\r\n\u001b[?2004l\r\u001b[?2004h>             manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.272463, "o", "                \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h>                 \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.272493, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.272568, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.27264, "o", "            print()\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.272859, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         passed = run_level(level, filtergraph)\r\n\u001b[?2004l\r"]
[646.273062, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.273153, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.273223, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.27328, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.273414, "o", "            \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[646.273607, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r"]
