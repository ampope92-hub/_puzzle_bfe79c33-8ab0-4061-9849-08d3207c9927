[729.239197, "o", "\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\rt\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> import sys\r\n\u001b[?2004l\r\u001b[?2004h> import json\r\n\u001b[?2004l\r\u001b[?2004h> import subprocess\r\n\u001b[?2004l\r extra_args\r\n    cmd += [outp\u001b[?2004h> import base64\r\n\u001b[?2004l\r\u001b[?2004h> import argparse\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.239229, "i", "NCODED[level_idx])\n\n\ndef run_level(level, filtergraph):\n    \"\"\"Run a single level with given filtergraph. Returns True if passed.\"\"\"\n    level[\"gen_input\"]()\n\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n\n    is_audio = level[\"number\"] == 3\n\n    success = run_ffmpeg_filter(\n        input_path, output_path, filtergraph,\n        extra_args=level[\"ffmpeg_extra_args\"],\n        is_audio=is_audio\n    )\n\n    if not success:\n        return False\n\n    return level[\"validate\"]()\n\n\ndef auto_solve():\n    \"\"\"Run all levels with known correct solutions.\"\"\"\n    ensure_dirs()\n    manifest = []\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    for i, level in enumerate(LEVELS):\n        solution = get_solution(i)\n        print(f\"Level {level['number']}: {level['name']}\")\n\n        passed = run_level(level, solution)\n\n        if passed:\n            print(\"  PASS\")\n            total_score += 10\n        else:\n            print(\"  FAIL\")"]
