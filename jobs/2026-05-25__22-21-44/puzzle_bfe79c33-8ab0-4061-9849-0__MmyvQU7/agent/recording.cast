[646.216316, "i", "cat > /app/ffpuzzle.py << 'PYTHON_EOF'\n#!/usr/bin/env python3\nimport os\nimport sys\nimport json\nimport subprocess\nimport base64\nimport argparse\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n# Solutions are base64-encoded and reversed to avoid plaintext exposure\ndef _encode_solution(s):\n    return base64.b64encode(s[::-1].encode()).decode()\n\ndef _decode_solution(s):\n    return base64.b64decode(s.encode()).decode()[::-1]\n\n# Obfuscated solutions (reversed then base64 encoded)\nSOLUTIONS_ENCODED = [\n    _encode_solution(\"scale=320:240\"),\n    _encode_solution(\"format=gray\"),\n    _encode_solution(\"atrim=0:3\"),\n    _encode_solution(\"crop=200:200\"),\n    _encode_solution(\"scale=320:240,hflip\"),\n]\n\n# Remove the helper that reveals the encoding scheme\n# Solutions are stored as pre-computed base64 strings\n\nLEVELS = [\n    {\n        \"number\": 1,\n        \"name\": \"Scale Down\",\n        \"description\": \"Scale a 640x480 video down to 320x240.\",\n        \"input_file\": \"level1_input.mp4\""]
