[729.269038, "o", "            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.270558, "o", "            \"-c:v\", \"rawvideo\", output_path\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.271078, "o", "            f\"testsrc=size={width}x{height}:duration={duration}:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.271721, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", output_path\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h>     subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
