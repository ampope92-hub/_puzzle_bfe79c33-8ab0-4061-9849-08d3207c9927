[729.272488, "o", "\u001b[?2004h> "]
[729.272552, "o", "    output_path = os.path.join(ASSETS_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[729.27289, "o", ">     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.273261, "o", "        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.273566, "o", "        f\"sine=frequency=440:duration={duration}\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.273817, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.27409, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.27443, "o", "    return output_path\r\n\u001b[?2004l\r"]
[729.274487, "o", "\u001b[?2004h> "]
[729.274626, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[729.274775, "o", "\u001b[?2004h> "]
[729.275414, "o", "def run_ffmpeg_filter(input_path, output_path, filtergraph, extra_args=None, is_audio=False):\r\n\u001b[?2004l\r"]
[729.275479, "o", "\u001b[?2004h> "]
[729.275928, "o", "    cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.27609, "o", "    if is_audio:\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[729.276418, "o", "        cmd += [\"-af\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h"]
[729.276682, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.276965, "o", "        cmd += [\"-vf\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.277053, "o", "    if extra_args:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd += extra_args\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.277603, "o", "    cmd += [output_path]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.27826, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.278871, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> def probe_file(filepath):\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.279636, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-show_format\", \"-show_streams\", filepath\r\n\u001b[?2004l\rle\u001b[?2004h>     ]\r\n\u001b[?2004l\rname\":\u001b[?2004h> "]
[729.281462, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.284672, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h>     return json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_video_dimensions(filename, expected_w, expected_h):\r\n\u001b[?2004l\r\u001b[?2004h>     filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h>     info = probe_file(filepath)\r\n\u001b[?2004l\r\u001b[?2004h>     if not info:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.285083, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.285477, "o", "            w = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.285729, "o", "            h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.285872, "o", "            return w == expected_w and h == expected_h\r\n\u001b[?2004l\r"]
[729.286072, "o", "\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rn\u001b[?2004h"]
[729.286224, "o", "> "]
[729.286384, "o", "def validate_pixel_format(filename, expected_fmt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.286411, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r"]
[729.286603, "o", "\u001b[?2004h> "]
[729.286942, "o", "    info = probe_file(filepath)\r\n\u001b[?2004l\r"]
[729.287246, "o", "\u001b[?2004h>     if not info:\r\n"]
[729.28741, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[729.287561, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.287825, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.2881, "o", "            pix_fmt = stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h>             return pix_fmt == expected_fmt\r\n\u001b[?2004l\r"]
[729.28825, "o", "\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.288429, "o", "def validate_audio_duration(filename, min_dur, max_dur):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.288571, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.288712, "o", "    info = probe_file(filepath)\r\n\u001b[?2004l\r\u001b[?2004h>     if not info:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[729.288817, "o", "\u001b[?2004h> "]
[729.288962, "o", "    duration = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.28901, "o", "    fmt_dur = info.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r"]
[729.289238, "o", "\u001b[?2004h>     if fmt_dur:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.289451, "o", "        duration = float(fmt_dur)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.289492, "o", "        for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.28972, "o", "            if stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.289954, "o", "                dur = stream.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h>                 if dur:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.290146, "o", "                    duration = float(dur)\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.290249, "o", "    if duration is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.290362, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.290545, "o", "    return min_dur <= duration <= max_dur\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[729.290741, "o", "\u001b[?2004h> def get_solution(level_idx):\r\n\u001b[?2004l\r"]
[729.290926, "o", "\u001b[?2004h>     return _decode_solution(SOLUTIONS_ENCODED[level_idx])\r\n\u001b[?2004l\r"]
[729.291165, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def run_level(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.291505, "o", "    \"\"\"Run a single level with given filtergraph. Returns True if passed.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     level[\"gen_input\"]()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[729.291681, "o", "\u001b[?2004h> "]
[729.291889, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.292059, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.292172, "o", "    is_audio = level[\"number\"] == 3\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     success = run_ffmpeg_filter(\r\n\u001b[?2004l\r"]
[729.292335, "o", "\u001b[?2004h> "]
[729.292449, "o", "        input_path, output_path, filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.292593, "o", "        extra_args=level[\"ffmpeg_extra_args\"],\r\n\u001b[?2004l\r\u001b[?2004h>         is_audio=is_audio\r\n\u001b[?2004l\r"]
[729.292745, "o", "\u001b[?2004h>     )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if not success:\r\n\u001b[?2004l\r"]
[729.292903, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[729.293044, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.293161, "o", "    return level[\"validate\"]()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.293375, "o", "def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[729.293529, "o", "> "]
[729.293567, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.293765, "o", "    total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.293946, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.294178, "o", "    for i, level in enumerate(LEVELS):\r\n\u001b[?2004l\r\u001b[?2004h>         solution = get_solution(i)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.294267, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.294385, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.294546, "o", "        passed = run_level(level, solution)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r"]
[729.294665, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[729.294771, "o", ">             total_score += 10\r\n\u001b[?2004l\r"]
[729.294863, "o", "\u001b[?2004h> "]
[729.294897, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[729.295, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
