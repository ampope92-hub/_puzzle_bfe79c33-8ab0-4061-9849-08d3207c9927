[?2004l[?2004h> def auto_solve():
[?2004l[?2004h>     """Run all levels with known correct solutions."""
[?2004l[?2004h>     ensure_dirs()
[?2004l[?2004h>     manifest = []
[?2004l[?2004h>     score = 0
[?2004l[?2004h>     total = len(LEVELS) * 10
[?2004l[?2004h> 
[?2004l[?2004h>     for level_info in LEVELS:
[?2004l[?2004h>         lvl = level_info["level"]
[?2004l[?2004h>         print(f"Level {lvl}: {level_info['name']}")
[?2004l[?2004h> 
[?2004l[?2004h>         # Generate input
[?2004l[?2004h>         if not generate_input(level_info):
[?2004l[?2004h>             print("  FAIL")
[?2004l[?2004h>             manifest.append({"level": lvl, "filename": level_info["output_file"], "passed": False})
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         # Get solution and run
[?2004l[?2004h>         solution = get_solution(lvl)
[?2004l[?2004h>         success = run_filtergraph(level_info, solution)
[?2004l[?2004h> 
[?2004l[?2004h>         if success:
[?2004l[?2004h>             # Validate
[?2004l[?2004h>             passed = level_info["validate"]()
[?2004l[?2004h>         else:
[?2004l[?2004h>             passed = False
[?2004l[?2004h> 
[?2004l[?2004h>         if passed:
[?2004l[?2004h>             print("  PASS")
[?2004l[?2004h>             score += 10
[?2004l[?2004h>         else:
[?2004l[?2004h>             print("  FAIL")
[?2004l[?2004h> 
[?2004l[?2004h>         manifest.append({"level": lvl, "filename": level_info["output_file"], "passed": passed})
[?2004l[?2004h> 
[?2004l[?2004h>     print(f"Score: {score}/{total}")
[?2004l[?2004h> 
[?2004l[?2004h>     # Write manifest
[?2004l[?2004h>     with open(MANIFEST_PATH, "w") as f:
[?2004l[?2004h>         json.dump(manifest, f, indent=2)
[?2004l[?2004h> 
[?2004l[?2004h> def interactive_mode():
[?2004l[?2004h>     """Run the game in interactive mode."""
[?2004l[?2004h>     ensure_dirs()
[?2004l[?2004h>     score = 0
[?2004l[?2004h>     total = len(LEVELS) * 10
[?2004l[?2004h> 
[?2004l[?2004h>     for level_info in LEVELS:
[?2004l[?2004h>         lvl = level_info["level"]
[?2004l[?2004h>         print(f"\n{'='*50}")
[?2004l[?2004h>         print(f"Level {lvl}: {level_info['name']}")
[?2004l[?2004h>         print(f"{'='*50}")
[?2004l[?2004h>         print(f"\n{level_info['description']}")
[?2004l[?2004h>         print(f"\nInput file: {level_info['input_file']}")
[?2004l[?2004h>         print(f"Output file: {level_info['output_file']}")
[?2004l[?2004h> 
[?2004l[?2004h>         # Generate input
[?2004l[?2004h>         if not generate_input(level_info):
[?2004l[?2004h>             print("Error generating input file. Skipping level.")
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         # Get user input
[?2004l[?2004h>         print("\nEnter your filtergraph expression (or 'skip' to skip):")
[?2004l[?2004h>         try:
[?2004l[?2004h>             user_input = input("> ").strip()
[?2004l[?2004h>         except (EOFError, KeyboardInterrupt):
[?2004l[?2004h>             print("\nExiting game.")
[?2004l[?2004h>             return
[?2004l[?2004h> 
[?2004l[?2004h>         if user_input.lower() == "skip":
[?2004l[?2004h>             print("  Skipped.")
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         # Run filtergraph
[?2004l[?2004h>         success = run_filtergraph(level_info, user_input)
[?2004l[?2004h> 
[?2004l[?2004h>         if success:
[?2004l[?2004h>             passed = level_info["validate"]()
[?2004l[?2004h>         else:
[?2004l[?2004h>             passed = False
[?2004l[?2004h> 
[?2004l[?2004h>         if passed:
