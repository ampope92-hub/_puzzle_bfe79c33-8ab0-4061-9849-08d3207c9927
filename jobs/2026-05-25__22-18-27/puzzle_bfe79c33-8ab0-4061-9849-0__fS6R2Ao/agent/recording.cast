[55.375954, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive_mode():\r\n\u001b[?2004l\r"]
[55.375965, "o", "\u001b[?2004h> "]
[55.376061, "o", "    \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.376241, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.376354, "o", "    total = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.376553, "o", "    for level_info in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h>         lvl = level_info[\"level\"]\r\n\u001b[?2004l\r"]
