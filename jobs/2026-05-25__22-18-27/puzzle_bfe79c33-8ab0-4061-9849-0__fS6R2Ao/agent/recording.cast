[56.434718, "i", "python3 -c \"\nimport base64\n\ndef obfuscate(s):\n    return base64.b64encode(s[::-1].encode()).decode()\n\ndef deobfuscate(s):\n    return base64.b64decode(s.encode()).decode()[::-1]\n\nsolutions = {\n    1: 'scale=320:240',\n    2: 'format=gray',\n    3: 'atrim=0:3',\n    4: 'crop=200:200',\n    5: 'scale=320:240,hflip',\n}\n\nfor k, v in solutions.items():\n    enc = obfuscate(v)\n    dec = deobfuscate(enc)\n    print(f'Level {k}: {v!r} -> {enc!r} -> {dec!r} (match={v==dec})')\n\"\n"]
