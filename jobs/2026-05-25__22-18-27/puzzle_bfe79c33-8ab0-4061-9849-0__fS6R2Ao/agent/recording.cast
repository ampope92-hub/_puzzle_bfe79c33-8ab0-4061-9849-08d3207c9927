[55.378134, "o", "            return\r\n\u001b[?2004l\r"]
[55.378259, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if user_input.lower() == \"skip\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.3783, "o", "            print(\"  Skipped.\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
