[55.362098, "o", "def run_cmd(cmd, quiet=True):\r\n\u001b[?2004l\rrint(f\"\u001b[?2004h"]
[55.362126, "o", "> "]
[55.362303, "o", "    \"\"\"Run a command and return (returncode, stdout, stderr).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.362446, "o", "        r = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.362737, "o", "        return r.returncode, r.stdout, r.stderr\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.362844, "o", "    except subprocess.TimeoutExpired:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.362998, "o", "> "]
[55.363138, "o", "        return 1, \"\", \"timeout\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.36334, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.363407, "o", "        return 1, \"\", str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.363481, "o", "def ffprobe_json(filepath):\r\n\u001b[?2004l\r"]
[55.363651, "o", "\u001b[?2004h> "]
[55.363874, "o", "    \"\"\"Get ffprobe JSON output for a file.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r"]
[55.363912, "o", "\u001b[?2004h> "]
[55.364112, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.364313, "o", "        \"-show_format\", \"-show_streams\", filepath\r\n\u001b[?2004l\r"]
[55.364648, "o", "\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.364985, "o", "    rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.36516, "o", "        return json.loads(stdout)\r\n\u001b[?2004l\r\u001b[?2004h>     except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.365353, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.365628, "o", "def check_video_dims(filepath, expected_w, expected_h):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.366378, "o", "    \"\"\"Check that the video has the expected dimensions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.366421, "o", "> "]
[55.366637, "o", "    info = ffprobe_json(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.36672, "o", "    if not info:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[55.366823, "o", "\u001b[?2004h> "]
[55.366925, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\r\n       \u001b[?2004h> "]
[55.367023, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.367145, "o", "> "]
[55.367266, "o", "            w = stream.get(\"width\")\r\n\u001b[?2004l\r"]
[55.367459, "o", "\u001b[?2004h>             h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.367608, "o", "            if w == expected_w and h == expected_h:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.367728, "o", "                return True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.367857, "o", "    return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.367997, "o", "def check_pix_fmt(filepath, expected_fmt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.368223, "o", "    \"\"\"Check that the video has the expected pixel format.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.3684, "o", "    info = ffprobe_json(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.368425, "o", "    if not info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.368441, "o", "        return False\r\n\u001b[?2004l\r"]
[55.368531, "o", "\u001b[?2004h> "]
[55.368731, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.368743, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.368839, "o", "            pf = stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.369019, "o", "            if pf == expected_fmt:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.369139, "o", "                return True\r\n\u001b[?2004l\r\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.369316, "o", "def check_audio_duration(filepath, min_dur, max_dur):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.369542, "o", "    \"\"\"Check that the audio duration is within range.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     info = ffprobe_json(filepath)\r\n\u001b[?2004l\r"]
[55.369734, "o", "\u001b[?2004h>     if not info:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.370008, "o", "    # Try format duration first\r\n\u001b[?2004l\r\u001b[?2004h>     fmt_dur = info.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.370138, "o", "    if fmt_dur:\r\n\u001b[?2004l\r\u001b[?2004h>         dur = float(fmt_dur)\r\n\u001b[?2004l\r\u001b[?2004h>         if min_dur <= dur <= max_dur:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.370224, "o", "            return True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.370252, "o", "    # Try stream duration\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.370369, "o", "> "]
[55.370524, "o", "    for stream in info.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.370564, "o", "            sdur = stream.get(\"duration\")"]
[55.370648, "o", "\r\n\u001b[?2004l\r"]
[55.370667, "o", "\u001b[?2004h> "]
[55.370768, "o", "            if sdur:\r\n\u001b[?2004l\r\u001b[?2004h>                 dur = float(sdur)\r\n\u001b[?2004l\r"]
[55.370811, "o", "\u001b[?2004h> "]
[55.371001, "o", "                if min_dur <= dur <= max_dur:\r\n\u001b[?2004l\r\u001b[?2004h>                     return True\r\n\u001b[?2004l\r\u001b[?2004h>     return False\r\n\u001b[?2004l\r"]
[55.371212, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def generate_input(level_info):\r\n\u001b[?2004l\r"]
[55.371352, "o", "\u001b[?2004h>     \"\"\"Generate the input file for a level.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.37144, "o", "    input_path = os.path.join(ASSETS_DIR, level_info[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.371553, "o", "    if not os.path.exists(input_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.371642, "o", "        rc, _, stderr = run_cmd(level_info[\"gen_cmd\"])\r\n\u001b[?2004l\r\u001b[?2004h>         if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.371771, "o", "            print(f\"  Error generating input: {stderr}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.371928, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.372081, "o", "def run_filtergraph(level_info, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run the user's filtergraph and return success.\"\"\"\r\n\u001b[?2004l\r"]
[55.3722, "o", "\u001b[?2004h>     cmd = level_info[\"build_cmd\"](filtergraph)\r\n\u001b[?2004l\r"]
[55.372358, "o", "\u001b[?2004h>     rc, stdout, stderr = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     return rc == 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.372536, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.372656, "o", "    \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.372802, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.372836, "o", "    total = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.372843, "o", "> "]
[55.373026, "o", "    for level_info in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.373118, "o", "        lvl = level_info[\"level\"]\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lvl}: {level_info['name']}\")\r\n\u001b[?2004l\r"]
[55.373145, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.373216, "o", ">         # Generate input\r\n\u001b[?2004l\r"]
[55.373382, "o", "\u001b[?2004h>         if not generate_input(level_info):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.373531, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.37363, "o", "            manifest.append({\"level\": lvl, \"filename\": level_info[\"output_file\"], \"passed\": False})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.373838, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         # Get solution and run\r\n\u001b[?2004l\r\u001b[?2004h"]
