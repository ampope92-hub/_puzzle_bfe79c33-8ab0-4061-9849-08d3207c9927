[55.376632, "o", "\u001b[?2004h> "]
[55.376781, "o", "        print(f\"Level {lvl}: {level_info['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.376878, "o", "        print(f\"{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377038, "o", "        print(f\"\\n{level_info['description']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377122, "o", "        print(f\"\\nInput file: {level_info['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377217, "o", "        print(f\"Output file: {level_info['output_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377315, "o", "        # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377428, "o", "        if not generate_input(level_info):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.37758, "o", "            print(\"Error generating input file. Skipping level.\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r"]
[55.377697, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         # Get user input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377865, "o", "        print(\"\\nEnter your filtergraph expression (or 'skip' to skip):\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             user_input = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.377982, "o", "        except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
