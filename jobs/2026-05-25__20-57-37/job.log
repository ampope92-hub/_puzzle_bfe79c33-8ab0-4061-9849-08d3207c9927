.path.join(ASSETS_DIR, "level2_input.avi")\n    if not os.path.exists(l2):\n        p = run([\n            "ffmpeg", "-y",\n            "-f", "lavfi", "-i", "testsrc2=size=640x480:rate=30",\n            "-t", "2",\n            "-c:v", "rawvideo",\n            "-pix_fmt", "yuv420p",\n            l2,\n        ])\n        if p.returncode != 0:\n            raise RuntimeError(p.stderr)\n\n    # Level 3: 10-second audio clip wav\n    l3 = os.path.join(ASSETS_DIR, "level3_input.wav")\n    if not os.path.exists(l3):\n        p = run([\n            "ffmpeg", "-y",\n            "-f", "lavfi", "-i", "sine=frequency=440:sample_rate=48000",\n            "-t", "10",\n            "-c:a", "pcm_s16le",\n            l3,\n        ])\n        if p.returncode != 0:\n            raise RuntimeError(p.stderr)\n\n    # Level 4: 640x480 video\n    l4 = os.path.join(ASSETS_DIR, "level4_input.mp4")\n    if not os.path.exists(l4):\n        p = run([\n            "ffmpeg", "-y",\n            "-f", "lavfi", "-i", "testsrc2=size=640x480:rate=30",\n            "-t", "2",\n            "-pix_fmt", "yuv420p",\n            l4,\n        ])\n        if p.returncode != 0:\n            raise RuntimeError(p.stderr)\n\n    # Level 5: 640x480 video\n    l5 = os.path.join(ASSETS_DIR, "level5_input.mp4")\n    if not os.path.exists(l5):\n        p = run([\n            "ffmpeg", "-y",\n            "-f", "lavfi", "-i", "testsrc2=size=640x480:rate=30",\n            "-t", "2",\n            "-pix_fmt", "yuv420p",\n            l5,\n        ])\n        if p.returncode != 0:\n            raise RuntimeError(p.stderr)\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_filename: str\n    output_filename: str\n    media_type: str  # \'video\' or \'audio\'\n    container: str\n    encoder_args: List[str]\n    correct_filter: str\n    validate: Callable[[str], Tuple[bool, str]]\n\n\ndef ffmpeg_apply_filter(input_path: str, output_path: str, media_type: str, filtergraph: str, encoder_args: List[str]) -> Tuple[bool, str]:\n    # Use -filter:v or -filter:a depending on media type\n    filt_opt = "-filter:v" if media_type == "video" else "-filter:a"\n\n    cmd = ["ffmpeg", "-y", "-v", "error", "-i", input_path, filt_opt, filtergraph] + encoder_args + [output_path]\n    p = run(cmd)\n    if p.returncode != 0:\n        return False, p.stderr.strip() or "ffmpeg failed"\n    return True, ""\n\n\ndef validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, "video")\n    if not st:\n        return False, "No video stream"\n    if int(st.get("width", -1)) != w or int(st.get("height", -1)) != h:\n        return False, f"Expected {w}x{h}, got {st.get(\'width\')}x{st.get(\'height\')}"\n    return True, ""\n\n\ndef validate_video_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, "video")\n    if not st:\n        return False, "No video stream"\n    got = st.get("pix_fmt")\n    if got != pix_fmt:\n        return False, f"Expected pix_fmt={pix_fmt}, got {got}"\n    return True, ""\n\n\ndef validate_audio_duration(path: str, lo: float, hi: float) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, "audio")\n    if not st:\n        return False, "No audio stream"\n\n    # Prefer format.duration; fallback to stream.duration\n    dur = safe_float(probe.get("format", {}).get("duration"), default=-1.0)\n    if dur <= 0:\n        dur = safe_float(st.get("duration"), default=-1.0)\n\n    if dur < lo or dur > hi:\n        return False, f"Expected duration between {lo} and {hi}, got {dur}"\n    return True, ""\n\n\ndef build_levels() -> List[Level]:\n    return [\n        Level(\n            num=1,\n            name="Scale Down",\n            description="Scale a 640x480 video down to 320x240. Enter a video filtergraph.",\n            input_filename="level1_input.mp4",\n            output_filename="level1_output.mp4",\n            media_type="video",\n            container="mp4",\n            encoder_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-an"],\n            correct_filter="scale=320:240",\n            validate=lambda p: validate_video_dims(p, 320, 240),\n        ),\n        Level(\n            num=2,\n            name="Grayscale",\n            description="Convert a video to grayscale. Output pixel format must be exactly \'gray\'. Enter a video filtergraph.",\n            input_filename="level2_input.avi",\n            output_filename="level2_output.avi",\n            media_type="video",\n            container="avi",\n            # rawvideo + pix_fmt=gray so ffprobe reports exact pix_fmt\n            encoder_args=["-c:v", "rawvideo", "-pix_fmt", "gray", "-an"],\n            correct_filter="format=gray",\n            validate=lambda p: validate_video_pix_fmt(p, "gray"),\n        ),\n        Level(\n            num=3,\n            name="Audio Trim",\n            description="Trim a 10-second audio clip to exactly ~3 seconds (duration must be 2.9 to 3.1). Enter an audio filtergraph.",\n            input_filename="level3_input.wav",\n            output_filename="level3_output.wav",\n            media_type="audio",\n            container="wav",\n            encoder_args=["-c:a", "pcm_s16le"],\n            correct_filter="atrim=0:3",\n            validate=lambda p: validate_audio_duration(p, 2.9, 3.1),\n        ),\n        Level(\n            num=4,\n            name="Center Crop",\n            description="Crop the center 200x200 region from a 640x480 video. Enter a video filtergraph.",\n            input_filename="level4_input.mp4",\n            output_filename="level4_output.mp4",\n            media_type="video",\n            container="mp4",\n            encoder_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-an"],\n            correct_filter="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n            validate=lambda p: validate_video_dims(p, 200, 200),\n        ),\n        Level(\n            num=5,\n            name="Scale + HFlip",\n            description="Multi-step: take a 640x480 video, scale it to 320x240, AND apply a horizontal flip. Enter a video filtergraph.",\n            input_filename="level5_input.mp4",\n            output_filename="level5_output.mp4",\n            media_type="video",\n            container="mp4",\n            encoder_args=["-c:v", "libx264", "-pix_fmt", "yuv420p", "-an"],\n            correct_filter="scale=320:240,hflip",\n            validate=lambda p: validate_video_dims(p, 320, 240),\n        ),\n    ]\n\n\ndef play_level(level: Level, filtergraph: str, auto: bool = False) -> Tuple[bool, str]:\n    in_path = os.path.join(ASSETS_DIR, level.input_filename)\n    out_path = os.path.join(OUTPUT_DIR, level.output_filename)\n\n    ok, err = ffmpeg_apply_filter(in_path, out_path, level.media_type, filtergraph, level.encoder_args)\n    if not ok:\n        return False, err\n\n    try:\n        v_ok, v_msg = level.validate(out_path)\n        if not v_ok:\n            return False, v_msg\n        return True, ""\n    except Exception as e:\n        return False, str(e)\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    generate_inputs()\n    levels = build_levels()\n\n    score = 0\n    for lvl in levels:\n        print(f"Level {lvl.num}: {lvl.name}")\n        print(lvl.description)\n        user_fg = input("Filtergraph> ").strip()\n        passed, msg = play_level(lvl, user_fg)\n        if passed:\n            print("  PASS")\n            score += 10\n        else:\n            print("  FAIL")\n            if msg:\n                print(f"  Reason: {msg}")\n\n    print(f"Score: {score}/{len(levels)*10}")\n    return 0\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    generate_inputs()\n    levels = build_levels()\n\n    manifest: List[Dict] = []\n    score = 0\n\n    for lvl in levels:\n        print(f"Level {lvl.num}: {lvl.name}")\n        passed, msg = play_level(lvl, lvl.correct_filter, auto=True)\n        if passed:\n            print("  PASS")\n            score += 10\n        else:\n            print("  FAIL")\n            if msg:\n                # keep deterministic but informative; not required by spec\n                print(f"  Reason: {msg}")\n\n        manifest.append({"level": lvl.num, "filename": lvl.output_filename, "passed": bool(passed)})\n\n    print(f"Score: {score}/{len(levels)*10}")\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump(manifest, f, indent=2)\n        f.write("\\n")\n\n    return 0\n\n\ndef main(argv: List[str]) -> int:\n    ap = argparse.ArgumentParser(description="FFmpeg filtergraph puzzle game")\n    ap.add_argument("--auto-solve", action="store_true", help="Run all levels with known correct solutions")\n    args = ap.parse_args(argv)\n\n    if args.auto_solve:\n        return auto_solve()\n    return interactive()\n\n\nif __name__ == "__main__":\n    raise SystemExit(main(sys.argv[1:]))\nPY\nchmod +x /app/ffpuzzle.py\n'] min_timeout_sec: 1.0 max_timeout_sec: 180.0
