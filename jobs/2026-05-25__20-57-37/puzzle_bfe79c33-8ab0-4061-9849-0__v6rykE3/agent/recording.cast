[45.65918, "o", "\u001b[?2004h> def auto_solve() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.659372, "o", "    generate_inputs()\r\n\u001b[?2004l\r\u001b[?2004h>     levels = build_levels()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.659396, "o", "    manifest: List[Dict] = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.659559, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.659625, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.659733, "o", ">     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.659901, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.65994, "o", "        passed, msg = play_level(lvl, lvl.correct_filter, auto=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
