[45.65775, "o", "    score = 0\r\n\u001b[?2004l\r"]
[45.657814, "o", "\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r"]
[45.657825, "o", "\u001b[?2004h> "]
[45.657967, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)"]
[45.658003, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.658082, "o", "> "]
[45.658199, "o", "        user_fg = input(\"Filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         passed, msg = play_level(lvl, user_fg)\r\n\u001b[?2004l\r"]
