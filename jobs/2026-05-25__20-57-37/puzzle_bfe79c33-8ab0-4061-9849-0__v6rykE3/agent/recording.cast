[45.657035, "o", "> "]
[45.65708, "o", "            return False, v_msg\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.657119, "o", "        return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.657256, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
