[45.660903, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.660961, "o", "> "]
[45.661083, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
