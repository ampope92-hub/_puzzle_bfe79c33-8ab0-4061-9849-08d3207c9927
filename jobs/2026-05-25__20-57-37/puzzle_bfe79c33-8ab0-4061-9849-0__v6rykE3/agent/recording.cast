[45.602388, "i", "Level 5: 640x480 video\n    l5 = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n    if not os.path.exists(l5):\n        p = run([\n            \"ffmpeg\", \"-y\",\n            \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n            \"-t\", \"2\",\n            \"-pix_fmt\", \"yuv420p\",\n            l5,\n        ])\n        if p.returncode != 0:\n            raise RuntimeError(p.stderr)\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_filename: str\n    output_filename: str\n    media_type: str  # 'video' or 'audio'\n    container: str\n    encoder_args: List[str]\n    correct_filter: str\n    validate: Callable[[str], Tuple[bool, str]]\n\n\ndef ffmpeg_apply_filter(input_path: str, output_path: str, media_type: str, filtergraph: str, encoder_args: List[str]) -> Tuple[bool, str]:\n    # Use -filter:v or -filter:a depending on media type\n    filt_opt = \"-filter:v\" if media_type == \"video\" else \"-filter:a\"\n\n    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", input_path, filt_opt, filtergraph] + encoder_ar"]
