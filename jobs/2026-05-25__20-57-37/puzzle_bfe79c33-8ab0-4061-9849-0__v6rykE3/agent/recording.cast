[45.652197, "o", "            description=\"Trim a 10-second audio clip to exactly ~3 seconds (duration must be 2.9 to 3.1). Enter an audio filtergraph.\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.652363, "o", "> "]
[45.652545, "o", "            input_filename=\"level3_input.wav\",\r\n\u001b[?2004l\r\u001b[?2004h>             output_filename=\"level3_output.wav\",\r\n\u001b[?2004l\r\u001b[?2004h>             media_type=\"audio\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
