[45.652698, "o", "\u001b[?2004h> "]
[45.652948, "o", "            encoder_args=[\"-c:a\", \"pcm_s16le\"],\r\n\u001b[?2004l\r\u001b[?2004h>             correct_filter=\"atrim=0:3\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.653014, "o", "            validate=lambda p: validate_audio_duration(p, 2.9, 3.1),\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.653102, "o", "> "]
