[45.661693, "o", "\u001b[?2004h> "]
[45.661814, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r"]
[45.661915, "o", "\u001b[?2004h> "]
[45.662059, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with known correct solutions\")\r\n\u001b[?2004l\r"]
[45.662144, "o", "\u001b[?2004h>     args = ap.parse_args(argv)\r\n\u001b[?2004l\r"]
[45.662169, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.662314, "o", "    if args.auto_solve:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.662382, "o", "        return auto_solve()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.662441, "o", "    return interactive()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.662521, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.662679, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
