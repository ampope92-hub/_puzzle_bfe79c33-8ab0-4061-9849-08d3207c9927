[45.602412, "i", "gs + [output_path]\n    p = run(cmd)\n    if p.returncode != 0:\n        return False, p.stderr.strip() or \"ffmpeg failed\"\n    return True, \"\"\n\n\ndef validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, \"video\")\n    if not st:\n        return False, \"No video stream\"\n    if int(st.get(\"width\", -1)) != w or int(st.get(\"height\", -1)) != h:\n        return False, f\"Expected {w}x{h}, got {st.get('width')}x{st.get('height')}\"\n    return True, \"\"\n\n\ndef validate_video_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, \"video\")\n    if not st:\n        return False, \"No video stream\"\n    got = st.get(\"pix_fmt\")\n    if got != pix_fmt:\n        return False, f\"Expected pix_fmt={pix_fmt}, got {got}\"\n    return True, \"\"\n\n\ndef validate_audio_duration(path: str, lo: float, hi: float) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    st = get_first_stream(probe, \"audio\")\n    if not s"]
[45.602634, "i", "t:\n        return False, \"No audio stream\"\n\n    # Prefer format.duration; fallback to stream.duration\n    dur = safe_float(probe.get(\"format\", {}).get(\"duration\"), default=-1.0)\n    if dur <= 0:\n        dur = safe_float(st.get(\"duration\"), default=-1.0)\n\n    if dur < lo or dur > hi:\n        return False, f\"Expected duration between {lo} and {hi}, got {dur}\"\n    return True, \"\"\n\n\ndef build_levels() -> List[Level]:\n    return [\n        Level(\n            num=1,\n            name=\"Scale Down\",\n            description=\"Scale a 640x480 video down to 320x240. Enter a video filtergraph.\",\n            input_filename=\"level1_input.mp4\",\n            output_filename=\"level1_output.mp4\",\n            media_type=\"video\",\n            container=\"mp4\",\n            encoder_args=[\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", \"-an\"],\n            correct_filter=\"scale=320:240\",\n            validate=lambda p: validate_video_dims(p, 320, 240),\n        ),\n        Level(\n            num=2,\n            name=\"Grayscale\",\n            descrip"]
