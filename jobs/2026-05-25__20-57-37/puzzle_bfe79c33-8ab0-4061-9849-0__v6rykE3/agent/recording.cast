[45.648881, "o", "> "]
[45.649106, "o", "            input_filename=\"level2_input.avi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.649313, "o", "            output_filename=\"level2_output.avi\",\r\n\u001b[?2004l\rl"]
[45.649418, "o", "u"]
[45.649678, "o", "\u001b[?2004h>             media_type=\"video\",\r\n\u001b[?2004l\r"]
[45.649773, "o", "\u001b[?2004h> "]
[45.649889, "o", "            container=\"avi\",\r\n\u001b[?2004l\rv\u001b[?2004h> "]
[45.650806, "o", "            # rawvideo + pix_fmt=gray so ffprobe reports exact pix_fmt\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.650833, "o", "> "]
[45.651297, "o", "            encoder_args=[\"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\", \"-an\"],\r\n\u001b[?2004l\r"]
[45.651358, "o", "\u001b[?2004h> "]
