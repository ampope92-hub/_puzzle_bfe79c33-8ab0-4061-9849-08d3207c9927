[45.60424, "i", "          correct_filter=\"scale=320:240,hflip\",\n            validate=lambda p: validate_video_dims(p, 320, 240),\n        ),\n    ]\n\n\ndef play_level(level: Level, filtergraph: str, auto: bool = False) -> Tuple[bool, str]:\n    in_path = os.path.join(ASSETS_DIR, level.input_filename)\n    out_path = os.path.join(OUTPUT_DIR, level.output_filename)\n\n    ok, err = ffmpeg_apply_filter(in_path, out_path, level.media_type, filtergraph, level.encoder_args)\n    if not ok:\n        return False, err\n\n    try:\n        v_ok, v_msg = level.validate(out_path)\n        if not v_ok:\n            return False, v_msg\n        return True, \"\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    generate_inputs()\n    levels = build_levels()\n\n    score = 0\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        print(lvl.description)\n        user_fg = input(\"Filtergraph> \").strip()\n        passed, msg = play_level(lvl, user_fg)\n        if passed:\n            print("]
