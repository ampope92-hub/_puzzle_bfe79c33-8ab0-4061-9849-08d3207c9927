[45.656184, "o", "def play_level(level: Level, filtergraph: str, auto: bool = False) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.656281, "o", "    in_path = os.path.join(ASSETS_DIR, level.input_filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.656325, "o", "> "]
[45.656421, "o", "    out_path = os.path.join(OUTPUT_DIR, level.output_filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.656533, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.65665, "o", "    ok, err = ffmpeg_apply_filter(in_path, out_path, level.media_type, filtergraph, level.encoder_args)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.656717, "o", "> "]
[45.656787, "o", "    if not ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.656855, "o", "        return False, err\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
