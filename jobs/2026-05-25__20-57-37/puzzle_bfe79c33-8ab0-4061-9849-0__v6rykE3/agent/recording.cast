[45.629368, "o", "video_dims(p\u001b[?2004h>     encoder_args: List[str]\r\n\u001b[?2004l\r     ),\r\n    \u001b[?2004h>     correct_filter: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.629495, "o", "    validate: Callable[[str], Tuple[bool, str]]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.630345, "o", "def ffmpeg_apply_filter(input_path: str, output_path: str, media_type: str, filtergraph: str, encoder_args: List[str]) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.630718, "o", "    # Use -filter:v or -filter:a depending on media type\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.630969, "o", "    filt_opt = \"-filter:v\" if media_type == \"video\" else \"-filter:a\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.632088, "o", "    cmd = [\"ffmpeg\", \"-y\", \"-v\", \"error\", \"-i\", input_path, filt_opt, filtergraph] + encoder_args + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h>     p = run(cmd)\r\n\u001b[?2004l\r"]
[45.632329, "o", "\u001b[?2004h>     if p.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.632695, "o", "        return False, p.stderr.strip() or \"ffmpeg failed\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.632955, "o", ">     return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.63351, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.63383, "o", "def validate_video_dims(path: str, w: int, h: int) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[45.633872, "o", "\u001b[?2004h> "]
[45.634055, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[45.634244, "o", "\u001b[?2004h> "]
[45.634936, "o", "    st = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r"]
[45.635114, "o", "\u001b[?2004h>     if not st:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.635276, "o", "        return False, \"No video stream\"\r\n\u001b[?2004l\r"]
[45.635569, "o", "\u001b[?2004h> "]
[45.635731, "o", "    if int(st.get(\"width\", -1)) != w or int(st.get(\"height\", -1)) != h:\r\n\u001b[?2004l\r"]
[45.635886, "o", "\u001b[?2004h> "]
[45.635987, "o", "        return False, f\"Expected {w}x{h}, got {st.get('width')}x{st.get('height')}\"\r\n\u001b[?2004l\r"]
[45.63602, "o", "\u001b[?2004h> "]
[45.636146, "o", "    return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.636339, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.637655, "o", "def validate_video_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.637814, "o", "> "]
[45.638024, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.638066, "o", "> "]
[45.638417, "o", "    st = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>     if not st:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.638692, "o", "        return False, \"No video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.638916, "o", "    got = st.get(\"pix_fmt\")\r\n\u001b[?2004l\r()\r\n\u001b[?2004h> "]
[45.639185, "o", "    if got != pix_fmt:\r\n\u001b[?2004l\r"]
[45.639214, "o", "\u001b[?2004h> "]
[45.639658, "o", "        return False, f\"Expected pix_fmt={pix_fmt}, got {got}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.639883, "o", ">     return True, \"\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.64038, "o", "def validate_audio_duration(path: str, lo: float, hi: float) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.640658, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r_le\u001b[?2004h> "]
[45.640749, "o", "    st = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.640877, "o", "    if not st:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.641165, "o", "        return False, \"No audio stream\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.641491, "o", "    # Prefer format.duration; fallback to stream.duration\r\n\u001b[?2004l\r   if msg:\r\n     "]
[45.641632, "o", "\u001b[?2004h> "]
[45.641947, "o", "    dur = safe_float(probe.get(\"format\", {}).get(\"duration\"), default=-1.0)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.641999, "o", ">     if dur <= 0:\r\n\u001b[?2004l\r"]
[45.642052, "o", "\u001b[?2004h> "]
[45.642341, "o", "        dur = safe_float(st.get(\"duration\"), default=-1.0)\r\n\u001b[?2004l\r"]
[45.642441, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.642718, "o", "    if dur < lo or dur > hi:\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.642765, "o", "> "]
[45.643291, "o", "        return False, f\"Expected duration between {lo} and {hi}, got {dur}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.643384, "o", "> "]
[45.643409, "o", "    return True, \"\"\r\n\u001b[?2004l\r"]
