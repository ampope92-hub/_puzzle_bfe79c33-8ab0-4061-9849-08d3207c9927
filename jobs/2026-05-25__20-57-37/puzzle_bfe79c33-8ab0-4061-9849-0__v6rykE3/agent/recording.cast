[45.604299, "i", "\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n            if msg:\n                print(f\"  Reason: {msg}\")\n\n    print(f\"Score: {score}/{len(levels)*10}\")\n    return 0\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    generate_inputs()\n    levels = build_levels()\n\n    manifest: List[Dict] = []\n    score = 0\n\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        passed, msg = play_level(lvl, lvl.correct_filter, auto=True)\n        if passed:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n            if msg:\n                # keep deterministic but informative; not required by spec\n                print(f\"  Reason: {msg}\")\n\n        manifest.append({\"level\": lvl.num, \"filename\": lvl.output_filename, \"passed\": bool(passed)})\n\n    print(f\"Score: {score}/{len(levels)*10}\")\n\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump(manifest, f, indent=2)\n        f.write(\"\\n\")\n\n    return 0\n\n\ndef main(a"]
