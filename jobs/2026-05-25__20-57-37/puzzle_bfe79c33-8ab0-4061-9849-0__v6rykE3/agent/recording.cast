[45.651759, "o", ">         ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.651938, "o", "        Level(\r\n\u001b[?2004l\r\u001b[?2004h>             num=3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
