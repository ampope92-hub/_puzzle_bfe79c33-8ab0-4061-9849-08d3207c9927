[45.628138, "o", "\u001b[?2004h>             raise RuntimeError(p.stderr)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> @dataclass\r\n\u001b[?2004l\r\u001b[?2004h> class Level:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.628314, "o", "    num: int\r\n\u001b[?2004l\r\u001b[?2004h>     name: str\r\n\u001b[?2004l\r\u001b[?2004h>     description: str\r\n\u001b[?2004l\r\u001b[?2004h>     input_filename: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.628468, "o", "    output_filename: str\r\n\u001b[?2004l\r\u001b[?2004h> "]
