[195.368699, "o", "\u001b[?2004h> "]
[195.368748, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r"]
[195.368757, "o", "\u001b[?2004h> "]
[195.368774, "o", "            score += 10\r\n\u001b[?2004l\r"]
[195.36885, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r"]
