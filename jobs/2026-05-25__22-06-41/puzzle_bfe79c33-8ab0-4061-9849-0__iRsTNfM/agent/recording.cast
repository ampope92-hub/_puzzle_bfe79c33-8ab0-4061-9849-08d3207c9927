[195.348281, "o", "def validate_audio_dur_approx_3s(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[195.348476, "o", "\u001b[?2004h> "]
