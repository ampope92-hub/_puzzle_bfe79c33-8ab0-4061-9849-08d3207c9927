[195.349036, "o", "\u001b[?2004h>         a = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.349157, "o", "        dur = a.get(\"duration\") or probe.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\rl"]
[195.349404, "o", "\u001b[?2004h> "]
[195.349589, "o", "        if dur is None:"]
[195.349678, "o", "\r\n\u001b[?2004l\r"]
[195.349778, "o", "\u001b[?2004h> "]
[195.350029, "o", "            return False, \"duration not found\"\r\n\u001b[?2004l\r\u001b[?2004h>         d = float(dur)\r\n\u001b[?2004l\r"]
[195.350169, "o", "\u001b[?2004h>         if 2.9 <= d <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.350271, "o", "            return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.350443, "o", "        return False, f\"expected ~3.0s, got {d:.3f}s\"\r\n\u001b[?2004l\r\u001b[?2004h"]
