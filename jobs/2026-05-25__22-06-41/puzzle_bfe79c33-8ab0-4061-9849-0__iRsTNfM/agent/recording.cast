[55.158926, "o", "        raise RuntimeError(f\"ffprobe failed: {cp.stderr.strip()}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.159303, "o", "    return json.loads(cp.stdout)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.159366, "o", "\u001b[?2004h> "]
[55.159976, "o", "def get_first_stream(probe: Dict, codec_type: str) -> Dict:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.160195, "o", "    for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.16043, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.160689, "o", "> "]
[55.16081, "o", "            return s\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.160911, "o", "> "]
[55.161076, "o", "    raise KeyError(f\"No {codec_type} stream found\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r-\u001b[?2004h"]
[55.161162, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.161343, "o", "def safe_unlink(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.161522, "o", ">     try:\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[55.161791, "o", "        os.unlink(path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.162033, "o", "> "]
[55.162211, "o", "    except FileNotFoundError:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r"]
[55.16246, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.162631, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.162747, "o", "> "]
[55.162962, "o", "def obf_decode(token: str) -> str:\r\n\u001b[?2004l\r"]
[55.163034, "o", "\u001b[?2004h> "]
[55.163618, "o", "    # token is base64 of reversed utf-8 bytes\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.16381, "o", "> "]
[55.164148, "o", "    raw = base64.b64decode(token.encode(\"ascii\"))\r\n\u001b[?2004l\r"]
[55.164214, "o", "\u001b[?2004h"]
[55.16436, "o", "> "]
[55.164934, "o", "    return raw.decode(\"utf-8\")[::-1]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.16499, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rt"]
[55.165646, "o", "\u001b[?2004h> @dataclass\r\n\u001b[?2004l\r\u001b[?2004h> class Level:\r\n\u001b[?2004l\r\u001b[?2004h>     num: int\r\n\u001b[?2004l\r\u001b[?2004h>     name: str\r\n\u001b[?2004l\r\u001b[?2004h>     description: str\r\n\u001b[?2004l\r\u001b[?2004h>     input_path: str\r\n\u001b[?2004l\r\u001b[?2004h>     output_path: str\r\n\u001b[?2004l\r\u001b[?2004h>     output_ext: str\r\n\u001b[?2004l\r\u001b[?2004h>     build_input: Callable[[], None]\r\n\u001b[?2004l\r\u001b[?2004h>     validate: Callable[[str], Tuple[bool, str]]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.165907, "o", "    solution_token: str  # obfuscated\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rg\u001b[?2004h> \r\n\u001b[?2004l\rb"]
[55.166058, "o", "\u001b[?2004h> # --- Input generators ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.166242, "o", "\u001b[?2004h> "]
[55.166417, "o", "def gen_level1_input(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.166624, "o", "    # 640x480, 2 seconds, deterministic\r\n\u001b[?2004l\r"]
[55.166672, "o", "\u001b[?2004h> "]
[55.166928, "o", "    run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.167213, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.1673, "o", "> "]
[55.167689, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.167893, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.168015, "o", "> "]
[55.168142, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.16825, "o", "        path"]
[55.168271, "o", "\r\n\u001b[?2004l\r"]
[55.168336, "o", "\u001b[?2004h>     ])"]
[55.1685, "o", "\r\n\u001b[?2004l\r"]
[55.168668, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rr\u001b[?2004h> \r\n"]
[55.16878, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[55.169442, "o", "def gen_level2_input(path: str) -> None:\r\n\u001b[?2004l\r"]
[55.169594, "o", "\u001b[?2004h> "]
[55.170343, "o", "    # Use AVI with rawvideo; keep pix_fmt not critical for input.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.17052, "o", "    run([\r\n\u001b[?2004l\r"]
[55.170668, "o", "\u001b[?2004h> "]
[55.170806, "o", "        \"ffmpeg\", \"-y\",\r\n"]
[55.17091, "o", "\u001b[?2004l\r"]
[55.171067, "o", "\u001b[?2004h> "]
[55.171738, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.171886, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.172018, "o", "> "]
[55.17213, "o", "        \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r"]
[55.172216, "o", "\u001b[?2004h> "]
[55.172347, "o", "        path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.172442, "o", "    ])\r\n"]
[55.172607, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.172759, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.17316, "o", "def gen_level3_input(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.173393, "o", "    run([\r\n\u001b[?2004l\r"]
[55.17355, "o", "\u001b[?2004h> "]
[55.173826, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.173859, "o", "> "]
[55.174292, "o", "        \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.174591, "o", "        \"-t\", \"10\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.175001, "o", "        \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.175096, "o", "        path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.175263, "o", "    ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.17558, "o", "def gen_level4_input(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.175787, "o", "    run([\r\n\u001b[?2004l\r"]
[55.176033, "o", "\u001b[?2004h>         \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r"]
[55.176361, "o", "\u001b[?2004h>         \"-t\", \"2\",\r\n\u001b[?2004l\r   "]
[55.176492, "o", "\u001b[?2004h> "]
[55.176977, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.17728, "o", "        path\r\n\u001b[?2004l\r\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.177429, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.177531, "o", "> def gen_level5_input(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     run([\r\n\u001b[?2004l\ry (missing hflip)\"\r\n        return True, \"ok\"\r\n    ex\u001b[?2004h> "]
[55.177644, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.177809, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.177904, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r"]
[55.177996, "o", "\u001b[?2004h> "]
[55.178112, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         path\r\n\u001b[?2004l\rtion) )\r\n    # \u001b[?2004h> "]
[55.178256, "o", "    ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rs\u001b[?2004h> "]
[55.178321, "o", "# --- Validators ---\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.178466, "o", "\u001b[?2004h> "]
[55.178671, "o", "def validate_scale_320x240(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.178775, "o", ">     try:\r\n\u001b[?2004l\rLevel(\r\n  \u001b[?2004h"]
[55.178876, "o", ">         probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r"]
[55.179023, "o", "\u001b[?2004h> "]
[55.17905, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>         w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.179388, "o", "        h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.179483, "o", "> "]
[55.179545, "o", "        if w == 320 and h == 240:\r\n\u001b[?2004l\r\u001b[?2004h>             return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.179574, "o", "> "]
[55.180036, "o", "        return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.18021, "o", ">     except Exception as e:\r\n\u001b[?2004l\r"]
[55.180331, "o", "\u001b[?2004h> "]
[55.180411, "o", "        return False, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.180482, "o", "> "]
[55.180964, "o", "def validate_gray_pixfmt(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.18111, "o", ">     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.181227, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\rx240,\u001b[?2004h> "]
[55.181448, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.181557, "o", "        pix = v.get(\"pix_fmt\")\r\n\u001b[?2004l\r"]
[55.181619, "o", "\u001b[?2004h> "]
[55.181844, "o", "        if pix == \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h>             return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.182078, "o", "        return False, f\"expected pix_fmt=gray, got {pix}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.182341, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.182564, "o", "        return False, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.182676, "o", "\u001b[?2004h> "]
[55.182867, "o", "def validate_audio_duration_3s(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.183181, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.18339, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         a = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.18357, "o", "        # Prefer stream duration, fall back to format duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.183767, "o", "        dur = a.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.184031, "o", "        if dur is None:\r\n\u001b[?2004l\r"]
[55.184151, "o", "\u001b[?2004h> "]
[55.184328, "o", "            dur = probe.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.18446, "o", "        if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.184497, "o", "> "]
[55.184724, "o", "            return False, \"duration not found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.184952, "o", "        dur_f = float(dur)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.185213, "o", "        if 2.9 <= dur_f <= 3.1:\r\n\u001b[?2004l\r\u001b[?2004h>             return True, \"ok\"\r\n\u001b[?2004l\r 10-second audio clip to exact\u001b[?2004h> "]
[55.185393, "o", "        return False, f\"expected ~3.0s, got {dur_f:.3f}s\"\r\n\u001b[?2004l\r\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.185559, "o", "        return False, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r "]
[55.185643, "o", "\"lev"]
[55.185742, "o", "\u001b[?2004h> "]
[55.185862, "o", "def validate_crop_200x200(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.185958, "o", ">     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.186029, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.186224, "o", ">         v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r"]
[55.186443, "o", "\u001b[?2004h>         w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h>         h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.18661, "o", "        if w == 200 and h == 200:\r\n\u001b[?2004l\r\u001b[?2004h>             return True, \"ok\"\r\n\u001b[?2004l\r"]
[55.186659, "o", "\u001b[?2004h> "]
[55.186887, "o", "        return False, f\"expected 200x200, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.187051, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[55.187206, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.187462, "o", "def validate_scale_and_hflip(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[55.187634, "o", "\u001b[?2004h> "]
[55.187782, "o", "    # Strictly validate size; deterministic checking of flip is nontrivial without\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.187844, "o", "    # comparing pixels. Since this is a filtergraph teaching game, enforce both\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.187875, "o", "> "]
[55.18811, "o", "    # by requiring a metadata side-channel is not possible. We'll validate the\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.188139, "o", "> "]
[55.188342, "o", "    # size strictly and also ensure output differs from a pure scale-only render\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.188373, "o", "> "]
[55.188562, "o", "    # by hashing a single frame extracted as rawvideo.\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\rY"]
[55.188601, "o", "w==\",  # crop=w=2"]
[55.188804, "o", "\u001b[?2004h>         probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.188919, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.18911, "o", "        w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.189142, "o", "> "]
[55.189264, "o", "        h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.189391, "o", "        if not (w == 320 and h == 240):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.189817, "o", "            return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.18985, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[55.189927, "o", "> "]
[55.190321, "o", "        # Compare against a scale-only reference frame hash.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.190486, "o", "        # Extract frame 0 as RGB24 and hash bytes.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.190587, "o", "        def frame_hash(video_path: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.190699, "o", ">             cp = run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.191047, "o", "                \"ffmpeg\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-i\", video_path,\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-vf\", \"select=eq(n\\\\,0)\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.191152, "o", "                \"-frames:v\", \"1\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.191255, "o", "                \"-f\", \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.19137, "o", "                \"-pix_fmt\", \"rgb24\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
