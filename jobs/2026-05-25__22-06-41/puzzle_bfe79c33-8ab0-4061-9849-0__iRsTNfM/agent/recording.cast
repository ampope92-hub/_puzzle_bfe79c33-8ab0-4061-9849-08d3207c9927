[399.127554, "i", "python3 - <<'PY'\nimport re\npath='/app/ffpuzzle.py'\nlines=open(path,'r',encoding='utf-8').read().splitlines(True)\nwant={\n  1:'MDQyOjAyMz1lbGFjcw==',\n  2:'eWFyZz10YW1yb2Y=',\n  3:'MzowPW1pcnRh',\n  4:'Mi8pMDAyLWhpKD15OjIvKTAwMi13aSg9eDowMDI9aDowMDI9dz1wb3Jj',\n  5:'cGlsZmgsMDQyOjAyMz1lbGFjcw=='\n}\nfor i,l in enumerate(lines):\n    m=re.search(r'Level\\((\\d+),', l)\n    if not m:\n        continue\n    lvl=int(m.group(1))\n    # find solution_token line within next few lines\n    for j in range(i, min(i+6, len(lines))):\n        if 'solution_token=' in lines[j]:\n            lines[j]=re.sub(r'solution_token=\"[^\"]+\"', f'solution_token=\"{want[lvl]}\"', lines[j])\n            break\nopen(path,'w',encoding='utf-8').writelines(lines)\nprint('patched tokens')\nPY\n"]
