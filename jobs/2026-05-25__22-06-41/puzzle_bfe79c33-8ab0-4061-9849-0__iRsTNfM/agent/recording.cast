[195.354066, "o", "            stdout=subprocess.PIPE,\r\n\u001b[?2004l\r\u001b[?2004h>             stderr=subprocess.PIPE,\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\rool, str]:"]
[195.354109, "o", "\u001b[?2004h>         if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
