[156.857482, "o", "> "]
[156.85771, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.857805, "o", "> "]
[156.858037, "o", "        \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.858139, "o", "> "]
