[195.36753, "o", "> \r\n\u001b[?2004l\r"]
[195.367621, "o", "\u001b[?2004h>     ok, msg = ffmpeg_apply(level, filtergraph)\r\n\u001b[?2004l\r"]
[195.367666, "o", "\u001b[?2004h> "]
[195.367696, "o", "    if not ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.367793, "o", "        return False, f\"render: {msg}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
