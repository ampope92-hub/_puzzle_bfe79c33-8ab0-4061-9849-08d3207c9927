[156.860693, "o", "    run(["]
[156.860991, "o", "\r\n\u001b[?2004l\r"]
[156.861253, "o", "\u001b[?2004h> "]
[156.861698, "o", "        \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-t\", \"10\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.86221, "o", "        \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
