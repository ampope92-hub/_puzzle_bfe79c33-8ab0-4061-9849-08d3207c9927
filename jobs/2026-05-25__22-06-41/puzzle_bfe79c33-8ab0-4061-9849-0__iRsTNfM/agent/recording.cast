[195.367343, "o", "> "]
[195.367443, "o", "def run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.367464, "o", "    if not os.path.exists(level.input_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
