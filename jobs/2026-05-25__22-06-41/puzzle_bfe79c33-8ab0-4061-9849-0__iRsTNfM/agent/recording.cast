[195.367891, "o", "\u001b[?2004h> "]
[195.367971, "o", "    if not passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.368028, "o", "        return False, f\"validate: {vmsg}\"\r\n\u001b[?2004l\r\u001b[?2004h>     return True, \"ok\"\r\n\u001b[?2004l\r"]
