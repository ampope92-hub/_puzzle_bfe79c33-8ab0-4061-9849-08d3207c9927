[156.859752, "o", "        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\r\n\u001b[?2004l\r"]
[156.859895, "o", "\u001b[?2004h>         \"-t\", \"2\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\rver"]
[156.860053, "o", "\u001b[?2004h>         path,\r\n\u001b[?2004l\r"]
[156.860272, "o", "\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
