[104.098686, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.098788, "o", "def ffmpeg_apply(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.09898, "o", "    safe_unlink(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if level.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.099159, "o", "            \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\", level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r"]
[104.099308, "o", "\u001b[?2004h>             level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h>     elif level.num == 3:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r"]
[104.099416, "o", "\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.099564, "o", "            \"-i\", level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.09959, "o", "            \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.099636, "o", "            level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.099678, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.099739, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.09981, "o", "            \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.099929, "o", "            \"-i\", level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.100016, "o", "            \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>             level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.100128, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     cp = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.100166, "o", ">     if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.100232, "o", "        return False, cp.stderr.strip() or \"ffmpeg failed\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.10028, "o", "> "]
[104.100305, "o", "    return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[104.100311, "o", "\u001b[?2004h> "]
[104.100443, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.100529, "o", "    if not os.path.exists(level.input_path):\r\n\u001b[?2004l\r\u001b[?2004h>         level.build_input()\r\n\u001b[?2004l\r"]
[104.100679, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ok, msg = ffmpeg_apply(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h"]
[104.100791, "o", ">     if not ok:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, f\"render: {msg}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[104.100926, "o", "\u001b[?2004h>     passed, vmsg = level.validate(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     if not passed:\r\n\u001b[?2004l\r"]
[104.101046, "o", "\u001b[?2004h> "]
[104.101127, "o", "        return False, f\"validate: {vmsg}\"\r\n\u001b[?2004l\r\u001b[?2004h>     return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[104.101146, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101212, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101231, "o", "    manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101503, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         filt = obf_decode(lvl.solution_token)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101588, "o", "        passed, _ = run_level(lvl, filt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101725, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.101852, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.10192, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": lvl.num,\r\n\u001b[?2004l\r"]
[104.102046, "o", "\u001b[?2004h>             \"filename\": os.path.basename(lvl.output_path),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102161, "o", "            \"passed\": bool(passed),\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102263, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102407, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>         f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102477, "o", "    print(f\"Score: {score}/{len(levels) * 10}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102565, "o", "    return 0 if score == len(levels) * 10 else 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102724, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     total = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[104.102907, "o", "    for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h>         total += 10\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r"]
[104.10308, "o", "\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h>             user_filt = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
