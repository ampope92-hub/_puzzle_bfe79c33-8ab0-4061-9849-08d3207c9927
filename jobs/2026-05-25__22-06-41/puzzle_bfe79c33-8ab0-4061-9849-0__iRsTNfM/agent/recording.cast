[156.8628, "o", "    ])\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r,\u001b[?2004h> "]
[156.863138, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.863614, "o", "> "]
[156.863788, "o", "# ----------------- validators -----------------\r\n\u001b[?2004l\r"]
[156.863843, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.864346, "o", "def validate_wh(out_path: str, w_exp: int, h_exp: int) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.864648, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.864932, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.864972, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.865174, "o", "        w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.865299, "o", "        h = int(v.get(\"height\", -1))\r\n"]
[156.865369, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[156.865763, "o", "        if w == w_exp and h == h_exp:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.866201, "o", "            return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.867002, "o", "        return False, f\"expected {w_exp}x{h_exp}, got {w}x{h}\"\r\n\u001b[?2004l\re\u001b[?2004h> "]
[156.86746, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.86773, "o", "> "]
[156.867844, "o", "        return False, str(e)\r\n\u001b[?2004l\rs.pat\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.868037, "o", "def validate_pixfmt_gray(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.868159, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.868775, "o", "        probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r"]
[156.868921, "o", "\u001b[?2004h> "]
[156.869203, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.869437, "o", "        pix = v.get(\"pix_fmt\")\r\n\u001b[?2004l\r"]
[156.869578, "o", "\u001b[?2004h"]
[156.869661, "o", ">         if pix == \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.86982, "o", "            return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.869991, "o", "> "]
[156.870376, "o", "        return False, f\"expected pix_fmt=gray, got {pix}\"\r\n\u001b[?2004l\r"]
[156.870515, "o", "\u001b[?2004h> "]
[156.870786, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.870955, "o", "> "]
[156.871261, "o", "        return False, str(e)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.871731, "o", "def validate_audio_dur_approx_3s(out_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[156.871886, "o", "\u001b[?2004h> "]
[156.872018, "o", "    try:\r\n\u001b[?2004l\r"]
[156.872267, "o", "\u001b[?2004h> "]
[156.872426, "o", "        probe = ffprobe_json(out_path)"]
[156.872465, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.872631, "o", "        a = get_first_stream(probe, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.872934, "o", "        dur = a.get(\"duration\") or probe.get(\"format\", {}).get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.873093, "o", ">         if dur is None:\r\n\u001b[?2004l\r"]
[156.873219, "o", "\u001b[?2004h> "]
[156.87329, "o", "            return False, \"duration not found\"\r\n\u001b[?2004l\rf l\u001b[?2004h"]
[156.873397, "o", ">         d = float(dur)\r\n\u001b[?2004l\r"]
[156.873503, "o", "\u001b[?2004h> "]
[156.87372, "o", "        if 2.9 <= d <= 3.1:\r\n\u001b[?2004l\r"]
[156.873859, "o", "\u001b[?2004h> "]
[156.873965, "o", "            return True, \"ok\"\r\n\u001b[?2004l\r"]
[156.874057, "o", "\u001b[?2004h> "]
[156.874201, "o", "        return False, f\"expected ~3.0s, got {d:.3f}s\"\r\n\u001b[?2004l\r"]
[156.874331, "o", "\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, str(e)\r\n\u001b[?2004l\r"]
[156.874555, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.874738, "o", "def validate_scale_and_hflip(out_path: str, in_path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.874852, "o", "> "]
[156.875098, "o", "    ok, msg = validate_wh(out_path, 320, 240)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.875234, "o", "    if not ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.875355, "o", "        return ok, msg\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rl"]
[156.875524, "o", "\u001b[?2004h>     import hashlib\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.876183, "o", "    def frame_hash(video_path: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.876558, "o", "        cp = subprocess.run(\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.876609, "o", ">             ["]
[156.876631, "o", "\r\n\u001b[?2004l\r"]
[156.87675, "o", "\u001b[?2004h"]
[156.876924, "o", "> "]
[156.877148, "o", "                \"ffmpeg\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.877192, "o", "> "]
[156.877605, "o", "                \"-i\", video_path,\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.877646, "o", "> "]
[156.877938, "o", "                \"-vf\", \"select=eq(n\\\\,0)\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.878147, "o", "                \"-frames:v\", \"1\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"-f\", \"rawvideo\",\r\n\u001b[?2004l\r"]
[156.878356, "o", "\u001b[?2004h> "]
[156.878436, "o", "                \"-pix_fmt\", \"rgb24\",\r\n\u001b[?2004l\r"]
[156.878526, "o", "\u001b[?2004h>                 \"-\",\r\n\u001b[?2004l\rrncode != 0:\r\n "]
[156.878625, "o", "       \u001b[?2004h> "]
[156.878692, "o", "            ],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.87923, "o", "            stdout=subprocess.PIPE,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.879326, "o", "            stderr=subprocess.PIPE,\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r"]
[156.879398, "o", "\u001b[?2004h> "]
[156.879499, "o", "        if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.879799, "o", "> "]
[156.879981, "o", "            raise RuntimeError(cp.stderr.decode(\"utf-8\", errors=\"ignore\").strip())\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.880083, "o", "> "]
[156.880163, "o", "        return hashlib.sha256(cp.stdout).hexdigest()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[156.88019, "o", "\u001b[?2004l\r"]
[156.880294, "o", "\u001b[?2004h> "]
[156.880539, "o", "    ref_path = os.path.join(OUTPUT_DIR, \"_level5_ref_scaleonly.mp4\")\r\n\u001b[?2004l\r"]
[156.880743, "o", "\u001b[?2004h>     safe_unlink(ref_path)\r\n\u001b[?2004l\r\u001b[?2004h>     cp_ref = run([\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-i\", in_path,\r\n\u001b[?2004l\r"]
[156.881046, "o", "\u001b[?2004h>         \"-vf\", \"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         ref_path,\r\n\u001b[?2004l\r  "]
[156.88115, "o", "\u001b[?2004h>     ])\r\n\u001b[?2004l\rscore =\u001b[?2004h> "]
[156.881173, "o", "    if cp_ref.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.881544, "o", "        return False, f\"ref render failed: {cp_ref.stderr.strip()}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.881617, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.881673, "o", "    try:\r\n\u001b[?2004l\r"]
[156.881711, "o", "\u001b[?2004h>         h_out = frame_hash(out_path)\r\n\u001b[?2004l\r"]
[156.881774, "o", "\u001b[?2004h> "]
[156.881878, "o", "        h_ref = frame_hash(ref_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.881961, "o", "    finally:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.88212, "o", "        safe_unlink(ref_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r=\u001b[?2004h> "]
[156.882385, "o", "    if h_out == h_ref:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.882493, "o", "        return False, \"output appears to be scale-only (missing hflip)\"\r\n\u001b[?2004l\r"]
[156.882574, "o", "\u001b[?2004h>     return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.882602, "o", "vl.num,\r\n            \"fi\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.882786, "o", "# ----------------- level definitions -----------------\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rp"]
[156.882981, "o", "\u001b[?2004h> def make_levels() -> List[Level]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.883118, "o", "    l1_in = os.path.join(ASSETS_DIR, \"level1_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.883282, "o", "    l2_in = os.path.join(ASSETS_DIR, \"level2_input.avi\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.883314, "o", "> "]
[156.883634, "o", "    l3_in = os.path.join(ASSETS_DIR, \"level3_input.wav\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.883805, "o", "    l4_in = os.path.join(ASSETS_DIR, \"level4_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.883933, "o", "    l5_in = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.884142, "o", "    # Plain solutions (kept out of source via tokenization at build time).\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.884301, "o", "    # Tokens are base64(reverse(solution)).\r\n"]
[156.884368, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[156.884415, "o", "    tok1 = \"MGI0MjoyMz1lbGFjcw==\"  # scale=320:240"]
[156.884509, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.884669, "o", "    tok2 = obf_encode(\"format=gray\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.884855, "o", "    tok3 = obf_encode(\"atrim=0:3\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.885757, "o", "    tok4 = obf_encode(\"crop=w=200:h=200:x=(iw-200)/2:y=(ih-200)/2\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.885783, "o", "> "]
[156.886144, "o", "    tok5 = \"cGlsZmgscGI0MjoyMz1lbGFjcw==\"  # scale=320:240,hflip\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.886181, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[156.886199, "o", ">     return [\r\n\u001b[?2004l\r"]
[156.886254, "o", "\u001b[?2004h> "]
[156.887117, "o", "        Level(1, \"Scale down\", \"Scale a 640x480 video down to 320x240.\", l1_in,\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.887151, "o", "> "]
[156.887319, "o", "              os.path.join(OUTPUT_DIR, \"level1_output.mp4\"),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.88766, "o", "              build_input=lambda p=l1_in: gen_video_mp4_640x480(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.888334, "o", "              validate=lambda out: validate_wh(out, 320, 240),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.888514, "o", "              solution_token=tok1),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.888803, "o", "        Level(2, \"Grayscale\", \"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\", l2_in,\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.88883, "o", "> "]
[156.889168, "o", "              os.path.join(OUTPUT_DIR, \"level2_output.avi\"),\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.889187, "o", "> "]
[156.88936, "o", "              build_input=lambda p=l2_in: gen_video_avi_raw_640x480(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.889767, "o", "              validate=validate_pixfmt_gray,\r\n\u001b[?2004l\r\u001b[?2004h>               solution_token=tok2),\r\n\u001b[?2004l\r\u001b[?2004h>         Level(3, \"Audio trim\", \"Trim a 10-second audio clip to exactly 3 seconds (2.9s - 3.1s accepted).\", l3_in,\r\n\u001b[?2004l\r\u001b[?2004h>               os.path.join(OUTPUT_DIR, \"level3_output.wav\"),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.890009, "o", "              build_input=lambda p=l3_in: gen_audio_wav_10s(p),\r\n\u001b[?2004l\r\u001b[?2004h>               validate=validate_audio_dur_approx_3s,\r\n\u001b[?2004l\r\u001b[?2004h>               solution_token=tok3),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.89017, "o", "        Level(4, \"Center crop\", \"Crop the center 200x200 region from a 640x480 video.\", l4_in,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.890255, "o", "              os.path.join(OUTPUT_DIR, \"level4_output.mp4\"),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.890368, "o", "              build_input=lambda p=l4_in: gen_video_mp4_640x480(p),\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.890397, "o", "> "]
[156.890526, "o", "              validate=lambda out: validate_wh(out, 200, 200),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.890544, "o", "              solution_token=tok4),\r\n\u001b[?2004l\r\u001b[?2004h> "]
