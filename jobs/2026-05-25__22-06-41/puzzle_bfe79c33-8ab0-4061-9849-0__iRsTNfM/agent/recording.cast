[55.20563, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> def run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[55.205693, "o", "\u001b[?2004h> "]
[55.205768, "o", "    # Ensure input exists (or regenerate deterministically)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.205784, "o", "    if not os.path.exists(level.input_path):\r\n\u001b[?2004l\r"]
