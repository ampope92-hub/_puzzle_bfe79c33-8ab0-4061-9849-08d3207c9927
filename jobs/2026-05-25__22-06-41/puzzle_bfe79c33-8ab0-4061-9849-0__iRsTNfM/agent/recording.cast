[195.327255, "i", "python3 - <<'PY'\nscript = '''#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef run(cmd: List[str]) -> subprocess.CompletedProcess:\n    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef safe_unlink(path: str) -> None:\n    try:\n        os.unlink(path)\n    except FileNotFoundError:\n        pass\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cp = run([\n        \"ffprobe\",\n        \"-v\", \"error\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        path,\n    ])\n    if cp.returncode != 0:\n        raise RuntimeError(f\"ffprobe failed: {cp.stderr.strip()}\")\n    return json.loads(cp.stdout)\n\n\ndef get_first_"]
[195.327485, "i", "stream(probe: Dict, codec_type: str) -> Dict:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    raise KeyError(f\"No {codec_type} stream found\")\n\n\ndef obf_decode(token: str) -> str:\n    # token is base64(reverse(solution))\n    raw = base64.b64decode(token.encode(\"ascii\"))\n    return raw.decode(\"utf-8\")[::-1]\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_path: str\n    output_path: str\n    build_input: Callable[[], None]\n    validate: Callable[[str], Tuple[bool, str]]\n    solution_token: str\n\n\ndef gen_video_mp4_640x480(path: str) -> None:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-pix_fmt\", \"yuv420p\",\n        path,\n    ])\n\n\ndef gen_video_avi_raw_640x480(path: str) -> None:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-c:v\", \"raw"]
[195.327538, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> script = '''#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import argparse\r\n\u001b[?2004l\r\u001b[?2004h> import base64\r\n\u001b[?2004l\r"]
[195.327553, "i", "video\",\n        path,\n    ])\n\n\ndef gen_audio_wav_10s(path: str) -> None:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\n        \"-t\", \"10\",\n        \"-c:a\", \"pcm_s16le\",\n        path,\n    ])\n\n\ndef validate_wh(out_path: str, w_exp: int, h_exp: int) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        v = get_first_stream(probe, \"video\")\n        w = int(v.get(\"width\", -1))\n        h = int(v.get(\"height\", -1))\n        if w == w_exp and h == h_exp:\n            return True, \"ok\"\n        return False, f\"expected {w_exp}x{h_exp}, got {w}x{h}\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_pixfmt_gray(out_path: str) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        v = get_first_stream(probe, \"video\")\n        pix = v.get(\"pix_fmt\")\n        if pix == \"gray\":\n            return True, \"ok\"\n        return False, f\"expected pix_fmt=gray, got {pix}\"\n    except Exception as e:\n    "]
