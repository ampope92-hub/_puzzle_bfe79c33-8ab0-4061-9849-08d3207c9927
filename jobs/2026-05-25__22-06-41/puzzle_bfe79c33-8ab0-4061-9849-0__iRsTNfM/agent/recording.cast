[156.891001, "o", "\u001b[?2004h> "]
[156.891133, "o", "              validate=lambda out, inp=l5_in: validate_scale_and_hflip(out, inp),\r\n\u001b[?2004l\r\u001b[?2004h>               solution_token=tok5),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.891166, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.89125, "o", "\u001b[?2004h> "]
[156.891342, "o", "def ffmpeg_apply(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.891424, "o", "> "]
[156.891451, "o", "    safe_unlink(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.891627, "o", "\u001b[?2004h>     if level.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.891755, "o", "            \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\", level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.891913, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892021, "o", "            level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892132, "o", "    elif level.num == 3:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892261, "o", "            \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\", level.input_path,\r\n\u001b[?2004l\r"]
[156.892342, "o", "\u001b[?2004h>             \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892363, "o", "            \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892437, "o", "            level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.892501, "o", ">         ]\r\n\u001b[?2004l\r"]
[156.892508, "o", "\u001b[?2004h"]
[156.892674, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-v\", \"error\",\r\n\u001b[?2004l\r"]
[156.892781, "o", "\u001b[?2004h> "]
[156.892837, "o", "            \"-i\", level.input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892871, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.892921, "o", "            level.output_path,\r\n\u001b[?2004l\r"]
[156.892971, "o", "\u001b[?2004h> "]
[156.893096, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893273, "o", "    cp = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, cp.stderr.strip() or \"ffmpeg failed\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893408, "o", "    return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893468, "o", "def run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[156.893498, "o", "\u001b[?2004h> "]
[156.893591, "o", "    if not os.path.exists(level.input_path):\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.893633, "o", "> "]
[156.893708, "o", "        level.build_input()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.89374, "o", "    ok, msg = ffmpeg_apply(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893862, "o", "    if not ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893888, "o", "        return False, f\"render: {msg}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.893938, "o", "    passed, vmsg = level.validate(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     if not passed:\r\n\u001b[?2004l\r"]
[156.893982, "o", "\u001b[?2004h> "]
[156.894034, "o", "        return False, f\"validate: {vmsg}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.894161, "o", ">     return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894253, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.89435, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.894431, "o", "\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r"]
[156.894447, "o", "\u001b[?2004h> "]
[156.894595, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894631, "o", "        filt = obf_decode(lvl.solution_token)\r\n\u001b[?2004l\r\u001b[?2004h>         passed, _ = run_level(lvl, filt)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894673, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.894726, "o", "> "]
[156.894753, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r"]
[156.894818, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894873, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894976, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.894998, "o", "            \"level\": lvl.num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895105, "o", "            \"filename\": os.path.basename(lvl.output_path),\r\n\u001b[?2004l\r\u001b[?2004h>             \"passed\": bool(passed),\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.895139, "o", ">         })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.895244, "o", "\u001b[?2004h> "]
[156.895266, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895387, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895473, "o", "        f.write(\"\\n\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895621, "o", "    print(f\"Score: {score}/{len(levels) * 10}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0 if score == len(levels) * 10 else 1"]
[156.895709, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.895766, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895839, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895906, "o", "    total = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.895933, "o", "    earned = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.895995, "o", "\u001b[?2004h> "]
[156.896013, "o", "    for lvl in levels:\r\n\u001b[?2004l\r"]
[156.896095, "o", "\u001b[?2004h>         total += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.896115, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.896221, "o", "> "]
[156.896326, "o", "        print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.896404, "o", "            user_filt = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r"]
[156.896518, "o", "\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if not user_filt:"]
[156.896613, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.89665, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[156.896735, "o", "\u001b[?2004l\r"]
[156.896837, "o", "\u001b[?2004h> "]
[156.896859, "o", "        passed, detail = run_level(lvl, user_filt)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897025, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             earned += 10\r\n\u001b[?2004l\r"]
[156.897078, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897105, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897178, "o", "            print(f\"  {detail}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.897344, "o", "\u001b[?2004h> "]
[156.897357, "o", "    print(f\"Score: {earned}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.897438, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.89751, "o", "def main(argv: Optional[List[str]] = None) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897628, "o", "    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897738, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.897795, "o", "> "]
[156.897862, "o", "    args = ap.parse_args(argv)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897883, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.897943, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.897979, "o", "> "]
[156.898056, "o", "    levels = make_levels()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:"]
[156.898121, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.898188, "o", "        return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.898236, "o", "> "]
[156.898326, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[156.898419, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.898486, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[156.898544, "o", "\u001b[?2004h> "]
[156.89859, "o", "    raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> '''\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.898659, "o", "print(base64.b64encode(script.encode('utf-8')).decode('ascii'))\r\n\u001b[?2004l\r\u001b[?2004h"]
[156.898719, "o", "> "]
