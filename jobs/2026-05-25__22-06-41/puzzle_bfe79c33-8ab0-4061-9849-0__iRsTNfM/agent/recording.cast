[156.852564, "o", "def get_first_stream(probe: Dict, codec_type: str) -> Dict:\r\n\u001b[?2004l\r\u001b[?2004h>     for s in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.853144, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r\u001b[?2004h>             return s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.853483, "o", "    raise KeyError(f\"No {codec_type} stream found\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rput.mp4\"\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.853717, "o", "def obf_encode(plain: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.854347, "o", "    return base64.b64encode(plain[::-1].encode(\"utf-8\")).decode(\"ascii\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.854532, "o", "def obf_decode(token: str) -> str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.854692, "o", "    raw = base64.b64decode(token.encode(\"ascii\"))\r\n\u001b[?2004l\r\u001b[?2004h>     return raw.decode(\"utf-8\")[::-1]\r\n\u001b[?2004l\r"]
[156.854725, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
