[195.345946, "o", "\u001b[?2004l\r\u001b[?2004h>         probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.346384, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
