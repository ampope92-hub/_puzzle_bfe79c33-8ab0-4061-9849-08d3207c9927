[156.848683, "i", "python3 - <<'PY'\nimport base64\nscript = r'''#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n\ndef run(cmd: List[str]) -> subprocess.CompletedProcess:\n    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef safe_unlink(path: str) -> None:\n    try:\n        os.unlink(path)\n    except FileNotFoundError:\n        pass\n\n\ndef ffprobe_json(path: str) -> Dict:\n    cp = run([\n        \"ffprobe\",\n        \"-v\", \"error\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        path,\n    ])\n    if cp.returncode != 0:\n        raise RuntimeError(f\"ffprobe failed: {cp.stderr.strip()}\")\n    return json.loads(cp.stdout)\n\n"]
[156.848832, "i", "\ndef get_first_stream(probe: Dict, codec_type: str) -> Dict:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    raise KeyError(f\"No {codec_type} stream found\")\n\n\ndef obf_encode(plain: str) -> str:\n    return base64.b64encode(plain[::-1].encode(\"utf-8\")).decode(\"ascii\")\n\n\ndef obf_decode(token: str) -> str:\n    raw = base64.b64decode(token.encode(\"ascii\"))\n    return raw.decode(\"utf-8\")[::-1]\n\n\n@dataclass\nclass Level:\n    num: int\n    name: str\n    description: str\n    input_path: str\n    output_path: str\n    build_input: Callable[[], None]\n    validate: Callable[[str], Tuple[bool, str]]\n    solution_token: str\n\n\n# ----------------- input generators (lavfi only) -----------------\n\ndef gen_video_mp4_640x480(path: str) -> None:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-pix_fmt\", \"yuv420p\",\n        path,\n    ])\n\n\ndef gen_video_avi_raw_640x480(path: str) -> Non"]
[156.848885, "o", "python3 - <<'PY'\r\n\u001b[?2004l\r\u001b[?2004h> import base64\r\n\u001b[?2004l\r"]
[156.848969, "i", "e:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30\",\n        \"-t\", \"2\",\n        \"-c:v\", \"rawvideo\",\n        path,\n    ])\n\n\ndef gen_audio_wav_10s(path: str) -> None:\n    run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000\",\n        \"-t\", \"10\",\n        \"-c:a\", \"pcm_s16le\",\n        path,\n    ])\n\n\n# ----------------- validators -----------------\n\ndef validate_wh(out_path: str, w_exp: int, h_exp: int) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        v = get_first_stream(probe, \"video\")\n        w = int(v.get(\"width\", -1))\n        h = int(v.get(\"height\", -1))\n        if w == w_exp and h == h_exp:\n            return True, \"ok\"\n        return False, f\"expected {w_exp}x{h_exp}, got {w}x{h}\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_pixfmt_gray(out_path: str) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        v = get_fi"]
[156.849004, "o", "\u001b[?2004h> script = r'''#!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> import argparse\r\n\u001b[?2004l\r\u001b[?2004h> import base64\r\n\u001b[?2004l\r\u001b[?2004h> import json"]
[156.849121, "i", "rst_stream(probe, \"video\")\n        pix = v.get(\"pix_fmt\")\n        if pix == \"gray\":\n            return True, \"ok\"\n        return False, f\"expected pix_fmt=gray, got {pix}\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_audio_dur_approx_3s(out_path: str) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        a = get_first_stream(probe, \"audio\")\n        dur = a.get(\"duration\") or probe.get(\"format\", {}).get(\"duration\")\n        if dur is None:\n            return False, \"duration not found\"\n        d = float(dur)\n        if 2.9 <= d <= 3.1:\n            return True, \"ok\"\n        return False, f\"expected ~3.0s, got {d:.3f}s\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_scale_and_hflip(out_path: str, in_path: str) -> Tuple[bool, str]:\n    ok, msg = validate_wh(out_path, 320, 240)\n    if not ok:\n        return ok, msg\n\n    import hashlib\n\n    def frame_hash(video_path: str) -> str:\n        cp = subprocess.run(\n            [\n                \"ffmpe"]
[156.849227, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> import os\r\n\u001b[?2004l\r\u001b[?2004h> import subprocess\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.849349, "i", "g\", \"-v\", \"error\",\n                \"-i\", video_path,\n                \"-vf\", \"select=eq(n\\\\,0)\",\n                \"-frames:v\", \"1\",\n                \"-f\", \"rawvideo\",\n                \"-pix_fmt\", \"rgb24\",\n                \"-\",\n            ],\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n        )\n        if cp.returncode != 0:\n            raise RuntimeError(cp.stderr.decode(\"utf-8\", errors=\"ignore\").strip())\n        return hashlib.sha256(cp.stdout).hexdigest()\n\n    ref_path = os.path.join(OUTPUT_DIR, \"_level5_ref_scaleonly.mp4\")\n    safe_unlink(ref_path)\n    cp_ref = run([\n        \"ffmpeg\", \"-y\", \"-v\", \"error\",\n        \"-i\", in_path,\n        \"-vf\", \"scale=320:240\",\n        \"-pix_fmt\", \"yuv420p\",\n        ref_path,\n    ])\n    if cp_ref.returncode != 0:\n        return False, f\"ref render failed: {cp_ref.stderr.strip()}\"\n\n    try:\n        h_out = frame_hash(out_path)\n        h_ref = frame_hash(ref_path)\n    finally:\n        safe_unlink(ref_path)\n\n    if h_out == h_ref:\n        return False, \""]
[156.849403, "o", "from dataclasses import dataclass\r\n\u001b[?2004l\r\u001b[?2004h> from typing import Callable, Dict, List, Optional, Tuple\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ASSETS_DIR = \"/app/assets\"\r\n\u001b[?2004l\r\u001b[?2004h> OUTPUT_DIR = \"/app/output\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.849508, "i", "output appears to be scale-only (missing hflip)\"\n    return True, \"ok\"\n\n\n# ----------------- level definitions -----------------\n\ndef make_levels() -> List[Level]:\n    l1_in = os.path.join(ASSETS_DIR, \"level1_input.mp4\")\n    l2_in = os.path.join(ASSETS_DIR, \"level2_input.avi\")\n    l3_in = os.path.join(ASSETS_DIR, \"level3_input.wav\")\n    l4_in = os.path.join(ASSETS_DIR, \"level4_input.mp4\")\n    l5_in = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n\n    # Plain solutions (kept out of source via tokenization at build time).\n    # Tokens are base64(reverse(solution)).\n    tok1 = \"MGI0MjoyMz1lbGFjcw==\"  # scale=320:240\n    tok2 = obf_encode(\"format=gray\")\n    tok3 = obf_encode(\"atrim=0:3\")\n    tok4 = obf_encode(\"crop=w=200:h=200:x=(iw-200)/2:y=(ih-200)/2\")\n    tok5 = \"cGlsZmgscGI0MjoyMz1lbGFjcw==\"  # scale=320:240,hflip\n\n    return [\n        Level(1, \"Scale down\", \"Scale a 640x480 video down to 320x240.\", l1_in,\n              os.path.join(OUTPUT_DIR, \"level1_output.mp4\"),\n              build_input=lambda p=l1_in: ge"]
[156.84957, "o", "MANIFEST_PATH = \"/app/manifest.json\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.849588, "i", "n_video_mp4_640x480(p),\n              validate=lambda out: validate_wh(out, 320, 240),\n              solution_token=tok1),\n        Level(2, \"Grayscale\", \"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\", l2_in,\n              os.path.join(OUTPUT_DIR, \"level2_output.avi\"),\n              build_input=lambda p=l2_in: gen_video_avi_raw_640x480(p),\n              validate=validate_pixfmt_gray,\n              solution_token=tok2),\n        Level(3, \"Audio trim\", \"Trim a 10-second audio clip to exactly 3 seconds (2.9s - 3.1s accepted).\", l3_in,\n              os.path.join(OUTPUT_DIR, \"level3_output.wav\"),\n              build_input=lambda p=l3_in: gen_audio_wav_10s(p),\n              validate=validate_audio_dur_approx_3s,\n              solution_token=tok3),\n        Level(4, \"Center crop\", \"Crop the center 200x200 region from a 640x480 video.\", l4_in,\n              os.path.join(OUTPUT_DIR, \"level4_output.mp4\"),\n              build_input=lambda p=l4_in: gen_video_mp4_640x480(p),\n              validat"]
[156.849671, "o", "def run(cmd: List[str]) -> subprocess.CompletedProcess:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.84968, "i", "e=lambda out: validate_wh(out, 200, 200),\n              solution_token=tok4),\n        Level(5, \"Scale + hflip\", \"Scale to 320x240 AND apply a horizontal flip.\", l5_in,\n              os.path.join(OUTPUT_DIR, \"level5_output.mp4\"),\n              build_input=lambda p=l5_in: gen_video_mp4_640x480(p),\n              validate=lambda out, inp=l5_in: validate_scale_and_hflip(out, inp),\n              solution_token=tok5),\n    ]\n\n\ndef ffmpeg_apply(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    safe_unlink(level.output_path)\n\n    if level.num == 2:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-vf\", filtergraph,\n            \"-c:v\", \"rawvideo\",\n            level.output_path,\n        ]\n    elif level.num == 3:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-af\", filtergraph,\n            \"-c:a\", \"pcm_s16le\",\n            level.output_path,\n        ]\n    else:\n        cmd = [\n            \"ffmpeg\""]
[156.849685, "i", ", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-vf\", filtergraph,\n            \"-pix_fmt\", \"yuv420p\",\n            level.output_path,\n        ]\n\n    cp = run(cmd)\n    if cp.returncode != 0:\n        return False, cp.stderr.strip() or \"ffmpeg failed\"\n    return True, \"ok\"\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    if not os.path.exists(level.input_path):\n        level.build_input()\n\n    ok, msg = ffmpeg_apply(level, filtergraph)\n    if not ok:\n        return False, f\"render: {msg}\"\n\n    passed, vmsg = level.validate(level.output_path)\n    if not passed:\n        return False, f\"validate: {vmsg}\"\n    return True, \"ok\"\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    score = 0\n\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        filt = obf_decode(lvl.solution_token)\n        passed, _ = run_level(lvl, filt)\n        if passed:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n\n"]
[156.849701, "i", "        manifest.append({\n            \"level\": lvl.num,\n            \"filename\": os.path.basename(lvl.output_path),\n            \"passed\": bool(passed),\n        })\n\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump(manifest, f, indent=2)\n        f.write(\"\\n\")\n\n    print(f\"Score: {score}/{len(levels) * 10}\")\n    return 0 if score == len(levels) * 10 else 1\n\n\ndef interactive(levels: List[Level]) -> int:\n    total = 0\n    earned = 0\n\n    for lvl in levels:\n        total += 10\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        print(lvl.description)\n        try:\n            user_filt = input(\"> \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n\n        if not user_filt:\n            print(\"  FAIL\")\n            continue\n\n        passed, detail = run_level(lvl, user_filt)\n        if passed:\n            print(\"  PASS\")\n            earned += 10\n        else:\n            print(\"  FAIL\")\n            print(f\"  {detail}\")\n\n    print(f\"Score: {earned}/{total}\")"]
[156.849713, "i", "\n    return 0\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions\")\n    args = ap.parse_args(argv)\n\n    ensure_dirs()\n    levels = make_levels()\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n'''\nprint(base64.b64encode(script.encode('utf-8')).decode('ascii'))\nPY\n"]
[156.849863, "o", "    return subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\r\n\u001b[?2004l\r"]
