[195.328092, "i", "o_mp4_640x480(p),\n            validate=lambda out, inp=l5_in: validate_scale_and_hflip(out, inp),\n            solution_token=\"cGlsZmgscGI0MjoyMz1lbGFjcw==\",\n        ),\n    ]\n\n\ndef ffmpeg_apply(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    safe_unlink(level.output_path)\n\n    if level.num == 2:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-vf\", filtergraph,\n            \"-c:v\", \"rawvideo\",\n            level.output_path,\n        ]\n    elif level.num == 3:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-af\", filtergraph,\n            \"-c:a\", \"pcm_s16le\",\n            level.output_path,\n        ]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\", \"-v\", \"error\",\n            \"-i\", level.input_path,\n            \"-vf\", filtergraph,\n            \"-pix_fmt\", \"yuv420p\",\n            level.output_path,\n        ]\n\n    cp = run(cmd)\n    if cp.returncode != 0:\n        return False, cp.stderr.st"]
[195.328097, "i", "rip() or \"ffmpeg failed\"\n    return True, \"ok\"\n\n\ndef run_level(level: Level, filtergraph: str) -> Tuple[bool, str]:\n    if not os.path.exists(level.input_path):\n        level.build_input()\n\n    ok, msg = ffmpeg_apply(level, filtergraph)\n    if not ok:\n        return False, f\"render: {msg}\"\n\n    passed, vmsg = level.validate(level.output_path)\n    if not passed:\n        return False, f\"validate: {vmsg}\"\n    return True, \"ok\"\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = []\n    score = 0\n\n    for lvl in levels:\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        filt = obf_decode(lvl.solution_token)\n        passed, _ = run_level(lvl, filt)\n        if passed:\n            print(\"  PASS\")\n            score += 10\n        else:\n            print(\"  FAIL\")\n\n        manifest.append({\n            \"level\": lvl.num,\n            \"filename\": os.path.basename(lvl.output_path),\n            \"passed\": bool(passed),\n        })\n\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump(manifest"]
[195.3281, "i", ", f, indent=2)\n        f.write(\"\\n\")\n\n    print(f\"Score: {score}/{len(levels) * 10}\")\n    return 0 if score == len(levels) * 10 else 1\n\n\ndef interactive(levels: List[Level]) -> int:\n    total = 0\n    earned = 0\n\n    for lvl in levels:\n        total += 10\n        print(f\"Level {lvl.num}: {lvl.name}\")\n        print(lvl.description)\n        try:\n            user_filt = input(\"> \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n\n        if not user_filt:\n            print(\"  FAIL\")\n            continue\n\n        passed, detail = run_level(lvl, user_filt)\n        if passed:\n            print(\"  PASS\")\n            earned += 10\n        else:\n            print(\"  FAIL\")\n            print(f\"  {detail}\")\n\n    print(f\"Score: {earned}/{total}\")\n    return 0\n\n\ndef main(argv: Optional[List[str]] = None) -> int:\n    ap = argparse.ArgumentParser(description=\"FFmpeg filtergraph puzzle game\")\n    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with built-in solutions"]
[195.328104, "i", "\")\n    args = ap.parse_args(argv)\n\n    ensure_dirs()\n    levels = make_levels()\n\n    if args.auto_solve:\n        return auto_solve(levels)\n    return interactive(levels)\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n'''\nwith open('/app/ffpuzzle.py','w',encoding='utf-8') as f:\n    f.write(script)\nos.chmod('/app/ffpuzzle.py', 0o755)\nprint('wrote /app/ffpuzzle.py')\nPY\n"]
