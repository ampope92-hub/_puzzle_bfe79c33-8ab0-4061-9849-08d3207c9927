[195.342979, "o", "def validate_wh(out_path: str, w_exp: int, h_exp: int) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h>         probe = ffprobe_json(out_path)\r\n\u001b[?2004l\r"]
[195.343047, "o", "\u001b[?2004h> "]
[195.343264, "o", "        v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[195.343417, "o", "        w = int(v.get(\"width\", -1))\r\n\u001b[?2004l\r"]
[195.343467, "o", "\u001b[?2004h> "]
[195.343526, "o", "        h = int(v.get(\"height\", -1))\r\n\u001b[?2004l\rat\u001b[?2004h> "]
