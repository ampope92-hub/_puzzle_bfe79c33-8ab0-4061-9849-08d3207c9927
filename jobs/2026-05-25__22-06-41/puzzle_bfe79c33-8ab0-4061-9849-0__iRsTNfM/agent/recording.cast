[55.205939, "o", "        # Keep deterministic; do not regenerate unless missing.\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.206006, "o", ">         pass\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[55.206064, "o", "\u001b[?2004h> "]
[55.206132, "o", "    ok_run, msg_run = ffmpeg_apply_filter(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.206269, "o", "    if not ok_run:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, f\"render: {msg_run}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.206368, "o", "    passed, msg_val = level.validate(level.output_path)\r\n\u001b[?2004l\r"]
[55.206389, "o", "\u001b[?2004h>     if not passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[55.206494, "o", ">         return False, f\"validate: {msg_val}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.206622, "o", "    return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.206637, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.20674, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[55.206877, "o", "\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.206934, "o", "        print(f\"Level {lvl.num}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.207057, "o", "        filt = obf_decode(lvl.solution_token)\r\n\u001b[?2004l\r\u001b[?2004h>         passed, _detail = run_level(lvl, filt)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r"]
[55.207125, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r"]
[55.207206, "o", "\u001b[?2004h> "]
[55.207226, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[55.207352, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r"]
[55.207368, "o", "\u001b[?2004h>             \"level\": lvl.num,\r\n\u001b[?2004l\r"]
[55.207458, "o", "\u001b[?2004h>             \"filename\": os.path.basename(lvl.output_path),\r\n\u001b[?2004l\r"]
[55.207477, "o", "\u001b[?2004h> "]
[55.207536, "o", "            \"passed\": bool(passed),\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r"]
