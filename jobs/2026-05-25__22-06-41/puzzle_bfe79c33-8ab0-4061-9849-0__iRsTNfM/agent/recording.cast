[195.347102, "o", ">             return True, \"ok\"\r\n\u001b[?2004l\r      l5_in,\r\n            os.pa\u001b[?2004h> "]
[195.347447, "o", "        return False, f\"expected pix_fmt=gray, got {pix}\"\r\n\u001b[?2004l\ruil\u001b[?2004h> "]
