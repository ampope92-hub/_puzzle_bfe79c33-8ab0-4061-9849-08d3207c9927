[156.851409, "o", ">     except FileNotFoundError:\r\n\u001b[?2004l\r\u001b[?2004h>         pass\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ffprobe_json(path: str) -> Dict:\r\n\u001b[?2004l\r\u001b[?2004h>     cp = run([\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffprobe\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-v\", \"error\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-show_format\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-show_streams\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[156.851459, "o", "        path,\r\n\u001b[?2004l\r"]
[156.852064, "o", "\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h>     if cp.returncode != 0:\r\n\u001b[?2004l\rut_path)\r\n        h_ref = frame_has\u001b[?2004h>         raise RuntimeError(f\"ffprobe failed: {cp.stderr.strip()}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return json.loads(cp.stdout)\r\n\u001b[?2004l\r"]
