[195.327572, "i", "    return False, str(e)\n\n\ndef validate_audio_dur_approx_3s(out_path: str) -> Tuple[bool, str]:\n    try:\n        probe = ffprobe_json(out_path)\n        a = get_first_stream(probe, \"audio\")\n        dur = a.get(\"duration\") or probe.get(\"format\", {}).get(\"duration\")\n        if dur is None:\n            return False, \"duration not found\"\n        d = float(dur)\n        if 2.9 <= d <= 3.1:\n            return True, \"ok\"\n        return False, f\"expected ~3.0s, got {d:.3f}s\"\n    except Exception as e:\n        return False, str(e)\n\n\ndef validate_scale_and_hflip(out_path: str, in_path: str) -> Tuple[bool, str]:\n    ok, msg = validate_wh(out_path, 320, 240)\n    if not ok:\n        return ok, msg\n\n    import hashlib\n\n    def frame_hash(video_path: str) -> str:\n        cp = subprocess.run(\n            [\n                \"ffmpeg\", \"-v\", \"error\",\n                \"-i\", video_path,\n                \"-vf\", \"select=eq(n\\\\,0)\",\n                \"-frames:v\", \"1\",\n                \"-f\", \"rawvideo\",\n                \"-pix_fmt\", \"rgb24\",\n  "]
