[157.916519, "o", "> import base64, sys\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.916686, "o", "b64 = sys.stdin.read().strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[157.916848, "o", "# no-op placeholder\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
