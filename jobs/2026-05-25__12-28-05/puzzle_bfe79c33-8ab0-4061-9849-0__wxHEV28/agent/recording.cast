[44.708756, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.708977, "o", "    levels.append(\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             num=5,\r\n\u001b[?2004l\r"]
