[44.684077, "o", "        pr = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.684397, "o", "        vs = get_first_stream(pr, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.6845, "o", "        if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.68495, "o", "            return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.685184, "o", "        w = int(vs.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.685549, "o", "        h = int(vs.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.685726, "o", "        if w != 320 or h != 240:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.686206, "o", "            return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\rz\u001b[?2004h> "]
[44.68663, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[44.686683, "o", "\u001b[?2004h> "]
[44.686982, "o", "    def validate_gray(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>         pr = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[44.687146, "o", "\u001b[?2004h>         vs = get_first_stream(pr, \"video\")"]
[44.687166, "o", "\r\n\u001b[?2004l\r"]
[44.68751, "o", "\u001b[?2004h> "]
[44.687676, "o", "        if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.68772, "o", "            return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.6879, "o", "        pf = vs.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.688047, "o", "        # Require exact gray pixel format\r\n\u001b[?2004l\r"]
[44.688327, "o", "\u001b[?2004h> "]
[44.688478, "o", "        if pf != \"gray\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.689026, "o", "            return False, f\"expected pix_fmt gray, got {pf}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.689688, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.689911, "o", "    def validate_audio_3s(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.690271, "o", "        pr = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.690655, "o", "        a = get_first_stream(pr, \"audio\")\r\n\u001b[?2004l\r\u001b[?2004h>         if not a:\r\n\u001b[?2004l\re[bool, str, str]:\u001b[?2004h> "]
[44.691078, "o", "            return False, \"no audio stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.691133, "o", "        dur = parse_duration_seconds(pr)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.691415, "o", "        if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.69202, "o", "            return False, \"could not read duration\"\r\n\u001b[?2004l\r"]
[44.692166, "o", "\u001b[?2004h> "]
[44.69246, "o", "        # Strict: exactly 3.0 within tiny tolerance because containers/codecs are float.\r\n\u001b[?2004l\r \u001b[?2004h> "]
[44.692829, "o", "        if abs(dur - 3.0) > 0.02:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.693097, "o", "            return False, f\"expected duration ~3.00s, got {dur:.3f}s\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.693268, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[44.693347, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[44.693847, "o", "    def validate_crop_200x200(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.693888, "o", "> "]
[44.69418, "o", "        pr = ffprobe_json(path)\r\n\u001b[?2004l\r"]
[44.694355, "o", "\u001b[?2004h> "]
[44.694569, "o", "        vs = get_first_stream(pr, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.694798, "o", "        if not vs:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.695343, "o", "            return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.69577, "o", "        w = int(vs.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.695999, "o", "        h = int(vs.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.696286, "o", "        if w != 200 or h != 200:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.696439, "o", "            return False, f\"expected 200x200, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.696656, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.696993, "o", "    def validate_scaled_and_hflip(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.697352, "o", "        # Validate only size; transformation correctness for hflip is hard to verify purely by metadata.\r\n\u001b[?2004l\r\u001b[?2004h>         pr = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.697607, "o", "        vs = get_first_stream(pr, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.697848, "o", "        if not vs:\r\n\u001b[?2004l\r\u001b[?2004h>             return False, \"no video stream\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.698132, "o", ">         w = int(vs.get(\"width\", -1))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.698428, "o", "        h = int(vs.get(\"height\", -1))\r\n\u001b[?2004l\r\u001b[?2004h>         if w != 320 or h != 240:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.698694, "o", "            return False, f\"expected 320x240, got {w}x{h}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.69911, "o", "        return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     levels.append(\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r"]
[44.699269, "o", "\u001b[?2004h>             num=1,\r\n\u001b[?2004l\r"]
[44.699428, "o", "\u001b[?2004h> "]
[44.699646, "o", "            name=\"Level 1: Scale down\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.69997, "o", "            description=\"Scale a 640x480 video down to 320x240.\",\r\n\u001b[?2004l\r\u001b[?2004h>             input_args=[\r\n\u001b[?2004l\r\r\n   \u001b[?2004h> "]
[44.700188, "o", "                \"-f\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"lavfi\",\r\n\u001b[?2004l\r"]
[44.700575, "o", "\u001b[?2004h>                 \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.700846, "o", "                \"testsrc2=size=640x480:rate=30:duration=2\",\r\n\u001b[?2004l\r\u001b[?2004h>             ],\r\n\u001b[?2004l\r\u001b[?2004h>             out_filename=\"level1.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.700999, "o", "            stream_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h>             solution=\"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.701406, "o", "            validate=validate_scaled_320x240,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.701552, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h>     )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.701797, "o", "    levels.append(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.701844, "o", "        Level(\r\n\u001b[?2004l\r"]
