[61.332256, "o", "\u001b[?2004hroot@0b806797d2eb:/app# "]
[61.597672, "i", "perl -0777 -i -pe 's/if level\\.num == 2:\\n\\s*# Do not force pix_fmt; let user\\x27s format=gray persist\\.\\n\\s*cmd = \\[c for c in cmd if c != \"-pix_fmt\" and c != \"yuv420p\"\\]/if level.num == 2:\\n            # Preserve grayscale strictly (ffprobe pix_fmt==gray) by using a lossless codec\\/container that supports it.\\n            # Replace libx264 defaults with FFV1 + explicit gray pixel format.\\n            cmd = [\\n                \"ffmpeg\",\\n                \"-hide_banner\",\\n                \"-loglevel\",\\n                \"error\",\\n                \"-y\",\\n                *level.input_args,\\n                \"-vf\",\\n                filtergraph,\\n                \"-an\",\\n                \"-c:v\",\\n                \"ffv1\",\\n                \"-pix_fmt\",\\n                \"gray\",\\n                out_path,\\n            ]/s' /app/ffpuzzle.py\n"]
[61.598701, "o", "perl -0777 -i -pe 's/if level\\.num == 2:\\n\\s*# Do not force pix_fmt; let user\\x27s format=gray persist\\.\\n\\s*cmd = \\[c for c in cmd if c != \"-pix_fmt\" and c != \"yuv420p\"\\]/if level.num == 2:\\n            # Preserve grayscale strictly (ffprobe pix_fmt==gray) by using a lossless codec\\/container that supports it.\\n            # Replace libx264 defaults with FFV1 + explicit gray pixel format.\\n            cmd = [\\n                \"ffmpeg\",\\n                \"-hide_banner\",\\n                \"-loglevel\",\\n                \"error\",\\n                \"-y\",\\n                *level.input_args,\\n                \"-vf\",\\n                filtergraph,\\n                \"-an\",\\n                \"-c:v\",\\n                \"ffv1\",\\n                \"-pix_fmt\",\\n                \"gray\",\\n                out_path,\\n            ]/s' /app/ffpuzzle.py\r\n\u001b[?2004l\r"]
