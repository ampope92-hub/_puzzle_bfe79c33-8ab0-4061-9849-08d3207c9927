[44.664125, "i", "or: {e}\", out_path\n\n\ndef interactive(levels: List[Level]) -> int:\n    score = 0\n    for lvl in levels:\n        print(f\"\\n{lvl.name}\")\n        print(lvl.description)\n        print(\"Enter an FFmpeg filtergraph expression (no surrounding quotes):\")\n        try:\n            fg = input(\"> \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n        if not fg:\n            print(\"No input provided.\")\n            continue\n        ok, msg, out_path = run_level(lvl, fg)\n        print(f\"Output: {out_path}\")\n        print(\"PASS\" if ok else \"FAIL\")\n        if not ok:\n            print(f\"Reason: {msg}\")\n        else:\n            score += 10\n    total = len(levels) * 10\n    print(f\"Score: {score}/{total}\")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) -> int:\n    manifest = {\"files\": []}\n    score = 0\n    total = len(levels) * 10\n\n    for lvl in levels:\n        print(lvl.name)\n        ok, msg, out_path = run_level(lvl, lvl.solution)\n        print(\"PASS\" if ok else \"FAIL\")\n        if ok:"]
