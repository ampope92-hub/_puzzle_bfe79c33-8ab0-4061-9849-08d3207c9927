[44.709658, "o", "            input_args=[\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.709816, "o", "                \"-f\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"lavfi\",\r\n\u001b[?2004l\r"]
[44.709979, "o", "\u001b[?2004h>                 \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
