[44.70323, "o", "                \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>                 \"testsrc2=size=640x480:rate=30:duration=2\",\r\n\u001b[?2004l\r"]
[44.703267, "o", "\u001b[?2004h>             ],"]
