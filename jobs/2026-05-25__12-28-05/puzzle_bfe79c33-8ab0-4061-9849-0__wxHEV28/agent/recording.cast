[44.711006, "o", "> "]
[44.711045, "o", "def output_path_for(level: Level) -> str:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.711263, "o", "    return os.path.join(OUTPUT_DIR, level.out_filename)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.711413, "o", "def run_level(level: Level, filtergraph: str) -> Tuple[bool, str, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.711579, "o", "    \"\"\"Returns (ok, message, out_path).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.711887, "o", "    out_path = output_path_for(level)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.711944, "o", "    # Always overwrite deterministically\r\n\u001b[?2004l\r\u001b[?2004h>     # Use -vf for video, -af for audio. Keep encoding simple and deterministic.\r\n\u001b[?2004l\r"]
[44.71206, "o", "\u001b[?2004h>     if level.stream_type == \"video\":\r\n\u001b[?2004l\r"]
[44.712164, "o", "\u001b[?2004h> "]
[44.712248, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.71244, "o", "            \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-hide_banner\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-loglevel\",\r\n\u001b[?2004l\r"]
[44.712578, "o", "\u001b[?2004h>             \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.712597, "o", "            \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.712744, "o", "            *level.input_args,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vf\",\r\n\u001b[?2004l\r"]
[44.712932, "o", "\u001b[?2004h>             filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713025, "o", "            # Ensure we don't get odd sizes for some filters; and keep fps unchanged.\r\n\u001b[?2004l\r"]
[44.713175, "o", "\u001b[?2004h>             \"-an\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713416, "o", "            \"-c:v\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713498, "o", "            \"-pix_fmt\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713607, "o", "            # For grayscale level, user will set format=gray; but encoder/container might not support.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713824, "o", "            # We'll only force yuv420p for non-gray levels by checking expected; for gray we don't force.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713971, "o", "            # So we conditionally remove this below.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.713999, "o", "            \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714075, "o", "            out_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714188, "o", "        if level.num == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714301, "o", "            # Do not force pix_fmt; let user's format=gray persist.\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714435, "o", "            cmd = [c for c in cmd if c != \"-pix_fmt\" and c != \"yuv420p\"]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.714483, "o", "> "]
[44.714571, "o", "            \"ffmpeg\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-hide_banner\",\r\n\u001b[?2004l\r"]
[44.71465, "o", "\u001b[?2004h> "]
[44.714704, "o", "            \"-loglevel\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714838, "o", "            \"error\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.714951, "o", "            \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h>             *level.input_args,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.715109, "o", "            \"-af\",\r\n\u001b[?2004l\r\u001b[?2004h>             filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vn\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.715144, "o", "            \"-c:a\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.715291, "o", "            \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h>             out_path,\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r"]
[44.715463, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     rc, _, err = run(cmd)"]
[44.715549, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.71564, "o", "    if rc != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.715736, "o", "        return False, f\"ffmpeg failed: {err.strip()}\", out_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r"]
[44.715816, "o", "\u001b[?2004h"]
[44.715884, "o", "> "]
[44.715938, "o", "        ok, msg = level.validate(out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         return ok, msg, out_path\r\n\u001b[?2004l\r"]
[44.716096, "o", "\u001b[?2004h>     except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.716185, "o", "        return False, f\"validation error: {e}\", out_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.716272, "o", "def interactive(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.716378, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.716501, "o", ">         print(f\"\\n{lvl.name}\")\r\n\u001b[?2004l\r"]
[44.716627, "o", "\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.716727, "o", "        print(\"Enter an FFmpeg filtergraph expression (no surrounding quotes):\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.716812, "o", "        try:\r\n\u001b[?2004l\r"]
[44.717068, "o", "\u001b[?2004h>             fg = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except EOFError:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.71715, "o", "        if not fg:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717397, "o", "            print(\"No input provided.\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717428, "o", "        ok, msg, out_path = run_level(lvl, fg)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717529, "o", "        print(f\"Output: {out_path}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.717624, "o", ">         if not ok:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.71769, "o", "            print(f\"Reason: {msg}\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:"]
[44.717747, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717824, "o", "            score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717855, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.717983, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0"]
[44.718065, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[44.718165, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.718283, "o", "def auto_solve(levels: List[Level]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = {\"files\": []}\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.718494, "o", "    total = len(levels) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.718653, "o", "        print(lvl.name)\r\n\u001b[?2004l\r\u001b[?2004h>         ok, msg, out_path = run_level(lvl, lvl.solution)\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r"]
[44.718755, "o", "\u001b[?2004h>         if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r"]
[44.718852, "o", "\u001b[?2004h>         manifest[\"files\"].append(\r\n\u001b[?2004l\r\u001b[?2004h>             {\r\n\u001b[?2004l\r"]
[44.718917, "o", "\u001b[?2004h> "]
[44.718946, "o", "                \"level\": lvl.num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719071, "o", "                \"filename\": os.path.basename(out_path),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719162, "o", "                \"path\": out_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.71924, "o", "                \"valid\": bool(ok),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719334, "o", "                \"message\": msg,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719376, "o", "            }\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.719598, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719635, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2, sort_keys=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.719717, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0 if score == total else 1\r\n"]
[44.719835, "o", "\u001b[?2004l\r\u001b[?2004h"]
[44.719845, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.720013, "o", "def main(argv: List[str]) -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     parser = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.720161, "o", "    parser.add_argument(\"--auto-solve\", action=\"store_true\", help=\"Run all levels with known solutions\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.720173, "o", ">     args = parser.parse_args(argv)\r\n\u001b[?2004l\r"]
[44.720255, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.720381, "o", "    levels = build_levels()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.720416, "o", "    if args.auto_solve:\r\n\u001b[?2004l\r"]
[44.720499, "o", "\u001b[?2004h"]
[44.72058, "o", ">         return auto_solve(levels)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.720636, "o", "    return interactive(levels)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.720682, "o", "> \r\n\u001b[?2004l\r"]
[44.720729, "o", "\u001b[?2004h"]
[44.720773, "o", "> if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[44.720823, "o", "\u001b[?2004h> "]
[44.720942, "o", "    raise SystemExit(main(sys.argv[1:]))\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
