")\n\n    for level in LEVELS:\n        print(f"\\n{\'=\'*50}")\n        print(f"  {level[\'name\']}")\n        print(f"{\'=\'*50}")\n        print(f"\\n{level[\'description\']}")\n\n        # Generate input\n        print("  Generating input media...")\n        input_path = generate_input(level)\n        if input_path is None:\n            print("  Error generating input. Skipping level.")\n            manifest_entries.append({\n                "level": level["number"],\n                "filename": level["output_file"],\n                "validation": False\n            })\n            continue\n        print(f"  Input ready: {input_path}")\n\n        passed = False\n        attempts = 0\n        max_attempts = 5\n\n        while not passed and attempts < max_attempts:\n            attempts += 1\n            remaining = max_attempts - attempts\n\n            try:\n                user_input = input(f"\\n  Enter your filtergraph ({remaining} attempts left): ").strip()\n            except (EOFError, KeyboardInterrupt):\n                print("\\n  Exiting game.")\n                sys.exit(0)\n\n            if user_input.lower() == "quit":\n                print("\\n  Thanks for playing!")\n                print(f"  Final Score: {earned_points}/{total_points}")\n                sys.exit(0)\n            elif user_input.lower() == "skip":\n                print("  Skipping level.")\n                break\n            elif user_input.lower() == "hint":\n                print(f"\\n{level[\'description\']}")\n                attempts -= 1\n                continue\n            elif not user_input:\n                print("  Please enter a filtergraph expression.")\n                attempts -= 1\n                continue\n\n            # Apply filtergraph\n            output_path = os.path.join(OUTPUT_DIR, level["output_file"])\n            success = apply_filtergraph(input_path, user_input, output_path, level)\n            if not success:\n                print("  FFmpeg error - your filtergraph syntax may be incorrect.")\n                continue\n\n            # Validate\n            passed, message = validate_output(output_path, level)\n            if passed:\n                print(f"  PASS! +{POINTS_PER_LEVEL} points")\n                earned_points += POINTS_PER_LEVEL\n            else:\n                print(f"  Not quite: {message}")\n                if attempts >= max_attempts:\n                    print(f"  The correct answer was: {level[\'solution\']}")\n\n        manifest_entries.append({\n            "level": level["number"],\n            "filename": level["output_file"],\n            "validation": passed\n        })\n\n    # Final score\n    print(f"\\n{\'=\'*50}")\n    print(f"  Game Over!")\n    print(f"  Score: {earned_points}/{total_points}")\n    print(f"{\'=\'*50}")\n\n    # Write manifest\n    with open(MANIFEST_PATH, "w") as f:\n        json.dump(manifest_entries, f, indent=2)\n\n    print(f"\\n  Manifest written to {MANIFEST_PATH}")\n    print(f"  Output files in {OUTPUT_DIR}/")\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="FFmpeg Filtergraph Puzzle Game")\n    parser.add_argument(\n        "--auto-solve",\n        action="store_true",\n        help="Run all levels with known correct solutions (CI mode)"\n    )\n    args = parser.parse_args()\n\n    if args.auto_solve:\n        success = auto_solve_mode()\n        sys.exit(0 if success else 1)\n    else:\n        interactive_mode()\n\n\nif __name__ == "__main__":\n    main()\nENDOFSCRIPT\n'] min_timeout_sec: 2.0 max_timeout_sec: 180.0
