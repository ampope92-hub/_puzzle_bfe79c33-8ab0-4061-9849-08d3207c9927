ize=640x480:rate=25",\n            "-c:v", "libx264", "-preset", "ultrafast",\n            "-pix_fmt", "yuv420p",\n            "__OUTPUT__"\n        ],\n        "output_args": ["-c:v", "ffv1"],\n        "solution": "scale=320:240,hflip",\n        "validation": [\n            {"type": "video_dimensions", "width": 320, "height": 240}\n        ]\n    },\n]\n\n\ndef run_level(level, filtergraph, verbose=True):\n    """Run a single level with the given filtergraph. Returns (passed, output_file)."""\n    if verbose:\n        print(f"\\n{\'=\'*50}")\n        print(f"  {level[\'name\']}")\n        print(f"{\'=\'*50}")\n\n    # Generate input\n    if verbose:\n        print("  Generating input...")\n    input_path = generate_input(level)\n    if input_path is None:\n        if verbose:\n            print("  FAIL - Could not generate input")\n        return False, None\n\n    # Apply filtergraph\n    output_path = os.path.join(OUTPUT_DIR, level["output_file"])\n    if verbose:\n        print(f"  Applying filtergraph: {filtergraph}")\n    success = apply_filtergraph(input_path, filtergraph, output_path, level)\n    if not success:\n        if verbose:\n            print("  FAIL - FFmpeg returned an error")\n        return False, output_path\n\n    # Validate output\n    if verbose:\n        print("  Validating output...")\n    passed, message = validate_output(output_path, level)\n    if verbose:\n        if passed:\n            print("  PASS")\n        else:\n            print(f"  FAIL - {message}")\n\n    return passed, output_path\n\n\ndef auto_solve_mode():\n    """Run all levels with known correct solutions."""\n    ensure_dirs()\n\n    total_points = len(LEVELS) * POINTS_PER_LEVEL\n    earned_points = 0\n    manifest_entries = []\n\n    print("FFmpeg Filtergraph Puzzle - Auto-Solve Mode")\n    print("=" * 50)\n\n    for level in LEVELS:\n        print(f"\\n{level[\'name\']}")\n\n        # Generate input\n        input_path = generate_input(level)\n        if input_path i