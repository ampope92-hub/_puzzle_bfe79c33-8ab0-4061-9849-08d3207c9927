[65.818062, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"FFmpeg Filtergraph Puzzle - Auto-Solve Mode\")\r\n\u001b[?2004l\rror - yo"]
[65.818176, "o", "\u001b[?2004h> "]
[65.818271, "o", "    print(\"=\" * 50)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.818415, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.818685, "o", "        print(f\"\\n{level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
