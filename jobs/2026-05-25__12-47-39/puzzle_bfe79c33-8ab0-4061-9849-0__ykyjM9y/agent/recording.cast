[169.182635, "i", "cat > /app/ffpuzzle.py << 'ENDOFSCRIPT'\n#!/usr/bin/env python3\n\"\"\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nby having players solve progressively harder media transformation challenges.\n\nUsage:\n    python ffpuzzle.py              # Interactive mode\n    python ffpuzzle.py --auto-solve # Auto-solve mode for CI\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Directories\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n# Points per level\nPOINTS_PER_LEVEL = 10\n\n\ndef ensure_dirs():\n    \"\"\"Create assets and output directories if they don't exist.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_ffmpeg(args, timeout=30):\n    \"\"\"Run an FFmpeg command and return the result.\"\"\"\n    cmd = [\"ffmpeg\", \"-y\"] + args\n    result = subprocess.run(\n        cmd,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n        timeout=timeout\n    )\n    re"]
[169.182688, "i", "turn result\n\n\ndef run_ffprobe_json(filepath):\n    \"\"\"Run ffprobe on a file and return parsed JSON output.\"\"\"\n    cmd = [\n        \"ffprobe\",\n        \"-v\", \"quiet\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        filepath\n    ]\n    result = subprocess.run(\n        cmd,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.PIPE,\n        timeout=15\n    )\n    if result.returncode != 0:\n        return None\n    try:\n        return json.loads(result.stdout.decode())\n    except json.JSONDecodeError:\n        return None\n\n\ndef generate_input(level):\n    \"\"\"Generate synthetic input for a level using lavfi sources.\"\"\"\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    args = level[\"input_gen_args\"]\n    args = [a.replace(\"__OUTPUT__\", input_path) for a in args]\n    result = run_ffmpeg(args)\n    if result.returncode != 0:\n        print(f\"  ERROR generating input: {result.stderr.decode()[-500:]}\")\n        return None\n    return input_path\n\n\ndef apply_filtergraph(i"]
[169.182922, "i", "nput_path, filtergraph, output_path, level):\n    \"\"\"Apply a user's filtergraph to the input and produce output.\"\"\"\n    media_type = level.get(\"media_type\", \"video\")\n    output_args = level.get(\"output_args\", [])\n\n    if media_type == \"audio\":\n        args = [\n            \"-i\", input_path,\n            \"-af\", filtergraph,\n            \"-vn\"\n        ] + output_args + [output_path]\n    else:\n        args = [\n            \"-i\", input_path,\n            \"-vf\", filtergraph,\n            \"-an\",\n            \"-t\", \"2\"\n        ] + output_args + [output_path]\n\n    result = run_ffmpeg(args)\n    return result.returncode == 0\n\n\ndef validate_output(output_path, level):\n    \"\"\"Validate the output file against level requirements using ffprobe.\"\"\"\n    probe_data = run_ffprobe_json(output_path)\n    if probe_data is None:\n        return False, \"Could not probe output file\"\n\n    checks = level[\"validation\"]\n    streams = probe_data.get(\"streams\", [])\n    format_info = probe_data.get(\"format\", {})\n\n    for check in checks:\n        chec"]
[169.183116, "o", "cat > /app/ffpuzzle.py << 'ENDOFSCRIPT'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.183282, "i", "k_type = check[\"type\"]\n\n        if check_type == \"video_dimensions\":\n            video_stream = None\n            for s in streams:\n                if s.get(\"codec_type\") == \"video\":\n                    video_stream = s\n                    break\n            if video_stream is None:\n                return False, \"No video stream found\"\n            width = video_stream.get(\"width\")\n            height = video_stream.get(\"height\")\n            if width != check[\"width\"] or height != check[\"height\"]:\n                return False, f\"Dimensions mismatch: got {width}x{height}, expected {check['width']}x{check['height']}\"\n\n        elif check_type == \"pixel_format\":\n            video_stream = None\n            for s in streams:\n                if s.get(\"codec_type\") == \"video\":\n                    video_stream = s\n                    break\n            if video_stream is None:\n                return False, \"No video stream found\"\n            pix_fmt = video_stream.get(\"pix_fmt\")\n            if pix_fmt != check[\"pix_fmt\"]:\n"]
[169.183547, "o", "\"\"\"FFmpeg Filtergraph Puzzle Game\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> A terminal-based puzzle game that teaches FFmpeg filtergraphs\r\n\u001b[?2004l\r\u001b[?2004h> by having players solve progressively harder media transformation challenges.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Usage:\r\n\u001b[?2004l\r"]
[169.183648, "i", "                return False, f\"Pixel format mismatch: got {pix_fmt}, expected {check['pix_fmt']}\"\n\n        elif check_type == \"duration\":\n            duration = None\n            if \"duration\" in format_info:\n                duration = float(format_info[\"duration\"])\n            else:\n                for s in streams:\n                    if \"duration\" in s:\n                        duration = float(s[\"duration\"])\n                        break\n            if duration is None:\n                return False, \"Could not determine duration\"\n            tolerance = check.get(\"tolerance\", 0.5)\n            expected = check[\"duration\"]\n            if abs(duration - expected) > tolerance:\n                return False, f\"Duration mismatch: got {duration:.2f}s, expected {expected:.2f}s (tolerance {tolerance}s)\"\n\n        elif check_type == \"audio_duration\":\n            audio_stream = None\n            for s in streams:\n                if s.get(\"codec_type\") == \"audio\":\n                    audio_stream = s\n                    "]
