[169.205297, "o", "    probe_data = run_ffprobe_json(output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.205551, "o", "        return False, \"Could not probe output file\"\r\n\u001b[?2004l\r\r\n        \"input_\u001b[?2004h> \r\n\u001b[?2004l\rf\u001b[?2004h> "]
[169.205734, "o", "    checks = level[\"validation\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.206294, "o", "    streams = probe_data.get(\"streams\", [])\r\n\u001b[?2004l\r"]
[169.206334, "o", "\u001b[?2004h>     format_info = probe_data.get(\"format\", {})\r\n\u001b[?2004l\r"]
[169.206527, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.20667, "o", "    for check in checks:\r\n\u001b[?2004l\rr\u001b[?2004h> "]
[169.207182, "o", "        check_type = check[\"type\"]\r\n\u001b[?2004l\r0x480:rate=25\",\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         if check_type == \"video_dimensions\":\r\n\u001b[?2004l\r\u001b[?2004h>             video_stream = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.20727, "o", "            for s in streams:\r\n\u001b[?2004l\rU\u001b[?2004h> "]
[169.207492, "o", "                if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.207694, "o", "                    video_stream = s\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>             if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.20791, "o", "                return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.208135, "o", "            width = video_stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.20831, "o", "> "]
[169.208347, "o", "            height = video_stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.208485, "o", "            if width != check[\"width\"] or height != check[\"height\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.209094, "o", "                return False, f\"Dimensions mismatch: got {width}x{height}, expected {check['width']}x{check['height']}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\raudio\",\r\n      \u001b[?2004h> "]
[169.20925, "o", "        elif check_type == \"pixel_format\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.209288, "o", "> "]
[169.209459, "o", "            video_stream = None\r\n\u001b[?2004l\r\u001b[?2004h>             for s in streams:\r\n\u001b[?2004l\r"]
[169.209696, "o", "\u001b[?2004h> "]
[169.209846, "o", "                if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>                     video_stream = s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.210042, "o", "                    break\r\n\u001b[?2004l\r   \u001b[?2004h> "]
[169.2102, "o", "            if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.210412, "o", "                return False, \"No video stream found\"\r\n\u001b[?2004l\rTS-STARTPT\u001b[?2004h> "]
[169.210686, "o", "            pix_fmt = video_stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\"\u001b[?2004h> "]
[169.210734, "o", "            if pix_fmt != check[\"pix_fmt\"]:\r\n\u001b[?2004l\r"]
[169.210851, "o", "\u001b[?2004h> "]
[169.211796, "o", "                return False, f\"Pixel format mismatch: got {pix_fmt}, expected {check['pix_fmt']}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         elif check_type == \"duration\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.21192, "o", "            duration = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.212174, "o", ">             if \"duration\" in format_info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.212442, "o", "                duration = float(format_info[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.212543, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.212771, "o", "                for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.212935, "o", "                    if \"duration\" in s:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.213216, "o", "                        duration = float(s[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.213503, "o", "                        break\r\n\u001b[?2004l\r"]
[169.213655, "o", "\u001b[?2004h>             if duration is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.214501, "o", "                return False, \"Could not determine duration\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.214591, "o", "> "]
[169.214875, "o", "            tolerance = check.get(\"tolerance\", 0.5)\r\n\u001b[?2004l\r=640x480:rate=25\",\r\n  \u001b[?2004h> "]
[169.215127, "o", "            expected = check[\"duration\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.215488, "o", "            if abs(duration - expected) > tolerance:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.215975, "o", "                return False, f\"Duration mismatch: got {duration:.2f}s, expected {expected:.2f}s (tolerance {tolerance}s)\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.216238, "o", "        elif check_type == \"audio_duration\":\r\n\u001b[?2004l\r\u001b[?2004h>             audio_stream = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.216481, "o", "            for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.217312, "o", "                if s.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\rer\": 5,\r\n        \"na\u001b[?2004h>                     audio_stream = s\r\n\u001b[?2004l\r\u001b[?2004h>                     break\r\n\u001b[?2004l\r\u001b[?2004h>             if audio_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.217474, "o", "                return False, \"No audio stream found\"\r\n\u001b[?2004l\r\u001b[?2004h>             duration = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.217584, "o", "            if \"duration\" in audio_stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.218303, "o", "                duration = float(audio_stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.218559, "o", "            elif \"duration\" in format_info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.21883, "o", "                duration = float(format_info[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.219028, "o", "            if duration is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.219056, "o", "> "]
[169.219433, "o", "                return False, \"Could not determine audio duration\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.219815, "o", "            tolerance = check.get(\"tolerance\", 0.5)\r\n\u001b[?2004l\r"]
[169.219899, "o", "\u001b[?2004h> "]
[169.220121, "o", "            expected = check[\"duration\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[169.220351, "o", "> "]
[169.220414, "o", "            if abs(duration - expected) > tolerance:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[169.221124, "o", "                return False, f\"Audio duration mismatch: got {duration:.2f}s, expected {expected:.2f}s (tolerance {tolerance}s)\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
