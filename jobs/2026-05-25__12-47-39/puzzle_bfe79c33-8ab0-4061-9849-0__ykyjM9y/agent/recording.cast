[65.821995, "o", "            \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r"]
[65.822134, "o", "\u001b[?2004h>             \"validation\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })"]
[65.822169, "o", "\r\n\u001b[?2004l\r"]
[65.822318, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[65.822419, "o", ">     # Print final score\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.822455, "o", "    print(f\"\\nScore: {earned_points}/{total_points}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.822578, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.82277, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.822859, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.823007, "o", "        json.dump(manifest_entries, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.823029, "o", "> "]
[65.82309, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h"]
[65.823108, "o", "> "]
[65.823272, "o", "    print(f\"\\nManifest written to {MANIFEST_PATH}\")\r\n\u001b[?2004l\r"]
[65.823429, "o", "\u001b[?2004h> "]
[65.823545, "o", "    print(f\"Output files in {OUTPUT_DIR}/\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.823635, "o", "    return earned_points == total_points\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
