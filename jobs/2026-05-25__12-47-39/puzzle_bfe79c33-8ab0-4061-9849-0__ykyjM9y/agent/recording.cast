[65.815052, "o", "    success = apply_filtergraph(input_path, filtergraph, output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.815238, "o", "    if not success:\r\n\u001b[?2004l\r    \u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r"]
[65.815431, "o", "\u001b[?2004h>             print(\"  FAIL - FFmpeg returned an error\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.815515, "o", "        return False, output_path\r\n\u001b[?2004l\r"]
