[65.811399, "o", "def run_level(level, filtergraph, verbose=True):\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.811498, "o", "> "]
[65.811905, "o", "    \"\"\"Run a single level with the given filtergraph. Returns (passed, output_file).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     if verbose:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"\\n{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.812002, "o", "        print(f\"  {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.812177, "o", "        print(f\"{'='*50}\")\r\n\u001b[?2004l\r"]
[65.812324, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Generate input\r\n\u001b[?2004l\r"]
[65.812417, "o", "\u001b[?2004h> "]
[65.812579, "o", "    if verbose:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.812915, "o", "        print(\"  Generating input...\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.813079, "o", ">     input_path = generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.813298, "o", "    if input_path is None:\r\n\u001b[?2004l\r   \u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r"]
[65.813435, "o", "\u001b[?2004h> "]
[65.813557, "o", "            print(\"  FAIL - Could not generate input\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.813734, "o", "        return False, None\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.813829, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h"]
[65.813893, "o", ">     # Apply filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.814273, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r"]
[65.814551, "o", "\u001b[?2004h>     if verbose:\r\n\u001b[?2004l\r\u001b[?2004h> "]
