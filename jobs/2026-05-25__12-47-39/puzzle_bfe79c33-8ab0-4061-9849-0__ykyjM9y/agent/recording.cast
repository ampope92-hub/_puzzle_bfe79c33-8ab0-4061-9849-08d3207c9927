[65.817616, "o", ">     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.817764, "o", "    total_points = len(LEVELS) * POINTS_PER_LEVEL\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.817791, "o", "> "]
