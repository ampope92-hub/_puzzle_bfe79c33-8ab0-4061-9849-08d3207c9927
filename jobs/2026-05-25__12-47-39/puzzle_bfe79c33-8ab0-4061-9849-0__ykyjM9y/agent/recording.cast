[65.819528, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.819681, "o", "                \"validation\": False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.819786, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.819927, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.820016, "o", "        # Apply solution filtergraph\r\n\u001b[?2004l\r"]
[65.82028, "o", "\u001b[?2004h>         output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>         success = apply_filtergraph(input_path, level[\"solution\"], output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.820497, "o", "        if not success:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             manifest_entries.append({\r\n\u001b[?2004l\r"]
[65.820645, "o", "\u001b[?2004h>                 \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.820684, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.8208, "o", "                \"validation\": False\r\n\u001b[?2004l\r\u001b[?2004h>             })\r\n\u001b[?2004l\r"]
[65.820992, "o", "\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.821041, "o", "        # Validate\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.821161, "o", "> "]
[65.821298, "o", "        passed, message = validate_output(output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.821412, "o", ">         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.821613, "o", "            print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             earned_points += POINTS_PER_LEVEL\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.821788, "o", "            print(f\"FAIL - {message}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
