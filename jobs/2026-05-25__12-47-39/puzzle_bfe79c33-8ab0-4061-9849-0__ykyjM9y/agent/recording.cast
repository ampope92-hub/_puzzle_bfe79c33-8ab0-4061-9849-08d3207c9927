[65.769372, "o", "\r\n\u001b[?2004l\r"]
[65.769478, "o", "\u001b[?2004h>         return None\r\n\u001b[?2004l\r(\"tolerance\", 0.5)\r\n \u001b[?2004h> \r\n\u001b[?2004l\r"]
[65.769577, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.769726, "o", "def generate_input(level):\r\n"]
[65.769786, "o", "\u001b[?2004l\r\u001b[?2004h"]
[65.769844, "o", "> "]
[65.770005, "o", "    \"\"\"Generate synthetic input for a level using lavfi sources.\"\"\"\r\n\u001b[?2004l\r"]
[65.770139, "o", "\u001b[?2004h> "]
[65.770201, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r"]
[65.770285, "o", "\u001b[?2004h> "]
[65.770421, "o", "    args = level[\"input_gen_args\"]\r\n\u001b[?2004l\r"]
[65.770444, "o", "\u001b[?2004h> "]
[65.770719, "o", "    # Replace placeholder with actual output path\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.77084, "o", "> "]
[65.771077, "o", "    args = [a.replace(\"__OUTPUT__\", input_path) for a in args]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.77116, "o", "    result = run_ffmpeg(args)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.771355, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.771465, "o", "> "]
[65.771592, "o", "        print(f\"  ERROR generating input: {result.stderr.decode()[-500:]}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.771716, "o", "> "]
[65.771822, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.772034, "o", "    return input_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rcal\u001b[?2004h> "]
[65.772417, "o", "def apply_filtergraph(input_path, filtergraph, output_path, level):\r\n\u001b[?2004l\r"]
[65.772442, "o", "\u001b[?2004h> "]
[65.772788, "o", "    \"\"\"Apply a user's filtergraph to the input and produce output.\"\"\"\r\n\u001b[?2004l\r"]
[65.772833, "o", "\u001b[?2004h> "]
[65.773184, "o", "    media_type = level.get(\"media_type\", \"video\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r     \u001b[?2004h>     if media_type == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.773433, "o", "        args = [\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.773571, "o", "> "]
[65.773593, "o", "            \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.773665, "o", "            \"-af\", filtergraph,\r\n\u001b[?2004l\rx264\u001b[?2004h> "]
[65.773772, "o", "            \"-vn\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.773837, "o", "> "]
[65.77391, "o", "            output_path\r\n\u001b[?2004l\r"]
[65.773933, "o", "\u001b[?2004h> "]
[65.774042, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.774156, "o", ">     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.774236, "o", "        args = [\r\n\u001b[?2004l\r"]
[65.774311, "o", "\u001b[?2004h> "]
[65.774576, "o", "            \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.774915, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.775039, "o", "            \"-an\",\r\n\u001b[?2004l\r \u001b[?2004h> "]
[65.775168, "o", "            \"-t\", \"2\",\r\n\u001b[?2004l\r"]
[65.775219, "o", "\u001b[?2004h> "]
[65.775326, "o", "            output_path\r\n\u001b[?2004l\r"]
[65.775354, "o", "\u001b[?2004h>         ]\r\n\u001b[?2004l\r"]
[65.775448, "o", "\u001b[?2004h> "]
[65.775509, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.775612, "o", "    result = run_ffmpeg(args)\r\n\u001b[?2004l\r"]
[65.775691, "o", "\u001b[?2004h> "]
[65.775787, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[65.775868, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[65.775982, "o", "> "]
[65.776092, "o", "def validate_output(output_path, level):\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.776168, "o", "> "]
[65.776571, "o", "    \"\"\"Validate the output file against level requirements using ffprobe.\"\"\"\r\n\u001b[?2004l\r"]
[65.776655, "o", "\u001b[?2004h> "]
[65.776829, "o", "    probe_data = run_ffprobe_json(output_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.776906, "o", "> "]
[65.777029, "o", "    if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.777275, "o", "        return False, \"Could not probe output file\"\r\n\u001b[?2004l\r"]
[65.77743, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     checks = level[\"validation\"]\r\n\u001b[?2004l\r"]
[65.77754, "o", "\u001b[?2004h> "]
[65.77765, "o", "    streams = probe_data.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.777806, "o", "> "]
[65.778013, "o", "    format_info = probe_data.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.77819, "o", "    for check in checks:\r\n\u001b[?2004l\rargs\": [\r\n            \"-f\u001b[?2004h>         check_type = check[\"type\"]\r\n\u001b[?2004l\r       \"-i\", \"test\u001b[?2004h> \r\n\u001b[?2004l\rs\u001b[?2004h> "]
[65.778343, "o", "        if check_type == \"video_dimensions\":\r\n\u001b[?2004l\r     \u001b[?2004h> "]
[65.77854, "o", "            video_stream = None\r\n\u001b[?2004l\r"]
[65.778642, "o", "\u001b[?2004h>             for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.778786, "o", "                if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r"]
[65.778975, "o", "\u001b[?2004h>                     video_stream = s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.779135, "o", "                    break\r\n\u001b[?2004l\r\u001b[?2004h>             if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.779307, "o", "                return False, \"No video stream found\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.779518, "o", "            width = video_stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.77964, "o", "> "]
[65.779731, "o", "            height = video_stream.get(\"height\")\r\n\u001b[?2004l\r"]
[65.779747, "o", "\u001b[?2004h> "]
[65.780282, "o", "            if width != check[\"width\"] or height != check[\"height\"]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.780373, "o", "> "]
[65.780646, "o", "                return False, f\"Dimensions mismatch: got {width}x{height}, expected {check['width']}x{check['height']}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.780748, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.780921, "o", "        elif check_type == \"pixel_format\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.781051, "o", "            video_stream = None\r\n\u001b[?2004l\r,\u001b[?2004h> "]
[65.781203, "o", "            for s in streams:"]
[65.781359, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.781476, "o", "                if s.get(\"codec_type\") == \"video\":"]
[65.781539, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.781675, "o", "                    video_stream = s\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[65.781808, "o", "                    break\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.781866, "o", "> "]
[65.782146, "o", "            if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.782247, "o", "> "]
[65.782426, "o", "                return False, \"No video stream found\"\r\n\u001b[?2004l\r"]
[65.782446, "o", "\u001b[?2004h> "]
[65.78288, "o", "            pix_fmt = video_stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.782945, "o", "> "]
[65.783131, "o", "            if pix_fmt != check[\"pix_fmt\"]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.783206, "o", "> "]
[65.783956, "o", "                return False, f\"Pixel format mismatch: got {pix_fmt}, expected {check['pix_fmt']}\"\r\n\u001b[?2004l\r"]
[65.784132, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.784313, "o", "        elif check_type == \"duration\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.784449, "o", "            duration = None\r\n\u001b[?2004l\r"]
[65.784594, "o", "\u001b[?2004h> "]
[65.784758, "o", "            # Try format duration first\r\n\u001b[?2004l\r"]
[65.785055, "o", "\u001b[?2004h>             if \"duration\" in format_info:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.7854, "o", "                duration = float(format_info[\"duration\"])\r\n\u001b[?2004l\r"]
[65.785508, "o", "\u001b[?2004h> "]
[65.785665, "o", "            else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.785785, "o", "                # Try stream duration\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.785966, "o", "> "]
[65.786181, "o", "                for s in streams:\r\n\u001b[?2004l\r"]
[65.78629, "o", "\u001b[?2004h> "]
[65.78655, "o", "                    if \"duration\" in s:\r\n\u001b[?2004l\r"]
[65.786618, "o", "\u001b[?2004h> "]
[65.786729, "o", "                        duration = float(s[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.786841, "o", "> "]
[65.786946, "o", "                        break\r\n\u001b[?2004l\r"]
[65.786988, "o", "\u001b[?2004h> "]
[65.787137, "o", "            if duration is None:\r\n\u001b[?2004l\r\"\u001b[?2004h> "]
[65.787329, "o", "                return False, \"Could not determine duration\"\r\n\u001b[?2004l\r, \"libx264\", \"-preset\", \"ultrafast\",\r\n    \u001b[?2004h> "]
[65.787573, "o", "            tolerance = check.get(\"tolerance\", 0.5)\r\n\u001b[?2004l\r"]
[65.787633, "o", "\u001b[?2004h>             expected = check[\"duration\"]\r\n"]
[65.787737, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[65.787973, "o", "            if abs(duration - expected) > tolerance:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.788577, "o", "                return False, f\"Duration mismatch: got {duration:.2f}s, expected {expected:.2f}s (tolerance {tolerance}s)\"\r\n\u001b[?2004l\r"]
[65.788721, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.788947, "o", "        elif check_type == \"audio_duration\":\r\n\u001b[?2004l\r\u001b[?2004h>             audio_stream = None\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.789052, "o", ">             for s in streams:\r\n"]
[65.789071, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[65.78934, "o", "                if s.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.789369, "o", "> "]
[65.789509, "o", "                    audio_stream = s\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.78968, "o", "                    break\r\n\u001b[?2004l\r"]
[65.789737, "o", "\u001b[?2004h> "]
[65.789858, "o", "            if audio_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.790159, "o", "                return False, \"No audio stream found\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.790182, "o", "> "]
[65.790302, "o", "            duration = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.790669, "o", "            if \"duration\" in audio_stream:\r\n\u001b[?2004l\r"]
[65.790709, "o", "\u001b[?2004h> "]
[65.791124, "o", "                duration = float(audio_stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.791167, "o", "> "]
[65.791448, "o", "            elif \"duration\" in format_info:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.79149, "o", "> "]
[65.791767, "o", "                duration = float(format_info[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.791946, "o", "> "]
[65.792084, "o", "            if duration is None:\r\n\u001b[?2004l\r"]
[65.792262, "o", "\u001b[?2004h>                 return False, \"Could not determine audio duration\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.792467, "o", "            tolerance = check.get(\"tolerance\", 0.5)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.79267, "o", "            expected = check[\"duration\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.792869, "o", "            if abs(duration - expected) > tolerance:\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.793, "o", "> "]
[65.79322, "o", "                return False, f\"Audio duration mismatch: got {duration:.2f}s, expected {expected:.2f}s (tolerance {tolerance}s)\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.793395, "o", "    return True, \"All checks passed\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r)\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.793556, "o", "# Level definitions\r\n\u001b[?2004l\r\u001b[?2004h> LEVELS = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\rnt(f\"\\\u001b[?2004h> "]
[65.79373, "o", "        \"number\": 1,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.793933, "o", "        \"name\": \"Level 1: Scale Down\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.794135, "o", "        \"description\": (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.794277, "o", "            \"You have a 640x480 test video. Scale it down to 320x240.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.794406, "o", "            \"Hint: Use the 'scale' filter with width:height.\"\r\n\u001b[?2004l\r"]
[65.794441, "o", "\u001b[?2004h> "]
[65.794457, "o", "        ),\r\n"]
[65.794471, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[65.794652, "o", "        \"media_type\": \"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.794787, "o", "        \"input_file\": \"level1_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.794937, "o", "        \"output_file\": \"level1_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.795196, "o", "        \"input_gen_args\": [\r\n\u001b[?2004l\r\u001b[?2004h>             \"-f\", \"lavfi\",\r\n\u001b[?2004l\rOUTPUT_DIR, level[\"output_f\u001b[?2004h> "]
[65.795471, "o", "            \"-i\", \"testsrc=duration=3:size=640x480:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.795548, "o", "            \"-c:v\", \"libx264\", \"-preset\", \"ultrafast\",\r\n\u001b[?2004l\r"]
[65.79571, "o", "\u001b[?2004h> "]
[65.795725, "o", "            \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.795952, "o", "            \"__OUTPUT__\"\r\n\u001b[?2004l\r\u001b[?2004h>         ],\r\n\u001b[?2004l\r        if \u001b[?2004h> "]
[65.796065, "o", "        \"solution\": \"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"validation\": [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.796215, "o", "            {\"type\": \"video_dimensions\", \"width\": 320, \"height\": 240}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.796287, "o", "        ]\r\n\u001b[?2004l\r    \u001b[?2004h> "]
[65.796368, "o", "    },\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.796515, "o", "    {\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.797003, "o", ">         \"number\": 2,\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": \"Level 2: Convert to Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"description\": (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.797364, "o", "            \"You have a color 640x480 test video. Convert it to grayscale (gray pixel format).\\n\"\r\n\u001b[?2004l\r"]
[65.797469, "o", "\u001b[?2004h> "]
[65.797598, "o", "            \"Hint: Use the 'format' filter to change pixel format.\"\r\n\u001b[?2004l\rf auto_solve_mode():\r\n    \u001b[?2004h> "]
[65.797696, "o", "        ),\r\n\u001b[?2004l\rall \u001b[?2004h> "]
[65.797948, "o", "        \"media_type\": \"video\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.797977, "o", "> "]
[65.798173, "o", "        \"input_file\": \"level2_input.mp4\",\r\n\u001b[?2004l\r_\u001b[?2004h> "]
[65.798531, "o", "        \"output_file\": \"level2_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"input_gen_args\": [\r\n\u001b[?2004l\r\u001b[?2004h>             \"-f\", \"lavfi\",\r\n\u001b[?2004l\r"]
[65.798755, "o", "\u001b[?2004h> "]
[65.798832, "o", "            \"-i\", \"testsrc=duration=3:size=640x480:rate=25\",\r\n\u001b[?2004l\r=\" \u001b[?2004h>             \"-c:v\", \"libx264\", \"-preset\", \"ultrafast\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.798986, "o", "            \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"__OUTPUT__\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[65.799109, "o", ">         ],\r\n\u001b[?2004l\r"]
[65.799192, "o", "\u001b[?2004h>         \"solution\": \"format=gray\","]
[65.799411, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[65.799509, "o", "        \"validation\": [\r\n\u001b[?2004l\r_path is None:\r\n         \u001b[?2004h> "]
