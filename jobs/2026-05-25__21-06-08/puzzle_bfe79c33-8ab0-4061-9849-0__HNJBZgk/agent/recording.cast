[45.355915, "i", "evel):\n    \"\"\"Validate the output file against the level's requirements.\"\"\"\n    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    if not os.path.exists(output_path):\n        return False\n    probe = run_ffprobe(output_path)\n    if probe is None:\n        return False\n    return level[\"validate\"](probe)\n\n\ndef run_level(level, filtergraph, verbose=True):\n    \"\"\"Run a single level with the given filtergraph. Returns True if passed.\"\"\"\n    # Generate input\n    if not generate_input(level):\n        if verbose:\n            print(\"  Failed to generate input\")\n        return False\n    \n    # Apply filtergraph\n    if not apply_filtergraph(level, filtergraph):\n        if verbose:\n            print(\"  Failed to apply filtergraph\")\n        return False\n    \n    # Validate\n    passed = validate_output(level)\n    return passed\n\n\ndef auto_solve():\n    \"\"\"Run all levels with known correct solutions.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n    \n    results = []\n  "]
