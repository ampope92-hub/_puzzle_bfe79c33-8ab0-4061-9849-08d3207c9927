[45.355333, "i", "       \"generate_cmd\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n        ],\n        \"solution\": \"scale=320:240,hflip\",\n        \"ffmpeg_extra_output\": [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"],\n        \"validate\": lambda probe: check_video_dimensions(probe, 320, 240),\n    },\n]\n\n\ndef check_video_dimensions(probe, expected_w, expected_h):\n    try:\n        streams = probe.get(\"streams\", [])\n        for s in streams:\n            if s.get(\"codec_type\") == \"video\":\n                w = int(s.get(\"width\", 0))\n                h = int(s.get(\"height\", 0))\n                if w == expected_w and h == expected_h:\n                    return True\n        return False\n    except (KeyError, ValueError, TypeError):\n        return False\n\n\ndef check_pixel_format(probe, expected_fmt):\n    try:\n        streams = probe.get(\"streams\", [])\n        for s in stream"]
[45.355549, "i", "s:\n            if s.get(\"codec_type\") == \"video\":\n                pix_fmt = s.get(\"pix_fmt\", \"\")\n                if pix_fmt == expected_fmt:\n                    return True\n        return False\n    except (KeyError, ValueError, TypeError):\n        return False\n\n\ndef check_audio_duration(probe, min_dur, max_dur):\n    try:\n        streams = probe.get(\"streams\", [])\n        for s in streams:\n            if s.get(\"codec_type\") == \"audio\":\n                duration = float(s.get(\"duration\", 0))\n                if min_dur <= duration <= max_dur:\n                    return True\n        # Also check format-level duration\n        fmt = probe.get(\"format\", {})\n        duration = float(fmt.get(\"duration\", 0))\n        if min_dur <= duration <= max_dur:\n            return True\n        return False\n    except (KeyError, ValueError, TypeError):\n        return False\n\n\ndef run_ffprobe(filepath):\n    \"\"\"Run ffprobe and return parsed JSON output.\"\"\"\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \""]
