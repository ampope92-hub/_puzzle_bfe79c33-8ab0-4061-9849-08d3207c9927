[45.356193, "i", "  total_score = 0\n    max_score = len(LEVELS) * 10\n    \n    for level in LEVELS:\n        print(f\"Level {level['number']}: {level['name']}\")\n        passed = run_level(level, level[\"solution\"], verbose=True)\n        if passed:\n            print(\"  PASS\")\n            total_score += 10\n        else:\n            print(\"  FAIL\")\n        results.append({\n            \"level\": level[\"number\"],\n            \"filename\": level[\"output_file\"],\n            \"passed\": passed\n        })\n    \n    print(f\"Score: {total_score}/{max_score}\")\n    \n    # Write manifest\n    with open(MANIFEST_PATH, \"w\") as f:\n        json.dump(results, f, indent=2)\n\n\ndef interactive_mode():\n    \"\"\"Run the game in interactive mode.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n    \n    results = []\n    total_score = 0\n    max_score = len(LEVELS) * 10\n    \n    print(\"=== FFmpeg Filtergraph Puzzle Game ===\")\n    print(\"Solve each level by typing the correct filtergraph expression.\\n\")\n    \n    for level in LEV"]
