[45.405394, "o", "> "]
[45.405513, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r"]
[45.405545, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[45.405635, "o", "\u001b[?2004h> "]
[45.405748, "o", "        passed = validate_output(level)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r"]
[45.405914, "o", "\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r"]
[45.406019, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r"]
