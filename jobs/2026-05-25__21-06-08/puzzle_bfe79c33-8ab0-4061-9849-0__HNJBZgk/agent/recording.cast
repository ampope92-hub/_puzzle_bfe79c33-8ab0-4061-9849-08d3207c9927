[45.406506, "o", "        print()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.406605, "o", "    print(f\"Score: {total_score}/{max_score}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.406676, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.4068, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(results, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
