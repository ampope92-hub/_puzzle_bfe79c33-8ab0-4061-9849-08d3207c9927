[45.381189, "o", "        streams = probe.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h>         for s in streams:\r\n\u001b[?2004l\r"]
[45.381267, "o", "\u001b[?2004h> "]
[45.381489, "o", "            if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r, indent=2)\r\n\r\n\r\ndef\u001b[?2004h> "]
[45.38186, "o", "                w = int(s.get(\"width\", 0))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.382133, "o", "                h = int(s.get(\"height\", 0))\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.38265, "o", "                if w == expected_w and h == expected_h:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.382931, "o", "                    return True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.383145, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.383399, "o", "    except (KeyError, ValueError, TypeError):\r\n\u001b[?2004l\r"]
[45.383437, "o", "\u001b[?2004h> "]
[45.383708, "o", "        return False\r\n\u001b[?2004l\r"]
[45.383759, "o", "\u001b[?2004h> "]
[45.383901, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.383939, "o", "> "]
[45.384151, "o", "def check_pixel_format(probe, expected_fmt):\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\ry "]
[45.384221, "o", "typin\u001b[?2004h> "]
[45.384583, "o", "        streams = probe.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h>         for s in streams:\r\n\u001b[?2004l\r"]
[45.384656, "o", "\u001b[?2004h> "]
[45.385274, "o", "            if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.385574, "o", "                pix_fmt = s.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.385673, "o", "> "]
[45.385852, "o", "                if pix_fmt == expected_fmt:\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.385886, "o", "> "]
[45.38622, "o", "                    return True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.386346, "o", "        return False\r\n\u001b[?2004l\r"]
[45.386405, "o", "\u001b[?2004h> "]
[45.386814, "o", "    except (KeyError, ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.387122, "o", ">         return False\r\n\u001b[?2004l\r"]
[45.387433, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def check_audio_duration(probe, min_dur, max_dur):\r\n\u001b[?2004l\r"]
[45.387487, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.387666, "o", "        streams = probe.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.387841, "o", "        for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.387983, "o", "            if s.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.388196, "o", "                duration = float(s.get(\"duration\", 0))\r\n\u001b[?2004l\r\u001b[?2004h>                 if min_dur <= duration <= max_dur:\r\n\u001b[?2004l\r"]
[45.388394, "o", "\u001b[?2004h> "]
[45.388551, "o", "                    return True\r\n\u001b[?2004l\r\u001b[?2004h>         # Also check format-level duration\r\n"]
[45.388577, "o", "\u001b[?2004l\r"]
[45.388841, "o", "\u001b[?2004h> "]
[45.388984, "o", "        fmt = probe.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.389254, "o", "        duration = float(fmt.get(\"duration\", 0))\r\n\u001b[?2004l\r"]
[45.389299, "o", "\u001b[?2004h> "]
[45.389568, "o", "        if min_dur <= duration <= max_dur:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.389931, "o", "            return True\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.390072, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.390469, "o", "    except (KeyError, ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.390749, "o", ">         return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.390932, "o", "def run_ffprobe(filepath):\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.391123, "o", "> "]
[45.391283, "o", "    \"\"\"Run ffprobe and return parsed JSON output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.391395, "o", ">     cmd = [\r\n\u001b[?2004l\r"]
[45.391471, "o", "\u001b[?2004h> "]
[45.391816, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.391963, "o", "        \"-show_streams\", \"-show_format\", filepath\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.392332, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.392455, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.392567, "o", "    try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.392682, "o", "        return json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.392854, "o", ">     except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393021, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393112, "o", "def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393389, "o", "    \"\"\"Generate the synthetic input file for a level.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393589, "o", "    cmd = level[\"generate_cmd\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393909, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h>     return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.393973, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r "]
[45.394072, "o", "\u001b[?2004h"]
[45.394281, "o", "> def apply_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.394444, "o", "    \"\"\"Apply a filtergraph to the input and produce the output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.394692, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.394773, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.394917, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.395104, "o", "    cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.395326, "o", "        \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.395596, "o", "        \"-vf\" if level[\"number\"] != 3 else \"-af\", filtergraph\r\n\u001b[?2004l\r\u001b[?2004h>     ] + level[\"ffmpeg_extra_output\"] + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.395849, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396081, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396235, "o", "def validate_output(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396367, "o", "    \"\"\"Validate the output file against the level's requirements.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396588, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396689, "o", "    if not os.path.exists(output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396808, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     probe = run_ffprobe(output_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.396847, "o", "    if probe is None:\r\n\u001b[?2004l\r"]
[45.396937, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[45.397018, "o", "\u001b[?2004h> "]
[45.397037, "o", "    return level[\"validate\"](probe)\r\n\u001b[?2004l\r"]
[45.397308, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def run_level(level, filtergraph, verbose=True):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.397447, "o", "    \"\"\"Run a single level with the given filtergraph. Returns True if passed.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.397664, "o", "    if not generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.397829, "o", "            print(\"  Failed to generate input\")\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Apply filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.397962, "o", "    if not apply_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.398046, "o", "        if verbose:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.398124, "o", "            print(\"  Failed to apply filtergraph\")\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[45.398299, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Validate\r\n\u001b[?2004l\r\u001b[?2004h>     passed = validate_output(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.398371, "o", "    return passed\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.398422, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.398526, "o", "> "]
[45.398552, "o", "    \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.398681, "o", "    os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.398761, "o", "> "]
[45.398895, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     results = []\r\n\u001b[?2004l\r"]
[45.399085, "o", "\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     max_score = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[45.399226, "o", "\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.39925, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.399395, "o", "        passed = run_level(level, level[\"solution\"], verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.399541, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r"]
[45.399701, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.399725, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         results.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.399897, "o", "            \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.400098, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[45.400234, "o", "\u001b[?2004h>     print(f\"Score: {total_score}/{max_score}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.400396, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     # Write manifest\r\n\u001b[?2004l\r"]
[45.400481, "o", "\u001b[?2004h> "]
[45.400559, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(results, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.400633, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.400724, "o", "def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.400818, "o", "    \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.400869, "o", "    os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r"]
[45.401017, "o", "\u001b[?2004h> "]
[45.401042, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.401265, "o", ">     results = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     max_score = len(LEVELS) * 10\r\n\u001b[?2004l\r"]
[45.401459, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=== FFmpeg Filtergraph Puzzle Game ===\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.401642, "o", "    print(\"Solve each level by typing the correct filtergraph expression.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.401797, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.401824, "o", "        print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.40198, "o", "        print(f\"  {level['description']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.40217, "o", "        print(f\"  Input: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Output: {level['output_file']}\")\r\n\u001b[?2004l\r"]
[45.402243, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.402319, "o", "        # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.402348, "o", "        if not generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.40254, "o", "            print(\"  ERROR: Failed to generate input file.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.4028, "o", "            results.append({\r\n\u001b[?2004l\r\u001b[?2004h>                 \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.402913, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.402998, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h>             })\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.403008, "o", ">             continue\r\n\u001b[?2004l\r"]
[45.403109, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r"]
[45.403201, "o", "\u001b[?2004h> "]
[45.403246, "o", "            filtergraph = input(\"  Your filtergraph> \").strip()"]
[45.403254, "o", "\r\n\u001b[?2004l\r"]
[45.403352, "o", "\u001b[?2004h> "]
[45.403581, "o", "        except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\n  Skipping...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.403632, "o", "            results.append({\r\n\u001b[?2004l\r\u001b[?2004h>                 \"level\": level[\"number\"],\r\n"]
[45.403846, "o", "\u001b[?2004l\r\u001b[?2004h>                 \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.403872, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.403908, "o", "            })\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.403964, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[45.404105, "o", "\u001b[?2004h>         if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.404248, "o", "            print(\"  No filtergraph provided. Skipping.\")\r\n\u001b[?2004l\r\u001b[?2004h>             results.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.404273, "o", "                \"level\": level[\"number\"],\r\n\u001b[?2004l\r"]
[45.40434, "o", "\u001b[?2004h> "]
[45.40444, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.404572, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h>             })\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.404703, "o", ">         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.404843, "o", "        success = apply_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>         if not success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.404895, "o", "            print(\"  FFmpeg failed to apply your filtergraph.\")\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")"]
[45.404942, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.404996, "o", ">             results.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.405109, "o", "                \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
