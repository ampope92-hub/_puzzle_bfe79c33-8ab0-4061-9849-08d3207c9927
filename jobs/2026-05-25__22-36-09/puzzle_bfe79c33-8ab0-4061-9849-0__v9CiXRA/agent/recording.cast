[51.61943, "o", "\u001b[?2004h"]
[51.619494, "o", "> "]
[51.619592, "o", "def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.619758, "o", "    cmd = level[\"gen_input\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.6199, "o", "    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.620007, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.620175, "o", "        print(f\"  Error generating input: {result.stderr.decode()[-200:]}\")\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n"]
[51.620276, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
