[51.593496, "i", "cat > /app/ffpuzzle.py << 'PYTHON_SCRIPT'\n#!/usr/bin/env python3\nimport subprocess\nimport json\nimport sys\nimport os\nimport base64\n\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\n# Solutions are base64-encoded to avoid plaintext spoilers\n# Each entry: base64(reversed(solution))\ndef _encode_solution(s):\n    return base64.b64encode(s[::-1].encode()).decode()\n\ndef _decode_solution(encoded):\n    return base64.b64decode(encoded.encode()).decode()[::-1]\n\nLEVELS = [\n    {\n        \"level\": 1,\n        \"name\": \"Scale Down\",\n        \"description\": \"Scale a 640x480 video down to 320x240.\\nInput: 640x480 video\\nGoal: Output must be 320x240\",\n        \"input_file\": \"level1_input.mp4\",\n        \"output_file\": \"level1_output.mp4\",\n        \"gen_input\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level1_input.mp4\")\n        ],\n        "]
[51.593714, "i", "\"build_cmd\": lambda fg, inp, out: [\n            \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", fg,\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", out\n        ],\n        \"solution\": _decode_solution(\"MDQyeDAyMz1lbGFjcw==\"),\n        \"validate\": lambda probe: (\n            probe.get(\"width\") == 320 and probe.get(\"height\") == 240\n        ),\n    },\n    {\n        \"level\": 2,\n        \"name\": \"Grayscale Conversion\",\n        \"description\": \"Convert a video to grayscale.\\nInput: Color video\\nGoal: Output pixel format must be 'gray'\",\n        \"input_file\": \"level2_input.avi\",\n        \"output_file\": \"level2_output.avi\",\n        \"gen_input\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"rgb24\",\n            os.path.join(ASSETS_DIR, \"level2_input.avi\")\n        ],\n        \"build_cmd\": lambda fg, inp, out: [\n            \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", fg,\n            \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"gray\", out\n        ],\n     "]
