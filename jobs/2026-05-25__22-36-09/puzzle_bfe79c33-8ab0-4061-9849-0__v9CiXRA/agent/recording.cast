[51.593914, "i", ",\n        \"output_file\": \"level5_output.mp4\",\n        \"gen_input\": [\n            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n            \"testsrc=duration=2:size=640x480:rate=25\",\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\n            os.path.join(ASSETS_DIR, \"level5_input.mp4\")\n        ],\n        \"build_cmd\": lambda fg, inp, out: [\n            \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", fg,\n            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", out\n        ],\n        \"solution\": _decode_solution(\"cGlsZmgsMDQyeDAyMz1lbGFjcw==\"),\n        \"validate\": lambda probe: (\n            probe.get(\"width\") == 320 and probe.get(\"height\") == 240\n        ),\n    },\n]\n\n\ndef ensure_dirs():\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef generate_input(level):\n    cmd = level[\"gen_input\"]\n    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n    if result.returncode != 0:\n        print(f\"  Error generating input: {result.stderr.decode()[-200:]}\")\n        return Fal"]
[51.593919, "i", "se\n    return True\n\n\ndef run_filtergraph(level, filtergraph):\n    inp = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    out = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    cmd = level[\"build_cmd\"](filtergraph, inp, out)\n    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n    if result.returncode != 0:\n        print(f\"  FFmpeg error: {result.stderr.decode()[-300:]}\")\n        return False\n    return True\n\n\ndef probe_output(level):\n    out = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \"-show_streams\", out\n    ]\n    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n    if result.returncode != 0:\n        return None\n    data = json.loads(result.stdout.decode())\n    streams = data.get(\"streams\", [])\n    if not streams:\n        return None\n    stream = streams[0]\n    info = {}\n    if \"width\" in stream:\n        info[\"width\"] = int(stream[\"width\"])\n    if \"height\" in stream:\n"]
