[52.844285, "i", "python3 -c \"\nimport base64\n\ndef encode(s):\n    return base64.b64encode(s[::-1].encode()).decode()\n\ndef decode(encoded):\n    return base64.b64decode(encoded.encode()).decode()[::-1]\n\nsolutions = [\n    'scale=320:240',\n    'format=gray',\n    'atrim=0:3',\n    'crop=200:200',\n    'scale=320:240,hflip'\n]\n\nfor s in solutions:\n    enc = encode(s)\n    dec = decode(enc)\n    print(f'{s} -> {enc} -> {dec}')\n\"\n"]
[52.844837, "o", "python3 -c \"\r\n\u001b[?2004l\r\u001b[?2004h> import base64\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def encode(s):\r\n\u001b[?2004l\r\u001b[?2004h>     return base64.b64encode(s[::-1].encode()).decode()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def decode(encoded):\r\n\u001b[?2004l\r\u001b[?2004h> "]
