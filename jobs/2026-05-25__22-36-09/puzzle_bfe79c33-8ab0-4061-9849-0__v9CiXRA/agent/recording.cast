[51.622991, "o", ">         return None\r\n\u001b[?2004l\r\u001b[?2004h>     stream = streams[0]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.623237, "o", "    info = {}\r\n\u001b[?2004l\r\u001b[?2004h>     if \"width\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>         info[\"width\"] = int(stream[\"width\"])\r\n\u001b[?2004l\r\u001b[?2004h>     if \"height\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.623472, "o", ">         info[\"height\"] = int(stream[\"height\"])\r\n\u001b[?2004l\r\u001b[?2004h>     if \"pix_fmt\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>         info[\"pix_fmt\"] = stream[\"pix_fmt\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
