[51.594068, "i", "        info[\"height\"] = int(stream[\"height\"])\n    if \"pix_fmt\" in stream:\n        info[\"pix_fmt\"] = stream[\"pix_fmt\"]\n    if \"duration\" in stream:\n        info[\"duration\"] = stream[\"duration\"]\n    elif \"tags\" in stream and \"DURATION\" in stream[\"tags\"]:\n        # Parse HH:MM:SS.xxx format\n        dur_str = stream[\"tags\"][\"DURATION\"]\n        parts = dur_str.split(\":\")\n        info[\"duration\"] = str(float(parts[0])*3600 + float(parts[1])*60 + float(parts[2]))\n    else:\n        # Try format-level duration\n        cmd2 = [\n            \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n            \"-show_format\", out\n        ]\n        result2 = subprocess.run(cmd2, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n        if result2.returncode == 0:\n            fmt_data = json.loads(result2.stdout.decode())\n            if \"format\" in fmt_data and \"duration\" in fmt_data[\"format\"]:\n                info[\"duration\"] = fmt_data[\"format\"][\"duration\"]\n    return info\n\n\ndef validate_level(level, probe_info):\n    if probe_in"]
