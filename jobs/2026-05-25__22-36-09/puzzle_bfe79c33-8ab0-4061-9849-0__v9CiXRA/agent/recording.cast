[51.620784, "o", "> "]
[51.620929, "o", "    cmd = level[\"build_cmd\"](filtergraph, inp, out)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.621174, "o", "    result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.621341, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.621451, "o", "        print(f\"  FFmpeg error: {result.stderr.decode()[-300:]}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
