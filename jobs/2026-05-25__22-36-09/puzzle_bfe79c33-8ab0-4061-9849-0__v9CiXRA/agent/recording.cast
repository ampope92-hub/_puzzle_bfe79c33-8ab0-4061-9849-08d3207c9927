[51.622057, "o", "\u001b[?2004h>         \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.622173, "o", "        \"-show_streams\", out\r\n\u001b[?2004l\r\u001b[?2004h> "]
