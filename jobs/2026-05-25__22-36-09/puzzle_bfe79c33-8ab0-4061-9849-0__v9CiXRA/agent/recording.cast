[51.625093, "o", "            if \"format\" in fmt_data and \"duration\" in fmt_data[\"format\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.625322, "o", "                info[\"duration\"] = fmt_data[\"format\"][\"duration\"]\r\n\u001b[?2004l\r\u001b[?2004h>     return info\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[51.625359, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.625439, "o", "def validate_level(level, probe_info):\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.625531, "o", ">     if probe_info is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.625626, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.625703, "o", "        return level[\"validate\"](probe_info)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[51.625789, "o", "    except (KeyError, TypeError, ValueError):\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[51.625814, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[51.625897, "o", "> "]
