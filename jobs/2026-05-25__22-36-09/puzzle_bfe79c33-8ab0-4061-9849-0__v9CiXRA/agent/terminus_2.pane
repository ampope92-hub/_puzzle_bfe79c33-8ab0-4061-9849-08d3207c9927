[?2004l[?2004h> 
[?2004l[?2004h>         if not generate_input(level):
[?2004l[?2004h>             print("  FAIL")
[?2004l[?2004h>             manifest.append({"level": num, "filename": level["output_file"], "passed": False})
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         solution = level["solution"]
[?2004l[?2004h>         if not run_filtergraph(level, solution):
[?2004l[?2004h>             print("  FAIL")
[?2004l[?2004h>             manifest.append({"level": num, "filename": level["output_file"], "passed": False})
[?2004l[?2004h>             continue
[?2004l[?2004h> 
[?2004l[?2004h>         probe_info = probe_output(level)
[?2004l[?2004h>         passed = validate_level(level, probe_info)
[?2004l[?2004h> 
