[45.881316, "i", "ple[List[str], str]:\n    return ([\n        \"-f\", \"lavfi\",\n        \"-i\", \"testsrc=size=640x480:rate=30:duration=5\",\n    ], \"mp4\")\n\n\ndef input_audio_10s() -> Tuple[List[str], str]:\n    # deterministic sine wave\n    return ([\n        \"-f\", \"lavfi\",\n        \"-i\", \"sine=frequency=440:sample_rate=48000:duration=10\",\n    ], \"wav\")\n\n\n# ---- Validators (ffprobe JSON) ----\n\ndef validate_video_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return False, \"no video stream\"\n        aw, ah = vs.get(\"width\"), vs.get(\"height\")\n        ok = (aw == w and ah == h)\n        return ok, f\"width={aw} height={ah}\"\n    return _v\n\n\ndef validate_video_grayscale() -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return False, \"no vid"]
[45.881327, "o", "import argparse\r\n\u001b[?2004l\r"]
[45.881333, "i", "eo stream\"\n        pix = vs.get(\"pix_fmt\")\n        # Accept common grayscale formats only\n        ok = pix in (\"gray\", \"gray8\", \"gray16le\", \"gray16be\")\n        return ok, f\"pix_fmt={pix}\"\n    return _v\n\n\ndef validate_audio_duration_exact(target: float, tol: float = 0.02) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        fmt = probe.get(\"format\", {})\n        dur_s = fmt.get(\"duration\")\n        try:\n            dur = float(dur_s)\n        except Exception:\n            return False, f\"duration={dur_s}\"\n        ok = abs(dur - target) <= tol\n        return ok, f\"duration={dur:.6f} (target {target})\"\n    return _v\n\n\ndef validate_crop_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    # For a crop, output dims should match crop size.\n    return validate_video_dims(w, h)\n\n\ndef validate_scaled_and_flipped(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    # Strictly validate dimensions; flip correctness is hard to assert via me"]
[45.88161, "i", "tadata.\n    # We'll additionally compare a checksum of a reference transform (scale+flip)\n    # computed deterministically from the same source.\n    def _v(path: str) -> Tuple[bool, str]:\n        # dim check\n        ok1, d1 = validate_video_dims(w, h)(path)\n        if not ok1:\n            return False, d1\n\n        # Create a reference and compare per-frame hash (framemd5) of first few frames\n        ref_path = os.path.join(OUTPUT_DIR, \"_ref_level5_framemd5.txt\")\n        out_md5 = os.path.join(OUTPUT_DIR, \"_out_level5_framemd5.txt\")\n\n        # Build ref from same deterministic source\n        ref_cmd = [\n            \"ffmpeg\", \"-hide_banner\", \"-v\", \"error\",\n            \"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30:duration=5\",\n            \"-vf\", \"scale=320:240,hflip\",\n            \"-frames:v\", \"10\",\n            \"-f\", \"framemd5\", ref_path,\n            \"-y\"\n        ]\n        code, _, err = run(ref_cmd)\n        if code != 0:\n            return False, f\"ref framemd5 failed: {err.strip()}\"\n\n        out_cmd = [\n "]
[45.881972, "o", "\u001b[?2004h> import json"]
[45.882158, "i", "           \"ffmpeg\", \"-hide_banner\", \"-v\", \"error\",\n            \"-i\", path,\n            \"-frames:v\", \"10\",\n            \"-f\", \"framemd5\", out_md5,\n            \"-y\"\n        ]\n        code, _, err = run(out_cmd)\n        if code != 0:\n            return False, f\"out framemd5 failed: {err.strip()}\"\n\n        try:\n            with open(ref_path, \"r\", encoding=\"utf-8\") as f:\n                ref = f.read()\n            with open(out_md5, \"r\", encoding=\"utf-8\") as f:\n                outt = f.read()\n        except Exception as e:\n            return False, f\"hash read failed: {e}\"\n\n        ok2 = (ref == outt)\n        return (ok2, (d1 + (\"; flip+scale=OK\" if ok2 else \"; flip+scale=MISMATCH\")))\n\n    return _v\n\n\n# ---- FFmpeg execution for a level ----\n\ndef build_output_path(level_num: int, ext: str) -> str:\n    return os.path.join(OUTPUT_DIR, f\"level{level_num:02d}.{ext}\")\n\n\ndef apply_filtergraph(level: Level, filtergraph: str, out_path: str) -> Tuple[bool, str]:\n    input_args, _in_ext = level.input_spec()\n\n    # Always re"]
