[45.927203, "o", "        print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.927367, "o", "        print(\"Example input: generated via lavfi (no files needed).\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.927521, "o", "        fg = input(\"Your filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         out_path = build_output_path(lvl.number, lvl.out_ext)\r\n\u001b[?2004l\r"]
[45.927632, "o", "\u001b[?2004h> "]
[45.927863, "o", "        ok, details = apply_filtergraph(lvl, fg, out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         if details:\r\n\u001b[?2004l\r\u001b[?2004h>             print(details)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.927973, "o", "        if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.928123, "o", "        manifest_entries.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": lvl.number,\r\n\u001b[?2004l\r\u001b[?2004h> "]
