[105.400594, "i", "        json.dump({\"outputs\": manifest_entries}, f, indent=2)\n\n    print(f\"Score: {score}/{total}\")\n    return 0 if score == total else 1\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    total = len(levels()) * 10\n    score = 0\n    manifest_entries = []\n\n    for lvl in levels():\n        print(lvl.name)\n        out_path = build_output_path(lvl.number, lvl.out_ext)\n        ok, details = apply_filtergraph(lvl, lvl.solution, out_path)\n        print(\"PASS\" if ok else \"FAIL\")\n        if not ok and details:\n            print(details)\n        if ok:\n            score += 10\n        manifest_entries.append({\"level\": lvl.number, \"filename\": os.path.basename(out_path), \"ok\": bool(ok)})\n\n    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\n        json.dump({\"outputs\": manifest_entries}, f, indent=2)\n\n    print(f\"Score: {score}/{total}\")\n    return 0 if score == total else 1\n\n\ndef main() -> int:\n    ap = argparse.ArgumentParser(description=\"FFPuzzle - learn FFmpeg filtergraphs\")\n    ap.add_argument(\"--auto-solve\", ac"]
