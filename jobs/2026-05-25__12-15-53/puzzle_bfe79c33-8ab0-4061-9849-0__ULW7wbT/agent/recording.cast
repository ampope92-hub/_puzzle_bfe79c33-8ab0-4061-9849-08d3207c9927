[105.399048, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport subprocess\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nAPP_DIR = \"/app\"\nASSETS_DIR = os.path.join(APP_DIR, \"assets\")\nOUTPUT_DIR = os.path.join(APP_DIR, \"output\")\nMANIFEST_PATH = os.path.join(APP_DIR, \"manifest.json\")\n\n\ndef run(cmd: List[str]) -> Tuple[int, str, str]:\n    p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n    out, err = p.communicate()\n    return p.returncode, out, err\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef ffprobe_json(path: str) -> Dict:\n    code, out, err = run([\n        \"ffprobe\",\n        \"-v\", \"error\",\n        \"-print_format\", \"json\",\n        \"-show_streams\",\n        \"-show_format\",\n        path,\n    ])\n    if code != 0:\n        raise RuntimeError(f\"ffprobe failed for {path}: {err.strip()}\")\n    return json.loads(out)\n\n\ndef get_fir"]
[105.39923, "i", "st_stream(probe: Dict, codec_type: str) -> Optional[Dict]:\n    for s in probe.get(\"streams\", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    media_type: str  # \"video\" or \"audio\"\n    input_spec: Callable[[], Tuple[List[str], str]]\n    out_ext: str\n    validate: Callable[[str], Tuple[bool, str]]\n    solution: str\n    force_pix_fmt: Optional[str] = None  # encoder pixel format override\n\n\n# ---- lavfi inputs (no external files) ----\n\ndef input_video_640x480_5s() -> Tuple[List[str], str]:\n    return ([\"-f\", \"lavfi\", \"-i\", \"testsrc2=size=640x480:rate=30:duration=5\"], \"mp4\")\n\n\ndef input_video_640x480_5s_color() -> Tuple[List[str], str]:\n    return ([\"-f\", \"lavfi\", \"-i\", \"testsrc=size=640x480:rate=30:duration=5\"], \"mp4\")\n\n\ndef input_audio_10s() -> Tuple[List[str], str]:\n    return ([\"-f\", \"lavfi\", \"-i\", \"sine=frequency=440:sample_rate=48000:duration=10\"], \"wav\")\n\n\n# ---- Validators (strict via ffp"]
[105.399292, "o", "cat > /app/ffpuzzle.py <<'PY'\r\n\u001b[?2004l\r"]
[105.399313, "i", "robe JSON) ----\n\ndef validate_video_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return False, \"no video stream\"\n        aw, ah = vs.get(\"width\"), vs.get(\"height\")\n        ok = (aw == w and ah == h)\n        return ok, f\"width={aw} height={ah}\"\n    return _v\n\n\ndef validate_video_grayscale() -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, \"video\")\n        if not vs:\n            return False, \"no video stream\"\n        pix = vs.get(\"pix_fmt\")\n        ok = pix in (\"gray\", \"gray8\", \"gray16le\", \"gray16be\")\n        return ok, f\"pix_fmt={pix}\"\n    return _v\n\n\ndef validate_audio_duration_exact(target: float, tol: float = 0.02) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        d"]
