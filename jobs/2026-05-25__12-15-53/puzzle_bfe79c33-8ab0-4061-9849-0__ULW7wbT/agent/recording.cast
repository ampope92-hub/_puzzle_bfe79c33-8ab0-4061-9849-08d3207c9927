[127.094767, "i", "perl -0777 -i -pe 's/if level\\.media_type == \"video\":\\n        pix_fmt = level\\.force_pix_fmt or \"yuv420p\"\\n        cmd \\+= \\[\\n            \"-vf\", filtergraph,\\n            \"-an\",\\n            \"-c:v\", \"libx264\",\\n            \"-pix_fmt\", pix_fmt,\\n            \"-preset\", \"veryfast\",\\n            \"-crf\", \"18\",\\n            \"-movflags\", \"\\+faststart\",\\n            out_path,\\n        \\]/if level.media_type == \"video\":\\n        pix_fmt = level.force_pix_fmt or \"yuv420p\"\\n        vcodec = level.force_vcodec or \"libx264\"\\n        cmd += [\"-vf\", filtergraph, \"-an\", \"-c:v\", vcodec, \"-pix_fmt\", pix_fmt]\\n        if vcodec == \"libx264\":\\n            cmd += [\"-preset\", \"veryfast\", \"-crf\", \"18\"]\\n        if out_path.endswith(\".mp4\"):\\n            cmd += [\"-movflags\", \"+faststart\"]\\n        cmd += [out_path]/smg' /app/ffpuzzle.py\n"]
[127.098061, "o", "perl -0777 -i -pe 's/if level\\.media_type == \"video\":\\n        pix_fmt = level\\.force_pix_fmt or \"yuv420p\"\\n        cmd \\+= \\[\\n            \"-vf\", filtergraph,\\n            \"-an\",\\n            \"-c:v\", \"libx264\",\\n            \"-pix_fmt\", pix_fmt,\\n            \"-preset\", \"veryfast\",\\n            \"-crf\", \"18\",\\n            \"-movflags\", \"\\+faststart\",\\n            out_path,\\n        \\]/if level.media_type == \"video\":\\n        pix_fmt = level.force_pix_fmt or \"yuv420p\"\\n        vcodec = level.force_vcodec or \"libx264\"\\n        cmd += [\"-vf\", filtergraph, \"-an\", \"-c:v\", vcodec, \"-pix_fmt\", pix_fmt]\\n        if vcodec == \"libx264\":\\n            cmd += [\"-preset\", \"veryfast\", \"-crf\", \"18\"]\\n        if out_path.endswith(\".mp4\"):\\n            cmd += [\"-movflags\", \"+faststart\"]\\n        cmd += [out_path]/smg' /app/ffpuzzle.py\r\n\u001b[?2004l\r"]
[127.104707, "o", "\u001b[?2004hroot@571751f755b8:/app# "]
