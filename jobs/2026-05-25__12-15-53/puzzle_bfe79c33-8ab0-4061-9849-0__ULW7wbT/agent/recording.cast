[105.419088, "o", "        ok, details = level.validate(out_path)\r\n\u001b[?2004l\r\u001b[?2004h>         return ok, details\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.41918, "o", "    except Exception as e:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.419276, "o", "        return False, f\"validation exception: {e}\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def levels() -> List[Level]:\r\n"]
