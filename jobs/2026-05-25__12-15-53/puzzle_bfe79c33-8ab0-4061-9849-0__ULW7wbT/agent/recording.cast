[45.882609, "i", "-encode to deterministic-ish output, avoid timestamps variability\n    # Video: libx264, yuv420p unless grayscale requires gray explicitly via filter\n    # Audio: pcm_s16le\n    cmd = [\"ffmpeg\", \"-hide_banner\", \"-v\", \"error\", \"-y\"]\n    cmd += input_args\n\n    if level.media_type == \"video\":\n        cmd += [\"-vf\", filtergraph]\n        cmd += [\n            \"-an\",\n            \"-c:v\", \"libx264\",\n            \"-pix_fmt\", \"yuv420p\",\n            \"-preset\", \"veryfast\",\n            \"-crf\", \"18\",\n            \"-movflags\", \"+faststart\",\n            out_path,\n        ]\n    else:\n        cmd += [\"-af\", filtergraph]\n        cmd += [\n            \"-vn\",\n            \"-c:a\", \"pcm_s16le\",\n            out_path,\n        ]\n\n    code, _out, err = run(cmd)\n    if code != 0:\n        return False, err.strip()\n\n    try:\n        ok, details = level.validate(out_path)\n        return ok, details\n    except Exception as e:\n        return False, f\"validation exception: {e}\"\n\n\ndef levels() -> List[Level]:\n    return [\n        Level(\n            n"]
