[45.880226, "i", "cat > /app/ffpuzzle.py <<'PY'\n#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport shlex\nimport subprocess\nimport sys\nfrom dataclasses import dataclass\nfrom typing import Callable, Dict, List, Optional, Tuple\n\nAPP_DIR = \"/app\"\nASSETS_DIR = os.path.join(APP_DIR, \"assets\")\nOUTPUT_DIR = os.path.join(APP_DIR, \"output\")\nMANIFEST_PATH = os.path.join(APP_DIR, \"manifest.json\")\n\n\ndef run(cmd: List[str]) -> Tuple[int, str, str]:\n    p = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\n    out, err = p.communicate()\n    return p.returncode, out, err\n\n\ndef ffprobe_json(path: str) -> Dict:\n    code, out, err = run([\n        \"ffprobe\",\n        \"-v\", \"error\",\n        \"-print_format\", \"json\",\n        \"-show_streams\",\n        \"-show_format\",\n        path,\n    ])\n    if code != 0:\n        raise RuntimeError(f\"ffprobe failed for {path}: {err.strip()}\")\n    return json.loads(out)\n\n\ndef get_first_stream(probe: Dict, codec_type: str) -> Optional[Dict]:\n    for s in probe.get(\"streams\""]
[45.881054, "i", ", []):\n        if s.get(\"codec_type\") == codec_type:\n            return s\n    return None\n\n\ndef ensure_dirs() -> None:\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\n@dataclass\nclass Level:\n    number: int\n    name: str\n    description: str\n    media_type: str  # \"video\" or \"audio\"\n    # returns: (ffmpeg args that create input) and input extension\n    input_spec: Callable[[], Tuple[List[str], str]]\n    # expected extension for output (container)\n    out_ext: str\n    # validation function takes output path -> (ok, details)\n    validate: Callable[[str], Tuple[bool, str]]\n    # known correct filtergraph\n    solution: str\n\n\n# ---- Level input generators (lavfi only) ----\n\ndef input_video_640x480_5s() -> Tuple[List[str], str]:\n    # deterministic synthetic video\n    # testsrc2 is stable; force 30 fps for predictable timebase\n    return ([\n        \"-f\", \"lavfi\",\n        \"-i\", \"testsrc2=size=640x480:rate=30:duration=5\",\n    ], \"mp4\")\n\n\ndef input_video_640x480_5s_color() -> Tu"]
