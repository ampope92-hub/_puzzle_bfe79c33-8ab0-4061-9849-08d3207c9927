[105.419581, "o", "            name=\"Scale Down\","]
[105.419699, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.419783, "o", "            description=\"Scale a 640x480 video down to exactly 320x240.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.419877, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.420009, "o", "            input_spec=input_video_640x480_5s,\r\n\u001b[?2004l\r\u001b[?2004h>             out_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.420202, "o", "            validate=validate_video_dims(320, 240),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.420324, "o", "            solution=\"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.420474, "o", "            number=2,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.420625, "o", "            description=\"Convert the video to grayscale pixel format.\",\r\n\u001b[?2004l\r\u001b[?2004h>             media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.420867, "o", ">             input_spec=input_video_640x480_5s_color,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421096, "o", "            out_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             validate=validate_video_grayscale(),\r\n\u001b[?2004l\r"]
[105.421262, "o", "\u001b[?2004h>             solution=\"format=gray\",\r\n\u001b[?2004l\r\u001b[?2004h>             force_pix_fmt=\"gray\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421428, "o", "            number=3,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Audio Trim\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421696, "o", "            description=\"Trim a 10-second audio clip to exactly 3 seconds.\",\r\n\u001b[?2004l\r\u001b[?2004h>             media_type=\"audio\",\r\n\u001b[?2004l\r\u001b[?2004h>             input_spec=input_audio_10s,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421749, "o", "            out_ext=\"wav\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421851, "o", "            validate=validate_audio_duration_exact(3.0, tol=0.02),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.421953, "o", "            solution=\"atrim=0:3,asetpts=PTS-STARTPTS\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r"]
[105.422075, "o", "\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             number=4,\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.422225, "o", ">             name=\"Center Crop\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.42245, "o", "            description=\"Crop the center 200x200 region from a 640x480 video.\","]
[105.422557, "o", "\r\n\u001b[?2004l\r"]
[105.422584, "o", "\u001b[?2004h> "]
[105.423294, "o", "            media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h>             input_spec=input_video_640x480_5s,\r\n\u001b[?2004l\r\u001b[?2004h>             out_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             validate=validate_video_dims(200, 200),\r\n\u001b[?2004l\r\u001b[?2004h>             solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>         Level(\r\n\u001b[?2004l\r\u001b[?2004h>             number=5,\r\n\u001b[?2004l\r\u001b[?2004h>             name=\"Scale + HFlip\",\r\n\u001b[?2004l\r"]
[105.423466, "o", "\u001b[?2004h> "]
[105.423755, "o", "            description=\"Multi-step: scale 640x480 video to 320x240 AND apply a horizontal flip.\",\r\n\u001b[?2004l\r"]
[105.423941, "o", "\u001b[?2004h> "]
[105.424427, "o", "            media_type=\"video\",\r\n"]
[105.424581, "o", "\u001b[?2004l\r"]
[105.424808, "o", "\u001b[?2004h> "]
[105.425044, "o", "            input_spec=input_video_640x480_5s,\r\n\u001b[?2004l\r"]
[105.425371, "o", "\u001b[?2004h>             out_ext=\"mp4\",\r\n\u001b[?2004l\r"]
[105.425512, "o", "\u001b[?2004h> "]
[105.425846, "o", "            validate=validate_video_dims(320, 240),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.425999, "o", "            solution=\"scale=320:240,hflip\",\r\n\u001b[?2004l\r"]
[105.426183, "o", "\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.426401, "o", ">     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[105.426518, "o", "\u001b[?2004h> def interactive() -> int:"]
[105.426705, "o", "\r\n\u001b[?2004l\r"]
[105.426896, "o", "\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.427024, "o", "    total = len(levels()) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r"]
[105.427182, "o", "\u001b[?2004h>     manifest_entries = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[105.427338, "o", "\u001b[?2004h> "]
[105.427494, "o", "    print(\"FFPuzzle - FFmpeg filtergraph trainer\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.427707, "o", "    print(\"Type only the filtergraph expression (no ffmpeg command).\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.427973, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels():\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.428097, "o", ">         print(f\"Level {lvl.number}: {lvl.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.428195, "o", "        print(lvl.description)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.428304, "o", "        fg = input(\"Your filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.428528, "o", "        out_path = build_output_path(lvl.number, lvl.out_ext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.428728, "o", "        ok, details = apply_filtergraph(lvl, fg, out_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.428926, "o", "        print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         if details:\r\n\u001b[?2004l\r\u001b[?2004h>             print(details)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429106, "o", "        if ok:\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429271, "o", "        manifest_entries.append({\"level\": lvl.number, \"filename\": os.path.basename(out_path), \"ok\": bool(ok)})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429355, "o", "        print(\"\")\r\n\u001b[?2004l\r"]
[105.429381, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429595, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump({\"outputs\": manifest_entries}, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.429729, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429759, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.429842, "o", "    return 0 if score == total else 1\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[105.429883, "o", "\u001b[?2004l\r"]
[105.430058, "o", "\u001b[?2004h> def auto_solve() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.430135, "o", "    total = len(levels()) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.430174, "o", "> "]
[105.430336, "o", "    manifest_entries = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for lvl in levels():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.430485, "o", "        print(lvl.name)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.430635, "o", "        out_path = build_output_path(lvl.number, lvl.out_ext)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.430655, "o", "        ok, details = apply_filtergraph(lvl, lvl.solution, out_path)\r\n\u001b[?2004l\r"]
[105.430809, "o", "\u001b[?2004h> "]
[105.430912, "o", "        print(\"PASS\" if ok else \"FAIL\")\r\n\u001b[?2004l\r"]
[105.431145, "o", "\u001b[?2004h>         if not ok and details:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.431176, "o", "            print(details)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.431294, "o", "        if ok:\r\n\u001b[?2004l\r"]
[105.431465, "o", "\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.431625, "o", "        manifest_entries.append({\"level\": lvl.number, \"filename\": os.path.basename(out_path), \"ok\": bool(ok)})\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.431655, "o", "    with open(MANIFEST_PATH, \"w\", encoding=\"utf-8\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.43178, "o", "        json.dump({\"outputs\": manifest_entries}, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.431881, "o", "    print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return 0 if score == total else 1"]
[105.431892, "o", "\r\n\u001b[?2004l\r"]
[105.431989, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[105.432211, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> def main() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ap = argparse.ArgumentParser(description=\"FFPuzzle - learn FFmpeg filtergraphs\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[105.432235, "o", "> "]
[105.43241, "o", "    ap.add_argument(\"--auto-solve\", action=\"store_true\", help=\"run all levels with known correct solutions\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.432486, "o", "    args = ap.parse_args()\r\n\u001b[?2004l\r"]
[105.432521, "o", "\u001b[?2004h> "]
[105.432701, "o", "    return auto_solve() if args.auto_solve else interactive()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[105.432877, "o", "    raise SystemExit(main())\r\n\u001b[?2004l\r\u001b[?2004h> PY\r\n\u001b[?2004l\r"]
