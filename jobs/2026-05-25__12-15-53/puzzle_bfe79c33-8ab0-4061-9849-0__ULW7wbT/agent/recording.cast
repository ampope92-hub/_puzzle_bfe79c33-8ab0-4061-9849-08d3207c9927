[45.926081, "o", "\u001b[?2004h>             media_type=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.926225, "o", "            input_spec=input_video_640x480_5s,\r\n\u001b[?2004l\r\u001b[?2004h>             out_ext=\"mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>             validate=validate_scaled_and_flipped(320, 240),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.926291, "o", "            solution=\"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h>         ),\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[45.926502, "o", "> def interactive() -> int:\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.926653, "o", "    total = len(levels()) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.926856, "o", "    print(\"FFPuzzle - FFmpeg filtergraph trainer\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"Type only the filtergraph expression (no ffmpeg command).\\n\")\r\n\u001b[?2004l\r"]
[45.926976, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     manifest_entries = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
