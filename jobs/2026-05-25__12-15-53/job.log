 str]:\n    return (["-f", "lavfi", "-i", "sine=frequency=440:sample_rate=48000:duration=10"], "wav")\n\n\n# ---- Validators (strict via ffprobe JSON) ----\n\ndef validate_video_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return False, "no video stream"\n        aw, ah = vs.get("width"), vs.get("height")\n        ok = (aw == w and ah == h)\n        return ok, f"width={aw} height={ah}"\n    return _v\n\n\ndef validate_video_grayscale() -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return False, "no video stream"\n        pix = vs.get("pix_fmt")\n        ok = pix in ("gray", "gray8", "gray16le", "gray16be")\n        return ok, f"pix_fmt={pix}"\n    return _v\n\n\ndef validate_audio_duration_exact(target: float, tol: float = 0.02) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        dur_s = probe.get("format", {}).get("duration")\n        try:\n            dur = float(dur_s)\n        except Exception:\n            return False, f"duration={dur_s}"\n        ok = abs(dur - target) <= tol\n        return ok, f"duration={dur:.6f} (target {target})"\n    return _v\n\n\ndef build_output_path(level_num: int, ext: str) -> str:\n    return os.path.join(OUTPUT_DIR, f"level{level_num:02d}.{ext}")\n\n\ndef apply_filtergraph(level: Level, filtergraph: str, out_path: str) -> Tuple[bool, str]:\n    input_args, _ = level.input_spec()\n\n    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-y"] + input_args\n\n    if level.media_type == "video":\n        pix_fmt = level.force_pix_fmt or "yuv420p"\n        cmd += [\n            "-vf", filtergraph,\n            "-an",\n            "-c:v", "libx264",\n            "-pix_fmt", pix_fmt,\n            "-preset", "veryfast",\n            "-crf", "18",\n            "-movflags", "+faststart",\n            out_path,\n        ]\n    else:\n        cmd += [\n            "-af", filtergraph,\n            "-vn",\n            "-c:a", "pcm_s16le",\n            out_path,\n        ]\n\n    code, _out, err = run(cmd)\n    if code != 0:\n        return False, err.strip()\n\n    try:\n        ok, details = level.validate(out_path)\n        return ok, details\n    except Exception as e:\n        return False, f"validation exception: {e}"\n\n\ndef levels() -> List[Level]:\n    return [\n        Level(\n            number=1,\n            name="Scale Down",\n            description="Scale a 640x480 video down to exactly 320x240.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_video_dims(320, 240),\n            solution="scale=320:240",\n        ),\n        Level(\n            number=2,\n            name="Grayscale",\n            description="Convert the video to grayscale pixel format.",\n            media_type="video",\n            input_spec=input_video_640x480_5s_color,\n            out_ext="mp4",\n            validate=validate_video_grayscale(),\n            solution="format=gray",\n            force_pix_fmt="gray",\n        ),\n        Level(\n            number=3,\n            name="Audio Trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.",\n            media_type="audio",\n            input_spec=input_audio_10s,\n            out_ext="wav",\n            validate=validate_audio_duration_exact(3.0, tol=0.02),\n            solution="atrim=0:3,asetpts=PTS-STARTPTS",\n        ),\n        Level(\n            number=4,\n            name="Center Crop",\n            description="Crop the center 200x200 region from a 640x480 video.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_video_dims(200, 200),\n            solution="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n        ),\n        Level(\n            number=5,\n            name="Scale + HFlip",\n            description="Multi-step: scale 640x480 video to 320x240 AND apply a horizontal flip.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_video_dims(320, 240),\n            solution="scale=320:240,hflip",\n        ),\n    ]\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    total = len(levels()) * 10\n    score = 0\n    manifest_entries = []\n\n    print("FFPuzzle - FFmpeg filtergraph trainer")\n    print("Type only the filtergraph expression (no ffmpeg command).\\n")\n\n    for lvl in levels():\n        print(f"Level {lvl.number}: {lvl.name}")\n        print(lvl.description)\n        fg = input("Your filtergraph> ").strip()\n        out_path = build_output_path(lvl.number, lvl.out_ext)\n        ok, details = apply_filtergraph(lvl, fg, out_path)\n        print("PASS" if ok else "FAIL")\n        if details:\n            print(details)\n        if ok:\n            score += 10\n        manifest_entries.append({"level": lvl.number, "filename": os.path.basename(out_path), "ok": bool(ok)})\n        print("")\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump({"outputs": manifest_entries}, f, indent=2)\n\n    print(f"Score: {score}/{total}")\n    return 0 if score == total else 1\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n    total = len(levels()) * 10\n    score = 0\n    manifest_entries = []\n\n    for lvl in levels():\n        print(lvl.name)\n        out_path = build_output_path(lvl.number, lvl.out_ext)\n        ok, details = apply_filtergraph(lvl, lvl.solution, out_path)\n        print("PASS" if ok else "FAIL")\n        if not ok and details:\n            print(details)\n        if ok:\n            score += 10\n        manifest_entries.append({"level": lvl.number, "filename": os.path.basename(out_path), "ok": bool(ok)})\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump({"outputs": manifest_entries}, f, indent=2)\n\n    print(f"Score: {score}/{total}")\n    return 0 if score == total else 1\n\n\ndef main() -> int:\n    ap = argparse.ArgumentParser(description="FFPuzzle - learn FFmpeg filtergraphs")\n    ap.add_argument("--auto-solve", action="store_true", help="run all levels with known correct solutions")\n    args = ap.parse_args()\n    return auto_solve() if args.auto_solve else interactive()\n\n\nif __name__ == "__main__":\n    raise SystemExit(main())\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
