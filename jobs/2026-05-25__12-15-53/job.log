        "-f", "lavfi",\n        "-i", "testsrc2=size=640x480:rate=30:duration=5",\n    ], "mp4")\n\n\ndef input_video_640x480_5s_color() -> Tuple[List[str], str]:\n    return ([\n        "-f", "lavfi",\n        "-i", "testsrc=size=640x480:rate=30:duration=5",\n    ], "mp4")\n\n\ndef input_audio_10s() -> Tuple[List[str], str]:\n    # deterministic sine wave\n    return ([\n        "-f", "lavfi",\n        "-i", "sine=frequency=440:sample_rate=48000:duration=10",\n    ], "wav")\n\n\n# ---- Validators (ffprobe JSON) ----\n\ndef validate_video_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return False, "no video stream"\n        aw, ah = vs.get("width"), vs.get("height")\n        ok = (aw == w and ah == h)\n        return ok, f"width={aw} height={ah}"\n    return _v\n\n\ndef validate_video_grayscale() -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        vs = get_first_stream(probe, "video")\n        if not vs:\n            return False, "no video stream"\n        pix = vs.get("pix_fmt")\n        # Accept common grayscale formats only\n        ok = pix in ("gray", "gray8", "gray16le", "gray16be")\n        return ok, f"pix_fmt={pix}"\n    return _v\n\n\ndef validate_audio_duration_exact(target: float, tol: float = 0.02) -> Callable[[str], Tuple[bool, str]]:\n    def _v(path: str) -> Tuple[bool, str]:\n        probe = ffprobe_json(path)\n        fmt = probe.get("format", {})\n        dur_s = fmt.get("duration")\n        try:\n            dur = float(dur_s)\n        except Exception:\n            return False, f"duration={dur_s}"\n        ok = abs(dur - target) <= tol\n        return ok, f"duration={dur:.6f} (target {target})"\n    return _v\n\n\ndef validate_crop_dims(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    # For a crop, output dims should match crop size.\n    return validate_video_dims(w, h)\n\n\ndef validate_scaled_and_flipped(w: int, h: int) -> Callable[[str], Tuple[bool, str]]:\n    # Strictly validate dimensions; flip correctness is hard to assert via metadata.\n    # We\'ll additionally compare a checksum of a reference transform (scale+flip)\n    # computed deterministically from the same source.\n    def _v(path: str) -> Tuple[bool, str]:\n        # dim check\n        ok1, d1 = validate_video_dims(w, h)(path)\n        if not ok1:\n            return False, d1\n\n        # Create a reference and compare per-frame hash (framemd5) of first few frames\n        ref_path = os.path.join(OUTPUT_DIR, "_ref_level5_framemd5.txt")\n        out_md5 = os.path.join(OUTPUT_DIR, "_out_level5_framemd5.txt")\n\n        # Build ref from same deterministic source\n        ref_cmd = [\n            "ffmpeg", "-hide_banner", "-v", "error",\n            "-f", "lavfi", "-i", "testsrc2=size=640x480:rate=30:duration=5",\n            "-vf", "scale=320:240,hflip",\n            "-frames:v", "10",\n            "-f", "framemd5", ref_path,\n            "-y"\n        ]\n        code, _, err = run(ref_cmd)\n        if code != 0:\n            return False, f"ref framemd5 failed: {err.strip()}"\n\n        out_cmd = [\n            "ffmpeg", "-hide_banner", "-v", "error",\n            "-i", path,\n            "-frames:v", "10",\n            "-f", "framemd5", out_md5,\n            "-y"\n        ]\n        code, _, err = run(out_cmd)\n        if code != 0:\n            return False, f"out framemd5 failed: {err.strip()}"\n\n        try:\n            with open(ref_path, "r", encoding="utf-8") as f:\n                ref = f.read()\n            with open(out_md5, "r", encoding="utf-8") as f:\n                outt = f.read()\n        except Exception as e:\n            return False, f"hash read failed: {e}"\n\n        ok2 = (ref == outt)\n        return (ok2, (d1 + ("; flip+scale=OK" if ok2 else "; flip+scale=MISMATCH")))\n\n    return _v\n\n\n# ---- FFmpeg execution for a level ----\n\ndef build_output_path(level_num: int, ext: str) -> str:\n    return os.path.join(OUTPUT_DIR, f"level{level_num:02d}.{ext}")\n\n\ndef apply_filtergraph(level: Level, filtergraph: str, out_path: str) -> Tuple[bool, str]:\n    input_args, _in_ext = level.input_spec()\n\n    # Always re-encode to deterministic-ish output, avoid timestamps variability\n    # Video: libx264, yuv420p unless grayscale requires gray explicitly via filter\n    # Audio: pcm_s16le\n    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-y"]\n    cmd += input_args\n\n    if level.media_type == "video":\n        cmd += ["-vf", filtergraph]\n        cmd += [\n            "-an",\n            "-c:v", "libx264",\n            "-pix_fmt", "yuv420p",\n            "-preset", "veryfast",\n            "-crf", "18",\n            "-movflags", "+faststart",\n            out_path,\n        ]\n    else:\n        cmd += ["-af", filtergraph]\n        cmd += [\n            "-vn",\n            "-c:a", "pcm_s16le",\n            out_path,\n        ]\n\n    code, _out, err = run(cmd)\n    if code != 0:\n        return False, err.strip()\n\n    try:\n        ok, details = level.validate(out_path)\n        return ok, details\n    except Exception as e:\n        return False, f"validation exception: {e}"\n\n\ndef levels() -> List[Level]:\n    return [\n        Level(\n            number=1,\n            name="Scale Down",\n            description="Scale a 640x480 video down to exactly 320x240.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_video_dims(320, 240),\n            solution="scale=320:240",\n        ),\n        Level(\n            number=2,\n            name="Grayscale",\n            description="Convert the video to grayscale pixel format.",\n            media_type="video",\n            input_spec=input_video_640x480_5s_color,\n            out_ext="mp4",\n            validate=validate_video_grayscale(),\n            solution="format=gray",\n        ),\n        Level(\n            number=3,\n            name="Audio Trim",\n            description="Trim a 10-second audio clip to exactly 3 seconds.",\n            media_type="audio",\n            input_spec=input_audio_10s,\n            out_ext="wav",\n            validate=validate_audio_duration_exact(3.0, tol=0.02),\n            solution="atrim=0:3,asetpts=PTS-STARTPTS",\n        ),\n        Level(\n            number=4,\n            name="Center Crop",\n            description="Crop the center 200x200 region from a 640x480 video.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_crop_dims(200, 200),\n            solution="crop=200:200:(in_w-200)/2:(in_h-200)/2",\n        ),\n        Level(\n            number=5,\n            name="Scale + HFlip",\n            description="Multi-step: scale 640x480 video to 320x240 AND apply a horizontal flip.",\n            media_type="video",\n            input_spec=input_video_640x480_5s,\n            out_ext="mp4",\n            validate=validate_scaled_and_flipped(320, 240),\n            solution="scale=320:240,hflip",\n        ),\n    ]\n\n\ndef interactive() -> int:\n    ensure_dirs()\n    total = len(levels()) * 10\n    score = 0\n\n    print("FFPuzzle - FFmpeg filtergraph trainer")\n    print("Type only the filtergraph expression (no ffmpeg command).\\n")\n\n    manifest_entries = []\n\n    for lvl in levels():\n        print(f"Level {lvl.number}: {lvl.name}")\n        print(lvl.description)\n        print("Example input: generated via lavfi (no files needed).")\n        fg = input("Your filtergraph> ").strip()\n        out_path = build_output_path(lvl.number, lvl.out_ext)\n        ok, details = apply_filtergraph(lvl, fg, out_path)\n        print("PASS" if ok else "FAIL")\n        if details:\n            print(details)\n        if ok:\n            score += 10\n        manifest_entries.append({\n            "level": lvl.number,\n            "filename": os.path.basename(out_path),\n            "ok": bool(ok),\n        })\n        print("")\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump({"outputs": manifest_entries}, f, indent=2)\n\n    print(f"Score: {score}/{total}")\n    return 0 if score == total else 1\n\n\ndef auto_solve() -> int:\n    ensure_dirs()\n\n    manifest_entries = []\n    total_levels = len(levels())\n    total = total_levels * 10\n    score = 0\n\n    for lvl in levels():\n        print(lvl.name)\n        out_path = build_output_path(lvl.number, lvl.out_ext)\n        ok, details = apply_filtergraph(lvl, lvl.solution, out_path)\n        print("PASS" if ok else "FAIL")\n        if not ok and details:\n            # keep stderr/details for debugging in CI logs\n            print(details)\n        if ok:\n            score += 10\n        manifest_entries.append({\n            "level": lvl.number,\n            "filename": os.path.basename(out_path),\n            "ok": bool(ok),\n        })\n\n    with open(MANIFEST_PATH, "w", encoding="utf-8") as f:\n        json.dump({"outputs": manifest_entries}, f, indent=2)\n\n    print(f"Score: {score}/{total}")\n    return 0 if score == total else 1\n\n\ndef main() -> int:\n    ap = argparse.ArgumentParser(description="FFPuzzle - learn FFmpeg filtergraphs")\n    ap.add_argument("--auto-solve", action="store_true", help="run all levels with known correct solutions")\n    args = ap.parse_args()\n\n    if args.auto_solve:\n        return auto_solve()\n    return interactive()\n\n\nif __name__ == "__main__":\n    raise SystemExit(main())\nPY\n'] min_timeout_sec: 0.1 max_timeout_sec: 180.0
