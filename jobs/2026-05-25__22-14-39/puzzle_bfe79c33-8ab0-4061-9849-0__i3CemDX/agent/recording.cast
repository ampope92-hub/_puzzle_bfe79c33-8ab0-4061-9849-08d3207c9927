[48.195547, "o", "\u001b[?2004h>         \"input_file\": \"level3_input.wav\",\r\n\u001b[?2004l\rretu"]
[48.195977, "o", "\u001b[?2004h>         \"output_file\": \"level3_output.wav\",\r\n\u001b[?2004l\rrn False\r\n        # Try stream duration first\u001b[?2004h> "]
