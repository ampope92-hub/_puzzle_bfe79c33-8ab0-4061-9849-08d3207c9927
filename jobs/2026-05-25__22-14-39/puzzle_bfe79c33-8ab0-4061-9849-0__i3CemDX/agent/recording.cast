[48.221421, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r"]
