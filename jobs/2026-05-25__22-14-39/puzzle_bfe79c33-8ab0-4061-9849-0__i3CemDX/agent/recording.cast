[48.196577, "o", "\u001b[?2004h> "]
[48.196701, "o", "            \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.196962, "o", "            \"sine=frequency=440:duration=10\",\r\n\u001b[?2004l\r\u001b[?2004h>             os.path.join(ASSETS_DIR, \"level3_input.wav\")\r\n\u001b[?2004l\r"]
[48.197176, "o", "\u001b[?2004h>         ],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.197443, "o", "        \"stream_type\": \"audio\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.197586, "o", ">     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.197809, "o", "        \"number\": 4,\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": \"Center Crop\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.198296, "o", "        \"description\": \"Crop the center 200x200 region from a 640x480 video.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.198517, "o", "        \"input_file\": \"level4_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.198836, "o", "        \"output_file\": \"level4_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"gen_cmd\": ["]
[48.199078, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\","]
[48.199268, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.199409, "o", "            \"testsrc=duration=2:size=640x480:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.199535, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.199772, "o", "            os.path.join(ASSETS_DIR, \"level4_input.mp4\")\r\n\u001b[?2004l\r"]
[48.199902, "o", "\u001b[?2004h> "]
[48.200018, "o", "        ],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.200252, "o", "        \"stream_type\": \"video\",\r\n\u001b[?2004l\r"]
[48.200319, "o", "\u001b[?2004h>     },\r\n\u001b[?2004l\r by dim"]
[48.202416, "o", "\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.202491, "o", "        \"number\": 5,\r\n\u001b[?2004l\r"]
[48.20279, "o", "\u001b[?2004h> "]
[48.202923, "o", "        \"name\": \"Scale and Flip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.203384, "o", "        \"description\": \"Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.203593, "o", "        \"input_file\": \"level5_input.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.203921, "o", "        \"output_file\": \"level5_output.mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"gen_cmd\": [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.204093, "o", "            \"testsrc=duration=2:size=640x480:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.2043, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.204407, "o", "            os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.204432, "o", "> "]
[48.204543, "o", "        ],\r\n\u001b[?2004l\r"]
[48.204676, "o", "\u001b[?2004h>         \"stream_type\": \"video\",\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.204738, "o", "> ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.204813, "o", "\r\n\u001b[?2004l\r"]
[48.204907, "o", "\u001b[?2004h> def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.204992, "o", "    \"\"\"Generate synthetic input for a level.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.205076, "o", "    cmd = level[\"gen_cmd\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.205308, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[48.20543, "o", "> "]
[48.205556, "o", "def run_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.20562, "o", "    \"\"\"Apply a filtergraph to the level's input, producing the output.\"\"\"\r\n\u001b[?2004l\rsolution(SO\u001b[?2004h"]
[48.205688, "o", "> "]
[48.205766, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.20595, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[48.206093, "o", "\u001b[?2004h> "]
[48.206152, "o", "    if level[\"stream_type\"] == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.206186, "o", "            \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r"]
[48.206279, "o", "\u001b[?2004h> "]
[48.206499, "o", "            \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.206524, "o", "            output_path\r\n\u001b[?2004l\r"]
[48.206637, "o", "\u001b[?2004h> "]
[48.206798, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         # Video\r\n\u001b[?2004l\r"]
[48.206856, "o", "\u001b[?2004h> "]
[48.206909, "o", "        if level[\"number\"] == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.20704, "o", "            # Use rawvideo codec for level 2 to preserve pix_fmt\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.207165, "o", "            cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.2073, "o", "                \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r"]
[48.207376, "o", "\u001b[?2004h> "]
[48.207465, "o", "                \"-vf\", filtergraph,\r\n\u001b[?2004l\r"]
[48.207534, "o", "\u001b[?2004h> "]
[48.207632, "o", "                \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.207699, "o", "                output_path\r\n\u001b[?2004l\r"]
[48.207769, "o", "\u001b[?2004h>             ]\r\n\u001b[?2004l\r\u001b[?2004h>         else:"]
[48.207851, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.207978, "o", "            cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.208083, "o", "                \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r(LEVELS) * 10\r\n    \r\n    pr\u001b[?2004h> "]
[48.208158, "o", "                \"-vf\", filtergraph,\r\n\u001b[?2004l\r"]
[48.208239, "o", "\u001b[?2004h> "]
[48.208342, "o", "                \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.208406, "o", "                output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.208467, "o", "            ]\r\n\u001b[?2004l\r\")\r\n    \r\n    f\u001b[?2004h> "]
[48.208556, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.208787, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h>     return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.20881, "o", "\u001b[?2004h> "]
[48.208953, "o", "def probe_output(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.20928, "o", "    \"\"\"Probe the output file and return stream info.\"\"\"\r\n"]
[48.209355, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[48.209572, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.209713, "o", "    if not os.path.exists(output_path):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.209869, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.209947, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.210146, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.210319, "o", "        \"-show_streams\", \"-show_format\", output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\rt filt"]
[48.210368, "o", "\u001b[?2004h> "]
[48.210544, "o", "    result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r"]
[48.210565, "o", "\u001b[?2004h> "]
[48.210701, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.210773, "o", ">         return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.210789, "o", "> "]
[48.211533, "o", "    return json.loads(result.stdout)"]
[48.21157, "o", "\r\n\u001b[?2004l\r"]
[48.211741, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level(level, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.212048, "o", "    \"\"\"Validate the output against level requirements.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r"]
[48.212572, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r succ"]
[48.212695, "o", "\u001b[?2004h>     streams = probe_data.get(\"streams\", [])\r\n\u001b[?2004l\r"]
[48.212741, "o", "\u001b[?2004h> "]
[48.212874, "o", "    if not streams:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.213019, "o", "    level_num = level[\"number\"]\r\n\u001b[?2004l\r probe_output(level)\r\n      \u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[48.213223, "o", ">     if level_num == 1:\r\n\u001b[?2004l\r\u001b[?2004h>         # Check 320x240\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.213413, "o", "        video_stream = next((s for s in streams if s[\"codec_type\"] == \"video\"), None)\r\n\u001b[?2004l\r\u001b[?2004h>         if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.213438, "o", "            return False\r\n\u001b[?2004l\r"]
[48.213574, "o", "\u001b[?2004h> "]
[48.213729, "o", "        return video_stream[\"width\"] == 320 and video_stream[\"height\"] == 240\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     elif level_num == 2:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.213763, "o", "        # Check pix_fmt is gray\r\n"]
[48.213771, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[48.213959, "o", "        video_stream = next((s for s in streams if s[\"codec_type\"] == \"video\"), None)\r\n\u001b[?2004l\r\u001b[?2004h>         if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214118, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214221, "o", "        return video_stream.get(\"pix_fmt\") == \"gray\"\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[48.214255, "o", "\u001b[?2004h>     elif level_num == 3:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214406, "o", "        # Check duration is between 2.9 and 3.1 seconds\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.214474, "o", "> "]
[48.214568, "o", "        audio_stream = next((s for s in streams if s[\"codec_type\"] == \"audio\"), None)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214682, "o", "        if audio_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214776, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.214865, "o", "        # Try stream duration first, then format duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.21498, "o", "        duration = None\r\n\u001b[?2004l\r\u001b[?2004h>         if \"duration\" in audio_stream:\r\n\u001b[?2004l\r"]
[48.215045, "o", "\u001b[?2004h> "]
[48.215196, "o", "            duration = float(audio_stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h>         elif \"format\" in probe_data and \"duration\" in probe_data[\"format\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.215277, "o", "            duration = float(probe_data[\"format\"][\"duration\"])\r\n\u001b[?2004l\r"]
[48.215314, "o", "\u001b[?2004h>         if duration is None:\r\n\u001b[?2004l\r"]
[48.215357, "o", "\u001b[?2004h> "]
[48.215488, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>         return 2.9 <= duration <= 3.1\r\n\u001b[?2004l\r\u001b[?2004h>     "]
[48.215688, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     elif level_num == 4:\r\n\u001b[?2004l\r\u001b[?2004h>         # Check 200x200\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.215798, "o", "        video_stream = next((s for s in streams if s[\"codec_type\"] == \"video\"), None)\r\n\u001b[?2004l\r\u001b[?2004h>         if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216038, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>         return video_stream[\"width\"] == 200 and video_stream[\"height\"] == 200\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216185, "o", "    elif level_num == 5:\r\n\u001b[?2004l\r\u001b[?2004h>         # Check 320x240 (flip can't be verified by dimensions alone, but we check size)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216216, "o", "        video_stream = next((s for s in streams if s[\"codec_type\"] == \"video\"), None)"]
[48.21629, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216354, "o", "        if video_stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216412, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216521, "o", "        return video_stream[\"width\"] == 320 and video_stream[\"height\"] == 240\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[48.216683, "o", "\u001b[?2004h> def run_level(level, filtergraph, verbose=True):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.216843, "o", "    \"\"\"Run a single level with the given filtergraph. Returns True if passed.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.217074, "o", "    success = run_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>     if not success:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.217168, "o", "    probe_data = probe_output(level)\r\n\u001b[?2004l\r\u001b[?2004h>     return validate_level(level, probe_data)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.217307, "o", "def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.217358, "o", ">     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.217436, "o", "    total = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.21746, "o", "    for i, level in enumerate(LEVELS):\r\n\u001b[?2004l\r"]
[48.217555, "o", "\u001b[?2004h> "]
[48.217649, "o", "        solution = decode_solution(SOLUTIONS[i])\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"Level {level['number']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[48.217688, "o", "\u001b[?2004h> "]
[48.218264, "o", "        passed = run_level(level, solution, verbose=False)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": level[\"number\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"Score: {score}/{total}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[48.21833, "o", "\u001b[?2004h>     with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r"]
[48.218515, "o", "\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.218545, "o", "def interactive():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.21865, "o", "    \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.218764, "o", "    score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.218814, "o", "    print(\"=== FFmpeg Filtergraph Puzzle Game ===\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.218965, "o", "    print(\"Solve each level by entering the correct filtergraph expression.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for i, level in enumerate(LEVELS):\r\n\u001b[?2004l\r"]
[48.218985, "o", "\u001b[?2004h> "]
[48.219223, "o", "        print(f\"--- Level {level['number']}: {level['name']} ---\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  {level['description']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.219361, "o", "        print(f\"  Input: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Output: {level['output_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.219511, "o", "        \r\n\u001b[?2004l\r"]
[48.219604, "o", "\u001b[?2004h>         try:\r\n\u001b[?2004l\r"]
[48.219772, "o", "\u001b[?2004h>             filtergraph = input(\"Your filtergraph> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.219911, "o", "            print(\"\\nExiting.\")\r\n\u001b[?2004l\r\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.219961, "o", "        if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[48.220058, "o", "            print(\"  No input provided. Skipping.\\n\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[48.220131, "o", ">             manifest.append({\r\n\u001b[?2004l\r"]
