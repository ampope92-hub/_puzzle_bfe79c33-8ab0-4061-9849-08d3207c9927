[203.704078, "o", "            name=\"Level 1: Scale Down\",\r\n\u001b[?2004l\r\u001b[?2004h>             description=(\r\n\u001b[?2004l\r"]
[203.704239, "o", "\u001b[?2004h> "]
[203.704538, "o", "                \"You have a 640x480 video. Scale it down to 320x240.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.70472, "o", "                \"Hint: Use the 'scale' filter with width:height.\"\r\n\u001b[?2004l\r"]
[203.704849, "o", "\u001b[?2004h>             ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.705075, "o", "            solution=\"scale=320:240\"\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r"]
[203.705098, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.705227, "o", "    def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706196, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r"]
[203.706236, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706434, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706643, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706807, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.706847, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707005, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707105, "o", "                w = stream.get(\"width\")\r\n\u001b[?2004l\r"]
[203.707257, "o", "\u001b[?2004h> "]
[203.707289, "o", "                h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.707383, "o", "                return w == 320 and h == 240\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.707443, "o", "> "]
[203.707497, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[203.707595, "o", "\u001b[?2004h> "]
[203.707611, "o", "class Level2(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
