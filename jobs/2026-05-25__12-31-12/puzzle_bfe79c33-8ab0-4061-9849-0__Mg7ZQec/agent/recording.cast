[203.717179, "o", "    def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.717574, "o", "        super().__init__(\r\n\u001b[?2004l\r"]
[203.717601, "o", "\u001b[?2004h> "]
[203.717701, "o", "            number=4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.717852, "o", "            name=\"Level 4: Center Crop\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.717872, "o", "> "]
[203.71793, "o", "            description=(\r\n\u001b[?2004l\r"]
[203.718018, "o", "\u001b[?2004h> "]
[203.718262, "o", "                \"You have a 640x480 video. Crop the center 200x200 region.\\n\"\r\n\u001b[?2004l\r"]
[203.718385, "o", "\u001b[?2004h> "]
[203.718522, "o", "                \"Hint: Use the 'crop' filter with w:h:x:y parameters.\"\r\n\u001b[?2004l\r"]
[203.718546, "o", "\u001b[?2004h> "]
[203.718642, "o", "            ),\r\n\u001b[?2004l\r_points = 0\r\n   \u001b[?2004h> "]
[203.718751, "o", "            solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.718829, "o", "        )\r\n\u001b[?2004l\rap\u001b[?2004h> "]
[203.718864, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.71893, "o", "> "]
[203.719093, "o", "    def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.71937, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.719402, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.719516, "o", "> "]
[203.719587, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.720075, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r"]
[203.720186, "o", "        print(f\"\\n{'=' * \u001b[?2004h> "]
[203.720383, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.720445, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.720724, "o", "                w = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.720845, "o", "                h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.721005, "o", "> "]
[203.721138, "o", "                return w == 200 and h == 200\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.721282, "o", "        return False\r\n\u001b[?2004l\rr\u001b[?2004h> \r\n\u001b[?2004l\ri\u001b[?2004h"]
[203.721339, "o", "> \r\n\u001b[?2004l\r"]
[203.721397, "o", "\u001b[?2004h> class Level5(Level):\r\n\u001b[?2004l\r"]
[203.721473, "o", "\u001b[?2004h>     \"\"\"Scale to 320x240 AND apply horizontal flip.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.721493, "o", "> "]
[203.721612, "o", "    def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.721632, "o", "        super().__init__(\r\n"]
[203.721637, "o", "\u001b[?2004l\r"]
[203.721723, "o", "\u001b[?2004h>             number=5,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.721811, "o", "            name=\"Level 5: Scale + Flip\",\r\n\u001b[?2004l\r\u001b[?2004h>             description=(\r\n\u001b[?2004l\r"]
[203.721831, "o", "\u001b[?2004h> "]
[203.722316, "o", "                \"You have a 640x480 video. Scale it to 320x240 AND apply a horizontal flip.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.722401, "o", "> "]
[203.722457, "o", "                \"Hint: Chain multiple filters with commas.\"\r\n\u001b[?2004l\r"]
[203.722502, "o", "\u001b[?2004h> "]
[203.722543, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.722688, "o", "            solution=\"scale=320:240,hflip\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.72271, "o", ">         )\r\n\u001b[?2004l\r          \u001b[?2004h> "]
[203.722775, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.722825, "o", "    def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.72288, "o", "> "]
[203.723557, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.723657, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.723766, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.723917, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.723992, "o", ">             return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.724058, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.724166, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.724321, "o", "                w = stream.get(\"width\")\r\n\u001b[?2004l\r"]
[203.724347, "o", "\u001b[?2004h> "]
[203.724474, "o", "                h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.72463, "o", "                return w == 320 and h == 240\r\n\u001b[?2004l\r"]
[203.724732, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r              break\r\n\r\n  \u001b[?2004h> "]
[203.724894, "o", "def get_levels():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.724983, "o", "    \"\"\"Return all puzzle levels.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.725118, "o", "    return [Level1(), Level2(), Level3(), Level4(), Level5()]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[203.725241, "o", " \u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.725363, "o", "def run_level(level, filtergraph, verbose=True):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.725522, "o", "    \"\"\"Run a single level with the given filtergraph. Returns (success, output_path).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.725588, "o", "    # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.725617, "o", "    if verbose:\r\n\u001b[?2004l\r"]
[203.725663, "o", "\u001b[?2004h> "]
[203.725765, "o", "        print(f\"  Generating input...\")\r\n\u001b[?2004l\r"]
[203.725807, "o", "\u001b[?2004h> "]
[203.72592, "o", "    if not level.generate_input():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.726074, "o", "        if verbose:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.726281, "o", "            print(f\"  ERROR: Failed to generate input for {level.name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.726549, "o", "        return False, None\r\n\u001b[?2004l\r"]
[203.726579, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.72673, "o", "    output = level.output_path()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[203.726814, "o", "    # Apply filtergraph\r\n\u001b[?2004l\r\u001b[?2004h>     if verbose:\r\n"]
[203.726847, "o", "\u001b[?2004l\r"]
[203.72696, "o", "\u001b[?2004h> "]
[203.727006, "o", "        print(f\"  Applying filtergraph: {filtergraph}\")\r\n\u001b[?2004l\r"]
[203.727011, "o", "\u001b[?2004h> \r\n"]
[203.7272, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[203.72738, "o", "    success = level.apply_filter(filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     if not success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.727535, "o", "        if verbose:\r\n\u001b[?2004l\r  \u001b[?2004h"]
[203.727594, "o", "> "]
[203.727712, "o", "            print(f\"  ERROR: FFmpeg failed to apply filtergraph\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
