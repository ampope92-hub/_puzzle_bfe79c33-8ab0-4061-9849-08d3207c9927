[203.669781, "i", "cat > /app/ffpuzzle.py << 'PYTHON_EOF'\n#!/usr/bin/env python3\n\"\"\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nby having players solve progressively harder media transformation challenges.\n\nUsage:\n    python ffpuzzle.py             # Interactive mode\n    python ffpuzzle.py --auto-solve # Auto-solve mode (for CI)\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Directories\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\nPOINTS_PER_LEVEL = 10\n\n\ndef ensure_dirs():\n    \"\"\"Create required directories.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_ffmpeg(args, timeout=30):\n    \"\"\"Run an FFmpeg command and return success status.\"\"\"\n    cmd = [\"ffmpeg\", \"-y\"] + args\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=timeout\n        )\n        return re"]
[203.670024, "i", "sult.returncode == 0\n    except subprocess.TimeoutExpired:\n        return False\n    except Exception:\n        return False\n\n\ndef run_ffprobe(filepath):\n    \"\"\"Run ffprobe on a file and return parsed JSON output.\"\"\"\n    cmd = [\n        \"ffprobe\",\n        \"-v\", \"quiet\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        filepath\n    ]\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=15\n        )\n        if result.returncode == 0:\n            return json.loads(result.stdout.decode())\n    except Exception:\n        pass\n    return None\n\n\ndef generate_input_video(output_path, width=640, height=480, duration=5, fps=25):\n    \"\"\"Generate a synthetic test video using lavfi testsrc.\"\"\"\n    args = [\n        \"-f\", \"lavfi\",\n        \"-i\", f\"testsrc=size={width}x{height}:rate={fps}:duration={duration}\",\n        \"-c:v\", \"libx264\",\n        \"-pix_fmt\", \"yuv420p\",\n        output_path\n    ]\n"]
[203.670107, "o", "cat > /app/ffpuzzle.py << 'PYTHON_EOF'\r\n\u001b[?2004l\r\u001b[?2004h> #!/usr/bin/env python3\r\n\u001b[?2004l\r"]
[203.670137, "i", "    return run_ffmpeg(args)\n\n\ndef generate_input_audio(output_path, duration=10, sample_rate=44100):\n    \"\"\"Generate a synthetic test audio using lavfi sine.\"\"\"\n    args = [\n        \"-f\", \"lavfi\",\n        \"-i\", f\"sine=frequency=440:sample_rate={sample_rate}:duration={duration}\",\n        \"-c:a\", \"aac\",\n        output_path\n    ]\n    return run_ffmpeg(args)\n\n\ndef apply_filtergraph_video(input_path, output_path, filtergraph):\n    \"\"\"Apply a video filtergraph with standard settings.\"\"\"\n    args = [\n        \"-i\", input_path,\n        \"-vf\", filtergraph,\n        \"-c:v\", \"libx264\",\n        \"-pix_fmt\", \"yuv420p\",\n        output_path\n    ]\n    return run_ffmpeg(args)\n\n\ndef apply_filtergraph_video_gray(input_path, output_path, filtergraph):\n    \"\"\"Apply a video filtergraph preserving grayscale pixel format.\"\"\"\n    args = [\n        \"-i\", input_path,\n        \"-vf\", filtergraph,\n        \"-c:v\", \"ffv1\",\n        \"-pix_fmt\", \"gray\",\n        output_path\n    ]\n    return run_ffmpeg(args)\n\n\ndef apply_filtergraph_audio(input_path,"]
[203.670217, "o", "\u001b[?2004h> "]
[203.670343, "i", " output_path, filtergraph):\n    \"\"\"Apply an audio filtergraph.\"\"\"\n    args = [\n        \"-i\", input_path,\n        \"-af\", filtergraph,\n        \"-c:a\", \"aac\",\n        output_path\n    ]\n    return run_ffmpeg(args)\n\n\n# --- Level Definitions ---\n\nclass Level:\n    \"\"\"Base class for a puzzle level.\"\"\"\n    def __init__(self, number, name, description, solution):\n        self.number = number\n        self.name = name\n        self.description = description\n        self.solution = solution\n\n    def input_path(self):\n        return os.path.join(ASSETS_DIR, f\"level{self.number}_input.mp4\")\n\n    def output_path(self):\n        return os.path.join(OUTPUT_DIR, f\"level{self.number}_output.mp4\")\n\n    def generate_input(self):\n        raise NotImplementedError\n\n    def apply_filter(self, filtergraph):\n        \"\"\"Apply the user's filtergraph to produce output.\"\"\"\n        return apply_filtergraph_video(self.input_path(), self.output_path(), filtergraph)\n\n    def validate(self, probe_data):\n        raise NotImplementedError\n\n\nclass L"]
[203.670515, "o", "\"\"\"FFmpeg Filtergraph Puzzle Game\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> A terminal-based puzzle game that teaches FFmpeg filtergraphs\r\n\u001b[?2004l\r\u001b[?2004h> by having players solve progressively harder media transformation challenges.\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> Usage:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.670971, "i", "evel1(Level):\n    \"\"\"Scale a 640x480 video down to 320x240.\"\"\"\n    def __init__(self):\n        super().__init__(\n            number=1,\n            name=\"Level 1: Scale Down\",\n            description=(\n                \"You have a 640x480 video. Scale it down to 320x240.\\n\"\n                \"Hint: Use the 'scale' filter with width:height.\"\n            ),\n            solution=\"scale=320:240\"\n        )\n\n    def generate_input(self):\n        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\n\n    def validate(self, probe_data):\n        if not probe_data or \"streams\" not in probe_data:\n            return False\n        for stream in probe_data[\"streams\"]:\n            if stream.get(\"codec_type\") == \"video\":\n                w = stream.get(\"width\")\n                h = stream.get(\"height\")\n                return w == 320 and h == 240\n        return False\n\n\nclass Level2(Level):\n    \"\"\"Convert a video to grayscale pixel format.\"\"\"\n    def __init__(self):\n        super().__init__(\n            "]
