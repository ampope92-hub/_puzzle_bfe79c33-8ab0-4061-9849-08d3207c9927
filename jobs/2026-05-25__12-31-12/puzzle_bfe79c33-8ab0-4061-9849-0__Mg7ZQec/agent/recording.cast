[203.714812, "o", "        return generate_input_audio(self.input_path(), duration=10)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.714931, "o", "    def apply_filter(self, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.715342, "o", "        return apply_filtergraph_audio(self.input_path(), self.output_path(), filtergraph)\r\n\u001b[?2004l\r"]
[203.715414, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.715534, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.715647, "o", "        if not probe_data or \"format\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.715677, "o", "> "]
[203.715742, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.715813, "o", "> "]
[203.71594, "o", "        duration_str = probe_data[\"format\"].get(\"duration\", \"0\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.716076, "o", "            duration = float(duration_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.716142, "o", "        except (ValueError, TypeError):\r\n\u001b[?2004l\r"]
[203.716189, "o", "\u001b[?2004h> "]
[203.716236, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.71644, "o", "        # Allow small tolerance for audio encoding\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.716626, "o", "        return abs(duration - 3.0) < 0.15\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.716658, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rta\u001b[?2004h> "]
[203.716871, "o", "class Level4(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
