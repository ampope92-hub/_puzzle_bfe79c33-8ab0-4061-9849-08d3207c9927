[59.478653, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.478863, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>                 w = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
