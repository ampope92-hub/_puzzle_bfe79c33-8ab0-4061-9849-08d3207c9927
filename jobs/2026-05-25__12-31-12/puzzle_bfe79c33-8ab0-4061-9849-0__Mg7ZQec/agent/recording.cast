[59.482564, "o", "                # but we verify the filtergraph ran successfully with correct size\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.482656, "o", "                return w == 320 and h == 240\r\n\u001b[?2004l\r\u001b[?2004h> "]
