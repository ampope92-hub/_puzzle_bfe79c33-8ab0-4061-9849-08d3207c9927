[59.438652, "i", "\n    def generate_input(self):\n        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\n\n    def validate(self, probe_data):\n        if not probe_data or \"streams\" not in probe_data:\n            return False\n        for stream in probe_data[\"streams\"]:\n            if stream.get(\"codec_type\") == \"video\":\n                w = stream.get(\"width\")\n                h = stream.get(\"height\")\n                return w == 320 and h == 240\n        return False\n\n\nclass Level2(Level):\n    \"\"\"Convert a video to grayscale pixel format.\"\"\"\n    def __init__(self):\n        super().__init__(\n            number=2,\n            name=\"Level 2: Grayscale\",\n            description=(\n                \"You have a color video (yuv420p). Convert it to grayscale.\\n\"\n                \"Hint: Use the 'format' filter to change pixel format to 'gray'.\"\n            ),\n            solution=\"format=gray\"\n        )\n\n    def generate_input(self):\n        return generate_input_video(self.input_path(), width=640, height=4"]
