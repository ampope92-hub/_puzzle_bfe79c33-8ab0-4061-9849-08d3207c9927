[59.449702, "o", "            stdout=subprocess.PIPE,\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.449821, "o", "> "]
[59.450029, "o", "            stderr=subprocess.PIPE,\r\n\u001b[?2004l\r Fal\u001b[?2004h> "]
[59.450197, "o", "            timeout=15\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.450347, "o", ">         )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.450536, "o", "        if result.returncode == 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.450884, "o", "            return json.loads(result.stdout.decode())\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.451102, "o", "    except Exception:\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.451158, "o", ">         pass\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.451373, "o", ">     return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.452029, "o", "def generate_input_video(output_path, width=640, height=480, duration=5, fps=25):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.452384, "o", "    \"\"\"Generate a synthetic test video using lavfi testsrc.\"\"\"\r\n\u001b[?2004l\rn_ffmp\u001b[?2004h> "]
[59.452593, "o", "    args = [\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.452781, "o", ">         \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.453186, "o", "        \"-i\", f\"testsrc=size={width}x{height}:rate={fps}:duration={duration}\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.453321, "o", "        \"-c:v\", \"libx264\",\r\n\u001b[?2004l\r__(\r\n\u001b[?2004h> "]
[59.453475, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r"]
[59.453566, "o", "\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.453744, "o", "    ]\r\n\u001b[?2004l\r\u001b[?2004h>     return run_ffmpeg(args)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[59.453796, "o", "> \r\n\u001b[?2004l\r"]
[59.45403, "o", "\u001b[?2004h> "]
[59.454583, "o", "def generate_input_audio(output_path, duration=10, sample_rate=44100):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Generate a synthetic test audio using lavfi sine.\"\"\"\r\n\u001b[?2004l\r"]
[59.454784, "o", "\u001b[?2004h> "]
[59.455161, "o", "    args = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.455222, "o", "        \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-i\", f\"sine=frequency=440:sample_rate={sample_rate}:duration={duration}\",\r\n\u001b[?2004l\r"]
[59.455935, "o", "\u001b[?2004h>         \"-c:a\", \"aac\",\r\n\u001b[?2004l\r\u001b[?2004h>         output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h>     return run_ffmpeg(args)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\ri\u001b[?2004h> def apply_filtergraph(input_path, output_path, filtergraph, is_audio=False):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.456005, "o", "    \"\"\"Apply a filtergraph to an input file and produce output.\"\"\"\r\n\u001b[?2004l\r"]
[59.4565, "o", "\u001b[?2004h>     if is_audio:\r\n\u001b[?2004l\r\u001b[?2004h>         args = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.456579, "o", "            \"-c:a\", \"aac\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.456675, "o", "            output_path\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.456734, "o", ">         ]\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.456805, "o", ">     else:\r\n\u001b[?2004l\rlueError, "]
[59.456856, "o", "\u001b[?2004h> "]
[59.456995, "o", "        args = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.457426, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-c:v\", \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h>             \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\r\n\r\nclass Level4(\u001b[?2004h>             output_path\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h>     return run_ffmpeg(args)\r\n\u001b[?2004l\r"]
[59.457536, "o", "Level):\r\n    \"\"\"Crop the center 200x200 region from a 640x480 v"]
[59.457647, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.457668, "o", "# --- Level Definitions ---\r\n"]
[59.457711, "o", "\u001b[?2004l\r\u001b[?2004h"]
[59.458318, "o", "> \r\n\u001b[?2004l\r"]
[59.458436, "o", "\u001b[?2004h> class Level:\r\n\u001b[?2004l\rup\u001b[?2004h>     \"\"\"Base class for a puzzle level.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     def __init__(self, number, name, description, solution, is_audio=False):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.458897, "o", "        self.number = number\r\n\u001b[?2004l\reo. \u001b[?2004h>         self.name = name\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.459064, "o", "        self.description = description\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.459105, "o", "        self.solution = solution\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.459391, "o", "        self.is_audio = is_audio\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def input_path(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.459936, "o", "        ext = \".m4a\" if self.is_audio else \".mp4\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.460076, "o", "        return os.path.join(ASSETS_DIR, f\"level{self.number}_input{ext}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r(), wid"]
[59.460123, "o", "\u001b[?2004h> "]
[59.46023, "o", "    def output_path(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.460263, "o", "        ext = \".m4a\" if self.is_audio else \".mp4\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.460707, "o", "        return os.path.join(OUTPUT_DIR, f\"level{self.number}_output{ext}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.460766, "o", "        raise NotImplementedError\r\n"]
[59.461, "o", "\u001b[?2004l\r\u001b[?2004h> \r\n"]
[59.461116, "o", "\u001b[?2004l\r\u001b[?2004h>     def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h>         raise NotImplementedError\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\r\n\u001b[?2004h> \r\n\u001b[?2004l\r "]
[59.461151, "o", "\u001b[?2004h> "]
[59.461286, "o", "class Level1(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.461455, "o", "    \"\"\"Scale a 640x480 video down to 320x240.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.461657, "o", "    def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h>         super().__init__(\r\n\u001b[?2004l\r\u001b[?2004h>             number=1,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.461806, "o", "            name=\"Level 1: Scale Down\",\r\n\u001b[?2004l\r"]
[59.461868, "o", "\u001b[?2004h> "]
[59.462472, "o", "            description=(\r\n\u001b[?2004l\r"]
[59.462595, "o", "\u001b[?2004h> "]
[59.46294, "o", "                \"You have a 640x480 video. Scale it down to 320x240.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.4633, "o", "                \"Hint: Use the 'scale' filter with width:height.\"\r\n\u001b[?2004l\r\u001b[?2004h>             ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.463759, "o", "            solution=\"scale=320:240\"\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def generate_input(self):"]
[59.464002, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.464728, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.465076, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r_input_video(self.input_\u001b[?2004h>             return False\r\n\u001b[?2004l\r"]
[59.465334, "o", "\u001b[?2004h>         for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.465683, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>                 w = stream.get(\"width\")\r\n\u001b[?2004l\r"]
[59.465723, "o", "\u001b[?2004h> "]
[59.465948, "o", "                h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.466052, "o", "                return w == 320 and h == 240\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.466313, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[59.466336, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.466612, "o", "class Level2(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.466698, "o", "    \"\"\"Convert a video to grayscale pixel format.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     def __init__(self):\r\n\u001b[?2004l\r            # We can ver\u001b[?2004h>         super().__init__(\r\n\u001b[?2004l\r"]
[59.466763, "o", "\u001b[?2004h> "]
[59.466934, "o", "            number=2,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.467128, "o", "            name=\"Level 2: Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h>             description=("]
[59.467243, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.467257, "o", "                \"You have a color video (yuv420p). Convert it to grayscale.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.467534, "o", "                \"Hint: Use the 'format' filter to change pixel format to 'gray'.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.467596, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.46768, "o", "> "]
[59.467757, "o", "            solution=\"format=gray\"\r\n\u001b[?2004l\run\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r_level(leve"]
[59.467794, "o", "\u001b[?2004h> "]
[59.467906, "o", "    def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.468202, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.468362, "o", "    def output_path(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.468797, "o", "        return os.path.join(OUTPUT_DIR, f\"level{self.number}_output.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r_\u001b[?2004h> "]
[59.468921, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.469059, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n"]
[59.46914, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[59.469307, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.469458, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\rin\u001b[?2004h> "]
[59.46962, "o", "                pix_fmt = stream.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.469712, "o", "                # gray or gray8 are acceptable\r\n\u001b[?2004l\r"]
[59.469771, "o", "\u001b[?2004h> "]
[59.469782, "o", "                return pix_fmt in (\"gray\", \"gray8\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.469862, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[59.469959, "o", "> "]
[59.470078, "o", "    def apply_filtergraph_custom(self, input_path, output_path, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.470327, "o", "        \"\"\"Custom apply for grayscale - don't force yuv420p output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.470362, "o", ">         args = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.470455, "o", "            \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.470537, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-c:v\", \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.470886, "o", "            output_path\r\n\u001b[?2004l\r\u001b[?2004h>         ]\r\n\u001b[?2004l\r\u001b[?2004h>         return run_ffmpeg(args)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rt\u001b[?2004h> class Level3(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.471055, "o", "    \"\"\"Trim a 10-second audio clip to exactly 3 seconds.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h>         super().__init__(\r\n\u001b[?2004l\r"]
[59.471204, "o", "\u001b[?2004h>             number=3,\r\n\u001b[?2004l\r"]
[59.471282, "o", "\u001b[?2004h>             name=\"Level 3: Audio Trim\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.471712, "o", "            description=(\r\n\u001b[?2004l\r\u001b[?2004h>                 \"You have a 10-second audio clip. Trim it to exactly 3 seconds.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h>                 \"Hint: Use the 'atrim' filter with start and end times.\"\r\n\u001b[?2004l\r\u001b[?2004h>             ),\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.471894, "o", ">             solution=\"atrim=start=0:end=3,asetpts=PTS-STARTPTS\",\r\n\u001b[?2004l\r"]
[59.472203, "o", "\u001b[?2004h>             is_audio=True\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def generate_input(self):\r\n\u001b[?2004l\r* POINTS_PER_LEVEL\r\n    earned_points = 0\r\n    manifest_entries = []\r\n"]
[59.472287, "o", "\u001b[?2004h> "]
[59.472523, "o", "        return generate_input_audio(self.input_path(), duration=10)\r\n\u001b[?2004l\r"]
[59.472615, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.472714, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.472955, "o", "        if not probe_data or \"format\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.473363, "o", "        duration_str = probe_data[\"format\"].get(\"duration\", \"0\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.473417, "o", "        try:\r\n\u001b[?2004l\r     \u001b[?2004h> "]
[59.473607, "o", "            duration = float(duration_str)\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.473827, "o", "> "]
[59.473966, "o", "        except (ValueError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h"]
[59.474408, "o", ">             return False\r\n\u001b[?2004l\r          print(f\"  FAIL\"\u001b[?2004h"]
[59.474448, "o", "> "]
[59.474644, "o", "        # Allow small tolerance for audio encoding\r\n\u001b[?2004l\r"]
[59.474907, "o", "\u001b[?2004h> "]
[59.475009, "o", "        return abs(duration - 3.0) < 0.15\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[59.475329, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> class Level4(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.475564, "o", "    \"\"\"Crop the center 200x200 region from a 640x480 video.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.475687, "o", "    def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.475801, "o", "        super().__init__(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.475937, "o", "            number=4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.476089, "o", "            name=\"Level 4: Center Crop\",\r\n\u001b[?2004l\r"]
[59.476186, "o", "\u001b[?2004h>             description=(\r\n\u001b[?2004l\r"]
[59.476353, "o", "\u001b[?2004h> "]
[59.476461, "o", "                \"You have a 640x480 video. Crop the center 200x200 region.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.476597, "o", "                \"Hint: Use the 'crop' filter with w:h:x:y parameters.\"\r\n\u001b[?2004l\r"]
[59.476758, "o", "\u001b[?2004h>             ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.477013, "o", "            solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.477085, "o", "        )\r\n"]
[59.47722, "o", "\u001b[?2004l\r"]
[59.477418, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def generate_input(self):\r\n\u001b[?2004l\rFEST_PATH, \"w\") as f:\r\n        j"]
[59.477571, "o", "\u001b[?2004h"]
[59.477772, "o", "> "]
[59.477984, "o", "        return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r)\r\n\r\n    r\u001b[?2004h> \r\n\u001b[?2004l\re"]
