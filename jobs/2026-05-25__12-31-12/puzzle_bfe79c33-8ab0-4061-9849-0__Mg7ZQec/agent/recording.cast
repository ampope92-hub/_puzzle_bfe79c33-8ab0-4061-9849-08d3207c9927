[59.440303, "i", "led on output\")\n        return False, output\n\n    valid = level.validate(probe_data)\n    return valid, output\n\n\ndef auto_solve_mode():\n    \"\"\"Run all levels with known correct solutions.\"\"\"\n    ensure_dirs()\n    levels = get_levels()\n    total_points = len(levels) * POINTS_PER_LEVEL\n    earned_points = 0\n    manifest_entries = []\n\n    print(\"=\" * 50)\n    print(\"FFmpeg Filtergraph Puzzle - Auto-Solve Mode\")\n    print(\"=\" * 50)\n    print()\n\n    for level in levels:\n        print(f\"{level.name}\")\n        valid, output = run_level(level, level.solution, verbose=True)\n\n        if valid:\n            print(f\"  PASS\")\n            earned_points += POINTS_PER_LEVEL\n        else:\n            print(f\"  FAIL\")\n\n        # Record manifest entry\n        output_filename = os.path.basename(output) if output else None\n        manifest_entries.append({\n            \"level\": level.number,\n            \"filename\": output_filename,\n            \"validation\": valid\n        })\n        print()\n\n    # Print final score\n    print(\"=\" * 50)"]
