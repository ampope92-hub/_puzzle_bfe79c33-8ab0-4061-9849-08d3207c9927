[59.48012, "o", "            description=(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.480262, "o", "                \"You have a 640x480 video. Scale it to 320x240 AND apply a horizontal flip.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.480498, "o", "                \"Hint: Chain multiple filters with commas.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[59.480669, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h>             solution=\"scale=320:240,hflip\"\r\n\u001b[?2004l\renerate_input():\r\n           "]
[59.480778, "o", " print(\"ERROR: "]
