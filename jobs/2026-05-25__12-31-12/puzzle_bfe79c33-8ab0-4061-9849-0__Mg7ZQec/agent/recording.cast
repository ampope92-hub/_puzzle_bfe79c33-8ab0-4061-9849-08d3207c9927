[59.437968, "i", "    return run_ffmpeg(args)\n\n\ndef generate_input_audio(output_path, duration=10, sample_rate=44100):\n    \"\"\"Generate a synthetic test audio using lavfi sine.\"\"\"\n    args = [\n        \"-f\", \"lavfi\",\n        \"-i\", f\"sine=frequency=440:sample_rate={sample_rate}:duration={duration}\",\n        \"-c:a\", \"aac\",\n        output_path\n    ]\n    return run_ffmpeg(args)\n\n\ndef apply_filtergraph(input_path, output_path, filtergraph, is_audio=False):\n    \"\"\"Apply a filtergraph to an input file and produce output.\"\"\"\n    if is_audio:\n        args = [\n            \"-i\", input_path,\n            \"-af\", filtergraph,\n            \"-c:a\", \"aac\",\n            output_path\n        ]\n    else:\n        args = [\n            \"-i\", input_path,\n            \"-vf\", filtergraph,\n            \"-c:v\", \"libx264\",\n            \"-pix_fmt\", \"yuv420p\",\n            output_path\n        ]\n    return run_ffmpeg(args)\n\n\n# --- Level Definitions ---\n\nclass Level:\n    \"\"\"Base class for a puzzle level.\"\"\"\n    def __init__(self, number, name, description, solution, is"]
