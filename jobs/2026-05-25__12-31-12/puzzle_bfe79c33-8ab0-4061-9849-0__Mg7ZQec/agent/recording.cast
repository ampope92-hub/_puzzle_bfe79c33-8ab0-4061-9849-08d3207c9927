[203.708039, "o", "\u001b[?2004h> "]
[203.708204, "o", "        super().__init__(\r\n\u001b[?2004l\r"]
[203.708292, "o", "\u001b[?2004h> "]
[203.708375, "o", "            number=2,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.70865, "o", "            name=\"Level 2: Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.708856, "o", ">             description=(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.709026, "o", "                \"You have a color video (yuv420p). Convert it to grayscale.\\n\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.709347, "o", "                \"Hint: Use the 'format' filter to change pixel format to 'gray'.\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.709471, "o", "            ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.709589, "o", "            solution=\"format=gray\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.709712, "o", ">         )\r\n\u001b[?2004l\r"]
[203.709815, "o", ", verbose=\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def generate_input(self):\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.710222, "o", ">         return generate_input_video(self.input_path(), width=640, height=480, duration=2)\r\n\u001b[?2004l\r"]
[203.710347, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     def output_path(self):\r\n\u001b[?2004l\rif verbose:\r\n        print(f\""]
[203.71049, "o", "\u001b[?2004h>         return os.path.join(OUTPUT_DIR, f\"level{self.number}_output.mkv\")\r\n\u001b[?2004l\r"]
[203.710605, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.710699, "o", "    def apply_filter(self, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.710837, "o", "        \"\"\"Apply filtergraph preserving grayscale format.\"\"\"\r\n\u001b[?2004l\r"]
[203.710873, "o", "\u001b[?2004h> "]
[203.711108, "o", "        return apply_filtergraph_video_gray(self.input_path(), self.output_path(), filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rAp\u001b[?2004h> "]
[203.711218, "o", "    def validate(self, probe_data):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.711506, "o", "        if not probe_data or \"streams\" not in probe_data:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.711638, "o", "        for stream in probe_data[\"streams\"]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.711671, "o", "> "]
[203.711812, "o", "            if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.711952, "o", "                pix_fmt = stream.get(\"pix_fmt\", \"\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.712129, "o", "                return pix_fmt in (\"gray\", \"gray8\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.712233, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.712341, "o", "class Level3(Level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.712608, "o", "    \"\"\"Trim a 10-second audio clip to exactly 3 seconds.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.71271, "o", "    def __init__(self):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.712834, "o", "        super().__init__(\r\n\u001b[?2004l\rlse, output\r\n\r\n    v\u001b[?2004h> "]
[203.712912, "o", "            number=3,\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.713011, "o", "> "]
[203.713076, "o", "            name=\"Level 3: Audio Trim\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.713148, "o", "            description=(\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.713185, "o", "> "]
[203.713256, "o", "                \"You have a 10-second audio clip. Trim it to exactly 3 seconds.\\n\"\r\n\u001b[?2004l\r"]
[203.71328, "o", "\u001b[?2004h> "]
[203.713504, "o", "                \"Hint: Use the 'atrim' filter with start and end times.\"\r\n\u001b[?2004l\r\u001b[?2004h>             ),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.713764, "o", "            solution=\"atrim=start=0:end=3,asetpts=PTS-STARTPTS\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[203.713864, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h"]
[203.71391, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h>     def input_path(self):\r\n\u001b[?2004l\r"]
[203.713948, "o", "\u001b[?2004h> "]
[203.714136, "o", "        return os.path.join(ASSETS_DIR, f\"level{self.number}_input.m4a\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[203.714167, "o", "\u001b[?2004h> "]
[203.714259, "o", "    def output_path(self):\r\n\u001b[?2004l\rlid"]
[203.714435, "o", "\u001b[?2004h> "]
[203.714598, "o", "        return os.path.join(OUTPUT_DIR, f\"level{self.number}_output.m4a\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rd"]
[203.714683, "o", "\u001b[?2004h> "]
