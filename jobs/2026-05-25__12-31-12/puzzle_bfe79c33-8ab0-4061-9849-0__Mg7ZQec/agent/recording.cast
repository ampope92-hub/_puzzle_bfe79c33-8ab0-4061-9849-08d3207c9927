[59.484341, "o", "        return False, None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[59.484409, "o", "\u001b[?2004h> "]
[59.484536, "o", "    output = level.output_path()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     # Apply filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
