[59.437108, "i", "cat > /app/ffpuzzle.py << 'PYTHON_EOF'\n#!/usr/bin/env python3\n\"\"\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nby having players solve progressively harder media transformation challenges.\n\nUsage:\n    python ffpuzzle.py             # Interactive mode\n    python ffpuzzle.py --auto-solve # Auto-solve mode (for CI)\n\"\"\"\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Directories\nASSETS_DIR = \"/app/assets\"\nOUTPUT_DIR = \"/app/output\"\nMANIFEST_PATH = \"/app/manifest.json\"\n\nPOINTS_PER_LEVEL = 10\n\n\ndef ensure_dirs():\n    \"\"\"Create required directories.\"\"\"\n    os.makedirs(ASSETS_DIR, exist_ok=True)\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_ffmpeg(args, timeout=30):\n    \"\"\"Run an FFmpeg command and return success status.\"\"\"\n    cmd = [\"ffmpeg\", \"-y\"] + args\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=timeout\n        )\n        return re"]
[59.437453, "i", "sult.returncode == 0\n    except subprocess.TimeoutExpired:\n        return False\n    except Exception:\n        return False\n\n\ndef run_ffprobe(filepath):\n    \"\"\"Run ffprobe on a file and return parsed JSON output.\"\"\"\n    cmd = [\n        \"ffprobe\",\n        \"-v\", \"quiet\",\n        \"-print_format\", \"json\",\n        \"-show_format\",\n        \"-show_streams\",\n        filepath\n    ]\n    try:\n        result = subprocess.run(\n            cmd,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.PIPE,\n            timeout=15\n        )\n        if result.returncode == 0:\n            return json.loads(result.stdout.decode())\n    except Exception:\n        pass\n    return None\n\n\ndef generate_input_video(output_path, width=640, height=480, duration=5, fps=25):\n    \"\"\"Generate a synthetic test video using lavfi testsrc.\"\"\"\n    args = [\n        \"-f\", \"lavfi\",\n        \"-i\", f\"testsrc=size={width}x{height}:rate={fps}:duration={duration}\",\n        \"-c:v\", \"libx264\",\n        \"-pix_fmt\", \"yuv420p\",\n        output_path\n    ]\n"]
