[50.841793, "o", "\u001b[?2004h> "]
[50.84185, "o", "        auto_solve()\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[50.841973, "o", "\u001b[?2004h>         interactive_mode()\r\n\u001b[?2004l\r\u001b[?2004h> "]
