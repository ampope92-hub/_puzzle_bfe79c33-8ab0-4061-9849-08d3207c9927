[50.808617, "o", ">     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.808925, "o", "        f\"testsrc=duration={duration}:size={width}x{height}:rate=25\",\r\n\u001b[?2004l\rfilter\u001b[?2004h> "]
[50.809384, "o", "        \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.809654, "o", "        output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r"]
[50.810308, "o", "\u001b[?2004h> "]
[50.811032, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.81119, "o", "    return output_path\r\n\u001b[?2004l\re\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.811887, "o", "def generate_video_input_avi(filename, width, height, duration):\r\n\u001b[?2004l\r"]
[50.812228, "o", "\u001b[?2004h>     \"\"\"Generate a synthetic video input in AVI format with rawvideo.\"\"\"\r\n\u001b[?2004l\r"]
[50.812486, "o", "\u001b[?2004h> "]
[50.812852, "o", "    output_path = os.path.join(ASSETS_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.813059, "o", "> "]
[50.813195, "o", "    cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.813338, "o", "        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r"]
[50.813389, "o", "\u001b[?2004h> "]
[50.813708, "o", "        f\"testsrc=duration={duration}:size={width}x{height}:rate=25\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"rgb24\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.813884, "o", "        output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.814386, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h>     return output_path\r\n\u001b[?2004l\rlutio\u001b[?2004h> \r\n\u001b[?2004l\rn\u001b[?2004h"]
[50.814431, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.81498, "o", "def generate_audio_input(filename, duration):\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Generate a synthetic audio input using sine wave.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.815229, "o", "    output_path = os.path.join(ASSETS_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.815308, "o", "    cmd = [\r\n\u001b[?2004l\r"]
[50.815381, "o", "\u001b[?2004h> "]
[50.816, "o", "        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\r\n\u001b[?2004l\r\u001b[?2004h>         f\"sine=frequency=440:duration={duration}\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.816143, "o", "        output_path\r\n\u001b[?2004l\r  "]
[50.816405, "o", "\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.817178, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h>     return output_path\r\n\u001b[?2004l\r"]
[50.817331, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rri\u001b[?2004h> "]
[50.817409, "o", "def run_ffprobe(filepath):\r\n\u001b[?2004l\r"]
[50.817566, "o", "\u001b[?2004h> "]
[50.818026, "o", "    \"\"\"Run ffprobe and return parsed JSON output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r"]
[50.818058, "o", "\u001b[?2004h> "]
[50.818237, "o", "        \"-show_streams\", \"-show_format\", filepath\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.818401, "o", ">     ]\r\n\u001b[?2004l\r\u001b[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.818703, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.818918, "o", "        return None\r\n\u001b[?2004l\r"]
[50.819042, "o", "\u001b[?2004h> "]
[50.819201, "o", "    return json.loads(result.stdout)\r\n\u001b[?2004l\r"]
[50.819275, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r F\u001b[?2004h> "]
[50.8197, "o", "def validate_video_dimensions(filename, expected_width, expected_height):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.819957, "o", "    \"\"\"Validate that video output has expected dimensions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.820237, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.820444, "o", "    probe = run_ffprobe(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.82071, "o", "    if probe is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.820988, "o", "    for stream in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.821352, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.821936, "o", "            w = stream.get(\"width\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.821979, "o", "> "]
[50.822122, "o", "            h = stream.get(\"height\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.822289, "o", "            return w == expected_width and h == expected_height\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.82254, "o", "    return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r "]
[50.822737, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.82289, "o", "def validate_pixel_format(filename, expected_pix_fmt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.823133, "o", "    \"\"\"Validate that video output has expected pixel format.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.823827, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.823865, "o", "> "]
[50.824187, "o", "    probe = run_ffprobe(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.824346, "o", "    if probe is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.824615, "o", "        return False\r\n\u001b[?2004l\rsuccess \u001b[?2004h> "]
[50.824986, "o", "    for stream in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.825115, "o", "        if stream.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.825261, "o", "            pix_fmt = stream.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.825631, "o", "            return pix_fmt == expected_pix_fmt\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.825676, "o", ">     return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.825702, "o", "> "]
[50.825835, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r \u001b[?2004h> "]
[50.82613, "o", "def validate_audio_duration(filename, min_dur, max_dur):\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.826175, "o", "> "]
[50.826452, "o", "    \"\"\"Validate that audio output has duration within range.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.826577, "o", "> "]
[50.826773, "o", "    filepath = os.path.join(OUTPUT_DIR, filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.826863, "o", "> "]
[50.827009, "o", "    probe = run_ffprobe(filepath)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.827211, "o", "    if probe is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.827477, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.827749, "o", "    # Check format duration first\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.827941, "o", "    fmt = probe.get(\"format\", {})\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.82798, "o", "> "]
[50.828222, "o", "    duration_str = fmt.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.828512, "o", "    if duration_str is not None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.82891, "o", "        duration = float(duration_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.829184, "o", "        return min_dur <= duration <= max_dur\r\n\u001b[?2004l\r\u001b[?2004h>     # Fallback to stream duration\r\n\u001b[?2004l\rint\u001b[?2004h> "]
[50.829447, "o", "    for stream in probe.get(\"streams\", []):\r\n\u001b[?2004l\r\u001b[?2004h>         if stream.get(\"codec_type\") == \"audio\":"]
[50.829496, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.829629, "o", "            duration_str = stream.get(\"duration\")\r\n\u001b[?2004l\r\u001b[?2004h>             if duration_str is not None:\r\n\u001b[?2004l\r"]
[50.829766, "o", "\u001b[?2004h> "]
[50.829801, "o", "                duration = float(duration_str)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.830111, "o", "                return min_dur <= duration <= max_dur\r\n\u001b[?2004l\r\u001b[?2004h>     return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def apply_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r"]
[50.830346, "o", "\u001b[?2004h> "]
[50.830481, "o", "    \"\"\"Apply a filtergraph to the level's input and produce output.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.830564, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.830715, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.830776, "o", "    # Determine if this is audio or video based on the input file extension\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.830972, "o", "    is_audio = level[\"input_file\"].endswith(\".wav\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.831015, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     if is_audio:\r\n\u001b[?2004l\r"]
[50.831024, "o", "\u001b[?2004h> "]
[50.831287, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.831381, "o", "            \"-af\", filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.831498, "o", "        ] + level[\"ffmpeg_extra_args\"] + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.83176, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>             \"ffmpeg\", \"-y\", \"-i\", input_path,\r\n\u001b[?2004l\r\u001b[?2004h>             \"-vf\", filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.83192, "o", "        ] + level[\"ffmpeg_extra_args\"] + [output_path]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.832131, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h>     return result.returncode == 0\r\n\u001b[?2004l\r"]
[50.832242, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.832538, "o", "def run_level(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.832685, "o", "    \"\"\"Run a single level: generate input, apply filter, validate.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.832878, "o", "    level[\"gen_input\"]()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Apply filtergraph\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833035, "o", "    success = apply_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833135, "o", "    if not success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833252, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Validate output\r\n\u001b[?2004l\r\u001b[?2004h>     return level[\"validate\"]()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.833375, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833521, "o", "def auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run through all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r"]
[50.833566, "o", "\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833589, "o", "    manifest = []\r\n\u001b[?2004l\r"]
[50.833705, "o", "\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833838, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.833992, "o", "    \r\n"]
[50.834084, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[50.834136, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.834172, "o", "        level_num = level[\"level\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.834316, "o", "        level_name = level[\"name\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.83445, "o", "        print(f\"Level {level_num}: {level_name}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.834555, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.834676, "o", "        # Decode the obfuscated solution\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.834709, "o", "        solution = _decode_solution(level[\"solution\"])\r\n\u001b[?2004l\r"]
[50.834945, "o", "\u001b[?2004h> "]
[50.83504, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         # Run the level\r\n\u001b[?2004l\r\u001b[?2004h>         passed = run_level(level, solution)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.835091, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r"]
[50.835217, "o", "\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r"]
[50.835276, "o", "\u001b[?2004h> "]
[50.835421, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[50.835695, "o", "\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h>             \"level\": level_num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.835782, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.835885, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.835984, "o", "    print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.836087, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.836356, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.836486, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[50.836622, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run the game in interactive mode.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.836659, "o", ">     manifest = []"]
[50.836824, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.83698, "o", "    total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r"]
[50.8372, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\" * 60)\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"  FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\" * 60)\r\n\u001b[?2004l\r"]
[50.837329, "o", "\u001b[?2004h>     print()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.837371, "o", "> "]
[50.837441, "o", "        level_num = level[\"level\"]\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.837507, "o", "> "]
[50.837624, "o", "        level_name = level[\"name\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.837835, "o", "        print(f\"--- Level {level_num}: {level_name} ---\")\r\n\u001b[?2004l\r\u001b[?2004h>         print(level[\"description\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.837999, "o", "        print()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.838136, "o", "        # Generate input\r\n\u001b[?2004l\r\u001b[?2004h>         level[\"gen_input\"]()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[50.838247, "o", "\u001b[?2004h> "]
[50.838339, "o", "        filtergraph = input(\"Enter your filtergraph expression: \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.838418, "o", "        if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.838525, "o", "            print(\"  FAIL (no input provided)\")\r\n\u001b[?2004l\r\u001b[?2004h>             print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.838554, "o", "            manifest.append({\r\n\u001b[?2004l\r"]
[50.838672, "o", "\u001b[?2004h>                 \"level\": level_num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.838811, "o", "                \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.838852, "o", "> "]
[50.838995, "o", "                \"passed\": False\r\n\u001b[?2004l\r\u001b[?2004h>             })\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839018, "o", "            continue\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839171, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         # Apply and validate\r\n\u001b[?2004l\r"]
[50.839244, "o", "\u001b[?2004h> "]
[50.839327, "o", "        success = apply_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.839402, "o", "> "]
[50.839475, "o", "        if success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839593, "o", "            passed = level[\"validate\"]()\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.839679, "o", ">         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839711, "o", "            passed = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839831, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.839896, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.839943, "o", "> "]
[50.840022, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.840144, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:"]
[50.840222, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r"]
[50.840289, "o", "\u001b[?2004h> "]
[50.840425, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r"]
[50.840506, "o", "\u001b[?2004h> "]
[50.840597, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.840722, "o", "            \"level\": level_num,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.84082, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.840876, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.840903, "o", "> "]
[50.840932, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.841069, "o", "    print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[50.841097, "o", ">     "]
[50.841207, "o", "\r\n\u001b[?2004l\r"]
[50.841243, "o", "\u001b[?2004h> "]
[50.841325, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.84143, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.841513, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[50.841586, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r"]
[50.841629, "o", "\u001b[?2004h> "]
