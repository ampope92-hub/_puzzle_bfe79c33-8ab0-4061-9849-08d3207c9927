[50.774867, "i", "            pix_fmt = stream.get(\"pix_fmt\")\n            return pix_fmt == expected_pix_fmt\n    return False\n\n\ndef validate_audio_duration(filename, min_dur, max_dur):\n    \"\"\"Validate that audio output has duration within range.\"\"\"\n    filepath = os.path.join(OUTPUT_DIR, filename)\n    probe = run_ffprobe(filepath)\n    if probe is None:\n        return False\n    # Check format duration first\n    fmt = probe.get(\"format\", {})\n    duration_str = fmt.get(\"duration\")\n    if duration_str is not None:\n        duration = float(duration_str)\n        return min_dur <= duration <= max_dur\n    # Fallback to stream duration\n    for stream in probe.get(\"streams\", []):\n        if stream.get(\"codec_type\") == \"audio\":\n            duration_str = stream.get(\"duration\")\n            if duration_str is not None:\n                duration = float(duration_str)\n                return min_dur <= duration <= max_dur\n    return False\n\n\ndef apply_filtergraph(level, filtergraph):\n    \"\"\"Apply a filtergraph to the level's input and produce o"]
