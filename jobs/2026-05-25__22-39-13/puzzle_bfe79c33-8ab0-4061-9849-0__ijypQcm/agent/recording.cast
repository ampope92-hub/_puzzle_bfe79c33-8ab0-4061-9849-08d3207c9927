[50.774097, "i", "te a synthetic video input in AVI format with rawvideo.\"\"\"\n    output_path = os.path.join(ASSETS_DIR, filename)\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n        f\"testsrc=duration={duration}:size={width}x{height}:rate=25\",\n        \"-c:v\", \"rawvideo\", \"-pix_fmt\", \"rgb24\",\n        output_path\n    ]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return output_path\n\n\ndef generate_audio_input(filename, duration):\n    \"\"\"Generate a synthetic audio input using sine wave.\"\"\"\n    output_path = os.path.join(ASSETS_DIR, filename)\n    cmd = [\n        \"ffmpeg\", \"-y\", \"-f\", \"lavfi\", \"-i\",\n        f\"sine=frequency=440:duration={duration}\",\n        output_path\n    ]\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return output_path\n\n\ndef run_ffprobe(filepath):\n    \"\"\"Run ffprobe and return parsed JSON output.\"\"\"\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \"-show_streams\", \"-show_form"]
