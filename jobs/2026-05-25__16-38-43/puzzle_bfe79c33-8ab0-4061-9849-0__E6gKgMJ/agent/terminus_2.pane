[?2004l[?2004h> def auto_solve_mode():
[?2004l[?2004h>     """Run all levels with known correct solutions."""
[?2004l[?2004h>     total_points = 0
[?2004l[?2004h>     earned_points = 0
[?2004l[?2004h>     manifest = []
[?2004l[?2004h>     
[?2004l[?2004h>     for level in LEVELS:
[?2004l[?2004h>         print(level["name"])
[?2004l[?2004h>         total_points += level["points"]
[?2004l[?2004h>         
[?2004l[?2004h>         passed, output_filename = run_level(level, level["solution"], verbose=True)
[?2004l[?2004h>         
[?2004l[?2004h>         if passed:
[?2004l[?2004h>             print("PASS")
[?2004l[?2004h>             earned_points += level["points"]
[?2004l[?2004h>         else:
[?2004l[?2004h>             print("FAIL")
[?2004l[?2004h>         
[?2004l[?2004h>         manifest.append({
[?2004l[?2004h>             "level": level["num"],
[?2004l[?2004h>             "filename": output_filename,
[?2004l[?2004h>             "valid": passed,
[?2004l[?2004h>         })
[?2004l[?2004h>     
[?2004l[?2004h>     # Print final score
[?2004l[?2004h>     print(f"Score: {earned_points}/{total_points}")
[?2004l[?2004h>     
[?2004l[?2004h>     # Write manifest
[?2004l[?2004h>     with open(MANIFEST_PATH, "w") as f:
[?2004l[?2004h>         json.dump(manifest, f, indent=2)
[?2004l[?2004h>     
[?2004l[?2004h>     return earned_points == total_points
