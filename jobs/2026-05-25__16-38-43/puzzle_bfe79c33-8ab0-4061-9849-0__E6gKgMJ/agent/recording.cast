[144.903327, "o", "        passed, output_filename = run_level(level, level[\\\"solution\\\"], verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[144.903413, "o", "> "]
