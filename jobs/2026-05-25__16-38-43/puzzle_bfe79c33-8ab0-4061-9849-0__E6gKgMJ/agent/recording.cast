[212.307693, "i", " output_path, level)\n    if not success:\n        if verbose:\n            print(\"  FFmpeg failed to apply the filtergraph.\")\n        return False, output_filename\n    probe_data = probe_file(output_path)\n    passed = validate_output(probe_data, level[\"checks\"])\n    if verbose and not passed:\n        print(f\"  Validation failed. Expected: {level[\\'checks\\']}\")\n        if probe_data and probe_data.get(\"streams\"):\n            stream = probe_data[\"streams\"][0]\n            print(f\"  Got: width={stream.get(\\'width\\')}, height={stream.get(\\'height\\')}, \"\n                  f\"pix_fmt={stream.get(\\'pix_fmt\\')}, duration={stream.get(\\'duration\\')}\")\n    return passed, output_filename\n\n\ndef auto_solve_mode():\n    \"\"\"Run all levels with known correct solutions.\"\"\"\n    total_points = 0\n    earned_points = 0\n    manifest = []\n    for level in LEVELS:\n        print(level[\"name\"])\n        total_points += level[\"points\"]\n        passed, output_filename = run_level(level, level[\"solution\"], verbose=True)\n        if passed:\n     "]
