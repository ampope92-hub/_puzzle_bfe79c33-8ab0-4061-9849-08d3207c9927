[53.071531, "o", "            f\"ffmpeg -y -i {input_path} -vf \\\"{filtergraph}\\\" \"\r\n\u001b[?2004l\r"]
[53.071575, "o", "\u001b[?2004h> "]
[53.072173, "o", "            f\"-c:v libx264 -pix_fmt yuv420p {output_path}\"\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r           \"\u001b[?2004h> "]
[53.072453, "o", "    elif input_type == \"audio\":\r\n\u001b[?2004l\r"]
[53.072696, "o", "\u001b[?2004h>         cmd = (\r\n\u001b[?2004l\r       \"points\":\u001b[?2004h> "]
[53.073348, "o", "            f\"ffmpeg -y -i {input_path} -af \\\"{filtergraph}\\\" \"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.073612, "o", "            f\"-c:a pcm_s16le {output_path}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.073987, "o", "        )\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[53.074313, "o", "\u001b[?2004h>         raise ValueError(f\"Unknown input type: {input_type}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.074476, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.074627, "o", "    result = run_cmd(cmd)\r\n"]
[53.074777, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[53.07493, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r"]
[53.075142, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[53.075293, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def probe_file(filepath):\r\n\u001b[?2004l\r"]
[53.075379, "o", "\u001b[?2004h> "]
[53.075593, "o", "    \"\"\"Use ffprobe to get file properties as JSON.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = (\r\n\u001b[?2004l\rth\": 640, \"h"]
[53.075639, "o", "\u001b[?2004h> "]
[53.076133, "o", "        f\"ffprobe -v quiet -print_format json -show_format -show_streams {filepath}\"\r\n\u001b[?2004l\r\u001b[?2004h>     )\r\n\u001b[?2004l\r"]
[53.07639, "o", "\u001b[?2004h>     result = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r"]
[53.076611, "o", "\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.076947, "o", "        return json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.077156, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.077209, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.077398, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.077719, "o", "def validate_output(probe_data, checks):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.078035, "o", "    \"\"\"Validate ffprobe output against expected checks.\r\n"]
[53.078173, "o", "\u001b[?2004l\r"]
[53.078418, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\rle it\u001b[?2004h> "]
[53.079292, "o", "    checks is a dict with keys like:\r\n\u001b[?2004l\r"]
[53.080331, "o", "\u001b[?2004h>       - width: expected width\r\n\u001b[?2004l\r\u001b[?2004h>       - height: expected height\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.080559, "o", "      - pix_fmt: expected pixel format\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.081121, "o", "      - duration_min: minimum duration in seconds\r\n\u001b[?2004l\r"]
[53.081769, "o", "\u001b[?2004h>       - duration_max: maximum duration in seconds\r\n\u001b[?2004l\r\": 640, \"height\": 480},\r\n        \"solution\": \"scale\u001b[?2004h>       - codec_type: 'video' or 'audio'\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"\r\n\u001b[?2004l\r\".mp4\",\r\n"]
[53.081842, "o", "\u001b[?2004h>     if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.082283, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.08248, "o", "    streams = probe_data.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.082608, "o", "    if not streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.082735, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.082953, "o", "    # Find the relevant stream\r\n\u001b[?2004l\r\u001b[?2004h>     codec_type = checks.get(\"codec_type\", \"video\")\r\n\u001b[?2004l\r"]
[53.083302, "o", "\u001b[?2004h> "]
[53.083491, "o", "    stream = None\r\n\u001b[?2004l\r\u001b[?2004h>     for s in streams:\r\n\u001b[?2004l\r"]
[53.083607, "o", "\u001b[?2004h> "]
[53.083778, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.083887, "o", "            stream = s\r\n\u001b[?2004l\rf in"]
[53.084092, "o", "\u001b[?2004h> "]
[53.084502, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.084621, "o", "    if stream is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.084928, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r420p "]
[53.085205, "o", "\u001b[?2004h> "]
[53.08543, "o", "    # Check width\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.08572, "o", "    if \"width\" in checks:\r\n\u001b[?2004l\r_"]
[53.085839, "o", "fmt\""]
[53.085883, "o", "\u001b[?2004h> "]
[53.08603, "o", "        if stream.get(\"width\") != checks[\"width\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.086241, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h"]
[53.086447, "o", ">     # Check height\r\n\u001b[?2004l\r"]
[53.086632, "o", "\u001b[?2004h>     if \"height\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.08677, "o", "        if stream.get(\"height\") != checks[\"height\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.086882, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[53.08698, "o", "\u001b[?2004h> "]
[53.087138, "o", "    # Check pixel format\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.087303, "o", "    if \"pix_fmt\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.087466, "o", "        if stream.get(\"pix_fmt\") != checks[\"pix_fmt\"]:\r\n\u001b[?2004l\rt_path} \u001b[?2004h> "]
[53.087704, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[53.087908, "o", "\u001b[?2004h>     # Check duration\r\n\u001b[?2004l\r\u001b[?2004h>     duration = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.088186, "o", "    if \"duration\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.088556, "o", "        duration = float(stream[\"duration\"])\r\n\u001b[?2004l\r"]
[53.088597, "o", "\u001b[?2004h> "]
[53.088745, "o", "    elif \"duration\" in probe_data.get(\"format\", {}):\r\n\u001b[?2004l\rath} -af \\\"{fi\u001b[?2004h> "]
[53.088944, "o", "        duration = float(probe_data[\"format\"][\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.089112, "o", "    \r\n\u001b[?2004l\r"]
[53.089308, "o", "\u001b[?2004h>     if \"duration_min\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.089609, "o", "        if duration is None or duration < checks[\"duration_min\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.089755, "o", "            return False\r\n\u001b[?2004l\r"]
[53.090063, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     if \"duration_max\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.090223, "o", "> "]
[53.090468, "o", "        if duration is None or duration > checks[\"duration_max\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.090611, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.09082, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\r\n \u001b[?2004h> "]
