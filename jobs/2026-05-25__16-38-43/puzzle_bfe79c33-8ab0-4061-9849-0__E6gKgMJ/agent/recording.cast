[53.053776, "i", "   if user_input.lower() in ('quit', 'exit'):\n            print(\"Exiting...\")\n            break\n        \n        passed, _ = run_level(level, user_input, verbose=True)\n        \n        if passed:\n            print(\"\\n  ✓ PASS! Well done!\")\n            earned_points += level[\"points\"]\n        else:\n            print(f\"\\n  ✗ FAIL. The correct answer was: {level['solution']}\")\n        print()\n    \n    print(\"-\"*60)\n    print(f\"\\nFinal Score: {earned_points}/{total_points}\")\n    print()\n\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\n    parser.add_argument(\n        \"--auto-solve\", action=\"store_true\",\n        help=\"Run in auto-solve mode with known correct solutions\"\n    )\n    args = parser.parse_args()\n    \n    if args.auto_solve:\n        success = auto_solve_mode()\n        sys.exit(0 if success else 1)\n    else:\n        interactive_mode()\n\n\nif __name__ == \"__main__\":\n    main()\nEOF\n"]
