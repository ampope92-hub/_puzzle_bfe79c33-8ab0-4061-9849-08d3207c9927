[53.053713, "i", "  else:\n        return False\n    \n    result = run_cmd(cmd)\n    if result.returncode != 0:\n        return False\n    return True\n\n\ndef run_level(level, filtergraph, verbose=False):\n    \"\"\"Run a single level with the given filtergraph. Returns (passed, output_path).\"\"\"\n    level_num = level[\"num\"]\n    input_type = level[\"input_type\"]\n    \n    # Generate input\n    input_path = generate_input(level_num, input_type, **level[\"input_params\"])\n    if input_path is None:\n        return False, None\n    \n    # Determine output path\n    output_filename = f\"level{level_num}_output{level['output_ext']}\"\n    output_path = os.path.join(OUTPUT_DIR, output_filename)\n    \n    # Apply filtergraph\n    success = apply_filtergraph_level(input_path, filtergraph, output_path, level)\n    if not success:\n        if verbose:\n            print(\"  FFmpeg failed to apply the filtergraph.\")\n        return False, output_filename\n    \n    # Validate output\n    probe_data = probe_file(output_path)\n    passed = validate_output(probe_data, level"]
