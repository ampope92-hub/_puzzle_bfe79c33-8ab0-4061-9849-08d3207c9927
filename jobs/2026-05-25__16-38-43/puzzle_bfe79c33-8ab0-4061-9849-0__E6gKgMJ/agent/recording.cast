[53.105513, "o", "\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.105833, "o", "def apply_filtergraph_level(input_path, filtergraph, output_path, level):\r\n\u001b[?2004l\rrin\u001b[?2004h"]
[53.105934, "o", "> "]
[53.106347, "o", "    \"\"\"Apply filtergraph with level-specific options.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.106375, "o", "    input_type = level[\"input_type\"]"]
[53.106456, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[53.106562, "o", "     \u001b[?2004h> "]
[53.106738, "o", "    if input_type == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.106958, "o", "        # For grayscale level, don't force yuv420p output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.107352, "o", "        if level.get(\"output_pix_fmt\") is None and \"pix_fmt\" in level[\"checks\"]:\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.107378, "o", "> "]
[53.107671, "o", "            # Let the pixel format pass through\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.107827, "o", "> "]
[53.107856, "o", "            cmd = (\r\n\u001b[?2004l\r"]
[53.107926, "o", "\u001b[?2004h> "]
[53.108225, "o", "                f\"ffmpeg -y -i {input_path} -vf \\\"{filtergraph}\\\" \"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.108391, "o", "                f\"-c:v libx264 {output_path}\"\r\n\u001b[?2004l\r\u001b[?2004h>             )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.108624, "o", "        else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.108756, "o", "            cmd = (\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.108947, "o", "                f\"ffmpeg -y -i {input_path} -vf \\\"{filtergraph}\\\" \"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.109236, "o", "                f\"-c:v libx264 -pix_fmt yuv420p {output_path}\"\r\n\u001b[?2004l\r\u001b[?2004h>             )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.109379, "o", "    elif input_type == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = (\r\n"]
[53.109504, "o", "\u001b[?2004l\r\u001b[?2004h> "]
[53.109712, "o", "            f\"ffmpeg -y -i {input_path} -af \\\"{filtergraph}\\\" \"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.109842, "o", "            f\"-c:a pcm_s16le {output_path}\"\r\n\u001b[?2004l\r\u001b[?2004h>         )\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.10987, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     "]
[53.109999, "o", "\r\n\u001b[?2004l\r"]
[53.110112, "o", "\u001b[?2004h>     result = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r"]
[53.11014, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.110235, "o", "    return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11036, "o", "def run_level(level, filtergraph, verbose=False):\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.110423, "o", "> "]
[53.110558, "o", "    \"\"\"Run a single level with the given filtergraph. Returns (passed, output_path).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.110629, "o", "> "]
[53.110723, "o", "    level_num = level[\"num\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.110939, "o", "    input_type = level[\"input_type\"]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11118, "o", "    input_path = generate_input(level_num, input_type, **level[\"input_params\"])\r\n\u001b[?2004l\r\u001b[?2004h>     if input_path is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False, None\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.111224, "o", ">     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.111314, "o", "    # Determine output path\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.111382, "o", "> "]
[53.111458, "o", "    output_filename = f\"level{level_num}_output{level['output_ext']}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.11154, "o", "> "]
[53.111629, "o", "    output_path = os.path.join(OUTPUT_DIR, output_filename)\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.111696, "o", ">     \r\n\u001b[?2004l\r"]
[53.111737, "o", "\u001b[?2004h> "]
[53.111821, "o", "    # Apply filtergraph\r\n\u001b[?2004l\r"]
[53.111869, "o", "\u001b[?2004h> "]
[53.111947, "o", "    success = apply_filtergraph_level(input_path, filtergraph, output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.112007, "o", ">     if not success:\r\n\u001b[?2004l\r"]
[53.112073, "o", "\u001b[?2004h> "]
[53.1121, "o", "        if verbose:"]
[53.112277, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.112447, "o", "            print(\"  FFmpeg failed to apply the filtergraph.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.112489, "o", "        return False, output_filename\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[53.1126, "o", "\u001b[?2004h>     # Validate output\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.112699, "o", "    probe_data = probe_file(output_path)\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.11282, "o", "> "]
[53.112845, "o", "    passed = validate_output(probe_data, level[\"checks\"])\r\n\u001b[?2004l\r"]
[53.112956, "o", "\u001b[?2004h>     \r\n"]
[53.11307, "o", "\u001b[?2004l\r\u001b[?2004h>     if verbose and not passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.113153, "o", "> "]
[53.113164, "o", "        print(f\"  Validation failed. Expected: {level['checks']}\")\r\n\u001b[?2004l\r"]
[53.113263, "o", "\u001b[?2004h> "]
[53.113359, "o", "        if probe_data and probe_data.get(\"streams\"):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11348, "o", "            stream = probe_data[\"streams\"][0]"]
[53.113514, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.113644, "o", "            print(f\"  Got: width={stream.get('width')}, height={stream.get('height')}, \"\r\n\u001b[?2004l\r\u001b[?2004h"]
[53.113731, "o", "> "]
[53.113841, "o", "                  f\"pix_fmt={stream.get('pix_fmt')}, duration={stream.get('duration')}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.113967, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     return passed, output_filename\r\n\u001b[?2004l\r"]
[53.11417, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.114379, "o", "    \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     total_points = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.114462, "o", "    earned_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11451, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.114607, "o", "        print(level[\"name\"])\r\n\u001b[?2004l\r"]
[53.114712, "o", "\u001b[?2004h"]
[53.114874, "o", "> "]
[53.115018, "o", "        total_points += level[\"points\"]\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h"]
[53.115176, "o", "> "]
[53.115284, "o", "        passed, output_filename = run_level(level, level[\"solution\"], verbose=True)\r\n\u001b[?2004l\r"]
[53.11545, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[53.115664, "o", "\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.115827, "o", "            earned_points += level[\"points\"]\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.115944, "o", "        manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.116051, "o", "            \"level\": level[\"num\"],\r\n\u001b[?2004l\r\u001b[?2004h>             \"filename\": output_filename,\r\n\u001b[?2004l\r"]
[53.116119, "o", "\u001b[?2004h> "]
[53.116218, "o", "            \"valid\": passed,\r\n\u001b[?2004l\r"]
[53.116353, "o", "\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     # Print final score\r\n\u001b[?2004l\r"]
[53.116548, "o", "\u001b[?2004h>     print(f\"Score: {earned_points}/{total_points}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[53.11658, "o", "\u001b[?2004h> "]
[53.116735, "o", "    # Write manifest\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.116846, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11695, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117038, "o", "    return earned_points == total_points\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[53.117106, "o", "\u001b[?2004h> "]
[53.117176, "o", "def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117352, "o", "    \"\"\"Run in interactive mode, prompting the user for filtergraphs.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117532, "o", "    total_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117642, "o", "    print(\"=\"*60)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117758, "o", "    print(\"  FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.117862, "o", "    print(\"=\"*60)\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r"]
[53.117941, "o", "\u001b[?2004h> "]
[53.117984, "o", "    print(\"Solve each level by typing the correct FFmpeg filtergraph.\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.11817, "o", "    print(\"Type 'quit' or 'exit' to stop.\")\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r"]
[53.118319, "o", "\u001b[?2004h> "]
[53.118397, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r"]
[53.118483, "o", "\u001b[?2004h> "]
[53.118549, "o", "        total_points += level[\"points\"]\r\n\u001b[?2004l\r"]
[53.118617, "o", "\u001b[?2004h> "]
[53.118688, "o", "        \r\n\u001b[?2004l\r"]
[53.118796, "o", "\u001b[?2004h>         print(\"-\"*60)\r\n\u001b[?2004l\r"]
[53.118956, "o", "\u001b[?2004h>         print(f\"\\n{level['name']}\")\r\n\u001b[?2004l\r"]
[53.119102, "o", "\u001b[?2004h> "]
[53.119208, "o", "        print(f\"\\n{level['description']}\")\r\n\u001b[?2004l\r"]
[53.119272, "o", "\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.119349, "o", "        \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.119399, "o", "        try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.119517, "o", "            user_input = input(\"Your filtergraph> \").strip()\r\n\u001b[?2004l\r"]
[53.119591, "o", "\u001b[?2004h> "]
[53.119666, "o", "        except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r"]
[53.119701, "o", "\u001b[?2004h> "]
[53.119783, "o", "            print(\"\\nExiting...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.119884, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.119995, "o", "        if user_input.lower() in ('quit', 'exit'):\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"Exiting...\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.120128, "o", "            break\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[53.120158, "o", "        passed, _ = run_level(level, user_input, verbose=True)\r\n"]
[53.12026, "o", "\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r"]
[53.120285, "o", "\u001b[?2004h> "]
[53.148155, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"\\n  ✓ PASS! Well done!\")\r\n\u001b[?2004l\r\u001b[?2004h>             earned_points += level[\"points\"]\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"\\n  ✗ FAIL. The correct answer was: {level['solution']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         print()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     print(\"-\"*60)\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"\\nFinal Score: {earned_points}/{total_points}\")\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def main():\r\n\u001b[?2004l\r\u001b[?2004h>     parser = argparse.ArgumentParser(description=\"FFmpeg Filtergraph Puzzle Game\")\r\n\u001b[?2004l\r\u001b[?2004h>     parser.add_argument(\r\n\u001b[?2004l\r\u001b[?2004h>         \"--auto-solve\", action=\"store_true\",\r\n\u001b[?2004l\r\u001b[?2004h>         help=\"Run in auto-solve mode with known correct solutions\"\r\n\u001b[?2004l\r\u001b[?2004h>     )\r\n\u001b[?2004l\r\u001b[?2004h>     args = parser.parse_args()\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     if args.auto_solve:\r\n\u001b[?2004l"]
[53.148423, "o", "\r\u001b[?2004h>         success = auto_solve_mode()\r\n\u001b[?2004l\r\u001b[?2004h>         sys.exit(0 if success else 1)\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         interactive_mode()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h>     main()\r\n\u001b[?2004l\r\u001b[?2004h> EOF\r\n\u001b[?2004l\r"]
[53.150768, "o", "\u001b[?2004hroot@cfac50873e20:/app# "]
[54.006725, "i", "chmod +x /app/ffpuzzle.py\n"]
[54.007233, "o", "chmod +x /app/ffpuzzle.py\r\n\u001b[?2004l\r"]
[54.010169, "o", "\u001b[?2004hroot@cfac50873e20:/app# "]
[54.360536, "i", "python3 /app/ffpuzzle.py --auto-solve\n"]
[54.36092, "o", "python3 /app/ffpuzzle.py --auto-solve\r\n\u001b[?2004l\r"]
[54.445574, "o", "Level 1: Scale Down\r\n"]
[55.26151, "o", "PASS\r\nLevel 2: Convert to Grayscale\r\n"]
[56.072329, "o", "  Validation failed. Expected: {'codec_type': 'video', 'pix_fmt': 'gray'}\r\n  Got: width=640, height=480, pix_fmt=yuvj420p, duration=2.000000\r\nFAIL\r\nLevel 3: Trim Audio\r\n"]
[56.308746, "o", "PASS\r\nLevel 4: Crop Center\r\n"]
[56.905197, "o", "PASS\r\nLevel 5: Scale and Flip\r\n"]
