[144.904877, "o", "    print(\\\"=\\\" * 60)\r\n\u001b[?2004l\r\u001b[?2004h>     print()\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.90497, "o", "    print(\\\"Solve each level by typing the correct FFmpeg filtergraph.\\\")\r\n\u001b[?2004l\r\u001b[?2004h>     print(\\\"Type 'quit' or 'exit' to stop.\\\")\r\n\u001b[?2004l\r"]
