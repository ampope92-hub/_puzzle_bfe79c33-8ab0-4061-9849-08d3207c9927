[144.898247, "o", "def apply_filtergraph_level(input_path, filtergraph, output_path, level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.898735, "o", "    \\\"\\\"\\\"Apply filtergraph with level-specific encoding options.\\\"\\\"\\\"\\n    input_type = level[\\\"input_type\\\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.899548, "o", "    codec = level[\\\"codec\\\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.899712, "o", "    pix_fmt = level.get(\\\"output_pix_fmt\\\")\r\n\u001b[?2004l\r\u001b[?2004h>     if input_type == \\\"video\\\":\r\n\u001b[?2004l\r\u001b[?2004h>         pix_fmt_arg = f\\\"-pix_fmt {pix_fmt}\\\" if pix_fmt else \\\"\\\"\r\n\u001b[?2004l\r\u001b[?2004h>         cmd = f\\\"ffmpeg -y -i {input_path} -vf \\\\\\\"{filtergraph}\\\\\\\" -c:v {codec} {pix_fmt_arg} {output_path}\\\"\r\n\u001b[?2004l\r\u001b[?2004h>     elif input_type == \\\"audio\\\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
