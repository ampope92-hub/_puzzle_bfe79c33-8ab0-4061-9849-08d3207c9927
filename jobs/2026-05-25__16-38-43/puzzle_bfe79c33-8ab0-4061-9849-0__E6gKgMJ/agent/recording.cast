[144.903719, "o", "\u001b[?2004h>             print(\\\"FAIL\\\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.903822, "o", "        manifest.append({\\\"level\\\": level[\\\"num\\\"], \\\"filename\\\": output_filename, \\\"valid\\\": passed})\r\n\u001b[?2004l\r\u001b[?2004h>     print(f\\\"Score: {earned_points}/{total_points}\\\")"]
[144.903909, "o", "\r\n\u001b[?2004l\r"]
[144.904057, "o", "\u001b[?2004h>     with open(MANIFEST_PATH, \\\"w\\\") as f:\r\n\u001b[?2004l\r\u001b[?2004h>         json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> "]
