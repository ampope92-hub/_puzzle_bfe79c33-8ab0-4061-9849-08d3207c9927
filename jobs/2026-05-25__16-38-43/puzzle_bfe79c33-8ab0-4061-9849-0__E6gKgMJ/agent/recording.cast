[144.899899, "o", "    else:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.900048, "o", "    result = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.90023, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.900346, "o", "def run_level(level, filtergraph, verbose=False):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.900506, "o", "    \\\"\\\"\\\"Run a single level with the given filtergraph. Returns (passed, output_filename).\\\"\\\"\\\"\\n    level_num = level[\\\"num\\\"]\r\n\u001b[?2004l\r\u001b[?2004h>     input_type = level[\\\"input_type\\\"]\r\n\u001b[?2004l\r"]
[144.900738, "o", "\u001b[?2004h>     input_path = generate_input(level_num, input_type, **level[\\\"input_params\\\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.90077, "o", "    if input_path is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.900892, "o", "        return False, None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901079, "o", "    output_filename = f\\\"level{level_num}_output{level['output_ext']}\\\"\r\n\u001b[?2004l\r\u001b[?2004h>     output_path = os.path.join(OUTPUT_DIR, output_filename)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901259, "o", "    success = apply_filtergraph_level(input_path, filtergraph, output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901412, "o", "    if not success:\r\n\u001b[?2004l\r\u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\\\"  FFmpeg failed to apply the filtergraph.\\\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901627, "o", "        return False, output_filename\r\n\u001b[?2004l\r\u001b[?2004h>     probe_data = probe_file(output_path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901654, "o", "    passed = validate_output(probe_data, level[\\\"checks\\\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901846, "o", "    if verbose and not passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.901961, "o", "        print(f\\\"  Validation failed. Expected: {level['checks']}\\\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
