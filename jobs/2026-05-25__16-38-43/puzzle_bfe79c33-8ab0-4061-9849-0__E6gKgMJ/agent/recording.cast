[144.861921, "i", "python3 -c \"\nimport textwrap\nscript = textwrap.dedent('''\n#!/usr/bin/env python3\n\\\"\\\"\\\"FFmpeg Filtergraph Puzzle Game\n\nA terminal-based puzzle game that teaches FFmpeg filtergraphs\nby having players solve progressively harder media transformation challenges.\n\\\"\\\"\\\"\\n\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Directories\nASSETS_DIR = \\\"/app/assets\\\"\nOUTPUT_DIR = \\\"/app/output\\\"\nMANIFEST_PATH = \\\"/app/manifest.json\\\"\n\n# Ensure directories exist\nos.makedirs(ASSETS_DIR, exist_ok=True)\nos.makedirs(OUTPUT_DIR, exist_ok=True)\n\n\ndef run_cmd(cmd, capture=True):\n    \\\"\\\"\\\"Run a shell command and return the result.\\\"\\\"\\\"\\n    result = subprocess.run(cmd, shell=True, capture_output=capture, text=True)\n    return result\n\n\ndef generate_input(level_num, input_type=\\\"video\\\", duration=5, width=640, height=480):\n    \\\"\\\"\\\"Generate synthetic input using FFmpeg lavfi sources.\\\"\\\"\\\"\\n    output_path = os.path.join(ASSETS_DIR, f\\\"level{level_num}_input\\\")\n    if input_type == \\\"video\\\":\n        output_"]
