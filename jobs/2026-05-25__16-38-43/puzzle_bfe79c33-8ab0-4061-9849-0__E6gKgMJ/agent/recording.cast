[212.306236, "i", " -f lavfi -i testsrc=duration={duration}:size={width}x{height}:rate=25 \"\n               f\"-c:v libx264 -pix_fmt yuv420p -t {duration} {output_path}\")\n    elif input_type == \"audio\":\n        output_path += \".wav\"\n        cmd = (f\"ffmpeg -y -f lavfi -i sine=frequency=440:duration={duration}:sample_rate=44100 \"\n               f\"-c:a pcm_s16le {output_path}\")\n    else:\n        raise ValueError(f\"Unknown input type: {input_type}\")\n    result = run_cmd(cmd)\n    if result.returncode != 0:\n        print(f\"Error generating input for level {level_num}: {result.stderr}\")\n        return None\n    return output_path\n\n\ndef probe_file(filepath):\n    \"\"\"Use ffprobe to get file properties as JSON.\"\"\"\n    cmd = f\"ffprobe -v quiet -print_format json -show_format -show_streams {filepath}\"\n    result = run_cmd(cmd)\n    if result.returncode != 0:\n        return None\n    try:\n        return json.loads(result.stdout)\n    except json.JSONDecodeError:\n        return None\n\n\ndef validate_output(probe_data, checks):\n    \"\"\"Validate ffprob"]
[212.30645, "i", "e output against expected checks.\"\"\"\n    if probe_data is None:\n        return False\n    streams = probe_data.get(\"streams\", [])\n    if not streams:\n        return False\n    codec_type = checks.get(\"codec_type\", \"video\")\n    stream = None\n    for s in streams:\n        if s.get(\"codec_type\") == codec_type:\n            stream = s\n            break\n    if stream is None:\n        return False\n    if \"width\" in checks:\n        if stream.get(\"width\") != checks[\"width\"]:\n            return False\n    if \"height\" in checks:\n        if stream.get(\"height\") != checks[\"height\"]:\n            return False\n    if \"pix_fmt\" in checks:\n        if stream.get(\"pix_fmt\") != checks[\"pix_fmt\"]:\n            return False\n    duration = None\n    if \"duration\" in stream:\n        duration = float(stream[\"duration\"])\n    elif \"duration\" in probe_data.get(\"format\", {}):\n        duration = float(probe_data[\"format\"][\"duration\"])\n    if \"duration_min\" in checks:\n        if duration is None or duration < checks[\"duration_min\"]:\n            "]
[212.306666, "i", "return False\n    if \"duration_max\" in checks:\n        if duration is None or duration > checks[\"duration_max\"]:\n            return False\n    return True\n\n\nLEVELS = [\n    {\n        \"num\": 1,\n        \"name\": \"Level 1: Scale Down\",\n        \"description\": \"You have a 640x480 video. Scale it down to 320x240.\\nHint: Use the scale filter.\",\n        \"input_type\": \"video\",\n        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\n        \"solution\": \"scale=320:240\",\n        \"output_ext\": \".mp4\",\n        \"codec\": \"libx264\",\n        \"output_pix_fmt\": \"yuv420p\",\n        \"checks\": {\"codec_type\": \"video\", \"width\": 320, \"height\": 240},\n        \"points\": 10,\n    },\n    {\n        \"num\": 2,\n        \"name\": \"Level 2: Convert to Grayscale\",\n        \"description\": \"You have a color video. Convert it to grayscale (gray pixel format).\\nHint: Use the format filter to change pixel format.\",\n        \"input_type\": \"video\",\n        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\n        \"solution\": \"format=gray"]
