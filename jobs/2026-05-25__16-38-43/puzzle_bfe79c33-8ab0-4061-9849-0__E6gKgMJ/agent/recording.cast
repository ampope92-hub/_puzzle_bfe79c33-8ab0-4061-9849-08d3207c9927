[212.327281, "o", "\u001b[?2004h> "]
[212.327338, "o", "        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.327481, "o", "        \"solution\": \"format=gray\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.327515, "o", "> "]
[212.327662, "o", "        \"output_ext\": \".mkv\",\r\n\u001b[?2004l\r    \u001b[?2004h"]
[212.327763, "o", ">         \"codec\": \"ffv1\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.327801, "o", "> "]
[212.327877, "o", "        \"output_pix_fmt\": None,\r\n\u001b[?2004l\r     \u001b[?2004h> "]
[212.328209, "o", "        \"checks\": {\"codec_type\": \"video\", \"pix_fmt\": \"gray\"},\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.328277, "o", ">         \"points\": 10,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.328332, "o", "    },\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.328368, "o", "    {\r\n\u001b[?2004l\r"]
[212.328506, "o", "\u001b[?2004h>         \"num\": 3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.328665, "o", "        \"name\": \"Level 3: Trim Audio\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.329242, "o", "        \"description\": \"You have a 10-second audio clip. Trim it to exactly 3 seconds.\\nHint: Use the atrim filter with start and end parameters.\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.329356, "o", ">         \"input_type\": \"audio\",\r\n\u001b[?2004l\rterac\u001b[?2004h"]
[212.329528, "o", ">         \"input_params\": {\"duration\": 10},\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.329733, "o", "        \"solution\": \"atrim=start=0:end=3,asetpts=PTS-STARTPTS\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.329842, "o", "        \"output_ext\": \".wav\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.329957, "o", "> "]
[212.330102, "o", "        \"codec\": \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.330193, "o", "        \"output_pix_fmt\": None,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.330405, "o", "        \"checks\": {\"codec_type\": \"audio\", \"duration_min\": 2.9, \"duration_max\": 3.1},\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.330508, "o", "        \"points\": 10,\r\n\u001b[?2004l\r to s\u001b[?2004h> "]
[212.33064, "o", "    },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.330745, "o", "        \"num\": 4,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.331025, "o", "        \"name\": \"Level 4: Crop Center\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.331389, "o", "        \"description\": \"You have a 640x480 video. Crop the center 200x200 region.\\nHint: Use the crop filter with width:height:x:y parameters.\",\r\n\u001b[?2004l\r    \u001b[?2004h> "]
[212.331614, "o", "        \"input_type\": \"video\",\r\n\u001b[?2004l\r"]
[212.331738, "o", "\u001b[?2004h> "]
[212.332147, "o", "        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.332238, "o", "> "]
[212.332516, "o", "        \"solution\": \"crop=200:200:220:140\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.332694, "o", "        \"output_ext\": \".mp4\",\r\n\u001b[?2004l\r        i\u001b[?2004h> "]
[212.333689, "o", "        \"codec\": \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"output_pix_fmt\": \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"checks\": {\"codec_type\": \"video\", \"width\": 200, \"height\": 200},\r\n\u001b[?2004l\r\u001b[?2004h>         \"points\": 10,\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r if pa\u001b[?2004h"]
[212.334021, "o", ">         \"num\": 5,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.334278, "o", "        \"name\": \"Level 5: Scale and Flip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.335072, "o", "        \"description\": \"You have a 640x480 video. Scale it to 320x240 AND apply a horizontal flip.\\nHint: Chain multiple filters with commas.\",\r\n\u001b[?2004l\r"]
[212.335291, "o", "\u001b[?2004h>         \"input_type\": \"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.335512, "o", "        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\r\n\u001b[?2004l\r\u001b[?2004h>         \"solution\": \"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"output_ext\": \".mp4\",\r\n\u001b[?2004l\r\"\u001b[?2004h> "]
[212.335709, "o", "        \"codec\": \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.335821, "o", "        \"output_pix_fmt\": \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.335968, "o", "> "]
[212.336166, "o", "        \"checks\": {\"codec_type\": \"video\", \"width\": 320, \"height\": 240},\r\n\u001b[?2004l\rwn correct so\u001b[?2004h"]
[212.336271, "o", "> "]
[212.336389, "o", "        \"points\": 10,\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.336535, "o", "> ]\r\n\u001b[?2004l\rar\u001b[?2004h> "]
[212.336647, "o", "\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.336677, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.337001, "o", "def apply_filtergraph_level(input_path, filtergraph, output_path, level):\r\n\u001b[?2004l\r"]
[212.337112, "o", "\u001b[?2004h> "]
[212.337157, "o", "    \"\"\"Apply filtergraph with level-specific encoding options.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.337194, "o", "> "]
[212.337388, "o", "    input_type = level[\"input_type\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.337719, "o", "    codec = level[\"codec\"]\r\n\u001b[?2004l\r\u001b[?2004h>     pix_fmt = level.get(\"output_pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h>     if input_type == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.337763, "o", "        pix_fmt_arg = f\"-pix_fmt {pix_fmt}\" if pix_fmt else \"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.33792, "o", "        cmd = f\\'ffmpeg -y -i {input_path} -vf \"{filtergraph}\" -c:v {codec} {pix_fmt_arg} {output_path}\\'\r\n\u001b[?2004l\r"]
[212.338037, "o", "\u001b[?2004h>     elif input_type == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.338181, "o", "        cmd = f\\'ffmpeg -y -i {input_path} -af \"{filtergraph}\" -c:a {codec} {output_path}\\'\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[212.338295, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.338399, "o", "    result = run_cmd(cmd)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r"]
[212.338426, "o", "\u001b[?2004h"]
[212.33852, "o", ">         return False\r\n\u001b[?2004l\r\u001b[?2004h>     return True"]
[212.338551, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n"]
[212.338628, "o", "\u001b[?2004l\r"]
[212.338693, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.338774, "o", "def run_level(level, filtergraph, verbose=False):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.338892, "o", "    \"\"\"Run a single level with the given filtergraph. Returns (passed, output_filename).\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.338907, "o", "    level_num = level[\"num\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.339009, "o", "    input_type = level[\"input_type\"]\r\n\u001b[?2004l\r"]
[212.339132, "o", "\u001b[?2004h> "]
[212.339206, "o", "    input_path = generate_input(level_num, input_type, **level[\"input_params\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.339313, "o", "    if input_path is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.339388, "o", "        return False, None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.339535, "o", "    output_filename = f\"level{level_num}_output{level[\\'output_ext\\']}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.339705, "o", "    output_path = os.path.join(OUTPUT_DIR, output_filename)\r\n\u001b[?2004l\r"]
[212.339878, "o", "\u001b[?2004h>     success = apply_filtergraph_level(input_path, filtergraph, output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341031, "o", "    if not success:\r\n\u001b[?2004l\r\u001b[?2004h>         if verbose:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FFmpeg failed to apply the filtergraph.\")\r\n\u001b[?2004l\r\u001b[?2004h>         return False, output_filename\r\n\u001b[?2004l\r\u001b[?2004h>     probe_data = probe_file(output_path)\r\n\u001b[?2004l\r\u001b[?2004h>     passed = validate_output(probe_data, level[\"checks\"])\r\n\u001b[?2004l\r\u001b[?2004h>     if verbose and not passed:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"  Validation failed. Expected: {level[\\'checks\\']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         if probe_data and probe_data.get(\"streams\"):\r\n\u001b[?2004l\r\u001b[?2004h>             stream = probe_data[\"streams\"][0]\r\n\u001b[?2004l\r\u001b[?2004h>             print(f\"  Got: width={stream.get(\\'width\\')}, height={stream.get(\\'height\\')}, \"\r\n\u001b[?2004l\r\u001b[?2004h>                   f\"pix_fmt={stream.get(\\'pix_fmt\\')}, duration={stream.get(\\'duration\\')}\")\r\n\u001b[?2004l\r\u001b[?2004h>     return passed, output_filename\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve_mode():"]
[212.341197, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run all levels with known correct solutions.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341394, "o", "    total_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341598, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h>         print(level[\"name\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341717, "o", "        total_points += level[\"points\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341773, "o", "        passed, output_filename = run_level(level, level[\"solution\"], verbose=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.341842, "o", "        if passed:\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.341955, "o", ">             print(\"PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>             earned_points += level[\"points\"]\r\n\u001b[?2004l\r"]
[212.342058, "o", "\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.342192, "o", "            print(\"FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.342338, "o", "        manifest.append({\"level\": level[\"num\"], \"filename\": output_filename, \"valid\": passed})\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.342498, "o", "    print(f\"Score: {earned_points}/{total_points}\")\r\n\u001b[?2004l\r\u001b[?2004h>     with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.343614, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h>     return earned_points == total_points\r\n\u001b[?2004l\r"]
[212.343985, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def interactive_mode():\r\n\u001b[?2004l\r\u001b[?2004h>     \"\"\"Run in interactive mode, prompting the user for filtergraphs.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h>     total_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     print(\"=\" * 60)\r\n\u001b[?2004l\r\u001b[?2004h> "]
