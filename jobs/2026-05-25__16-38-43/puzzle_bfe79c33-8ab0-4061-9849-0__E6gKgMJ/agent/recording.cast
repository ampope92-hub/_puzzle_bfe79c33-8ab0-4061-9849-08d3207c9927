[212.316316, "o", "        return json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h"]
[212.3164, "o", "> "]
[212.316826, "o", "    except json.JSONDecodeError:\r\n\u001b[?2004l\r"]
[212.316975, "o", "\u001b[?2004h>         return None\r\n\u001b[?2004l\roding options.\"\"\"\r\n  \u001b[?2004h> \r\n\u001b[?2004l\r"]
[212.317114, "o", " "]
[212.317222, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.3174, "o", "def validate_output(probe_data, checks):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.317724, "o", "    \"\"\"Validate ffprobe output against expected checks.\"\"\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.317762, "o", "    if probe_data is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.317865, "o", "        return False\r\n\u001b[?2004l\r"]
[212.31818, "o", "\u001b[?2004h>     streams = probe_data.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h>     if not streams:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     codec_type = checks.get(\"codec_type\", \"video\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.318337, "o", "    stream = None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.31845, "o", "    for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.318587, "o", "        if s.get(\"codec_type\") == codec_type:\r\n\u001b[?2004l\r"]
[212.318751, "o", "\u001b[?2004h>             stream = s\r\n\u001b[?2004l\rpath} -af \"{filtergraph"]
[212.31906, "o", "\u001b[?2004h>             break\r\n\u001b[?2004l\r\u001b[?2004h>     if stream is None:\r\n\u001b[?2004l\r"]
[212.319177, "o", "\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     if \"width\" in checks:\r\n\u001b[?2004l\r"]
[212.319305, "o", "\u001b[?2004h> "]
[212.319451, "o", "        if stream.get(\"width\") != checks[\"width\"]:\r\n\u001b[?2004l\r"]
[212.319546, "o", "\u001b[?2004h>             return False\r\n\u001b[?2004l\re\r\n    return True\r\n\r\n\r\ndef r"]
[212.319648, "o", "\u001b[?2004h> "]
[212.320046, "o", "    if \"height\" in checks:\r\n\u001b[?2004l\r"]
[212.320087, "o", "\u001b[?2004h> "]
[212.320188, "o", "        if stream.get(\"height\") != checks[\"height\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.320342, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.320806, "o", "    if \"pix_fmt\" in checks:\r\n\u001b[?2004l\r_filename).\u001b[?2004h>         if stream.get(\"pix_fmt\") != checks[\"pix_fmt\"]:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r"]
[212.321233, "o", "\u001b[?2004h>     duration = None\r\n\u001b[?2004l\r\u001b[?2004h>     if \"duration\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.321686, "o", "        duration = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.321741, "o", "    elif \"duration\" in probe_data.get(\"format\", {}):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.322228, "o", "        duration = float(probe_data[\"format\"][\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h>     if \"duration_min\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.3225, "o", "        if duration is None or duration < checks[\"duration_min\"]:\r\n\u001b[?2004l\r\u001b[?2004h>             return False\r\n\u001b[?2004l\r\u001b[?2004h>     if \"duration_max\" in checks:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.322713, "o", "        if duration is None or duration > checks[\"duration_max\"]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.322942, "o", "            return False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.323301, "o", "    return True\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[212.323535, "o", "\u001b[?2004h> LEVELS = [\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         \"num\": 1,\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": \"Level 1: Scale Down\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.32408, "o", "        \"description\": \"You have a 640x480 video. Scale it down to 320x240.\\nHint: Use the scale filter.\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.324297, "o", "        \"input_type\": \"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.324682, "o", "        \"input_params\": {\"duration\": 2, \"width\": 640, \"height\": 480},\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.325702, "o", "        \"solution\": \"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"output_ext\": \".mp4\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"codec\": \"libx264\",\r\n\u001b[?2004l\r"]
[212.326296, "o", "\u001b[?2004h>         \"output_pix_fmt\": \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"checks\": {\"codec_type\": \"video\", \"width\": 320, \"height\": 240},\r\n\u001b[?2004l\r\u001b[?2004h>         \"points\": 10,\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h>     {\r\n\u001b[?2004l\r\u001b[?2004h>         \"num\": 2,\r\n\u001b[?2004l\r\u001b[?2004h>         \"name\": \"Level 2: Convert to Grayscale\","]
[212.326361, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[212.326872, "o", "        \"description\": \"You have a color video. Convert it to grayscale (gray pixel format).\\nHint: Use the format filter to change pixel format.\",\r\n\u001b[?2004l\r"]
[212.326911, "o", "\u001b[?2004h> "]
