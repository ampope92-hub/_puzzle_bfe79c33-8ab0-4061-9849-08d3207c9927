[144.90247, "o", "                  f\\\"pix_fmt={stream.get('pix_fmt')}, duration={stream.get('duration')}\\\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.902671, "o", "    return passed, output_filename\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve_mode():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[144.902838, "o", "    \\\"\\\"\\\"Run all levels with known correct solutions.\\\"\\\"\\\"\\n    total_points = 0\r\n\u001b[?2004l\r\u001b[?2004h>     earned_points = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
