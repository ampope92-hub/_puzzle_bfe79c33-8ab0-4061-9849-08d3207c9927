[45.001007, "o", "def run_level_ffmpeg(level: Level, filtergraph: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.001238, "o", "    # Remove old output to avoid stale validations\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.001346, "o", "    if os.path.exists(level.output_path):\r\n\u001b[?2004l\r"]
[45.001423, "o", "\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.001644, "o", "            os.remove(level.output_path)\r\n\u001b[?2004l\r\u001b[?2004h>         except Exception:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.001721, "o", "            pass\r\n\u001b[?2004l\r0:200\u001b[?2004h> "]
[45.001878, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.00242, "o", "    if level.kind == \"video\":\r\n\u001b[?2004l\r"]
[45.00249, "o", "\u001b[?2004h> "]
[45.002575, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.002652, "o", "            \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r      num=5\u001b[?2004h> "]
[45.002912, "o", "            \"-i\", level.input_path,\r\n\u001b[?2004l\r \u001b[?2004h> "]
[45.003054, "o", "            \"-vf\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.003089, "o", "> "]
[45.003379, "o", "        ]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.00343, "o", "        # Level 2 must be AVI + rawvideo to preserve pix_fmt exactly\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.003441, "o", "        if level.num == 2:\r\n\u001b[?2004l\r"]
[45.003498, "o", "\u001b[?2004h> "]
[45.003748, "o", "            cmd += [\"-c:v\", \"rawvideo\"]\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             # Keep deterministic, no audio\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.003961, "o", "            cmd += [\"-an\", \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.00419, "o", "        cmd += [level.output_path]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.004415, "o", "        cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.004531, "o", "            \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.004933, "o", "            \"-i\", level.input_path,\r\n\u001b[?2004l\r"]
[45.005074, "o", "\u001b[?2004h> "]
[45.005371, "o", "            \"-af\", filtergraph,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.005491, "o", "            \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.005812, "o", "            level.output_path,\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.005846, "o", ">         ]\r\n\u001b[?2004l\rt[Level]) \u001b[?2004h> "]
[45.005862, "o", "\r\n\u001b[?2004l\r"]
[45.005877, "o", "\u001b[?2004h"]
[45.006044, "o", ">     cp = run(cmd)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.006077, "o", "    if cp.returncode != 0:\r\n\u001b[?2004l\r"]
[45.006186, "o", "\u001b[?2004h> "]
[45.006748, "o", "        return False, f\"ffmpeg error: {cp.stderr.strip().splitlines()[-1] if cp.stderr else 'unknown'}\"\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.006794, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.007377, "o", "    ok, reason = level.validate(level.output_path)\r\n\u001b[?2004l\r"]
[45.007411, "o", "\u001b[?2004h> "]
[45.007589, "o", "    return ok, reason\r\n\u001b[?2004l\r"]
[45.007807, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_wh(path: str, w: int, h: int) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h>     probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.008041, "o", "    v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.008066, "o", "> "]
[45.008522, "o", "    got_w, got_h = int(v.get(\"width\", -1)), int(v.get(\"height\", -1))\r\n\u001b[?2004l\r"]
[45.008564, "o", "\u001b[?2004h> "]
[45.008679, "o", "    if got_w != w or got_h != h:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.008922, "o", "        return False, f\"expected {w}x{h}, got {got_w}x{got_h}\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.009048, "o", "    return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rel\u001b[?2004h"]
[45.009077, "o", "> \r\n\u001b[?2004l\r]\u001b[?2004h> "]
[45.009387, "o", "def validate_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[45.009599, "o", "\u001b[?2004h> "]
[45.009801, "o", "    probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h>     v = get_first_stream(probe, \"video\")\r\n\u001b[?2004l\r"]
[45.009917, "o", "\u001b[?2004h>     got = v.get(\"pix_fmt\")\r\n\u001b[?2004l\r\u001b[?2004h>     if got != pix_fmt:\r\n\u001b[?2004l\r"]
[45.009976, "o", "\u001b[?2004h> "]
[45.010185, "o", "        return False, f\"expected pix_fmt={pix_fmt}, got {got}\"\r\n\u001b[?2004l\r"]
[45.010278, "o", "\u001b[?2004h>     return True, \"ok\"\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.010475, "o", "def validate_audio_duration(path: str, lo: float, hi: float) -> Tuple[bool, str]:\r\n\u001b[?2004l\r"]
[45.0106, "o", "\u001b[?2004h>     probe = ffprobe_json(path)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.010681, "o", "    dur = parse_duration_seconds(probe)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.010822, "o", "    if dur is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.010973, "o", "        return False, \"could not determine duration\"\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.011116, "o", "    if not (lo <= dur <= hi):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.01118, "o", "        return False, f\"expected duration in [{lo},{hi}], got {dur:.3f}\"\r\n\u001b[?2004l\r"]
[45.011205, "o", "\u001b[?2004h> "]
[45.011376, "o", "    return True, \"ok\"\r\n\u001b[?2004l\r"]
[45.011539, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[45.01157, "o", "  \u001b[?2004h> "]
[45.011832, "o", "def validate_crop_center_200(path: str) -> Tuple[bool, str]:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.01199, "o", "    return validate_wh(path, 200, 200)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rl"]
[45.012098, "o", "evels"]
[45.012167, "o", ")*10}\")"]
[45.012284, "o", "\u001b[?2004h> "]
[45.012386, "o", "def build_levels() -> List[Level]:\r\n\u001b[?2004l\r"]
[45.012474, "o", "\u001b[?2004h> "]
[45.012584, "o", "    l1_in = os.path.join(ASSETS_DIR, \"level1_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.012676, "o", "    l2_in = os.path.join(ASSETS_DIR, \"level2_input.avi\")\r\n\u001b[?2004l\rent(\u001b[?2004h> "]
[45.012793, "o", "    l3_in = os.path.join(ASSETS_DIR, \"level3_input.wav\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.012951, "o", "    l4_in = os.path.join(ASSETS_DIR, \"level4_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.013072, "o", "    l5_in = os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r"]
[45.013155, "o", "\u001b[?2004h> \r\n\u001b[?2004l\rn\u001b[?2004h> "]
[45.013312, "o", "    l1_out = os.path.join(OUTPUT_DIR, \"level1_output.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.01348, "o", "    l2_out = os.path.join(OUTPUT_DIR, \"level2_output.avi\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.013605, "o", "    l3_out = os.path.join(OUTPUT_DIR, \"level3_output.wav\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.013794, "o", "    l4_out = os.path.join(OUTPUT_DIR, \"level4_output.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.013877, "o", "    l5_out = os.path.join(OUTPUT_DIR, \"level5_output.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.013984, "o", "    levels: List[Level] = []\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     levels.append(Level(\r\n\u001b[?2004l\r"]
[45.014095, "o", "\u001b[?2004h>         num=1,\r\n\u001b[?2004l\r"]
[45.014175, "o", "\u001b[?2004h>         name=\"Scale down\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.014243, "o", ">         kind=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014351, "o", "        description=\"Scale a 640x480 video down to 320x240.\",\r\n\u001b[?2004l\r\u001b[?2004h>         input_path=l1_in,\r\n\u001b[?2004l\r"]
[45.014427, "o", "\u001b[?2004h>         output_path=l1_out,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014601, "o", "        generate_input=lambda p=l1_in: gen_level1_input(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014749, "o", "        validate=lambda p: validate_wh(p, 320, 240),\r\n\u001b[?2004l\r\u001b[?2004h>         solution=\"scale=320:240\",\r\n\u001b[?2004l\r\u001b[?2004h>     ))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     levels.append(Level(\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014862, "o", "        num=2,\r\n\u001b[?2004l\r\u001b[?2004h>         name=\"Grayscale\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014906, "o", "        kind=\"video\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.014971, "o", "        description=\"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[45.015033, "o", "> "]
[45.01522, "o", "        input_path=l2_in,\r\n\u001b[?2004l\r\u001b[?2004h>         output_path=l2_out,\r\n\u001b[?2004l\r\u001b[?2004h>         generate_input=lambda p=l2_in: gen_level2_input(p),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.015296, "o", "        validate=lambda p: validate_pix_fmt(p, \"gray\"),\r\n\u001b[?2004l\r\u001b[?2004h>         solution=\"format=gray\",\r\n\u001b[?2004l\r"]
[45.015427, "o", "\u001b[?2004h>     ))\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.015486, "o", "    levels.append(Level(\r\n\u001b[?2004l\r\u001b[?2004h>         num=3,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.015505, "o", "        name=\"Trim audio\",\r\n\u001b[?2004l\r"]
[45.015599, "o", "\u001b[?2004h>         kind=\"audio\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[45.015761, "o", "        description=\"Trim a 10-second audio clip to exactly 3 seconds (duration check allows 2.9..3.1).\",\r\n\u001b[?2004l\r\u001b[?2004h>         input_path=l3_in,\r\n\u001b[?2004l\r\u001b[?2004h> "]
