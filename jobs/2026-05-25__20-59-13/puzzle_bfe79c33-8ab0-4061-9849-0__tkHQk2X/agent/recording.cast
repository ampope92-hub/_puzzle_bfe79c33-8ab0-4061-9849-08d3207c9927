[45.000354, "o", ">         path,\r\n\u001b[?2004l\r   levels.appe\u001b[?2004h> "]
[45.000378, "o", "    ])\r\n\u001b[?2004l\r"]
[45.000395, "o", "\u001b[?2004h"]
[45.000408, "o", "> "]
