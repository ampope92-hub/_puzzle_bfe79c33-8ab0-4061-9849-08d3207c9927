[44.997593, "o", "\u001b[?2004h> "]
[44.997824, "o", "        \"-f\", \"lavfi\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.998234, "o", "        \"-i\", \"testsrc2=size=640x480:rate=30:duration=2\",\r\n\u001b[?2004l\r  \u001b[?2004h> "]
[44.998357, "o", "        \"-c:v\", \"libx264\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.998628, "o", "        \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.998657, "o", ">         path,\r\n\u001b[?2004l\r"]
[44.998679, "o", "on=\"Trim a 10-\u001b[?2004h>     ])\r\n\u001b[?2004l\rsec"]
[44.998708, "o", "ond \u001b[?2004h> "]
[44.999157, "o", "    if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.999253, "o", "> "]
