[44.994515, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r_"]
[44.994713, "o", "\u001b[?2004h> def gen_level2_input(path: str) -> None:\r\n\u001b[?2004l\r"]
[44.994738, "o", "\u001b[?2004h> "]
