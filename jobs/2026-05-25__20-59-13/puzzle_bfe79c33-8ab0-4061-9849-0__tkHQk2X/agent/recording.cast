[44.984068, "i", " it to 320x240, AND apply a horizontal flip.\",\n        input_path=l5_in,\n        output_path=l5_out,\n        generate_input=lambda p=l5_in: gen_level5_input(p),\n        validate=lambda p: validate_wh(p, 320, 240),\n        solution=\"scale=320:240,hflip\",\n    ))\n\n    return levels\n\n\ndef ensure_inputs(levels: List[Level]) -> None:\n    for lv in levels:\n        if not os.path.exists(lv.input_path):\n            lv.generate_input()\n\n\ndef interactive(levels: List[Level]) -> int:\n    total = 0\n    for lv in levels:\n        print(f\"Level {lv.num}: {lv.name}\")\n        print(lv.description)\n        try:\n            fg = input(\"Enter filtergraph: \").strip()\n        except EOFError:\n            print(\"\\nExiting.\")\n            break\n        ok, reason = run_level_ffmpeg(lv, fg)\n        if ok:\n            print(\"  PASS\")\n            total += 10\n        else:\n            print(\"  FAIL\")\n            print(f\"  Reason: {reason}\")\n    print(f\"Score: {total}/{len(levels)*10}\")\n    return 0\n\n\ndef auto_solve(levels: List[Level]) ->"]
