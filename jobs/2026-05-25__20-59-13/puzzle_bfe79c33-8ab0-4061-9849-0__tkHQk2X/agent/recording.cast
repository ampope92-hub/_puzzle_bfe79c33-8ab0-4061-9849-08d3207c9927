[44.999738, "o", ">     cp = run([\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.999856, "o", "        \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-f\", \"lavfi\",\r\n\u001b[?2004l\r"]
[44.999868, "o", "\u001b[?2004h> "]
