[44.98344, "i", "be AVI + rawvideo to preserve pix_fmt exactly\n        if level.num == 2:\n            cmd += [\"-c:v\", \"rawvideo\"]\n        else:\n            # Keep deterministic, no audio\n            cmd += [\"-an\", \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"]\n        cmd += [level.output_path]\n    else:\n        cmd = [\n            \"ffmpeg\", \"-y\",\n            \"-i\", level.input_path,\n            \"-af\", filtergraph,\n            \"-c:a\", \"pcm_s16le\",\n            level.output_path,\n        ]\n\n    cp = run(cmd)\n    if cp.returncode != 0:\n        return False, f\"ffmpeg error: {cp.stderr.strip().splitlines()[-1] if cp.stderr else 'unknown'}\"\n\n    ok, reason = level.validate(level.output_path)\n    return ok, reason\n\n\ndef validate_wh(path: str, w: int, h: int) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    v = get_first_stream(probe, \"video\")\n    got_w, got_h = int(v.get(\"width\", -1)), int(v.get(\"height\", -1))\n    if got_w != w or got_h != h:\n        return False, f\"expected {w}x{h}, got {got_w}x{got_h}\"\n    return True, \"ok\"\n\n\ndef"]
[44.983455, "i", " validate_pix_fmt(path: str, pix_fmt: str) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    v = get_first_stream(probe, \"video\")\n    got = v.get(\"pix_fmt\")\n    if got != pix_fmt:\n        return False, f\"expected pix_fmt={pix_fmt}, got {got}\"\n    return True, \"ok\"\n\n\ndef validate_audio_duration(path: str, lo: float, hi: float) -> Tuple[bool, str]:\n    probe = ffprobe_json(path)\n    dur = parse_duration_seconds(probe)\n    if dur is None:\n        return False, \"could not determine duration\"\n    if not (lo <= dur <= hi):\n        return False, f\"expected duration in [{lo},{hi}], got {dur:.3f}\"\n    return True, \"ok\"\n\n\ndef validate_crop_center_200(path: str) -> Tuple[bool, str]:\n    return validate_wh(path, 200, 200)\n\n\ndef build_levels() -> List[Level]:\n    l1_in = os.path.join(ASSETS_DIR, \"level1_input.mp4\")\n    l2_in = os.path.join(ASSETS_DIR, \"level2_input.avi\")\n    l3_in = os.path.join(ASSETS_DIR, \"level3_input.wav\")\n    l4_in = os.path.join(ASSETS_DIR, \"level4_input.mp4\")\n    l5_in = os.path.join(ASSETS_D"]
[44.983469, "i", "IR, \"level5_input.mp4\")\n\n    l1_out = os.path.join(OUTPUT_DIR, \"level1_output.mp4\")\n    l2_out = os.path.join(OUTPUT_DIR, \"level2_output.avi\")\n    l3_out = os.path.join(OUTPUT_DIR, \"level3_output.wav\")\n    l4_out = os.path.join(OUTPUT_DIR, \"level4_output.mp4\")\n    l5_out = os.path.join(OUTPUT_DIR, \"level5_output.mp4\")\n\n    levels: List[Level] = []\n\n    levels.append(Level(\n        num=1,\n        name=\"Scale down\",\n        kind=\"video\",\n        description=\"Scale a 640x480 video down to 320x240.\",\n        input_path=l1_in,\n        output_path=l1_out,\n        generate_input=lambda p=l1_in: gen_level1_input(p),\n        validate=lambda p: validate_wh(p, 320, 240),\n        solution=\"scale=320:240\",\n    ))\n\n    levels.append(Level(\n        num=2,\n        name=\"Grayscale\",\n        kind=\"video\",\n        description=\"Convert a video to grayscale. Output pixel format must be exactly 'gray'.\",\n        input_path=l2_in,\n        output_path=l2_out,\n        generate_input=lambda p=l2_in: gen_level2_input(p),\n        valida"]
[44.983474, "i", "te=lambda p: validate_pix_fmt(p, \"gray\"),\n        solution=\"format=gray\",\n    ))\n\n    levels.append(Level(\n        num=3,\n        name=\"Trim audio\",\n        kind=\"audio\",\n        description=\"Trim a 10-second audio clip to exactly 3 seconds (duration check allows 2.9..3.1).\",\n        input_path=l3_in,\n        output_path=l3_out,\n        generate_input=lambda p=l3_in: gen_level3_input(p),\n        validate=lambda p: validate_audio_duration(p, 2.9, 3.1),\n        solution=\"atrim=0:3\",\n    ))\n\n    levels.append(Level(\n        num=4,\n        name=\"Center crop\",\n        kind=\"video\",\n        description=\"Crop the center 200x200 region from a 640x480 video.\",\n        input_path=l4_in,\n        output_path=l4_out,\n        generate_input=lambda p=l4_in: gen_level4_input(p),\n        validate=validate_crop_center_200,\n        solution=\"crop=200:200:(in_w-200)/2:(in_h-200)/2\",\n    ))\n\n    levels.append(Level(\n        num=5,\n        name=\"Scale + hflip\",\n        kind=\"video\",\n        description=\"Take a 640x480 video, scale"]
