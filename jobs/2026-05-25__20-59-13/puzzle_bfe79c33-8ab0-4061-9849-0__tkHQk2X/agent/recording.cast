[44.995197, "o", "    cp = run([\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.995212, "o", "        \"-f\", \"lavfi\",\r\n\u001b[?2004l\r"]
[44.995368, "o", "\u001b[?2004h>         \"-i\", \"testsrc2=size=640x480:rate=30:duration=2\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.995777, "o", "        \"-c:v\", \"rawvideo\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-pix_fmt\", \"yuv420p\",\r\n\u001b[?2004l\r\u001b[?2004h>         path,\r\n\u001b[?2004l\r\u001b[?2004h>     ])\r\n\u001b[?2004l\r\u001b[?2004h>     if cp.returncode != 0:\r\n\u001b[?2004l\r"]
[44.996237, "o", "\u001b[?2004h>         raise RuntimeError(cp.stderr)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[44.996404, "o", "\u001b[?2004h> def gen_level3_input(path: str) -> None:\r\n\u001b[?2004l\r\u001b[?2004h>     # 10 second sine wave\r\n\u001b[?2004l\r\u001b[?2004h>     cp = run([\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffmpeg\", \"-y\",\r\n\u001b[?2004l\r\u001b[?2004h"]
[44.996424, "o", ">         \"-f\", \"lavfi\",\r\n\u001b[?2004l\rnd=\"video\",\r\n        des\u001b[?2004h"]
[44.996545, "o", "> "]
[44.996725, "o", "        \"-i\", \"sine=frequency=440:sample_rate=48000:duration=10\",\r\n\u001b[?2004l\r\u001b[?2004h>         \"-c:a\", \"pcm_s16le\",\r\n\u001b[?2004l\r\u001b[?2004h>         path,\r\n\u001b[?2004l\r\u001b[?2004h>     ])"]
[44.996942, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     if cp.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[44.997137, "o", "        raise RuntimeError(cp.stderr)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\rn\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[44.997169, "o", "> "]
