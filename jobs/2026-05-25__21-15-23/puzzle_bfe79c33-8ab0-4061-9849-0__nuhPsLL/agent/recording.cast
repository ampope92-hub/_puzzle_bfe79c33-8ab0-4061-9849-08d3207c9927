[40.678812, "o", "            os.path.join(ASSETS_DIR, \"level5_input.mp4\")\r\n\u001b[?2004l\r\u001b[?2004h>         ],\r\n\u001b[?2004l\r\u001b[?2004h>         \"solution\": \"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.679084, "o", "        \"validate\": lambda info: info.get(\"width\") == 320 and info.get(\"height\") == 240,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.679203, "o", "        \"ffmpeg_extra_output\": [\"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\"],\r\n\u001b[?2004l\r  els\u001b[?2004h>     },\r\n"]
[40.679362, "o", "\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_dirs():\r\n\u001b[?2004l\r"]
[40.679451, "o", "    print(\"  FAIL\")"]
[40.679537, "o", "\u001b[?2004h>     os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r"]
[40.679669, "o", "\u001b[?2004h> "]
[40.679814, "o", "    os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.679838, "o", "> def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = level[\"generate_cmd\"]\r\n\u001b[?2004l\r"]
[40.679997, "o", "\u001b[?2004h> "]
[40.68005, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68014, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.680249, "o", "def run_filtergraph(level, filtergraph):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.680341, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68053, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.680713, "o", "    # Determine if audio or video\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68083, "o", "    is_audio = level[\"input_file\"].endswith(\".wav\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.680879, "o", "    \r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\"ffmpeg\", \"-y\", \"-i\", input_path]\r\n\u001b[?2004l\r"]
[40.68102, "o", "\u001b[?2004h>     if is_audio:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.681201, "o", "        cmd += [\"-af\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r\u001b[?2004h>         cmd += [\"-vf\", filtergraph]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.681442, "o", "    cmd += level[\"ffmpeg_extra_output\"]\r\n\u001b[?2004l\r\u001b[?2004h>     cmd += [output_path]\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.681482, "o", "    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.681594, "o", "    return result.returncode == 0\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.681607, "o", "\u001b[?2004h> "]
[40.681973, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> def probe_output(level):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682015, "o", "    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682032, "o", "        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682255, "o", "        \"-show_streams\", \"-show_format\", output_path\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682417, "o", "    if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682437, "o", "    data = json.loads(result.stdout)\r\n\u001b[?2004l\r"]
[40.682557, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     info = {}\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.682777, "o", "    if data.get(\"streams\"):\r\n\u001b[?2004l\r\u001b[?2004h>         stream = data[\"streams\"][0]\r\n\u001b[?2004l\r\u001b[?2004h>         if \"width\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.683022, "o", "            info[\"width\"] = int(stream[\"width\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.683245, "o", "        if \"height\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>             info[\"height\"] = int(stream[\"height\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.683484, "o", "        if \"pix_fmt\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h>             info[\"pix_fmt\"] = stream[\"pix_fmt\"]\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.683867, "o", "        # Duration: try stream duration first, then format duration\r\n\u001b[?2004l\r\u001b[?2004h>         if \"duration\" in stream:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.684149, "o", "            info[\"duration\"] = float(stream[\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h>         elif data.get(\"format\") and \"duration\" in data[\"format\"]:\r\n\u001b[?2004l\r\u001b[?2004h>             info[\"duration\"] = float(data[\"format\"][\"duration\"])\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     return info\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def validate_level(level, info):\r\n\u001b[?2004l\r\u001b[?2004h>     if info is None:\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h>     return level[\"validate\"](info)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.684195, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> def auto_solve():"]
[40.684301, "o", "\r\n\u001b[?2004l\r"]
[40.684429, "o", "\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.684489, "o", "    total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.684575, "o", "    total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68464, "o", "    for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.684723, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.684758, "o", ">         \r\n\u001b[?2004l\r"]
[40.684835, "o", "\u001b[?2004h> "]
[40.684865, "o", "        # Generate input\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.684983, "o", "        generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685176, "o", "        # Run the known solution\r\n\u001b[?2004l\r\u001b[?2004h>         success = run_filtergraph(level, level[\"solution\"])\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         passed = False\r\n\u001b[?2004l\r"]
[40.68525, "o", "\u001b[?2004h>         if success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685348, "o", "            info = probe_output(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685464, "o", "            passed = validate_level(level, info)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685491, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685656, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68573, "o", "            print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>         "]
[40.685796, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.685924, "o", "            \"level\": level[\"level\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.686037, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68613, "o", "            \"passed\": passed\r\n\u001b[?2004l\r\u001b[?2004h>         })\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r"]
[40.686207, "o", "\u001b[?2004h> "]
[40.68627, "o", "    print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.686356, "o", "    with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.686487, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.686564, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
