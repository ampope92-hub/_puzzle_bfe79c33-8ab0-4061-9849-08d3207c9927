[40.686921, "o", "\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687036, "o", "        print(f\"\\n{'='*50}\")\r\n\u001b[?2004l\r"]
[40.687115, "o", "\u001b[?2004h> "]
[40.68714, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687178, "o", "        print(f\"{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687284, "o", "        print(f\"\\n{level['description']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687366, "o", "        print(f\"\\nInput file: {level['input_file']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687479, "o", "        print(f\"Output file: {level['output_file']}\")\r\n\u001b[?2004l\r"]
[40.687499, "o", "\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Generate input\r\n\u001b[?2004l\r"]
[40.687557, "o", "\u001b[?2004h>         generate_input(level)"]
[40.687696, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.687927, "o", "        # Get user's filtergraph\r\n\u001b[?2004l\r\u001b[?2004h>         print(\"\\nEnter your filtergraph expression:\")\r\n\u001b[?2004l\r\u001b[?2004h>         try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.688069, "o", "            filtergraph = input(\"> \").strip()\r\n\u001b[?2004l\r\u001b[?2004h>         except (EOFError, KeyboardInterrupt):\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.688306, "o", "            print(\"\\nExiting...\")\r\n\u001b[?2004l\r\u001b[?2004h>             return\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if not filtergraph:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.68882, "o", "            print(\"  No input provided. FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         # Run the filtergraph\r\n\u001b[?2004l\r\u001b[?2004h>         success = run_filtergraph(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if success:\r\n\u001b[?2004l\r\u001b[?2004h>             info = probe_output(level)\r\n\u001b[?2004l\r\u001b[?2004h>             passed = validate_level(level, info)\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.688966, "o", "            passed = False\r\n\u001b[?2004l\r\u001b[?2004h>         \r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.689106, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.689236, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h>     \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.689332, "o", "    print(f\"\\nScore: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.689379, "o", "> "]
[40.689443, "o", "    if \"--auto-solve\" in sys.argv:\r\n\u001b[?2004l\r\u001b[?2004h>         auto_solve()\r\n\u001b[?2004l\r"]
