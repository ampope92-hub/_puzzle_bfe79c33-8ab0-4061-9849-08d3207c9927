conds",\n        "input_file": "level3_input.wav",\n        "output_file": "level3_output.wav",\n        "generate_cmd": lambda inp: [\n            "ffmpeg", "-y", "-f", "lavfi", "-i",\n            "sine=frequency=440:duration=10",\n            inp\n        ],\n        "apply_cmd": lambda inp, out, fg: [\n            "ffmpeg", "-y", "-i", inp, "-af", fg, out\n        ],\n        "solution": "atrim=0:3",\n        "validate": lambda probe: 2.9 <= probe.get("duration", 0) <= 3.1,\n    },\n    {\n        "level": 4,\n        "name": "Center Crop",\n        "description": "Crop the center 200x200 region from a 640x480 video.\\nInput: 640x480 video\\nGoal: Output should be 200x200",\n        "input_file": "level4_input.mp4",\n        "output_file": "level4_output.mp4",\n        "generate_cmd": lambda inp: [\n            "ffmpeg", "-y", "-f", "lavfi", "-i",\n            "testsrc=duration=2:size=640x480:rate=25",\n            "-c:v", "libx264", "-pix_fmt", "yuv420p", inp\n        ],\n        "apply_cmd": lambda inp, out, fg: [\n            "ffmpeg", "-y", "-i", inp, "-vf", fg,\n            "-c:v", "libx264", "-pix_fmt", "yuv420p", out\n        ],\n        "solution": "crop=200:200",\n        "validate": lambda probe: probe["width"] == 200 and probe["height"] == 200,\n    },\n    {\n        "level": 5,\n        "name": "Scale and Flip",\n        "description": "Take a 640x480 video, scale it to 320x240, AND apply a horizontal flip.\\nInput: 640x480 video\\nGoal: Output should be 320x240 and horizontally flipped",\n        "input_file": "level5_input.mp4",\n        "output_file": "level5_output.mp4",\n        "generate_cmd": lambda inp: [\n            "ffmpeg", "-y", "-f", "lavfi", "-i",\n            "testsrc=duration=2:size=640x480:rate=25",\n            "-c:v", "libx264", "-pix_fmt", "yuv420p", inp\n        ],\n        "apply_cmd": lambda inp, out, fg: [\n            "ffmpeg", "-y", "-i", inp, "-vf", fg,\n            "-c:v", "libx264", "-pix_fmt", "yuv420p", out\n        ],