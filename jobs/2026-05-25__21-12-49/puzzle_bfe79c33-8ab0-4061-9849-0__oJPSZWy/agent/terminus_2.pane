[?2004l[?2004h> 
[?2004l[?2004h> def probe_file(filepath, level):
[?2004l[?2004h>     cmd = [
[?2004l[?2004h>         "ffprobe", "-v", "quiet", "-print_format", "json",
[?2004l[?2004h>         "-show_streams", "-show_format", filepath
[?2004l[?2004h>     ]
[?2004l[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)
[?2004l[?2004h>     if result.returncode != 0:
[?2004l[?2004h>         return None
[?2004l[?2004h>     data = json.loads(result.stdout)
[?2004l[?2004h>     streams = data.get("streams", [])
[?2004l[?2004h>     if not streams:
[?2004l[?2004h>         return None
[?2004l[?2004h> 
[?2004l[?2004h>     # For audio levels, get audio stream; for video, get video stream
[?2004l[?2004h>     level_num = level["level"]
[?2004l[?2004h>     if level_num == 3:
[?2004l[?2004h>         # Audio
[?2004l[?2004h>         for s in streams:
[?2004l[?2004h>             if s.get("codec_type") == "audio":
[?2004l[?2004h>                 duration = float(s.get("duration", data.get("format", {}).get("duration", 0)))
[?2004l[?2004h>                 return {"duration": duration}
[?2004l[?2004h>         # fallback to format duration
[?2004l[?2004h>         duration = float(data.get("format", {}).get("duration", 0))
[?2004l[?2004h>         return {"duration": duration}
[?2004l[?2004h>     else:
[?2004l[?2004h>         # Video
[?2004l[?2004h>         for s in streams:
[?2004l[?2004h>             if s.get("codec_type") == "video":
[?2004l[?2004h>                 return {
[?2004l[?2004h>                     "width": int(s.get("width", 0)),
[?2004l[?2004h>                     "height": int(s.get("height", 0)),
[?2004l[?2004h>                     "pix_fmt": s.get("pix_fmt", ""),
[?2004l[?2004h>                 }
[?2004l[?2004h>     return None
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def validate_level(level, output_path):
[?2004l[?2004h>     probe = probe_file(output_path, level)
[?2004l[?2004h>     if probe is None:
[?2004l[?2004h>         return False
[?2004l[?2004h>     try:
[?2004l[?2004h>         return level["validate"](probe)
[?2004l[?2004h>     except (KeyError, TypeError):
[?2004l[?2004h>         return False
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def run_auto_solve():
[?2004l[?2004h>     ensure_dirs()
[?2004l[?2004h>     manifest = []
[?2004l[?2004h>     total_score = 0
[?2004l[?2004h>     total_possible = len(LEVELS) * 10
[?2004l[?2004h> 
[?2004l[?2004h>     for level in LEVELS:
