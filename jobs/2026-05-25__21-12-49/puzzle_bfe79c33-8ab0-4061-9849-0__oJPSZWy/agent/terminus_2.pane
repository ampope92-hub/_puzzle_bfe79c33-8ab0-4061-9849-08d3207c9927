[?2004l[?2004h> def ensure_dirs():
[?2004l[?2004h>     os.makedirs(ASSETS_DIR, exist_ok=True)
[?2004l[?2004h>     os.makedirs(OUTPUT_DIR, exist_ok=True)
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def generate_input(level):
[?2004l[?2004h>     input_path = os.path.join(ASSETS_DIR, level["input_file"])
[?2004l[?2004h>     cmd = level["generate_cmd"](input_path)
[?2004l[?2004h>     subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
[?2004l[?2004h>     return input_path
[?2004l[?2004h> 
[?2004l[?2004h> 
[?2004l[?2004h> def apply_filter(level, filtergraph):
[?2004l[?2004h>     input_path = os.path.join(ASSETS_DIR, level["input_file"])
[?2004l[?2004h>     output_path = os.path.join(OUTPUT_DIR, level["output_file"])
[?2004l[?2004h>     cmd = level["apply_cmd"](input_path, output_path, filtergraph)
[?2004l[?2004h>     result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)
[?2004l[?2004h>     return result.returncode == 0, output_path
