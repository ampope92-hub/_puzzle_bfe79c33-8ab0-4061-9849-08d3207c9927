[40.946184, "i", "_DIR, exist_ok=True)\n\n\ndef generate_input(level):\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    cmd = level[\"generate_cmd\"](input_path)\n    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\n    return input_path\n\n\ndef apply_filter(level, filtergraph):\n    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\n    output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\n    cmd = level[\"apply_cmd\"](input_path, output_path, filtergraph)\n    result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)\n    return result.returncode == 0, output_path\n\n\ndef probe_file(filepath, level):\n    cmd = [\n        \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\n        \"-show_streams\", \"-show_format\", filepath\n    ]\n    result = subprocess.run(cmd, capture_output=True, text=True)\n    if result.returncode != 0:\n        return None\n    data = json.loads(result.stdout)\n    streams = data.get(\"streams\", [])\n    if not streams:\n        return N"]
