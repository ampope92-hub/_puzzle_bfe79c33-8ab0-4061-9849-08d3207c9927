[40.946728, "i", "eError):\n        return False\n\n\ndef run_auto_solve():\n    ensure_dirs()\n    manifest = []\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f\"Level {level['level']}: {level['name']}\")\n        generate_input(level)\n        success, output_path = apply_filter(level, level[\"solution\"])\n        if success:\n            passed = validate_level(level, output_path)\n        else:\n            passed = False\n\n        if passed:\n            total_score += 10\n            print(\"  PASS\")\n        else:\n            print(\"  FAIL\")\n\n        manifest.append({\n            \"level\": level[\"level\"],\n            \"filename\": level[\"output_file\"],\n            \"passed\": passed,\n        })\n\n    print(f\"Score: {total_score}/{total_possible}\")\n\n    with open(MANIFEST_PATH, \"w\") as f:\n        json.dump(manifest, f, indent=2)\n\n\ndef run_interactive():\n    ensure_dirs()\n    total_score = 0\n    total_possible = len(LEVELS) * 10\n\n    for level in LEVELS:\n        print(f\"\\n{'='*50}\")\n        print"]
