[40.946495, "i", "one\n\n    # For audio levels, get audio stream; for video, get video stream\n    level_num = level[\"level\"]\n    if level_num == 3:\n        # Audio\n        for s in streams:\n            if s.get(\"codec_type\") == \"audio\":\n                duration = float(s.get(\"duration\", data.get(\"format\", {}).get(\"duration\", 0)))\n                return {\"duration\": duration}\n        # fallback to format duration\n        duration = float(data.get(\"format\", {}).get(\"duration\", 0))\n        return {\"duration\": duration}\n    else:\n        # Video\n        for s in streams:\n            if s.get(\"codec_type\") == \"video\":\n                return {\n                    \"width\": int(s.get(\"width\", 0)),\n                    \"height\": int(s.get(\"height\", 0)),\n                    \"pix_fmt\": s.get(\"pix_fmt\", \"\"),\n                }\n    return None\n\n\ndef validate_level(level, output_path):\n    probe = probe_file(output_path, level)\n    if probe is None:\n        return False\n    try:\n        return level[\"validate\"](probe)\n    except (KeyError, Typ"]
