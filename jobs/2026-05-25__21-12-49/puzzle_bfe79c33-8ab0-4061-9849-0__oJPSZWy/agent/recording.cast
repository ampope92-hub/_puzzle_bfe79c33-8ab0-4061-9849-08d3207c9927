[40.980077, "o", ">             \"ffmpeg\", \"-y\", \"-i\", inp, \"-vf\", fg,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.980594, "o", "            \"-c:v\", \"libx264\", \"-pix_fmt\", \"yuv420p\", out\r\n\u001b[?2004l\r"]
[40.981349, "o", "\u001b[?2004h>         ],\r\n\u001b[?2004l\r\u001b[?2004h>         \"solution\": \"scale=320:240,hflip\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.982534, "o", "        \"validate\": lambda probe: probe[\"width\"] == 320 and probe[\"height\"] == 240,\r\n\u001b[?2004l\r"]
[40.983237, "o", "\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h> ]\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[40.983618, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def ensure_dirs():\r\n\u001b[?2004l\r"]
[40.984466, "o", "\u001b[?2004h>     os.makedirs(ASSETS_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h>     os.makedirs(OUTPUT_DIR, exist_ok=True)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.984864, "o", "def generate_input(level):\r\n\u001b[?2004l\r\u001b[?2004h>     input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.984948, "o", "    cmd = level[\"generate_cmd\"](input_path)\r\n\u001b[?2004l\r"]
[40.985177, "o", "\u001b[?2004h> "]
[40.985598, "o", "    subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)\r\n\u001b[?2004l\r\u001b[?2004h>     return input_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.985784, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.986091, "o", "def apply_filter(level, filtergraph):\r\n\u001b[?2004l\r"]
[40.986515, "o", "\u001b[?2004h> "]
[40.987288, "o", "    input_path = os.path.join(ASSETS_DIR, level[\"input_file\"])\r\n\u001b[?2004l\r\u001b[?2004h>     output_path = os.path.join(OUTPUT_DIR, level[\"output_file\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.987711, "o", "    cmd = level[\"apply_cmd\"](input_path, output_path, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>     result = subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.PIPE)\r\n\u001b[?2004l\r"]
[40.988799, "o", "\u001b[?2004h>     return result.returncode == 0, output_path\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> def probe_file(filepath, level):\r\n\u001b[?2004l\r\u001b[?2004h>     cmd = [\r\n\u001b[?2004l\r\u001b[?2004h>         \"ffprobe\", \"-v\", \"quiet\", \"-print_format\", \"json\",\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.989251, "o", "        \"-show_streams\", \"-show_format\", filepath\r\n\u001b[?2004l\r\u001b[?2004h>     ]\r\n\u001b[?2004l\r\u001b[?2004h>     result = subprocess.run(cmd, capture_output=True, text=True)\r\n\u001b[?2004l\r\u001b[?2004h>     if result.returncode != 0:\r\n\u001b[?2004l\r\u001b[?2004h>         return None\r\n\u001b[?2004l\r\u001b[?2004h>     data = json.loads(result.stdout)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.989478, "o", "> "]
[40.989628, "o", "    streams = data.get(\"streams\", [])\r\n\u001b[?2004l\r\u001b[?2004h>     if not streams:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.989646, "o", "> "]
[40.989809, "o", "        return None\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.989979, "o", "    # For audio levels, get audio stream; for video, get video stream\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.990273, "o", "    level_num = level[\"level\"]\r\n\u001b[?2004l\r\u001b[?2004h>     if level_num == 3:\r\n\u001b[?2004l\r\u001b[?2004h>         # Audio\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.990424, "o", "        for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.990707, "o", "            if s.get(\"codec_type\") == \"audio\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.990938, "o", "                duration = float(s.get(\"duration\", data.get(\"format\", {}).get(\"duration\", 0)))\r\n\u001b[?2004l\r\u001b[?2004h>                 return {\"duration\": duration}"]
[40.99112, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.991425, "o", "        # fallback to format duration\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.991513, "o", "        duration = float(data.get(\"format\", {}).get(\"duration\", 0))\r\n\u001b[?2004l\r\u001b[?2004h>         return {\"duration\": duration}"]
[40.991699, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>     else:\r\n\u001b[?2004l\r"]
[40.99191, "o", "\u001b[?2004h>         # Video\r\n\u001b[?2004l\r\u001b[?2004h>         for s in streams:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.992231, "o", "            if s.get(\"codec_type\") == \"video\":\r\n\u001b[?2004l\r\u001b[?2004h>                 return {\r\n\u001b[?2004l\r"]
[40.992399, "o", "\u001b[?2004h>                     \"width\": int(s.get(\"width\", 0)),\r\n\u001b[?2004l\r"]
[40.992489, "o", "\u001b[?2004h> "]
[40.992961, "o", "                    \"height\": int(s.get(\"height\", 0)),\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.993143, "o", "                    \"pix_fmt\": s.get(\"pix_fmt\", \"\"),\r\n\u001b[?2004l\r\u001b[?2004h>                 }\r\n\u001b[?2004l\r\u001b[?2004h>     return None\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.993187, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.993661, "o", "def validate_level(level, output_path):\r\n\u001b[?2004l\r\u001b[?2004h>     probe = probe_file(output_path, level)\r\n\u001b[?2004l\r\u001b[?2004h>     if probe is None:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.993894, "o", "        return False\r\n\u001b[?2004l\r\u001b[?2004h>     try:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.994343, "o", "        return level[\"validate\"](probe)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.994401, "o", "    except (KeyError, TypeError):\r\n\u001b[?2004l\r\u001b[?2004h>         return False\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.994914, "o", "def run_auto_solve():\r\n\u001b[?2004l\r\u001b[?2004h>     ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     manifest = []\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.99521, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h>         generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.995594, "o", "        success, output_path = apply_filter(level, level[\"solution\"])\r\n\u001b[?2004l\r\u001b[?2004h>         if success:\r\n\u001b[?2004l\r\u001b[?2004h>             passed = validate_level(level, output_path)\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             passed = False\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.996229, "o", "\r\n\u001b[?2004l\r\u001b[?2004h>         if passed:\r\n\u001b[?2004l\r\u001b[?2004h>             total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>         manifest.append({\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.996281, "o", "            \"level\": level[\"level\"],\r\n\u001b[?2004l\r"]
[40.996474, "o", "\u001b[?2004h> "]
[40.996517, "o", "            \"filename\": level[\"output_file\"],\r\n\u001b[?2004l\r"]
[40.996682, "o", "\u001b[?2004h>             \"passed\": passed,\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.996798, "o", "        })\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.99716, "o", "    print(f\"Score: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     with open(MANIFEST_PATH, \"w\") as f:\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.99742, "o", "> "]
[40.997626, "o", "        json.dump(manifest, f, indent=2)\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[40.997768, "o", "> def run_interactive():\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.998105, "o", "    ensure_dirs()\r\n\u001b[?2004l\r\u001b[?2004h>     total_score = 0\r\n\u001b[?2004l\r\u001b[?2004h>     total_possible = len(LEVELS) * 10\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     for level in LEVELS:\r\n\u001b[?2004l\r\u001b[?2004h>         print(f\"\\n{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.998342, "o", "        print(f\"Level {level['level']}: {level['name']}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.99839, "o", "        print(f\"{'='*50}\")\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.99858, "o", "        print(level[\"description\"])\r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.998792, "o", "        print()\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.998886, "o", "        generate_input(level)\r\n\u001b[?2004l\r\u001b[?2004h"]
[40.999027, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[40.9993, "o", "        filtergraph = input(\"Enter your filtergraph expression: \").strip()\r\n"]
[40.999537, "o", "\u001b[?2004l\r"]
[40.999722, "o", "\u001b[?2004h> "]
[40.999961, "o", "        if not filtergraph:"]
[41.000358, "o", "\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.00289, "o", "            print(\"  FAIL (empty input)\")\r\n"]
[41.003351, "o", "\u001b[?2004l\r\u001b[?2004h>             continue\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.003736, "o", "        success, output_path = apply_filter(level, filtergraph)\r\n\u001b[?2004l\r\u001b[?2004h>         if success:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.003898, "o", "            passed = validate_level(level, output_path)"]
[41.004042, "o", "\r\n\u001b[?2004l\r"]
[41.004192, "o", "\u001b[?2004h> "]
[41.004233, "o", "        else:\r\n\u001b[?2004l\r"]
[41.004364, "o", "\u001b[?2004h> "]
[41.004531, "o", "            passed = False\r\n\u001b[?2004l\r"]
[41.00492, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h"]
[41.005284, "o", ">         if passed:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.00583, "o", "            total_score += 10\r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.006314, "o", "            print(\"  PASS\")\r\n\u001b[?2004l\r\u001b[?2004h>         else:\r\n\u001b[?2004l\r"]
[41.006541, "o", "\u001b[?2004h>             print(\"  FAIL\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h>     print(f\"\\nScore: {total_score}/{total_possible}\")\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[41.006654, "o", "if __name__ == \"__main__\":\r\n\u001b[?2004l\r\u001b[?2004h> "]
